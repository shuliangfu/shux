/** 执行 asm 构建脚本；与 build_runtime.c build_run_asm_build 一致。 */
function build_run_asm_build(shu_path: *u8): i32 {
  let cmd: u8[4096] = [];
    let asm_prefix: u8[38] = [83,72,85,88,95,65,83,77,95,69,88,80,69,82,73,77,69,78,84,65,76,95,
    83,75,73,80,95,71,69,78,61,49,32,83,72,85,88,61];
    let asm_suffix: u8[28] = [32,46,47,115,99,114,105,112,116,115,47,98,117,105,108,100,95,115,
    104,117,120,95,97,115,109,46,115,104];
  let off: i32 = append_lit(cmd, 4096, 0, asm_prefix, 38);
  if (off < 0) { return -1; }
  off = copy_path(cmd, 4096, off, shu_path);
  if (off < 0) { return -1; }
  off = append_lit(cmd, 4096, off, asm_suffix, 28);
  if (off < 0) { return -1; }
  cmd[off] = 0;
  if (build_exec_system(cmd) != 0) { return -1; }
  return 0;
}

