/** format 整数 overload 共用体：按形参类型调用 fmt_scalar_to_buf。 */
function format(buf: *u8, cap: i32, a: i32, b: i32): i32 {
  let n1: i32 = fmt.fmt_scalar_to_buf(buf, cap, a);
  if (n1 < 0) { return -1; }
  let n2: i32 = fmt.fmt_scalar_to_buf(&buf[n1], cap - n1, b);
  if (n2 < 0) { return -1; }
  return n1 + n2;
}
function format(buf: *u8, cap: i32, a: i32, b: u32): i32 {
  let n1: i32 = fmt.fmt_scalar_to_buf(buf, cap, a);
  if (n1 < 0) { return -1; }
  let n2: i32 = fmt.fmt_scalar_to_buf(&buf[n1], cap - n1, b);
  if (n2 < 0) { return -1; }
  return n1 + n2;
}
