// std.io — Read/Write 与标准流 API（高性能 Shu IO 三层之 API 层，与 std.fs 联合极致压榨）
//
// 职责：Reader/Writer trait、ReadOnlySlice/WriteOnlySlice；对 std.io.driver 的薄封装，同步 = submit + 等一次完成。
// 提供：handle 常量、单次/批量读写、标准流（stdin/stdout/stderr）；fd 便捷 API（read_fd/write_fd/read_batch_fd/write_batch_fd）与 std.fs 联合走 io_uring/readv 极致压榨。
// 零拷贝：写路径已零拷贝（write/write_fd 直接传用户 ptr 进内核，无库内二次拷贝）；读零拷贝为 read_ptr/read_ptr_len、read_stdin_ptr，返回内部缓冲只读指针。
// read_ptr 生命周期（Z2）：
//   1. 指针指向 io.c 单线程内部缓冲（g_io_read_ptr_buf）；只读，勿写入或 free。
//   2. 有效至同线程下一次 read_ptr / read_stdin_ptr 成功返回新指针前；并发 read_ptr 不隔离（单缓冲）。
//   3. read_ptr_len() 仅对最近一次成功的 read_ptr/read_stdin_ptr 有效；失败或 EOF 后 len 可能为 0。
//   4. 与 []u8 slice 互操作：let p = read_ptr(h, 0); let n = read_ptr_len() as usize; 构造 ReadOnlySlice { data: { data: p, length: n } } 或 read_into 用户缓冲（勿对 p 越界写）。
//   5. M-5/ZC-3：read_ptr_slice / shu_io_read_ptr_slice 等 callee 由 typeck 自动绑域 []u8<io_read_ptr>（TLS g_io_read_ptr_buf）；勿赋给未标注 []u8。
//   6. ZC-2：read_ptr_gen()/read_ptr_gen_valid(g) 与 ReadPtrView {ptr,len,gen} 校验跨 read_ptr 调用；macOS/Linux 常规文件 mmap 绝对视图。
//   7. 大文件/长生命周期数据请用 read/read_fd 拷入用户缓冲，或 std.fs.fs_mmap_ro 映射只读页。
// ZC-1 Provided Buffers 生命周期：
//   1. 先 register_provided_buffers(nr, bufsz)；内核通过 IORING_OP_PROVIDE_BUFFERS 注册 buffer ring。
//   2. read_provided_fd / read_batch_provided_fd 返回后，数据在 provided_buffer_ptr(bid)；只读，勿 free。
//   3. 同线程下一次 provided recv 复用 bid 前有效；并发 provided recv 不隔离（每线程独立池）。
//   4. Linux 5.19+ / io_uring；macOS 等非 Linux 返回失败，请回退 read_fixed_fd 或 read_batch_fd。
// 依赖：std.io.driver（Buffer、submit_read/submit_write、read_ptr/read_ptr_len）；std.io.core（固定 buffer 池多块注册）。
import std.io.driver;
import std.io.core;
// ——— ReadOnlySlice / WriteOnlySlice（零拷贝只读/只写视图，预留与 driver 对接） ———
struct ReadOnlySlice {
  data: []u8
}
struct WriteOnlySlice {
  data: []u8
}
/**
 * ZC-2：read_ptr 三元组视图（ptr + len + gen）。
 * gen 与 read_ptr_gen_valid 配套，用于跨 read_ptr 调用校验指针是否仍有效。
 */
allow(padding) struct ReadPtrView {
  ptr: *u8;
  len: i32;
  gen: u64;
}
// ——— Reader / Writer trait（自举前必须清单第二步、高并发IO 1.1） ———
// 最小签名：仅 (self) + 返回类型；具体 impl 由 File/网络等类型实现；read/write 缓冲与长度由 impl 方法参数扩展。
trait Reader {
  function read(self): i32;
}
trait Writer {
  function write(self): i32;
}
// ——— 超时常量：timeout_ms 传 0 表示无超时（阻塞直到完成），与 driver 一致 ———
// 使用示例：read_with_timeout(ptr, len, 0) 等价于 read_stdin(ptr, len)。
// ——— 标准 handle（0=stdin，1=stdout，2=stderr；≥2 可与 std.fs/std.net fd 统一） ———
// SU 流水线 return 字面量可由 typeck 隐式升格为 usize（与 std 内 read(数字,…) 的常见写法等价）。
function handle_stdin(): usize { return 0; }
function handle_stdout(): usize { return 1; }
function handle_stderr(): usize { return 2; }
/** 将 std.fs 等得到的 fd 转为 io handle，用于 read/write；与 std.fs 联合压榨时 fd 走 io_uring/readv。 */
/** fd 转 handle；第二参 unused 与 codegen 产出一致，调用处传 0。 */
function handle_from_fd(fd: i32, _unused: i32): usize { return (fd as usize); }
// ——— 通用 handle 读写：任意 handle（stdin/stdout/stderr 或 fd）均可走同一套 submit ———
// 从 handle 读入至 ptr[0..len]，timeout_ms 毫秒（0=无超时）。返回读入字节数，0=EOF，-1=错误。
function read(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  let buf: Buffer = Buffer { ptr: ptr, len: len, handle: handle };
  return submit_read(buf, timeout_ms);
}
// 将 ptr[0..len] 写入 handle，timeout_ms 毫秒（0=无超时）。返回写入字节数，-1=错误。
function write(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  let buf: Buffer = Buffer { ptr: ptr, len: len, handle: handle };
  return submit_write(buf, timeout_ms);
}
/** 与 read 同义；供 std.fs 等模块调用，避免与 libc read(fd,buf,count) 同名冲突。 */
function read_into(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return read(handle, ptr, len, timeout_ms);
}
/** 与 write 同义；供 std.fs 等模块调用，避免与 libc write(fd,buf,count) 同名冲突。 */
function write_from(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return write(handle, ptr, len, timeout_ms);
}
// ——— 标准流便捷 API（等价于 read(0,...)/write(1,...)/write(2,...)，timeout=0） ———
function read_stdin(ptr: *u8, len: usize): i32 {
  return read(handle_stdin(), ptr, len, 0);
}
/** 零拷贝读：读入内部缓冲，返回只读指针；失败返回 0。生命周期见文件头 Z2 约定。 */
function read_ptr(handle: usize, timeout_ms: u32): *u8 {
  return driver_read_ptr(handle, timeout_ms);
}
/** 返回最近一次 read_ptr/read_stdin_ptr 成功读入的字节数；与 read_ptr/read_stdin_ptr 配套使用。 */
function read_ptr_len(): i32 {
  return driver_read_ptr_len();
}
/**
 * ZC-2：返回最近一次成功 read_ptr 的 generation。
 * 与 read_ptr_gen_valid 配套：跨 read_ptr 调用后 saved gen 不等则旧指针失效。
 */
function read_ptr_gen(): u64 {
  return driver_read_ptr_gen();
}
/** ZC-2：saved 与当前 generation 相等返回 1（视图仍有效），否则 0。 */
function read_ptr_gen_valid(saved: u64): i32 {
  return driver_read_ptr_gen_valid(saved);
}
/** ZC-2：上次 read_ptr 后端：0=TLS，1=mmap(Linux)，2=dispatch_data(macOS)。 */
function read_ptr_backend(): i32 {
  return driver_read_ptr_backend();
}
/**
 * ZC-2：零拷贝读并打包为 ReadPtrView（ptr+len+gen 一次取用）。
 * 失败时 ptr=0、len=0、gen 为当前 generation。
 */
function read_ptr_view(handle: usize, timeout_ms: u32): ReadPtrView {
  let p: *u8 = read_ptr(handle, timeout_ms);
  let n: i32 = read_ptr_len();
  let g: u64 = read_ptr_gen();
  return ReadPtrView { ptr: p, len: n, gen: g };
}
/** ZC-2：ReadPtrView 是否仍对应当前有效 read_ptr 视图。 */
function read_ptr_view_valid(v: ReadPtrView): i32 {
  if (v.ptr == 0 as *u8) {
    return 0;
  }
  return read_ptr_gen_valid(v.gen);
}
/** ZC-2：stdin 版 read_ptr_view。 */
function read_stdin_ptr_view(): ReadPtrView {
  return read_ptr_view(handle_stdin(), 0);
}
/**
 * M-5：零拷贝读并返回 []u8 slice（域 io_read_ptr，指向 TLS g_io_read_ptr_buf）。
 * 生命周期同 read_ptr；勿赋给未标注 []u8（typeck 域逃逸检查）。
 */
function read_ptr_slice(handle: usize, timeout_ms: u32): []u8<io_read_ptr> {
  return driver_read_ptr_slice(handle, timeout_ms);
}
/** 零拷贝读 stdin slice；等价 read_ptr_slice(handle_stdin(), 0)。 */
function read_stdin_ptr_slice(): []u8<io_read_ptr> {
  return read_ptr_slice(handle_stdin(), 0);
}
/** 零拷贝读 stdin：读入内部缓冲，返回只读指针；失败返回 0。指针在下次 read_stdin_ptr/read_ptr 前有效；长度用 read_ptr_len()。 */
function read_stdin_ptr(): *u8 {
  return read_ptr(handle_stdin(), 0);
}
function write_stdout(ptr: *u8, len: usize): i32 {
  return write(handle_stdout(), ptr, len, 0);
}
function write_stderr(ptr: *u8, len: usize): i32 {
  return write(handle_stderr(), ptr, len, 0);
}
// ——— 带超时的标准流 API ———
function read_with_timeout(ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return read(handle_stdin(), ptr, len, timeout_ms);
}
function write_with_timeout(ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return write(handle_stdout(), ptr, len, timeout_ms);
}
// 向 stderr 写入 ptr[0..len]，超时 timeout_ms（0=无超时）。返回写入字节数，-1=错误。
function write_stderr_with_timeout(ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return write(handle_stderr(), ptr, len, timeout_ms);
}
// ——— 批量读写：直接使用 std.io.driver 的 submit_read_batch / submit_write_batch（import std.io.driver 后传 [4]Buffer + n + timeout_ms） ———
// ——— 与 std.fs 联合极致压榨：fd 单次/批量走 io_uring（Linux）/readv/writev，一次 submit 多段 ———
/** 从 fd 读入至 ptr[0..len]（timeout=0）；fd 可为 std.fs 打开的文件。推荐 len ≥ std.fs.fs_read_chunk() 压榨 syscall。返回读入字节数，0=EOF，-1=错误。 */
function read_fd(fd: i32, ptr: *u8, len: usize): i32 {
  return read(handle_from_fd(fd, 0), ptr, len, 0);
}
/** 将 ptr[0..len] 写入 fd（timeout=0）；fd 可为 std.fs 打开的文件。返回写入字节数，-1=错误。 */
function write_fd(fd: i32, ptr: *u8, len: usize): i32 {
  return write(handle_from_fd(fd, 0), ptr, len, 0);
}
/** 从 fd 批量读：一次 submit 最多 4 段 (p0,l0)..(p3,l3)，n 为段数 1..4。Linux 走 io_uring 多 SQE 或 readv，极致压榨。返回总字节数，-1=错误。 */
function read_batch_fd(fd: i32, p0: *u8, l0: usize, p1: *u8, l1: usize, p2: *u8, l2: usize, p3: *u8, l3: usize, n: i32): i32 {
  let h: usize = handle_from_fd(fd, 0);
  let bufs: [4]Buffer = [
    Buffer { ptr: p0, len: l0, handle: h },
    Buffer { ptr: p1, len: l1, handle: h },
    Buffer { ptr: p2, len: l2, handle: h },
    Buffer { ptr: p3, len: l3, handle: h }
  ];
  return submit_read_batch(bufs, n, 0);
}
/** 向 fd 批量写：一次 submit 最多 4 段 (p0,l0)..(p3,l3)，n 为段数 1..4。Linux 走 io_uring 多 SQE 或 writev，极致压榨。返回总字节数，-1=错误。 */
function write_batch_fd(fd: i32, p0: *u8, l0: usize, p1: *u8, l1: usize, p2: *u8, l2: usize, p3: *u8, l3: usize, n: i32): i32 {
  let h: usize = handle_from_fd(fd, 0);
  let bufs: [4]Buffer = [
    Buffer { ptr: p0, len: l0, handle: h },
    Buffer { ptr: p1, len: l1, handle: h },
    Buffer { ptr: p2, len: l2, handle: h },
    Buffer { ptr: p3, len: l3, handle: h }
  ];
  return submit_write_batch(bufs, n, 0);
}
/** 与 Zig/Rust 对齐：从 fd 按「指针+段数」批量读；buffers 指向至少 n 个 Buffer（ptr/len 有效），n 为 1..16。timeout=0。返回总字节数，-1=错误。 */
function read_batch_fd_buf(fd: i32, buffers: *Buffer, n: i32): i32 {
  let h: usize = handle_from_fd(fd, 0);
  return submit_read_batch_buf(h, buffers, n, 0);
}
/** 与 Zig/Rust 对齐：向 fd 按「指针+段数」批量写；buffers 同上，n 为 1..16。返回总字节数，-1=错误。 */
function write_batch_fd_buf(fd: i32, buffers: *Buffer, n: i32): i32 {
  let h: usize = handle_from_fd(fd, 0);
  return submit_write_batch_buf(h, buffers, n, 0);
}
// ——— 便捷：向 stdout 写一段字节（等价于 write_stdout(ptr, len)） ———
function print_str(ptr: *u8, len: usize): i32 {
  return write_stdout(ptr, len);
}
// ——— 固定 buffer 池（多块）：注册最多 4 块 (p0,l0)..(p3,l3)，nr 为实际数量 1..4。返回 1 成功，0 失败。———
// 与 std.io.driver 中曾重复的同名实现已移到仅保留在 mod；asm 合并 dep 时仍依赖 runtime merge 对同 import 路径去重。
function register_fixed_buffers(p0: *u8, l0: usize, p1: *u8, l1: usize, p2: *u8, l2: usize, p3: *u8, l3: usize, nr: u32): i32 {
  return shu_io_register_buffers(p0, l0, p1, l1, p2, l2, p3, l3, nr);
}
/** 与 Zig/Rust 对齐：按「指针+块数」注册固定 buffer 池；bufs 指向至少 nr 个 Buffer（ptr/len 有效），nr 为 1..8。返回 1 成功，0 失败。 */
function register_fixed_buffers_buf(bufs: *Buffer, nr: u32): i32 {
  return submit_register_fixed_buffers_buf(bufs, nr);
}
/** 阶段 4 性能压榨：从 fd 用已注册 fixed buffer 读；buf_index 为 register_fixed_buffers 池下标，offset+len 须 ≤ 该块长度。返回读入字节数，0=EOF，-1=错误。供 std.net 热路径用。 */
function read_fixed_fd(fd: i32, buf_index: u32, offset: usize, len: usize, timeout_ms: u32): i32 {
  return shu_io_read_fixed(handle_from_fd(fd, 0), buf_index, offset, len, timeout_ms);
}
/** 阶段 4 性能压榨：向 fd 用已注册 fixed buffer 写；buf_index/offset/len 同上。返回写入字节数，-1=错误。 */
function write_fixed_fd(fd: i32, buf_index: u32, offset: usize, len: usize, timeout_ms: u32): i32 {
  return shu_io_write_fixed(handle_from_fd(fd, 0), buf_index, offset, len, timeout_ms);
}
// ─── ZC-1 Provided Buffers：IORING_OP_PROVIDE_BUFFERS + buffer ring（Linux 5.19+）───
// 热路径默认 SHU_IO_PROVIDE_LAZY=1：re-provide 后延迟 drain PROVIDE CQE，下轮读前批量收割。
/** 注册 provided 池；nr 1..32，bufsz 建议 4096。成功 1，失败/不支持 0。 */
function register_provided_buffers(nr: u32, bufsz: u32): i32 {
  return shu_io_register_provided_buffers(nr, bufsz);
}
/** 注销 provided 池。 */
function unregister_provided_buffers(): void {
  shu_io_unregister_provided_buffers();
}
/** 返回 bid 块只读指针；生命周期至该块被再次 recv 覆盖。 */
function provided_buffer_ptr(bid: u32): *u8 {
  return shu_io_provided_buffer_ptr(bid);
}
/** provided 单块容量。 */
function provided_buffer_size(): u32 {
  return shu_io_provided_buffer_size();
}
/** 单次 provided recv；out_bid/out_len 可传 0。返回字节数，0=EOF，-1=错误。 */
function read_provided_fd(fd: i32, timeout_ms: u32, out_bid: *u32, out_len: *u32): i32 {
  return shu_io_read_provided(handle_from_fd(fd, 0), timeout_ms, out_bid, out_len);
}
/** 批量 provided recv（n=1..4）；out_bids/out_lens 各 n 元素。返回总字节数，-1=错误。 */
function read_batch_provided_fd(fd: i32, n: i32, timeout_ms: u32, out_bids: *u32, out_lens: *u32): i32 {
  return shu_io_read_batch_provided(handle_from_fd(fd, 0), n, timeout_ms, out_bids, out_lens);
}
// ——— 多 fd 就绪等待：fds 指向 n 个 i32（fd），一次系统调用等待任意可读。返回就绪下标 0..n-1，超时/错误 -1。———
function wait_readable(fds: *i32, n: i32, timeout_ms: u32): i32 {
  return shu_io_wait_readable(fds, n, timeout_ms);
}
// ——— slice 版 API：使用 []u8 的 .data（*u8）与 .length（usize）对接 read/write ———
// IO-A5 v2：非阻塞 read；submit 返回 slot>=0，complete_read_async_slot(slot) 收割。
const IO_ASYNC_NOT_READY: i32 = -2;
/** 提交非阻塞 read；成功返回 slot>=0，失败 -1。 */
function read_async(handle: usize, ptr: *u8, len: usize): i32 {
  return shu_io_submit_read_async(ptr, len, handle);
}
/** 收割在途 read_async（单 in-flight 兼容）；见 IO_ASYNC_NOT_READY。 */
function complete_read_async(): i32 {
  return shu_io_complete_read_async();
}
/** 收割指定 slot 的 read_async。 */
function complete_read_async_slot(slot: i32): i32 {
  return shu_io_complete_read_async_slot(slot);
}
/** 提交非阻塞 write；成功返回 slot>=0，失败 -1。 */
function write_async(handle: usize, ptr: *u8, len: usize): i32 {
  return shu_io_submit_write_async(ptr, len, handle);
}
/** 收割在途 write_async（单 in-flight 兼容）；见 IO_ASYNC_NOT_READY。 */
function complete_write_async(): i32 {
  return shu_io_complete_write_async();
}
/** 收割指定 slot 的 write_async。 */
function complete_write_async_slot(slot: i32): i32 {
  return shu_io_complete_write_async_slot(slot);
}
// 从 stdin 读入至 buf[0..buf.length]，timeout_ms 毫秒（0=无超时）。返回读入字节数，0=EOF，-1=错误。
function read_into_slice(buf: []u8, timeout_ms: u32): i32 {
  return read(handle_stdin(), buf.data, buf.length, timeout_ms);
}
// 将 buf[0..buf.length] 写入 stdout，timeout_ms 毫秒（0=无超时）。返回写入字节数，-1=错误。
function write_from_slice(buf: []u8, timeout_ms: u32): i32 {
  return write(handle_stdout(), buf.data, buf.length, timeout_ms);
}
// ——— 标准输出（print_* 由 codegen 生成 printf 调用，此处占位保证可 import） ———
function print_i32(x: i32): i32 { return 0; }
function print_u32(x: u32): i32 { return 0; }
function print_i64(x: i64): i32 { return 0; }
// 占位，表示本模块可 import
function placeholder(): i32 { return 0; }
