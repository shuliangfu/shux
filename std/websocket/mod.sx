// std.websocket — RFC6455 WebSocket 握手与帧（STD-031）
//
// 【文件职责】导出 net/ws.inc.c 中的 C 实现；握手 HTTP 部分配合 std.http。
// 【依赖】std.net（TCP/TLS 连接）；std.context（取消/超时）；C 符号链入 std/net/net.o（ws.inc.c）。

const context = import("std.context");
const err = import("std.error");

extern function net_ws_compute_accept_c(key: *u8, key_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_handshake_request_c(host: *u8, path: *u8, key: *u8, out: *u8, out_cap: i32): i32;
extern function net_ws_validate_handshake_c(resp: *u8, resp_len: i32, key: *u8, key_len: i32): i32;
extern function net_ws_encode_text_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_encode_binary_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_encode_ping_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_encode_pong_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_encode_close_frame_c(status_code: i32, reason: *u8, reason_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_decode_frame_c(buf: *u8, buf_len: i32, out_opcode: *i32, out_payload: *u8,
  out_payload_cap: i32, out_payload_len: *i32): i32;
extern function net_ws_generate_key_c(out: *u8, out_cap: i32): i32;
extern function net_ws_client_handshake_c(fd: i32, host: *u8, path: *u8, key: *u8, key_len: i32, timeout_ms: u32): i32;
extern function net_ws_connect_c(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, timeout_ms: u32): i32;
extern function net_ws_connect_tls_c(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, timeout_ms: u32, out_tls: *i64): i32;
extern function net_ws_connect_url_c(url: *u8, url_len: i32, key: *u8, key_len: i32, timeout_ms: u32, out_fd: *i32, out_tls: *i64): i32;
extern function net_ws_parse_url_c(url: *u8, url_len: i32, host: *u8, host_cap: i32, path: *u8, path_cap: i32, out_port: *u32, out_secure: *i32): i32;
extern function net_ws_tls_is_available_c(): i32;
extern function net_ws_write_text_c(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32;
extern function net_ws_write_binary_c(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32;
extern function net_ws_read_frame_c(fd: i32, tls_ctx: i64, out_opcode: *i32, out_payload: *u8, out_cap: i32, out_payload_len: *i32, timeout_ms: u32): i32;
extern function net_ws_extract_key_from_request_c(req: *u8, req_len: i32, out_key: *u8, out_cap: i32): i32;
extern function net_ws_validate_upgrade_request_c(req: *u8, req_len: i32): i32;
extern function net_ws_server_accept_request_c(fd: i32, tls_ctx: i64, req: *u8, req_len: i32, timeout_ms: u32): i32;
extern function net_ws_server_handshake_c(fd: i32, tls_ctx: i64, timeout_ms: u32): i32;
extern function net_ws_encode_server_text_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_encode_server_binary_frame_c(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32;
extern function net_ws_write_server_text_c(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32;
extern function net_ws_write_server_binary_c(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32;
extern function net_ws_client_handshake_smoke_c(): i32;
extern function net_ws_server_accept_smoke_c(): i32;
extern function net_ws_parse_url_smoke_c(): i32;
extern function net_close_socket_c(fd: i32): i32;
extern function net_tls_close_c(ctx_handle: i64): i32;

/** WebSocket 会话（TCP fd + 可选 TLS ctx，0 表示 ws:// 明文）。 */
allow(padding) struct WsStream {
  fd: i32;
  tls_ctx: i64;
}

/** 成功。 */
function ws_err_ok(): i32 { return 0; }
/** IO / 连接失败。 */
function ws_err_io(): i32 { return -1; }
/** 握手失败。 */
function ws_err_handshake(): i32 { return -2; }
/** 空参数。 */
function ws_err_null(): i32 { return -3; }
/** TLS 不可用（须链入 std.net TLS 后端）。 */
function ws_err_tls_not_impl(): i32 { return -1221; }

/** 从 Context 推导 WebSocket I/O 超时毫秒；已取消/过期返回 net_err_*，否则 0 或正毫秒。 */
function ws_timeout_ms_from_ctx(ctx: Context): i32 {
  if (context.is_cancelled(ctx) != 0) {
    return err.net_err_cancelled();
  }
  let rem: i64 = context.remaining_ns(ctx);
  let dl: i64 = context.deadline_ns(ctx);
  if (dl > 0 && rem <= 0) {
    return err.net_err_timeout();
  }
  if (rem <= 0) {
    return 0;
  }
  let ms: i64 = rem / 1000000;
  if (ms <= 0) {
    return 1;
  }
  if (ms > 2147483647) {
    return 2147483647;
  }
  return ms as i32;
}

/** 请求/读写前检查 Context；0 可继续，否则返回 net_err_cancelled/timeout。 */
function ws_ctx_check(ctx: Context): i32 {
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  if (tm == err.net_err_cancelled()) {
    return tm;
  }
  if (tm == err.net_err_timeout()) {
    return tm;
  }
  return 0;
}

/** 将 C 层 TLS 不可用映射为 ws_err_tls_not_impl。 */
function ws_map_c_result(c_code: i32): i32 {
  if (c_code == ws_err_tls_not_impl()) {
    return ws_err_tls_not_impl();
  }
  return c_code;
}

/** RFC6455 帧 opcode：TEXT。 */
function ws_opcode_text(): i32 { return 1; }
/** RFC6455 帧 opcode：BINARY。 */
function ws_opcode_binary(): i32 { return 2; }
/** RFC6455 帧 opcode：CLOSE。 */
function ws_opcode_close(): i32 { return 8; }
/** RFC6455 帧 opcode：PING。 */
function ws_opcode_ping(): i32 { return 9; }
/** RFC6455 帧 opcode：PONG。 */
function ws_opcode_pong(): i32 { return 10; }

/** WSS 是否可用（OpenSSL/mbedTLS 链入时为 true）。 */
function wss_is_available(): bool {
  if (net_ws_tls_is_available_c() != 0) { return true; }
  return false;
}

/** 计算 Sec-WebSocket-Accept（RFC 6455 金样烟测）。 */
function ws_compute_accept(key: *u8, key_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_compute_accept_c(key, key_len, out, out_cap);
}

/** 构建客户端握手 HTTP 请求；返回写入字节数（不含 NUL）。 */
function ws_build_handshake_request(host: *u8, path: *u8, key: *u8, out: *u8, out_cap: i32): i32 {
  return net_ws_handshake_request_c(host, path, key, out, out_cap);
}

/** 校验服务端 101 握手响应；成功 0。 */
function ws_validate_handshake_response(resp: *u8, resp_len: i32, key: *u8, key_len: i32): i32 {
  return net_ws_validate_handshake_c(resp, resp_len, key, key_len);
}

/** 编码客户端 TEXT 帧（MASK=1）；返回帧总字节数。 */
function ws_encode_text_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_text_frame_c(payload, payload_len, out, out_cap);
}

/** 编码客户端 BINARY 帧（MASK=1）；返回帧总字节数。 */
function ws_encode_binary_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_binary_frame_c(payload, payload_len, out, out_cap);
}

/** 编码客户端 PING 帧；payload 可为空（0 长度心跳）。 */
function ws_encode_ping_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_ping_frame_c(payload, payload_len, out, out_cap);
}

/** 编码客户端 PONG 帧；通常 echo ping 负载。 */
function ws_encode_pong_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_pong_frame_c(payload, payload_len, out, out_cap);
}

/**
 * 编码客户端 CLOSE 帧。
 * status_code < 0 且无 reason 时发空负载；否则 2 字节大端 status + 可选 reason。
 */
function ws_encode_close_frame(status_code: i32, reason: *u8, reason_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_close_frame_c(status_code, reason, reason_len, out, out_cap);
}

/** 解析 WebSocket 帧；成功 0 并写 *out_payload_len。 */
function ws_decode_frame(buf: *u8, buf_len: i32, out_opcode: *i32, out_payload: *u8,
  out_payload_cap: i32, out_payload_len: *i32): i32 {
  return net_ws_decode_frame_c(buf, buf_len, out_opcode, out_payload, out_payload_cap, out_payload_len);
}

/** 生成 Sec-WebSocket-Key（24 字符 Base64）；失败 -1。 */
function ws_generate_key(out: *u8, out_cap: i32): i32 {
  return net_ws_generate_key_c(out, out_cap);
}

/**
 * 解析 ws(s)://host[:port]/path；成功 ws_err_ok()。
 * out_port 默认 80/443；out_secure=1 表示 wss。
 */
function ws_parse_url(url: *u8, url_len: i32, host: *u8, host_cap: i32, path: *u8, path_cap: i32,
  out_port: *u32, out_secure: *i32): i32 {
  if (url == 0 || host == 0 || path == 0 || out_port == 0) { return ws_err_null(); }
  return net_ws_parse_url_c(url, url_len, host, host_cap, path, path_cap, out_port, out_secure);
}

/**
 * 在已连接 TCP fd 上完成 WebSocket 客户端握手（明文 ws://）。
 * key/key_len 为 0 时自动生成 Key；成功 ws_err_ok()。
 */
function ws_client_handshake(fd: i32, host: *u8, path: *u8, key: *u8, key_len: i32, timeout_ms: u32): i32 {
  if (fd < 0 || host == 0 || path == 0) { return ws_err_null(); }
  return net_ws_client_handshake_c(fd, host, path, key, key_len, timeout_ms);
}

/** 带 Context 的客户端握手（已连接 fd）。 */
function ws_client_handshake_ctx(fd: i32, host: *u8, path: *u8, key: *u8, key_len: i32, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  return net_ws_client_handshake_c(fd, host, path, key, key_len, tm as u32);
}

/**
 * TCP 连接 + WebSocket 握手（ws://；port=0 默认 80）。
 * 成功返回 WsStream；失败 fd=-1。
 */
function ws_connect(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, timeout_ms: u32): WsStream {
  let bad: WsStream = WsStream { fd: -1, tls_ctx: 0 };
  let zero: i64 = 0;
  if (host == 0 || path == 0) { return bad; }
  let fd: i32 = net_ws_connect_c(host, port, path, key, key_len, timeout_ms);
  return WsStream { fd: fd, tls_ctx: zero };
}

/**
 * 带 Context 的 ws:// 连接；成功返回 fd，失败 fd=-1，取消/过期返回 net_err_*。
 */
function ws_connect_ctx_fd(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, ctx: Context): i32 {
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  if (tm < 0) {
    return tm;
  }
  if (host == 0 || path == 0) {
    return ws_err_null();
  }
  return net_ws_connect_c(host, port, path, key, key_len, tm as u32);
}

/** 带 Context 的 ws:// 连接；返回 WsStream（fd<0 含 net_err_* 负码）。 */
function ws_connect_ctx(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, ctx: Context): WsStream {
  let zero: i64 = 0;
  let fd: i32 = ws_connect_ctx_fd(host, port, path, key, key_len, ctx);
  return WsStream { fd: fd, tls_ctx: zero };
}

/**
 * TCP + TLS + WebSocket 握手（wss://；port=0 默认 443）。
 * TLS 不可用时返回 fd=-1（调用方应检查 wss_is_available）。
 */
function ws_connect_tls(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, timeout_ms: u32): WsStream {
  let bad: WsStream = WsStream { fd: -1, tls_ctx: 0 };
  let tls: i64 = 0;
  let fd: i32 = 0;
  if (host == 0 || path == 0) { return bad; }
  fd = net_ws_connect_tls_c(host, port, path, key, key_len, timeout_ms, &tls);
  if (fd < 0) { return bad; }
  return WsStream { fd: fd, tls_ctx: tls };
}

/** 带 Context 的 wss:// 连接；成功返回 fd 并写 *out_tls，取消/过期返回 net_err_*。 */
function ws_connect_tls_ctx_fd(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, ctx: Context, out_tls: *i64): i32 {
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  if (tm < 0) {
    return tm;
  }
  if (host == 0 || path == 0 || out_tls == 0) {
    return ws_err_null();
  }
  return ws_map_c_result(net_ws_connect_tls_c(host, port, path, key, key_len, tm as u32, out_tls));
}

/** 带 Context 的 wss:// 连接；返回 WsStream（fd<0 含 net_err_* 负码）。 */
function ws_connect_tls_ctx(host: *u8, port: u32, path: *u8, key: *u8, key_len: i32, ctx: Context): WsStream {
  let tls: i64 = 0;
  let fd: i32 = ws_connect_tls_ctx_fd(host, port, path, key, key_len, ctx, &tls);
  if (fd < 0) {
    return WsStream { fd: fd, tls_ctx: 0 };
  }
  return WsStream { fd: fd, tls_ctx: tls };
}

/**
 * ws(s):// URL 一站式连接。
 * 成功返回 WsStream（wss 时 tls_ctx 非 0）；失败 fd=-1。
 */
function ws_connect_url(url: *u8, url_len: i32, key: *u8, key_len: i32, timeout_ms: u32): WsStream {
  let bad: WsStream = WsStream { fd: -1, tls_ctx: 0 };
  let fd: i32 = -1;
  let tls: i64 = 0;
  if (url == 0) { return bad; }
  if (net_ws_connect_url_c(url, url_len, key, key_len, timeout_ms, &fd, &tls) != ws_err_ok()) {
    return bad;
  }
  return WsStream { fd: fd, tls_ctx: tls };
}

/**
 * 带 Context 的 ws(s):// URL 连接。
 * 成功 ws_err_ok() 并写 *out_fd/*out_tls；取消/过期返回 net_err_*。
 */
function ws_connect_url_ctx(url: *u8, url_len: i32, key: *u8, key_len: i32, ctx: Context, out_fd: *i32, out_tls: *i64): i32 {
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  if (tm < 0) {
    return tm;
  }
  if (url == 0 || out_fd == 0 || out_tls == 0) {
    return ws_err_null();
  }
  return ws_map_c_result(net_ws_connect_url_c(url, url_len, key, key_len, tm as u32, out_fd, out_tls));
}

/** 带 Context 的 ws(s):// URL 连接；返回 WsStream。 */
function ws_connect_url_ctx_stream(url: *u8, url_len: i32, key: *u8, key_len: i32, ctx: Context): WsStream {
  let bad: WsStream = WsStream { fd: -1, tls_ctx: 0 };
  let fd: i32 = -1;
  let tls: i64 = 0;
  if (ws_connect_url_ctx(url, url_len, key, key_len, ctx, &fd, &tls) != ws_err_ok()) {
    if (fd < 0) {
      return WsStream { fd: fd, tls_ctx: 0 };
    }
    return bad;
  }
  return WsStream { fd: fd, tls_ctx: tls };
}

/** 发送 TEXT 帧；成功返回写入 payload 字节数，失败 -1。 */
function ws_write_text(stream: WsStream, payload: *u8, payload_len: i32): i32 {
  if (stream.fd < 0) { return ws_err_io(); }
  return net_ws_write_text_c(stream.fd, stream.tls_ctx, payload, payload_len);
}

/** 发送 BINARY 帧；成功返回写入 payload 字节数，失败 -1。 */
function ws_write_binary(stream: WsStream, payload: *u8, payload_len: i32): i32 {
  if (stream.fd < 0) { return ws_err_io(); }
  return net_ws_write_binary_c(stream.fd, stream.tls_ctx, payload, payload_len);
}

/** 带 Context 的 TEXT 发送；取消/过期短路，不写入。 */
function ws_write_text_ctx(stream: WsStream, payload: *u8, payload_len: i32, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  return ws_write_text(stream, payload, payload_len);
}

/** 带 Context 的 BINARY 发送；取消/过期短路，不写入。 */
function ws_write_binary_ctx(stream: WsStream, payload: *u8, payload_len: i32, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  return ws_write_binary(stream, payload, payload_len);
}

/** 读取一帧；成功 ws_err_ok() 并写 opcode/payload_len。 */
function ws_read_frame(stream: WsStream, out_opcode: *i32, out_payload: *u8, out_cap: i32,
  out_payload_len: *i32, timeout_ms: u32): i32 {
  if (stream.fd < 0) { return ws_err_io(); }
  return net_ws_read_frame_c(stream.fd, stream.tls_ctx, out_opcode, out_payload, out_cap, out_payload_len, timeout_ms);
}

/** 带 Context 的读帧；deadline 推导 timeout_ms。 */
function ws_read_frame_ctx(stream: WsStream, out_opcode: *i32, out_payload: *u8, out_cap: i32,
  out_payload_len: *i32, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  return ws_read_frame(stream, out_opcode, out_payload, out_cap, out_payload_len, tm as u32);
}

/** 关闭 WebSocket 会话（TLS + TCP）。 */
function ws_close(stream: WsStream): i32 {
  let zero: i64 = 0;
  if (stream.tls_ctx != zero) {
    net_tls_close_c(stream.tls_ctx);
  }
  if (stream.fd < 0) { return ws_err_ok(); }
  return net_close_socket_c(stream.fd);
}

/** 从 HTTP Upgrade 请求提取 Sec-WebSocket-Key；成功返回 key 长度。 */
function ws_extract_key_from_request(req: *u8, req_len: i32, out_key: *u8, out_cap: i32): i32 {
  if (req == 0 || out_key == 0) { return ws_err_null(); }
  return net_ws_extract_key_from_request_c(req, req_len, out_key, out_cap);
}

/** 校验客户端 WebSocket Upgrade 请求（GET + Upgrade + Version 13 + Key）；成功 ws_err_ok()。 */
function ws_validate_upgrade_request(req: *u8, req_len: i32): i32 {
  if (req == 0) { return ws_err_null(); }
  return net_ws_validate_upgrade_request_c(req, req_len);
}

/**
 * 服务端：对已有 Upgrade 请求缓冲回复 101 并交接到帧层。
 * fd 为已 accept 的连接；tls_ctx=0 表示明文 ws。
 */
function ws_server_accept(fd: i32, tls_ctx: i64, req: *u8, req_len: i32, timeout_ms: u32): i32 {
  if (fd < 0 || req == 0) { return ws_err_null(); }
  return net_ws_server_accept_request_c(fd, tls_ctx, req, req_len, timeout_ms);
}

/** 带 Context 的服务端 accept（101 + 帧层交接）。 */
function ws_server_accept_ctx(fd: i32, tls_ctx: i64, req: *u8, req_len: i32, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  return ws_server_accept(fd, tls_ctx, req, req_len, tm as u32);
}

/** 服务端：从 fd 读取 Upgrade 请求并完成 101 握手；成功 ws_err_ok()。 */
function ws_server_handshake(fd: i32, tls_ctx: i64, timeout_ms: u32): i32 {
  if (fd < 0) { return ws_err_null(); }
  return net_ws_server_handshake_c(fd, tls_ctx, timeout_ms);
}

/** 带 Context 的服务端握手。 */
function ws_server_handshake_ctx(fd: i32, tls_ctx: i64, ctx: Context): i32 {
  let chk: i32 = ws_ctx_check(ctx);
  if (chk != 0) {
    return chk;
  }
  let tm: i32 = ws_timeout_ms_from_ctx(ctx);
  return ws_server_handshake(fd, tls_ctx, tm as u32);
}

/** 编码服务端 TEXT 帧（MASK=0，payload ≤ 125）；返回帧总字节数。 */
function ws_encode_server_text_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_server_text_frame_c(payload, payload_len, out, out_cap);
}

/** 编码服务端 BINARY 帧（MASK=0，payload ≤ 125）；返回帧总字节数。 */
function ws_encode_server_binary_frame(payload: *u8, payload_len: i32, out: *u8, out_cap: i32): i32 {
  return net_ws_encode_server_binary_frame_c(payload, payload_len, out, out_cap);
}

/** 服务端发送 TEXT 帧（无掩码）；成功返回 payload 字节数。 */
function ws_server_write_text(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32 {
  if (fd < 0) { return ws_err_io(); }
  return net_ws_write_server_text_c(fd, tls_ctx, payload, payload_len);
}

/** 服务端发送 BINARY 帧（无掩码）；成功返回 payload 字节数。 */
function ws_server_write_binary(fd: i32, tls_ctx: i64, payload: *u8, payload_len: i32): i32 {
  if (fd < 0) { return ws_err_io(); }
  return net_ws_write_server_binary_c(fd, tls_ctx, payload, payload_len);
}

/** C 层握手 socketpair 烟测；0 通过。 */
function ws_client_handshake_smoke(): i32 {
  return net_ws_client_handshake_smoke_c();
}

/** ws(s):// URL 解析烟测；0 通过。 */
function ws_parse_url_smoke(): i32 {
  return net_ws_parse_url_smoke_c();
}

/** 服务端 accept 烟测（请求解析 + socketpair 101）；0 通过。 */
function ws_server_accept_smoke(): i32 {
  return net_ws_server_accept_smoke_c();
}

/** WebSocket 模块是否可用（C 已链入 net.o）。 */
function ws_is_implemented(): i32 { return 1; }
