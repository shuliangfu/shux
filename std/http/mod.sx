/** HTTP/2 server push 未实现（旧 API；读路径已可收集）。 */
function http2_err_push_not_impl(): i32 { return -1233; }

/** HTTP/2 h2c 升级路径未实现（直连 preface 见 http2_h2c_session_begin）。 */
function http2_err_h2c_not_impl(): i32 { return -1234; }

/** h2c 仅支持 http://；https:// URL 返回此错误（-1235）。 */
function http2_err_h2c_scheme(): i32 { return -1235; }

/** 并发 stream 已达对端 SETTINGS 上限（-1236）。 */
function http2_err_max_streams(): i32 { return -1236; }

/** 连接未完成 handshake（-1237）。 */
function http2_err_conn_not_ready(): i32 { return -1237; }

/** URL scheme 与 H2 连接池类型不匹配（-1238）。 */
function http2_err_pool_scheme(): i32 { return -1238; }

/** 全局 H2 连接池 host:port 条目已满（-1239）。 */
function http2_err_global_pool_full(): i32 { return -1239; }

/** HTTP/2 h2c server 协议/请求错误（-1240）。 */
function http2_err_server(): i32 { return -1240; }

/** HTTP/2 server push 发送侧参数非法（-1242）。 */
function http2_err_server_push(): i32 { return -1242; }

/** client SETTINGS ENABLE_PUSH=0，server 软拒绝 push（-1243）。 */
function http2_err_server_push_disabled(): i32 { return -1243; }

/** 对端发送 GOAWAY / 期望 GOAWAY 时语义码（-1244）。 */
function http2_err_goaway(): i32 { return -1244; }

/** PING 往返失败 / 未收到匹配 PONG（-1245）。 */
function http2_err_ping(): i32 { return -1245; }

/** 对端 RST_STREAM / stream 被取消（-1246）。 */
function http2_err_rst_stream(): i32 { return -1246; }

/** HTTP/2 over TLS server 不可用或 ALPN 非 h2（-1241）。 */
function http2_err_server_tls(): i32 { return -1241; }

/** HTTP/2 发送窗口耗尽（须 WINDOW_UPDATE；v5 流控状态机）。 */
function http2_err_flow_blocked(): i32 { return -1232; }

/** HTTP/2 网络 h2 over TLS 不可用（须 std.net ALPN；v2）。 */
function http2_err_network_h2(): i32 { return -1231; }

/** HTTP/2 完整编解码层不可用（v1 前占位；现与 client_is_available 对齐）。 */
function http2_err_not_impl(): i32 { return -1230; }

