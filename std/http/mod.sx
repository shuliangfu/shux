/** SETTINGS MAX_CONCURRENT_STREAMS id（0x0003）。 */
function http2_setting_max_concurrent_streams(): i32 { return 3; }

/** SETTINGS INITIAL_WINDOW_SIZE id（0x0004）。 */
function http2_setting_initial_window_size(): i32 { return 4; }

