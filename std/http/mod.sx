/** 复制最近一次 push body；成功返回 body_len，无 push 返回 0。 */
function http2_push_last_copy(out_meta: *Http2PushLast, out_body: *u8, out_cap: i32): i32 {
  return http2_push_last_copy_c(out_meta, out_body, out_cap);
}

/**
 * 复制最近一次 push 资源到堆 body（std.heap.alloc_u8）。
 * 无 push 时 body.len=0 返回 0；失败 -1。调用方须 body_owned_free(out_body)。
 */
function push_last_body_owned(out_meta: *Http2PushLast, out_body: *HttpBodyOwned): i32 {
  let tmp: [4096]u8 = [];
  let n: i32 = 0;
  let p: *u8 = 0;
  let copied: i32 = 0;
  n = http2_push_last_copy(out_meta, &tmp[0], 4096);
  if (n < 0) {
    return -1;
  }
  if (n == 0) {
    out_body.ptr = 0;
    out_body.len = 0;
    return 0;
  }
  p = heap.alloc_u8(n);
  if (p == 0) {
    return -1;
  }
  copied = http_url_copy_c(&tmp[0], n, p, n);
  if (copied < 0) {
    heap.free_u8(p);
    return -1;
  }
  out_body.ptr = p;
  out_body.len = n;
  return n;
}

