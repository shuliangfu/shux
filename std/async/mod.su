// std.async — 最小异步门面（F4）：wait 与 IO submit 分离
//
// 【文件职责】
// 暴露 completion 等待原语，与 std.io 的 submit_read/submit_write 配合。
// Linux 上 std.io 内部已走 io_uring（submit_and_wait）；本模块提供多 fd 就绪等待（wait_completion），
// 供后续 language future/task 扩展时复用，避免在业务层重复 poll 循环。
//
// 【依赖】import std.io（wait_readable / read / write）。
import std.io;

/**
 * 等待 fds[0..n) 中任意 fd 可读；返回就绪下标 0..n-1，超时或错误 -1。
 * 与 std.io.wait_readable 等价，作为 async completion 等待入口。
 */
function wait_completion(fds: *i32, n: i32, timeout_ms: u32): i32 {
  return wait_readable(fds, n, timeout_ms);
}

/**
 * 提交一次读（同步完成）：内部 submit+wait，返回读入字节数。
 * 后续 language 支持 in-flight SQE 时可拆为 submit_read_async + wait_completion。
 */
function submit_read_sync(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return read(handle, ptr, len, timeout_ms);
}

/**
 * 提交一次写（同步完成）：内部 submit+wait，返回写入字节数。
 */
function submit_write_sync(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32 {
  return write(handle, ptr, len, timeout_ms);
}

// ─── A1/A2 协作调度（scheduler.c）：无栈 ping-pong bench ───
extern function shu_async_coop_pingpong(rounds: i64): i64;
extern function shu_async_coop_pingpong_jmp(rounds: i64): i64;

// ─── A3 CPS suspend/resume（scheduler.c；SHU_ASYNC_YIELD=1 时 await 边界 yield）───
extern function shu_async_cps_suspend(phase: *i32, next_phase: i32): i32;
/** IO-A5：await IO 边界 suspend；yield 时进 IO 等待队列。 */
extern function shu_async_cps_suspend_io(phase: *i32, next_phase: i32): i32;
extern function shu_async_run_i32(fn: *u8): i32;
/** IO-A5 v5：push i32 seed 并 submit 协程（spawn C 侧等价）。 */
extern function shu_async_spawn_i32(fn: *u8, seed: i32): i32;
/** IO-A5 v4：poll + drain 直至就绪环与 IO 等待队列皆空；返回已完成任务结果之和。 */
extern function shu_async_run_drain_until_idle(): i32;
/** run v4：实参 seed 队列（i32/u32/i64/usize）。 */
extern function shu_async_run_seed_reset(): void;
extern function shu_async_run_seed_push_i32(v: i32): void;
extern function shu_async_run_seed_push_u32(v: u32): void;
extern function shu_async_run_seed_push_i64(v: i64): void;
extern function shu_async_run_seed_push_usize(v: usize): void;
/** run v1 兼容：单 i32 实参 seed。 */
extern function shu_async_run_seed_set_i32(v: i32): void;
extern function shu_async_run_seed_valid(): i32;
extern function shu_async_run_seed_take_i32(): i32;
extern function shu_async_run_seed_take_u32(): u32;
extern function shu_async_run_seed_take_i64(): i64;
extern function shu_async_run_seed_take_usize(): usize;

// ─── A4 就绪队列（MPSC ring；per-worker 环 + worker_drain）───
// DOD-CL-S2：C 侧 shu_async_task_queue_t 已 align(64) head/tail/slots（见 std/async/scheduler.c）。
extern function shu_async_task_submit(fn: *u8): i32;
/** 提交到指定 worker 环（0..worker_count-1）。 */
extern function shu_async_task_submit_to(worker_id: u32, fn: *u8): i32;
extern function shu_async_scheduler_drain(): i32;
/** 单 worker consumer drain（A4 v2 多 consumer）。 */
extern function shu_async_worker_drain(worker_id: u32): i32;
extern function shu_async_worker_count(): u32;
extern function shu_async_worker_pending(worker_id: u32): u32;
extern function shu_async_queue_reset(): void;
extern function shu_async_scheduler_pending(): u32;
extern function shu_async_io_wake_all(): void;
extern function shu_async_io_waiters_pending(): u32;

/** CPS suspend 哨兵（与 scheduler.c SHU_ASYNC_SUSPENDED 一致）。 */
const SHU_ASYNC_SUSPENDED: i32 = 0x41535700;

/** A1：switch dispatch 双任务 ping-pong；rounds 轮返回总 ops（2*rounds）。 */
function coop_pingpong(rounds: i64): i64 {
  return shu_async_coop_pingpong(rounds);
}

/** A2：computed-goto 跳转表 dispatch；语义同 coop_pingpong。 */
function coop_pingpong_jmp(rounds: i64): i64 {
  return shu_async_coop_pingpong_jmp(rounds);
}

/** 占位：模块可 import；完整 future 运行时待语言阶段推进。 */
function placeholder(): i32 {
  return 0;
}
