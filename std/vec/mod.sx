// std.vec — 动态数组 Vec（对标 Zig ArrayList、Rust Vec、Go slice+append）
//
// 【文件职责】
// 基于 std.heap 的可增长数组：Vec_i32、Vec_u8，提供
// new/with_capacity、push/pop、get/len/capacity、
// clear/truncate/reserve、append_slice/from_slice、is_empty、ptr、deinit。
// DOD-S2：Vec3f_soa（默认三列 SoA）与 Vec3f_aos（opt-in 交错 AoS）。
//
// 【对标】
// Zig: std.ArrayList(T) — init/deinit、append、appendSlice、items、len、capacity、clear；
// Rust: Vec —
// new/with_capacity、push/pop、get/len/capacity、clear/truncate/reserve、extend_from_slice；
// Go: append(slice, ...)、len、cap。
const heap = import("std.heap");
/** 默认初始容量（元素个数）；首次 push 时若 cap==0 则分配此大小。设为 8
* 减少首次扩容次数。 */
function vec_default_capacity(): i32 { return 8; }
/** append_slice/from_slice 走 C memcpy 的阈值；≥ 此值时用块拷贝。 */
function vec_copy_threshold(): i32 { return 8; }
// ——— Vec_i32 ———
/** 动态数组：堆分配 *i32 + len + cap；调用方须在不用时调用 vec_i32_deinit。 */
allow(padding) struct Vec_i32 {
  ptr: *i32;
  len: i32;
  cap: i32;
}
/** 新建空 Vec_i32（ptr 为 null，cap 0）；首次 push 时分配。 */
function vec_i32_new(): Vec_i32 {
  return Vec_i32 { ptr: 0, len: 0, cap: 0 };
}
/** 预分配容量 capacity；ptr 可能为 null（capacity 0 时）。失败时 cap 置 0
* 并返回 -1，成功返回 0。 */
function vec_i32_with_capacity(v: *Vec_i32, capacity: i32): i32 {
  if (capacity <= 0) {
    v.ptr = 0;
    v.cap = 0;
    return 0;
  }
  let p: *i32 = heap.alloc_i32(capacity);
  if (p == 0) {
    v.cap = 0;
    return -1;
  }
  /* 根块末条须为 if/return，勿以赋值作 stmt_order 末条（隐式尾返回误判）。 */
  if (0 == 0) {
    v.ptr = p;
    v.cap = capacity;
    v.len = 0;
    return 0;
  }
  return -1;
}
/** 确保至少能再放 1 个元素；不足则扩容（2 倍或
* default_capacity）。失败返回 -1，成功返回 0。热路径：先判 len<cap 再算 want。
*/
function vec_i32_reserve_one(v: *Vec_i32): i32 {
  if (v.len < v.cap) { return 0; }
  let want: i32 = if (v.cap <= 0) { 8 } else { v.cap * 2 };
  if (want <= 0) { return -1; }
  let p: *i32 = if (v.ptr == 0) { heap.alloc_i32(want) } else { heap.realloc_i32(v.ptr, want) };
  if (p == 0) {
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = want;
    return 0;
  }
  return -1;
}
/** 追加元素 x；成功返回 0，分配失败返回 -1。 */
function vec_i32_push(v: *Vec_i32, x: i32): i32 {
  /*
  * 须满足非 void 函数体 stmt_order 末条不能落在「赋值」上（否则 .sx typeck
  * * * * 将末条 expr 当隐式尾返回）；
  * * * * * 用 if/else 使根块末条为 if（kind 5），与「先 if 再顺序赋值再
  return」的解析顺序区分。
  */
  if (vec_i32_reserve_one(v) != 0) {
    return -1;
  } else {
    v.ptr[v.len] = x;
    v.len = v.len + 1;
    return 0;
  }
}
/** 移除并返回最后一个元素；空 vec 未定义。 */
function vec_i32_pop(v: *Vec_i32): i32 {
  /* 根块仅含单个 if，避免末条 expr_stmt 被误判为隐式尾返回（见
  vec_i32_push）。 */
  if (0 == 0) {
    v.len = v.len - 1;
    return v.ptr[v.len];
  }
  return 0;
}
/** 长度（元素个数）。 */
function vec_i32_len(v: Vec_i32): i32 { return v.len; }
/** 容量（可容纳元素个数，不含 realloc）。 */
function vec_i32_capacity(v: Vec_i32): i32 { return v.cap; }
/** 取第 i 个元素；i 越界未定义。 */
function vec_i32_get(v: Vec_i32, i: i32): i32 { return v.ptr[i]; }
/** 写第 i 个元素为 x；i 越界未定义。 */
function vec_i32_set(v: *Vec_i32, i: i32, x: i32): void { v.ptr[i] = x; }
/** 是否为空（len==0）。返回 1 是，0 否。 */
function vec_i32_is_empty(v: Vec_i32): i32 {
  if (v.len <= 0) { return 1; }
  return 0;
}
/** 清空长度，不释放内存。 */
function vec_i32_clear(v: *Vec_i32): void { v.len = 0; }
/** 截断到 new_len；new_len > len 无操作。 */
function vec_i32_truncate(v: *Vec_i32, new_len: i32): void {
  if (new_len < v.len) { v.len = new_len; }
}
/** 确保容量至少为 new_cap；若当前 cap < new_cap 则 realloc。失败返回
* -1，成功返回 0。 */
function vec_i32_reserve(v: *Vec_i32, new_cap: i32): i32 {
  if (new_cap <= v.cap) { return 0; }
  let p: *i32 = if (v.ptr == 0) { heap.alloc_i32(new_cap) } else { heap.realloc_i32(v.ptr, new_cap) };
  if (p == 0) {
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = new_cap;
    return 0;
  }
  return -1;
}
/** 追加切片 ptr[0..n-1]；失败返回 -1，成功返回 0。≥8 元素走 C memcpy
* 快路径。 */
function vec_i32_append_slice(v: *Vec_i32, ptr: *i32, n: i32): i32 {
  if (n <= 0) { return 0; }
  if (vec_i32_reserve(v, v.len + n) != 0) { return -1; }
  heap.copy_i32_at(v.ptr, v.len, ptr, n);
  if (0 == 0) {
    v.len = v.len + n;
    return 0;
  }
}
/** 从切片 ptr[0..n-1] 拷贝构造新 Vec_i32；失败时返回 len=-1 的 vec。≥8 元素走
* C memcpy 快路径。 */
function vec_i32_from_slice(ptr: *i32, n: i32): Vec_i32 {
  let v: Vec_i32 = vec_i32_new();
  if (n <= 0) { return v; }
  if (vec_i32_with_capacity(&v, n) != 0) { return Vec_i32 { ptr: 0, len: -1, cap: 0 }; }
  heap.copy_i32_at(v.ptr, 0, ptr, n);
  if (0 == 0) {
    v.len = n;
    return v;
  }
  return vec_i32_new();
}
/** 零拷贝：返回内部缓冲首指针；与 vec_i32_len 组合即 (ptr, len)。 */
function vec_i32_ptr(v: Vec_i32): *i32 { return v.ptr; }
/** 释放堆内存并将 ptr 置为 null、len/cap 置 0。调用后不可再使用。 */
function vec_i32_deinit(v: *Vec_i32): void {
  if (v.ptr != 0) {
    heap.free_i32(v.ptr);
    v.ptr = 0;
  }
  v.len = 0;
  v.cap = 0;
}
// ——— Vec_u8 ———
/** 动态字节数组：堆分配 *u8 + len + cap；调用方须在不用时调用
* vec_u8_deinit。 */
allow(padding) struct Vec_u8 {
  ptr: *u8;
  len: i32;
  cap: i32;
}
/** 新建空 Vec_u8。 */
function vec_u8_new(): Vec_u8 {
  return Vec_u8 { ptr: 0, len: 0, cap: 0 };
}
/** 预分配容量 capacity；失败时 cap 置 0 并返回 -1。 */
function vec_u8_with_capacity(v: *Vec_u8, capacity: i32): i32 {
  if (capacity <= 0) {
    v.ptr = 0;
    v.cap = 0;
    return 0;
  }
  let p: *u8 = heap.alloc_u8(capacity);
  if (p == 0) {
    v.cap = 0;
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = capacity;
    v.len = 0;
    return 0;
  }
  return -1;
}
function vec_u8_reserve_one(v: *Vec_u8): i32 {
  if (v.len < v.cap) { return 0; }
  let want: i32 = if (v.cap <= 0) { 8 } else { v.cap * 2 };
  if (want <= 0) { return -1; }
  let p: *u8 = if (v.ptr == 0) { heap.alloc_u8(want) } else { heap.realloc_u8(v.ptr, want) };
  if (p == 0) {
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = want;
    return 0;
  }
  return -1;
}
function vec_u8_push(v: *Vec_u8, x: u8): i32 {
  /* 同 vec_i32_push：根块末条须避免「赋值」作隐式尾返回判定。 */
  if (vec_u8_reserve_one(v) != 0) {
    return -1;
  } else {
    v.ptr[v.len] = x;
    v.len = v.len + 1;
    return 0;
  }
}
function vec_u8_pop(v: *Vec_u8): u8 {
  if (0 == 0) {
    v.len = v.len - 1;
    return v.ptr[v.len];
  }
  return 0;
}
function vec_u8_len(v: Vec_u8): i32 { return v.len; }
/** 热路径：指针取长，避免按值传 Vec_u8 结构体。 */
function vec_u8_len_ptr(v: *Vec_u8): i32 { return v.len; }
function vec_u8_capacity(v: Vec_u8): i32 { return v.cap; }
function vec_u8_get(v: Vec_u8, i: i32): u8 { return 0; }
function vec_u8_set(v: *Vec_u8, i: i32, x: u8): void { v.ptr[i] = x; }
function vec_u8_is_empty(v: Vec_u8): i32 {
  if (v.len <= 0) { return 1; }
  return 0;
}
function vec_u8_clear(v: *Vec_u8): void { v.len = 0; }
function vec_u8_truncate(v: *Vec_u8, new_len: i32): void {
  if (new_len < v.len) { v.len = new_len; }
}
function vec_u8_reserve(v: *Vec_u8, new_cap: i32): i32 {
  if (new_cap <= v.cap) { return 0; }
  let p: *u8 = if (v.ptr == 0) { heap.alloc_u8(new_cap) } else { heap.realloc_u8(v.ptr, new_cap) };
  if (p == 0) {
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = new_cap;
    return 0;
  }
  return -1;
}
function vec_u8_append_slice(v: *Vec_u8, ptr: *u8, n: i32): i32 {
  if (n <= 0) { return 0; }
  if (vec_u8_reserve(v, v.len + n) != 0) { return -1; }
  heap.copy_u8_at(v.ptr, v.len, ptr, n);
  if (0 == 0) {
    v.len = v.len + n;
    return 0;
  }
}
function vec_u8_from_slice(ptr: *u8, n: i32): Vec_u8 {
  let v: Vec_u8 = vec_u8_new();
  if (n <= 0) { return v; }
  if (vec_u8_with_capacity(&v, n) != 0) { return Vec_u8 { ptr: 0, len: -1, cap: 0 }; }
  heap.copy_u8_at(v.ptr, 0, ptr, n);
  if (0 == 0) {
    v.len = n;
    return v;
  }
  return vec_u8_new();
}
function vec_u8_ptr(v: Vec_u8): *u8 { return v.ptr; }
function vec_u8_deinit(v: *Vec_u8): void {
  if (v.ptr != 0) {
    heap.free_u8(v.ptr);
    v.ptr = 0;
  }
  v.len = 0;
  v.cap = 0;
}

/** STD-112：按 Allocator 预分配 capacity；失败 -1。 */
function vec_u8_with_allocator(v: *Vec_u8, al: heap.Allocator, capacity: i32): i32 {
  if (capacity <= 0) {
    v.ptr = 0;
    v.cap = 0;
    return 0;
  }
  let p: *u8 = heap.allocator_alloc(al, capacity as usize);
  if (p == 0) {
    v.cap = 0;
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = capacity;
    v.len = 0;
    return 0;
  }
  return -1;
}

/** STD-112：按 Allocator 扩容预留 1 个元素；arena 满时 -1。 */
function vec_u8_reserve_one_with_allocator(v: *Vec_u8, al: heap.Allocator): i32 {
  if (v.len < v.cap) { return 0; }
  if (al.kind == heap.allocator_kind_arena()) { return -1; }
  let want: i32 = if (v.cap <= 0) { 8 } else { v.cap * 2 };
  if (want <= 0) { return -1; }
  let p: *u8 = if (v.ptr == 0) {
    heap.allocator_alloc(al, want as usize)
  } else {
    heap.allocator_realloc(al, v.ptr, want as usize)
  };
  if (p == 0) { return -1; }
  if (0 == 0) {
    v.ptr = p;
    v.cap = want;
    return 0;
  }
  return -1;
}

/** STD-112：按 Allocator 追加元素；失败 -1。 */
function vec_u8_push_with_allocator(v: *Vec_u8, al: heap.Allocator, x: u8): i32 {
  if (vec_u8_reserve_one_with_allocator(v, al) != 0) {
    return -1;
  } else {
    v.ptr[v.len] = x;
    v.len = v.len + 1;
    return 0;
  }
}

/** STD-112：按 Allocator 释放；arena 路径为 no-op。 */
function vec_u8_deinit_with_allocator(v: *Vec_u8, al: heap.Allocator): void {
  if (v.ptr != 0) {
    heap.allocator_free(al, v.ptr);
    v.ptr = 0;
  }
  v.len = 0;
  v.cap = 0;
}

// ——— Vec_u16（STD-161） ———
/** u16 动态数组。 */
allow(padding) struct Vec_u16 {
  ptr: *u16;
  len: i32;
  cap: i32;
}

/** 新建空 Vec_u16。 */
function vec_u16_new(): Vec_u16 {
  return Vec_u16 { ptr: 0, len: 0, cap: 0 };
}

/** Vec_u16 扩容预留 1 个元素；失败 -1。 */
function vec_u16_reserve_one(v: *Vec_u16): i32 {
  if (v.len < v.cap) { return 0; }
  let want: i32 = if (v.cap <= 0) { 8 } else { v.cap * 2 };
  let bytes: i32 = want * 2;
  let p: *u8 = if (v.ptr == 0) { heap.alloc_u8(bytes) } else { heap.realloc_u8(v.ptr as *u8, bytes) };
  if (p == 0) { return -1; }
  v.ptr = p as *u16;
  v.cap = want;
  return 0;
}

/** 追加 u16；失败 -1。 */
function vec_u16_push(v: *Vec_u16, x: u16): i32 {
  if (vec_u16_reserve_one(v) != 0) { return -1; }
  v.ptr[v.len] = x;
  v.len = v.len + 1;
  return 0;
}

/** Vec_u16 长度。 */
function vec_u16_len(v: Vec_u16): i32 { return v.len; }

/** 取第 i 个 u16。 */
function vec_u16_get(v: Vec_u16, i: i32): u16 { return v.ptr[i]; }

/** 释放 Vec_u16。 */
function vec_u16_deinit(v: *Vec_u16): void {
  if (v.ptr != 0) { heap.free_u8(v.ptr as *u8); v.ptr = 0; }
  v.len = 0;
  v.cap = 0;
}

// ——— Vec_u64（STD-014） ———

/** u64 动态数组；堆经 alloc_u64。 */
allow(padding) struct Vec_u64 {
  ptr: *u64;
  len: i32;
  cap: i32;
}

/** 新建空 Vec_u64。 */
function vec_u64_new(): Vec_u64 {
  return Vec_u64 { ptr: 0, len: 0, cap: 0 };
}

/** 预分配 capacity；失败 -1。 */
function vec_u64_with_capacity(v: *Vec_u64, capacity: i32): i32 {
  if (capacity <= 0) {
    v.ptr = 0;
    v.cap = 0;
    return 0;
  }
  let p: *u64 = heap.alloc_u64(capacity);
  if (p == 0) {
    v.cap = 0;
    return -1;
  }
  if (0 == 0) {
    v.ptr = p;
    v.cap = capacity;
    v.len = 0;
    return 0;
  }
  return -1;
}

/** 扩容预留 1 个 u64；失败 -1。 */
function vec_u64_reserve_one(v: *Vec_u64): i32 {
  if (v.len < v.cap) { return 0; }
  let want: i32 = if (v.cap <= 0) { 8 } else { v.cap * 2 };
  if (want <= 0) { return -1; }
  let p: *u64 = if (v.ptr == 0) { heap.alloc_u64(want) } else { heap.realloc_u64(v.ptr, want) };
  if (p == 0) { return -1; }
  if (0 == 0) {
    v.ptr = p;
    v.cap = want;
    return 0;
  }
  return -1;
}

/** 确保容量至少 new_cap；失败 -1。 */
function vec_u64_reserve(v: *Vec_u64, new_cap: i32): i32 {
  if (new_cap <= v.cap) { return 0; }
  let p: *u64 = if (v.ptr == 0) { heap.alloc_u64(new_cap) } else { heap.realloc_u64(v.ptr, new_cap) };
  if (p == 0) { return -1; }
  if (0 == 0) {
    v.ptr = p;
    v.cap = new_cap;
    return 0;
  }
  return -1;
}

/** 追加 u64 切片；失败 -1。 */
function vec_u64_append_slice(v: *Vec_u64, ptr: *u64, n: i32): i32 {
  if (n <= 0) { return 0; }
  if (vec_u64_reserve(v, v.len + n) != 0) { return -1; }
  heap.copy_u64_at(v.ptr, v.len, ptr, n);
  if (0 == 0) {
    v.len = v.len + n;
    return 0;
  }
  return -1;
}

/** 从 u64 切片构造 Vec_u64；失败 len=-1。 */
function vec_u64_from_slice(ptr: *u64, n: i32): Vec_u64 {
  let v: Vec_u64 = vec_u64_new();
  if (n <= 0) { return v; }
  if (vec_u64_with_capacity(&v, n) != 0) { return Vec_u64 { ptr: 0, len: -1, cap: 0 }; }
  heap.copy_u64_at(v.ptr, 0, ptr, n);
  if (0 == 0) {
    v.len = n;
    return v;
  }
  return vec_u64_new();
}

/** Vec_u64 长度。 */
function vec_u64_len(v: Vec_u64): i32 { return v.len; }

/** 取第 i 个 u64。 */
function vec_u64_get(v: Vec_u64, i: i32): u64 { return v.ptr[i]; }

/** 释放 Vec_u64。 */
function vec_u64_deinit(v: *Vec_u64): void {
  if (v.ptr != 0) { heap.free_u64(v.ptr); v.ptr = 0; }
  v.len = 0;
  v.cap = 0;
}

// ——— Vec_f64（STD-014） ———

/** f64 动态数组；堆经 alloc_f64。 */
allow(padding) struct Vec_f64 {
  ptr: *f64;
  len: i32;
  cap: i32;
}

/** 新建空 Vec_f64。 */
function vec_f64_new(): Vec_f64 {
