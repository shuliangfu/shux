/** 确保容量至少 new_cap；失败 -1。 */
function vec_f64_reserve(v: *Vec_f64, new_cap: i32): i32 {
  if (new_cap <= v.cap) { return 0; }
  let p: *f64 = if (v.ptr == 0) { heap.alloc_f64(new_cap) } else { heap.realloc_f64(v.ptr, new_cap) };
  if (p == 0) { return -1; }
