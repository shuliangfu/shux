// asm_nested_let_repro.su — 复现 while 体内 if-then 嵌套 let 的 asm 槽位登记（fr not
// in ctx / 139）

/** while + if-then 内 let fr；asm 须在块树或 if-then ensure 中登记 fr。 */
function demo_nested_let(): i32 {
  let i: i32 = 0;
  while (i < 10) {
    if (i > 0) {
      let fr: i32 = i + 1;
      i = fr;
    } else {
      i = i + 1;
    }
  }
  return i;
}
