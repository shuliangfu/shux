import ast;

/** full OR / let base / 三段；与 codegen field_access_base_is_pointer_ref 同结构 */
function field_like(arena: *ASTArena, base_ref: i32): i32 {
  if (ref_is_null(base_ref) || base_ref <= 0 || base_ref > arena.num_exprs) {
    return 0;
  }
  let base: Expr = ast_arena_expr_get(arena, base_ref);
  if (ref_is_null(base.resolved_type_ref) || base.resolved_type_ref <= 0 || base.resolved_type_ref > arena.num_types) {
    return 0;
  }
  let ty: Type = ast_arena_type_get(arena, base.resolved_type_ref);
  if (ty.kind == TypeKind.TYPE_PTR || ty.kind == TypeKind.TYPE_SLICE) {
    return 1;
  }
  return 0;
}

function main(): i32 {
  return 0;
}
