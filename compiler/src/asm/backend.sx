/** ГҘВ°ВҶ ExprKind ГЁВҪВ¬ГӨВёВәГҘВәВҸГҰВ•В° (0..60)ГҜВјВҢГӨВҫВӣГЁВҜВҠГҰВ–ВӯГҰВүВ“ГҘВҚВ°ГҜВјВӣtypeck ГҰВҡВӮГӨВёВҚГҰВ”ВҜГҰВҢВҒ enum as i32ГҜВјВҢГҰВ•В…Г§В”ВЁГҘВҲВҶГҰВ”ВҜГҰВҳВҫГҘВјВҸГҰВҳВ ГҘВ°В„ГЈВҖВӮ */
function expr_kind_ordinal(k: ExprKind): i32 {
  let o: i32 = k as i32;
  if (o < (ExprKind.EXPR_LIT as i32) || o > (ExprKind.EXPR_SPAWN as i32)) {
    return -1;
  }
  return o;
}

/**
 * ГҰВҳВҜГҘВҗВҰГӨВёВәГ§В©ВәГ§ВҡВ„ГҰВ•В°Г§В»В„ГҘВӯВ—Г©ВқВўГ©ВҮВҸ []ГҜВјВҲГ©ВӣВ¶ГҘВ…ВғГ§ВҙВ ГҜВјВүГЈВҖВӮ
 * let buf: T[N] = [] ГҰВ—В¶ГЁВ·ВіГЁВҝВҮ emit/storeГҜВјВҢГ§В”ВұГҰВ ВҲГҰВ§ВҪГҘВңВ°ГҘВқВҖГ§ВӣВҙГҰВҺВҘГӨВҪВңГӨВёВә buf Г©ВҰВ–ГҘВқВҖГҜВјВҲINDEX ГЁВөВ° VAR+LEAГҜВјВүГЈВҖВӮ
 */
/**
 * ГҘВ·ВҰГҘВңВЁ raxГЈВҖВҒГҘВҸВіГӨВёВәГ§В«ВӢГҘВҚВіГҰВ•В°ГҘВңВЁ rbx ГҰВ—В¶ enc_cmp_setcc ГӨВҪВҝГ§В”ВЁ cmp w1,w0ГҜВјВӣ
 * ГҘВ°ВҶ left OP right Г§ВҡВ„ lt/le/gt/ge ГҰВқВЎГӨВ»В¶Г§В ВҒГҘВҜВ№ГЁВ°ВғГҜВјВҲeq/ne ГӨВёВҚГҘВҸВҳГҜВјВүГЈВҖВӮ
 */
function asm_cmp_cc_when_rhs_imm_in_rbx(cc: i32): i32 {
  if (cc == 2) { return 4; }
  if (cc == 3) { return 5; }
  if (cc == 4) { return 2; }
  if (cc == 5) { return 3; }
  return cc;
}

function asm_init_is_empty_array_lit(arena: *ASTArena, init_ref: i32): i32 {
  if (init_ref == 0) {
    return 0;
  }
  let e: Expr = ast.ast_arena_expr_get(arena, init_ref);
  if (e.kind != ExprKind.EXPR_ARRAY_LIT) {
    return 0;
  }
  if (pipeline_expr_array_lit_num_elems_at(arena, init_ref) == 0) {
    return 1;
  }
  return 0;
}

/** ELF enc жҢү target_arch еҲҶжҙҫпјҡta 0=x86_64пјҢ1=arm64пјҢ2=riscv64гҖӮ */
function enc_label_arch(elf_ctx: *ElfCodegenCtx, name: u8[64], name_len: i32, is_func: i32, ta: i32): i32 {
  let use_len: i32 = name_len;
  let use_ptr: *u8 = &name[0];
  /** S4 freestandingпјҡLinux x86_64 з”ЁжҲ· `main` дҝқжҢҒ ELF иЈёеҗҚ mainпјҲдёҺ crt0_user_x86_64.s дёҖиҮҙпјүгҖӮ */
  if (ta == 1) { return arch.arm64_enc.enc_label(elf_ctx, use_ptr, use_len, is_func); }
  if (ta == 2) { return arch.riscv64_enc.enc_label(elf_ctx, use_ptr, use_len, is_func); }
  return arch.x86_64_enc.enc_label(elf_ctx, use_ptr, use_len, is_func);
}
function enc_prologue_arch(elf_ctx: *ElfCodegenCtx, frame_sz: i32, ta: i32): i32 {
