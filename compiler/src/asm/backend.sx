}
function arch_emit_idiv_rbx(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_idiv_rbx(out); }
  if (ta == 2) { return arch.riscv64.emit_idiv_rbx(out); }
  if (arch.x86_64.emit_cltd(out) != 0) { return -1; }
