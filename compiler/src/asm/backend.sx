extern function pipeline_module_import_path_len(module: *Module, idx: i32): i32;
/**
 * ГҘВ°ВҶ module Г©ВЎВ¶ГҘВұВӮ let/const ГҰВҢВүГҘВәВҸГҘВ№В¶ГҘВ…ВҘ main ГҘВҮВҪГҰВ•В°ГӨВҪВ“ГҜВјВҲГҘВқВ—ГҘВҶВ… letГҜВјВүГҜВјВҢГӨВҫВӣ asm ГҘВңВЁГҰВ ВҲГҰВ§ВҪГҘВҲВқГҘВ§ВӢГҘВҢВ–ГЈВҖВӮ
 * ГӨВёВҺ C codegen Г§ВҡВ„ static+init_globals Г§ВӯВүГӨВ»В·ГҜВјВӣГ©ВЎВ»ГҘВңВЁ asm_codegen_ast* Г§ВјВ–ГҘВҮВҪГҰВ•В°ГҘВүВҚГЁВ°ВғГ§В”ВЁГҜВјВҲast_pool.cГҜВјВүГЈВҖВӮ
 */
extern function pipeline_module_hoist_top_level_lets_into_main(module: *Module, arena: *ASTArena): void;

/** asm зј–еҪ“еүҚ module еүҚпјҡйЎ¶еұӮ let е№¶е…Ҙ main жҲ–еә“жЁЎеқ—йҰ–еҮҪж•°дҪ“пјҲдҝқз•ҷ SX дҪ“пјҢhelper_keep зңҹ emitпјүгҖӮ */
function asm_hoist_top_level_lets_for_codegen(module: *Module, arena: *ASTArena): void {
  if (module.num_top_level_lets > 0) {
    pipeline_module_hoist_top_level_lets_into_main(module, arena);
  }
}
