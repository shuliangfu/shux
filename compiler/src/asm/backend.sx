}


/** ГҘВ°ВҶ label ГҘВәВҸГҘВҸВ· id ГҰВ ВјГҘВјВҸГҘВҢВ–ГӨВёВә ".L_<id>" ГҘВҶВҷГҘВ…ВҘ bufГҜВјВҢГЁВҝВ”ГҘВӣВһГ©В•ВҝГҘВәВҰГҜВјВҲГӨВёВҚГҰВҺВЁГЁВҝВӣ ctx.label_counterГҜВјВүГЈВҖВӮГ§В”ВЁГӨВәВҺ match ГҘВӨВҡГҘВҲВҶГҰВ”ВҜГҰВ ВҮГ§ВӯВҫГЈВҖВӮ */
/** ж јејҸеҢ– ".L_<id>"пјӣM8-tail е§”жүҳ C glue pipeline_asm_format_label_id_cгҖӮ */
function format_label_id(buf: *u8, buf_size: i32, id: i32): i32 {
  return pipeline_asm_format_label_id_c(buf, buf_size, id);
}


/** ГҘВ°ВҶ break/continue ГҰВ ВҮГ§ВӯВҫГҘВҺВӢГҘВ…ВҘ 8 ГҘВұВӮГҰВ ВҲГҘВ№В¶ГЁВ®ВҫГӨВёВәГҘВҪВ“ГҘВүВҚГ§В”ВҹГҰВ•ВҲГҰВ ВҮГ§ВӯВҫГҜВјВӣd>=8 ГҰВ—В¶ГЁВҝВ”ГҘВӣВһ -1ГЈВҖВӮ */
function ctx_push_loop_labels(ctx: *AsmFuncCtx, exit_buf: *u8, exit_len: i32, loop_buf: *u8, loop_len: i32): i32 {
  let d: i32 = ctx.loop_label_depth;
  if (d >= 8) {
    return -1;
  }
  let base_off: i32 = d * 64;
  let k: i32 = 0;
  while (k < exit_len && k < 64) {
    ctx.loop_break_label_stack[base_off + k] = exit_buf[k];
    k = k + 1;
  }
  ctx.loop_break_len_stack[d] = exit_len;
  k = 0;
  while (k < loop_len && k < 64) {
    ctx.loop_continue_label_stack[base_off + k] = loop_buf[k];
    k = k + 1;
  }
  ctx.loop_continue_len_stack[d] = loop_len;
  ctx.loop_label_depth = d + 1;
  k = 0;
  while (k < exit_len && k < 64) {
    ctx.break_label[k] = exit_buf[k];
    k = k + 1;
  }
  ctx.break_len = exit_len;
  k = 0;
  while (k < loop_len && k < 64) {
    ctx.continue_label[k] = loop_buf[k];
    k = k + 1;
  }
  ctx.continue_len = loop_len;
  return 0;
}

/** ГҘВјВ№ГҘВҮВәГҘВҫВӘГ§ВҺВҜГҰВ ВҮГ§ВӯВҫГҰВ ВҲГ©ВЎВ¶ГҜВјВҢГҰВҒВўГҘВӨВҚГҘВӨВ–ГҘВұВӮ break/continue ГҰВҲВ–ГҰВёВ…Г©ВӣВ¶ГЈВҖВӮ */
function ctx_pop_loop_labels(ctx: *AsmFuncCtx): void {
  if (ctx.loop_label_depth <= 0) {
    ctx.break_len = 0;
    ctx.continue_len = 0;
    return;
  }
  ctx.loop_label_depth = ctx.loop_label_depth - 1;
  let d: i32 = ctx.loop_label_depth;
  if (d <= 0) {
    ctx.break_len = 0;
    ctx.continue_len = 0;
    return;
  }
  let prev: i32 = d - 1;
  let base_off: i32 = prev * 64;
  let bl: i32 = ctx.loop_break_len_stack[prev];
  let cl: i32 = ctx.loop_continue_len_stack[prev];
  let k: i32 = 0;
  while (k < bl && k < 64) {
    ctx.break_label[k] = ctx.loop_break_label_stack[base_off + k];
    k = k + 1;
  }
  ctx.break_len = bl;
  k = 0;
  while (k < cl && k < 64) {
    ctx.continue_label[k] = ctx.loop_continue_label_stack[base_off + k];
    k = k + 1;
  }
  ctx.continue_len = cl;
}

/** ELF еҫӘзҺҜдҪ“ stmt_orderпјӣM8-tail е§”жүҳ partial backend_emit_loop_body_content_elfпјҲC glueпјүгҖӮ */
