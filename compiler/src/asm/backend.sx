/** ГҘВ·ВҰГ§В§В»/Г©ВҖВ»ГЁВҫВ‘ГҘВҸВіГ§В§В»/Г§В®В—ГҰВңВҜГҘВҸВіГ§В§В»ГҜВјВҡГҘВҖВјГҘВңВЁ raxГҜВјВҢГЁВ®ВЎГҰВ•В°ГҘВ·ВІГҘВңВЁ rbxГҜВјВҲx86 ГӨВјВҡГҘВ…ВҲ mov rbxГўВҶВ’ecxГҜВјВүГЈВҖВӮ */
function arch_emit_shl_cl_eax(out: *CodegenOutBuf, ta: i32): i32 {
