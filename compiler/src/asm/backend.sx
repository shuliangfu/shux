/** LEA ГҘВұВҖГ©ВғВЁГҘВҸВҳГ©ВҮВҸГҘВңВ°ГҘВқВҖГҘВҲВ° raxГҜВјВҲx86/arm64ГҜВјВүГЈВҖВӮГ§В”ВЁГӨВәВҺ EXPR_INDEX base ГӨВёВә VARГЈВҖВҒSTRUCT_LIT/ARRAY_LIT temp ГҘВҢВәГЈВҖВӮ */
function arch_emit_lea_rbp_to_rax(out: *CodegenOutBuf, off: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_lea_rbp_to_rax(out, off); }
  if (ta == 2) { return arch.riscv64.emit_lea_rbp_to_rax(out, off); }
  return arch.x86_64.emit_lea_rbp_to_rax(out, off);
}
/**
 * TextГҜВјВҡГҘВұВҖГ©ВғВЁ VAR ГӨВёВәГҰВҢВҮГ©В’ВҲГҘВҲВҷГӨВ»ВҺГҰВ ВҲГҰВ§ВҪГЁВҪВҪГҘВ…ВҘГҰВҢВҮГ©В’ВҲГҘВҲВ° raxГҜВјВҢГҘВҗВҰГҘВҲВҷ rax = ГҰВ ВҲГҰВ§ВҪГҘВңВ°ГҘВқВҖГҜВјВҲГҘВ°ВұГҘВңВ°Г§В»В“ГҰВһВ„/ГҰВ•В°Г§В»В„ГҜВјВүГЈВҖВӮ
 * codegen.sx ГӨВёВӯ `fn(..., out: *CodegenOutBuf)` Г§ВӯВүГҘВҜВ№ `out.field` Г©ВЎВ»ГЁВөВ° loadГҜВјВҢГӨВёВҚГЁВғВҪ lea slotГЈВҖВӮ
 */
function arch_emit_local_slot_ptr_or_addr(arena: *ASTArena, out: *CodegenOutBuf, base_var: Expr, stack_off: i32, ta: i32, ctx: *AsmFuncCtx): i32 {
  if (asm_local_var_slot_holds_indirect_ptr(arena, base_var, ctx.module_ref) != 0) {
    return arch_emit_load_rbp_to_rax(out, stack_off, ta);
  }
  return arch_emit_lea_rbp_to_rax(out, stack_off, ta);
}
/** rax/x0 = rax/x0 + rbx/x1*4ГЈВҖВӮГ§В”ВЁГӨВәВҺ EXPR_INDEX ГӨВёВӢГҰВ ВҮГӨВ№ВҳГҘВ…ВғГ§ВҙВ ГҘВӨВ§ГҘВ°ВҸ 4ГЈВҖВӮ */
function arch_emit_rax_plus_rbx_scale4(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_rax_plus_rbx_scale4(out); }
  if (ta == 2) { return arch.riscv64.emit_rax_plus_rbx_scale4(out); }
  return arch.x86_64.emit_rax_plus_rbx_scale4(out);
}
/** rbxГғВ—1 ГҘВҶВҚГҘВҠВ ГҘВҲВ°ГҘВңВ°ГҘВқВҖГҜВјВҲu8 ГҰВ•В°Г§В»В„ГҜВјВүГЈВҖВӮ */
function arch_emit_rax_plus_rbx_scale1(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_rax_plus_rbx_scale1(out); }
  if (ta == 2) { return arch.riscv64.emit_rax_plus_rbx_scale1(out); }
  return arch.x86_64.emit_rax_plus_rbx_scale1(out);
}
/** rbxГғВ—8ГҜВјВҲГҰВҢВҮГ©В’ВҲГҘВҲВҮГ§ВүВҮГ§ВӯВүГҜВјВүГЈВҖВӮ */
function arch_emit_rax_plus_rbx_scale8(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_rax_plus_rbx_scale8(out); }
  if (ta == 2) { return arch.riscv64.emit_rax_plus_rbx_scale8(out); }
  return arch.x86_64.emit_rax_plus_rbx_scale8(out);
