  loop_break_label_stack: u8[512];
  loop_break_len_stack: i32[8];
  /** ГҘВөВҢГҘВҘВ—ГҘВҫВӘГ§ВҺВҜ continue ГҰВ ВҮГ§ВӯВҫГҰВ ВҲГҜВјВҡ8 ГҘВұВӮ ГғВ— 64 ГҘВӯВ—ГЁВҠВӮ = 512 ГҘВӯВ—ГЁВҠВӮГЈВҖВӮ */
  loop_continue_label_stack: u8[512];
  loop_continue_len_stack: i32[8];
  /** ГҘВҪВ“ГҘВүВҚГ§В”ВҹГҰВ•ВҲГ§ВҡВ„ break/continue ГҰВ ВҮГ§ВӯВҫГҜВјВҲГҰВ ВҲГ©ВЎВ¶ГҜВјВүГҜВјВӣГӨВҫВӣ EXPR_BREAK/EXPR_CONTINUE ГҘВҝВ«Г©ВҖВҹГЁВҜВ»ГҘВҸВ–ГЈВҖВӮ */
  break_label: u8[64];
  break_len: i32;
  continue_label: u8[64];
  continue_len: i32;
  /** ГҘВҫВӘГ§ВҺВҜГҰВ ВҮГ§ВӯВҫГҰВ ВҲГҰВ·ВұГҘВәВҰГҜВјВӣpush ГҰВ—В¶ d>=8 ГҘВҲВҷГҘВӨВұГЁВҙВҘГЈВҖВӮ */
  loop_label_depth: i32;
  /** Pipeline ГӨВҫВқГЁВөВ–ГҜВјВҲdep_paths / ndepГҜВјВүГҜВјВӣГӨВҫВӣГ§В»В‘ГҘВ®Вҡ import ГЁВ°ВғГ§В”ВЁ `mod.fn` ГҰВ—В¶ГӨВёВҺ codegen ГӨВёВҖГЁВҮВҙГҘВңВ°ГҰВӢВјГ§В¬ВҰГҘВҸВ·ГҘВҗВҚГЈВҖВӮ */
  dep_pipe: *PipelineDepCtx;
  /** ГҘВҮВҪГҰВ•В°ГҘВ°ВҫГҰВұВҮГҘВҗВҲГҰВ ВҮГ§ВӯВҫГҜВјВҲemit_next_label Г§В”ВҹГҰВҲВҗГҜВјВүГҜВјВҡ`return;`ГҜВјВҲГҰВ—В ГҰВ“ВҚГӨВҪВңГҰВ•В°ГҜВјВүГҘВҸВ‘ jmp ГЁВҮВіГҰВӯВӨГҜВјВҢГҘВҶВҚГӨВёВҺГҘВ°Вҫ return ГЁВЎВЁГЁВҫВҫГҘВјВҸГЈВҖВҒepilogue ГЁВЎВ”ГҰВҺВҘГЈВҖВӮ */
  tail_join_label: u8[64];
  tail_join_label_len: i32;
}

/** ГҘВ°ВҶ AsmFuncCtx ГҰВҢВҮГ©В’ВҲГЁВҪВ¬ГӨВёВә asm_ctx_local_* sidecar Г©В”В®ГҜВјВҲ*u8ГҜВјВүГЈВҖВӮ */
function asm_ctx_key(ctx: *AsmFuncCtx): *u8 {
  return ctx as *u8;
}

/** ГҘВүВҚГ§ВјВҖГӨВёВә ASCII ГЈВҖВҢbuild_ГЈВҖВҚГҜВјВҲ6 ГҘВӯВ—ГЁВҠВӮГҜВјВүГӨВёВ” name ГҘВ·ВІГҘВҗВ«ГҰВӯВӨГҘВүВҚГ§ВјВҖГҰВ—В¶ГЁВҝВ”ГҘВӣВһ 1ГҜВјВҢГӨВёВҺ codegen_c_prefix_redundant_with_name ГҘВҜВ№Г©ВҪВҗГЈВҖВӮ */
function asm_c_prefix_redundant_with_name(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32): i32 {
  if (prefix == 0 as *u8 || name == 0 as *u8) {
    return 0;
  }
  if (prefix_len != 6) {
    return 0;
  }
  if (prefix[0] != 98 || prefix[1] != 117 || prefix[2] != 105 || prefix[3] != 108 || prefix[4] != 100 || prefix[5] != 95) {
    return 0;
  }
  if (name_len < prefix_len) {
    return 0;
  }
  let i: i32 = 0;
  while (i < prefix_len) {
    if (name[i] != prefix[i]) {
      return 0;
    }
    i = i + 1;
  }
  return 1;
}

/** ГҘВ°ВҶ C ГҘВүВҚГ§ВјВҖГҘВӯВ—ГЁВҠВӮГӨВёВҺГҘВӯВ—ГҰВ®ВөГҘВҗВҚГҰВӢВјГҰВҲВҗГЁВҮВіГҘВӨВҡ 63 ГҘВӯВ—ГЁВҠВӮГ§ВҡВ„ call Г§В¬ВҰГҘВҸВ·ГҘВҶВҷГҘВ…ВҘ out_nameГҜВјВӣГҰВҲВҗГҘВҠВҹГЁВҝВ”ГҘВӣВһГ©В•ВҝГҘВәВҰГҜВјВҲ1..63ГҜВјВүГҜВјВҢГҘВӨВұГЁВҙВҘ -1ГЈВҖВӮ */
function asm_build_import_binding_call_sym(pre: *u8, pre_len: i32, field_name: *u8, field_len: i32, out_name: *u8): i32 {
  let pos: i32 = 0;
  let pi: i32 = 0;
  if (pre_len > 0 && asm_c_prefix_redundant_with_name(pre, pre_len, field_name, field_len) == 0) {
    while (pi < pre_len && pos < 63) {
      out_name[pos] = pre[pi];
      pos = pos + 1;
      pi = pi + 1;
    }
  }
  pi = 0;
  while (pi < field_len && pos < 63) {
    out_name[pos] = field_name[pi];
    pos = pos + 1;
    pi = pi + 1;
  }
  if (pos <= 0) {
    return -1;
  }
  return pos;
}

/** import ГЁВ·ВҜГҘВҫВ„Г§ВјВ“ГҘВҶВІГҘВҢВәГӨВёВӯ '.' ГҘВҲВҶГҰВ®ВөГҰВ•В°ГҜВјВҲГӨВёВҺ typeck_import_path_segment_count ГӨВёВҖГЁВҮВҙГҜВјВүГЈВҖВӮ */
function asm_import_path_segment_count_local(path: *u8, path_len: i32): i32 {
  if (path_len <= 0 || path == 0 as *u8) {
    return 0;
  }
  let n: i32 = 1;
  let ii: i32 = 0;
  while (ii < path_len) {
    if (path[ii] == 46) {
      n = n + 1;
    }
    ii = ii + 1;
  }
  return n;
}

/** ГҰВҜВ”ГЁВҫВғ module Г§В¬В¬ imp_ix ГҰВқВЎ import ГЁВ·ВҜГҘВҫВ„ГҘВҲВҮГ§ВүВҮ [off..off+seg_len) ГӨВёВҺГҘВӨВ–Г©ВғВЁГҘВӯВ—ГЁВҠВӮГҘВәВҸГҘВҲВ—ГҰВҳВҜГҘВҗВҰГ§ВӣВёГ§ВӯВүГЈВҖВӮ */
function asm_import_path_slice_equal(module: *Module, imp_ix: i32, off: i32, seg_len: i32, nm: *u8, nm_len: i32): bool {
  if (seg_len != nm_len || seg_len <= 0) {
    return false;
  }
  let i: i32 = 0;
  while (i < seg_len) {
    if (pipeline_module_import_path_byte_at(module, imp_ix, off + i) != nm[i]) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

/** ГҰВҜВ”ГЁВҫВғ import Г§В»В‘ГҘВ®ВҡГҘВҗВҚГӨВёВҺГҘВӨВ–Г©ВғВЁГҘВӯВ—ГЁВҠВӮГҘВәВҸГҘВҲВ—ГҰВҳВҜГҘВҗВҰГ§ВӣВёГ§ВӯВүГЈВҖВӮ */
function asm_import_binding_name_equal(module: *Module, imp_ix: i32, nm: *u8, nm_len: i32): bool {
  let bl: i32 = pipeline_module_import_binding_name_len(module, imp_ix);
  if (bl != nm_len || nm_len <= 0) {
    return false;
  }
  let i: i32 = 0;
  while (i < nm_len) {
    if (pipeline_module_import_binding_name_byte_at(module, imp_ix, i) != nm[i]) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

/** pipeline_module_import_path ГҘВҶВ…Г§В¬В¬ want_seg ГҰВ®ВөГЁВөВ·Г§ВӮВ№ГҘВҒВҸГ§В§В»ГӨВёВҺГ©В•ВҝГҘВәВҰГҜВјВҲГӨВёВҺ typeck_import_segment_at ГӨВёВҖГЁВҮВҙГҜВјВүГЈВҖВӮ */
function asm_import_segment_at_local(module: *Module, imp_ix: i32, want_seg: i32,
  ostr: *i32, olen: *i32): bool {
  if (module == 0 as *Module || imp_ix < 0 || imp_ix >= module.num_imports) {
    return false;
  }
  let pl: i32 = pipeline_module_import_path_len(module, imp_ix);
  if (pl <= 0 || pl > 63) {
    return false;
  }
  let ci: i32 = 0;
  let ss: i32 = 0;
  let k: i32 = 0;
  while (k <= pl) {
    let at_end_p: bool = k == pl;
    let dot_p: bool = false;
    if (!at_end_p && k < pl) {
      dot_p = pipeline_module_import_path_byte_at(module, imp_ix, k) == 46;
    }
    if (at_end_p || dot_p) {
      let seg_len_here: i32 = k - ss;
      if (seg_len_here <= 0) {
        return false;
      }
      if (ci == want_seg) {
        ostr[0] = ss;
        olen[0] = seg_len_here;
        return true;
      }
      if (dot_p) {
        ss = k + 1;
      }
      ci = ci + 1;
    }
    k = k + 1;
  }
  return false;
}

/** ГҘВ°ВҶГҰВӯВЈГҘВңВЁ codegen Г§ВҡВ„ module ГҘВңВЁГ§В¬В¬ imp_ix ГҰВ§ВҪГ§ВҡВ„ import Г©ВҖВ»ГЁВҫВ‘ГЁВ·ВҜГҘВҫВ„ГЁВҪВ¬ГҰВҲВҗ C ABI ГҘВүВҚГ§ВјВҖГҘВҶВҷГҘВ…ВҘ pre_bufГҜВјВӣГҰВҲВҗГҘВҠВҹГЁВҝВ”ГҘВӣВһГҘВүВҚГ§ВјВҖГ©В•ВҝГҘВәВҰГҜВјВҲГҘВӯВ—ГЁВҠВӮГҜВјВүГҜВјВҢГЁВ·ВҜГҘВҫВ„Г§В©ВәГҰВҲВ–ГҘВүВҚГ§ВјВҖГ§В©ВәГЁВҝВ”ГҘВӣВһ -1ГЈВҖВӮ */
function asm_fill_c_prefix_from_module_import(cur_mod: *Module, imp_ix: i32, pre_buf: *u8): i32 {
  let path_bytes: u8[64] = [];
  parser_get_module_import_path(cur_mod, imp_ix, path_bytes);
  if (path_bytes[0] == 0) {
    return -1;
  }
  codegen_import_path_to_c_prefix_into(&path_bytes[0], pre_buf, 128);
  let pre_len: i32 = 0;
  while (pre_len < 128 && pre_buf[pre_len] != 0) {
    pre_len = pre_len + 1;
  }
  if (pre_len <= 0) {
    return -1;
  }
  return pre_len;
}

/** ГЁВӢВҘГӨВёВә `import a.bГўВҖВҰ` + `a.bГўВҖВҰ.method(args)` ГҘВҪВўГҘВјВҸГҜВјВҢГҰВӢВјГЁВЈВ…ГӨВёВҺ codegen ГӨВёВҖГЁВҮВҙГ§ВҡВ„ C ABI Г§В¬ВҰГҘВҸВ·ГҘВ№В¶ГҘВҶВҷГҘВ…ВҘ sym_flatГҜВјВҢГЁВҝВ”ГҘВӣВһГҘВӯВ—ГЁВҠВӮГ©В•ВҝГҘВәВҰГҜВјВӣ-1 ГҰВңВӘГҘВҢВ№Г©В…ВҚГЈВҖВӮ
 * ГҰВҲВҗГҘВҠВҹГҰВ—В¶ГҘВҗВҢГҰВ—В¶ГҘВ°ВҶГҘВҜВ№ГҘВәВ” module import ГҰВ§ВҪГӨВёВӢГҰВ ВҮГҘВҶВҷГҘВ…ВҘ *out_match_imp_jГЈВҖВӮ
 * pipe ГӨВ»В…ГӨВҝВқГ§В•ВҷГҘВҸВӮГҰВ•В°ГҘВ…ВјГҘВ®В№ГҜВјВҡГҘВүВҚГ§ВјВҖГӨВёВҖГҘВҫВӢГӨВ»ВҺ cur_mod Г§ВҡВ„ import ГҰВ§ВҪГҘВҸВ–ГЁВ·ВҜГҘВҫВ„ГҜВјВҲcodegen dep ГҰВЁВЎГҘВқВ—ГҰВ—В¶ PipelineDepCtx.ndep ГҘВёВёГӨВёВәГҘВ…ВҘГҘВҸВЈ direct ГӨВҫВқГЁВөВ–ГҰВ•В°ГҜВјВҢ
 * ГӨВёВҺ cur_mod.num_imports ГӨВёВҚГӨВёВҖГЁВҮВҙГҜВјВҢГӨВёВҚГҘВҸВҜГ§В”ВЁ dep_j &lt; pipe.ndep ГҰВҲВӘГҰВ–ВӯГҰВҹВҘГҰВүВҫГҜВјВүГЈВҖВӮГҰВңВӘГҘВҢВ№Г©В…ВҚГӨВёВҚГҘВҶВҷ *outГЈВҖВӮ */
function asm_resolve_whole_import_qualified_symbol(
  arena: *ASTArena, cur_mod: *Module, pipe: *PipelineDepCtx, callee_expr_ref: i32, sym_flat: *u8,
  out_match_imp_j: *i32): i32 {
  /** M8-tail и–„еҢ…иЈ…пјҡpipe д»…дҝқз•ҷ ABI е…је®№пјҢжҹҘжүҫдёҖеҫӢе§”жүҳ C glueгҖӮ */
  return pipeline_asm_resolve_whole_import_qualified_symbol_c(arena, cur_mod, callee_expr_ref, sym_flat, out_match_imp_j);
}

/** text call е®һеҸӮпјӣM8-tail е§”жүҳ C glue pipeline_asm_emit_call_args_text_cпјҲexpr_ref жӣҝд»Ј Expr жҢүеҖјпјүгҖӮ */
function asm_emit_call_args_text(arena: *ASTArena, out: *CodegenOutBuf, expr_ref: i32, ctx: *AsmFuncCtx, target_arch: i32, nargs: i32): i32 {
  return pipeline_asm_emit_call_args_text_c(arena, out, expr_ref, ctx, target_arch, nargs);
}

/** ELF call е®һеҸӮпјӣM8-tail е§”жүҳ C glue pipeline_asm_emit_call_args_elf_cгҖӮ */
function asm_emit_call_args_elf(arena: *ASTArena, elf_ctx: *ElfCodegenCtx, e: Expr, expr_ref: i32, ctx: *AsmFuncCtx, ta: i32, nargs: i32): i32 {
  return pipeline_asm_emit_call_args_elf_c(arena, elf_ctx, expr_ref, ctx, ta, nargs);
}


/** ГҰВҜВ”ГЁВҫВғГӨВёВӨГҰВ®ВөГҰВ ВҮГЁВҜВҶГ§В¬ВҰГҘВӯВ—ГЁВҠВӮГҘВәВҸГҘВҲВ—ГҰВҳВҜГҘВҗВҰГ§ВӣВёГ§ВӯВүГҜВјВҲГӨВёВҺ typeck.name_equal Г§ВӯВүГӨВ»В·ГҜВјВҢГӨВҫВӣ asm ГҘВҶВ…ГҰВҹВҘ struct_layoutГҜВјВүГЈВҖВӮ */
function asm_names_equal(a: *u8, a_len: i32, b: *u8, b_len: i32): bool {
  if (a_len != b_len || a_len <= 0) {
    return false;
  }
  let i: i32 = 0;
  while (i < a_len) {
    if (a[i] != b[i]) {
      return false;
    }
    i = i + 1;
  }
  return true;
}
function asm_module_named_type_has_struct_layout(module: *Module, name: *u8, name_len: i32): bool {
  if (module == 0 as *Module || name_len <= 0) {
    return false;
  }
  let k: i32 = 0;
  while (k < module.num_struct_layouts) {
    let nlen: i32 = pipeline_module_struct_layout_name_len(module, k);
    if (nlen == name_len && nlen > 0) {
      let eq: bool = true;
      let j: i32 = 0;
      while (j < name_len && eq) {
        if (pipeline_module_struct_layout_name_byte_at(module, k, j) != name[j]) {
          eq = false;
        }
        j = j + 1;
      }
      if (eq) {
        return true;
      }
    }
    k = k + 1;
  }
  return false;
}

/**
 * FIELD_ACCESS ГҘВңВЁ effective address [rax+x0]+offset ГҘВӨВ„ГҘВәВ”ГҘВҠВ ГЁВҪВҪГ§ВҡВ„ГҘВӯВ—ГЁВҠВӮГҘВ®ВҪГҘВәВҰГЈВҖВӮ
 * module_ref ГӨВёВәГ§В©ВәГҰВ—В¶Г©ВҖВҖГҘВӣВһ 8 ГҘВӯВ—ГЁВҠВӮГӨВ»ВҘГӨВҝВқГҰВҢВҒГҘВҺВҶГҘВҸВІГЁВЎВҢГӨВёВәГЈВҖВӮ
 */
function asm_field_access_load_byte_sz(arena: *ASTArena, field_expr_ref: i32, module: *Module): i32 {
  if (field_expr_ref <= 0) {
    return 8;
  }
  let fx: Expr = ast.ast_arena_expr_get(arena, field_expr_ref);
  if (fx.resolved_type_ref <= 0) {
    return 8;
  }
  let t: Type = ast.ast_arena_type_get(arena, fx.resolved_type_ref);
  if (t.kind == TypeKind.TYPE_U8) {
    return 1;
  }
  if (t.kind == TypeKind.TYPE_PTR || t.kind == TypeKind.TYPE_I64 || t.kind == TypeKind.TYPE_U64
      || t.kind == TypeKind.TYPE_USIZE || t.kind == TypeKind.TYPE_ISIZE || t.kind == TypeKind.TYPE_F64) {
    return 8;
  }
  if (t.kind == TypeKind.TYPE_NAMED && module != 0 as *Module && asm_module_named_type_has_struct_layout(module, &t.name[0], t.name_len)) {
    return 8;
  }
  return 4;
}

/** Г©ВҮВҚГ§ВҪВ®ГҘВҮВҪГҰВ•В°ГӨВёВҠГӨВёВӢГҰВ–ВҮГҜВјВҢГ§В”ВЁГӨВәВҺГҰВ–В°ГҘВҮВҪГҰВ•В°ГҘВјВҖГҘВ§ВӢГЈВҖВӮmod ГЁВ®В°ГҘВ…ВҘ module_refГҜВјВҢГӨВҫВӣ emit_expr FIELD_ACCESS Г§ВӯВүГӨВҪВҝГ§В”ВЁГЈВҖВӮ */
/** йҮҚзҪ®еҮҪж•°дёҠдёӢж–ҮпјҢз”ЁдәҺж–°еҮҪж•°ејҖе§ӢгҖӮmod и®°е…Ҙ module_refпјӣlabel_counter дёҚйҮҚзҪ®д»Ҙе…ҚеӨҡеҮҪж•° .L_N йҮҚеҗҚгҖӮ */
function ctx_reset(ctx: *AsmFuncCtx, mod: *Module): void {
  ctx.frame_size = 0;
  ctx.next_offset = 0;
  ctx.num_locals = 0;
  ctx.module_ref = mod;
  ctx.break_len = 0;
  ctx.continue_len = 0;
  ctx.loop_label_depth = 0;
  ctx.dep_pipe = 0 as *PipelineDepCtx;
  ctx.tail_join_label_len = 0;
  asm_ctx_local_reset(asm_ctx_key(ctx));
}

/** ГҰВҢВүГҘВҪВўГҘВҸВӮ + ГҘВқВ—ГӨВёВӯ const + let ГҰВ•В°Г©ВҮВҸГЁВ®ВЎГ§В®В—ГҰВ ВҲГҘВёВ§ГҘВӨВ§ГҘВ°ВҸГҜВјВҲГҰВҜВҸГҰВ§ВҪ 8 ГҘВӯВ—ГЁВҠВӮГҜВјВҢГҘВҗВ‘ГӨВёВҠГҘВҸВ–ГҰВ•ВҙГҘВҲВ° 16ГҜВјВүГҜВјВҢГҘВ№В¶Г©ВўВ„Г§В•Вҷ 64 ГҘВӯВ—ГЁВҠВӮ temp ГҘВҢВәГӨВҫВӣ STRUCT_LIT/ARRAY_LITГЈВҖВӮ */
/** ж Ҳеё§еӨ§е°ҸпјӣM8-tail е§”жүҳ C glueпјҲеҪўеҸӮ + const/let + tempпјүгҖӮ */
function compute_frame_size(num_params: i32, arena: *ASTArena, block_ref: i32, mod: *Module): i32 {
  return pipeline_asm_compute_frame_size_c(num_params, arena, block_ref, mod);
}


/** ГҘВ°ВҶГҘВҮВҪГҰВ•В°Г§ВҡВ„ГҘВҪВўГҘВҸВӮГҘВЎВ«ГҘВ…ВҘ ctx ГҘВұВҖГ©ВғВЁ sidecarГҜВјВҲГҘВҒВҸГ§В§В» 8, 16, 24, ...ГҜВјВүГҜВјВӣГ©ВЎВ»ГҘВңВЁ fill_local_slots ГҘВүВҚГЁВ°ВғГ§В”ВЁГЈВҖВӮ */
/** еҪўеҸӮж§ҪпјӣM8-tail е§”жүҳ C glue pipeline_asm_fill_param_slotsгҖӮ */
function fill_param_slots(ctx: *AsmFuncCtx, mod: *Module, func_index: i32): void {
  pipeline_asm_fill_param_slots(ctx, mod, func_index);
}


/** ГҘВ°ВҶГҘВқВ—Г§ВҡВ„ const/let ГҘВЎВ«ГҘВ…ВҘ ctx ГҘВұВҖГ©ВғВЁ sidecarГҜВјВҢГҘВҒВҸГ§В§В»ГӨВ»ВҺ ctx.next_offset ГЁВөВ·ГҜВјВҲfill_param_slots ГҘВҗВҺГЁВ°ВғГ§В”ВЁГҜВјВүГЈВҖВӮ */
/** еқ—еҶ… const/let ж§ҪпјӣM8-tail е§”жүҳ C glue pipeline_asm_fill_local_slotsгҖӮ */
function fill_local_slots(ctx: *AsmFuncCtx, arena: *ASTArena, block_ref: i32): void {
  pipeline_asm_fill_local_slots(ctx, arena, block_ref);
}


/**
 * If ГЁВҜВӯГҘВҸВҘГ§ВҡВ„ then ГҘВқВ—ГҘВҸВҜГҘВҗВ«Г§ВӢВ¬Г§В«ВӢ const/letГҜВјВӣГ©ВЎВ»ГҘВ…ВҲГҘВ…ВҘ ctx.locals ГҰВҳВ ГҘВ°В„ГҰВүВҚГҘВҸВҜГЁВ§ВЈГҰВһВҗ EXPR_VARГЈВҖВӮ
 * ГӨВёВҺ EXPR_BLOCK ГЁВ·ВҜГҘВҫВ„ГӨВёВҖГЁВҮВҙГҜВјВҡГҰВҡВӮГҘВўВһГҰВ§ВҪГЁВЎВЁГҜВјВҢГҘВ®ВҢГҰВҲВҗГҘВҗВҺГҰВҒВўГҘВӨВҚ num_locals/next_offsetГҜВјВҢГҘВөВҢГҘВҘВ—ГҘВҲВҶГҰВ”ВҜГҰВ ВҲГҘВҒВҸГ§В§В»ГҘВҸВҜГҘВӣВһГҰВ”В¶ГҘВӨВҚГ§В”ВЁГЈВҖВӮ
 */
/** if then еқ— text и·Ҝеҫ„пјӣM8-tail е§”жүҳ partialпјҲC glueпјүгҖӮ */
function emit_if_then_block_body_text(arena: *ASTArena, out: *CodegenOutBuf, then_block_ref: i32, ctx: *AsmFuncCtx, target_arch: i32): i32 {
  return pipeline_asm_emit_if_then_block_body_text_c(arena, out, then_block_ref, ctx, target_arch);
}


/** ELF ГЁВ·ВҜГҘВҫВ„ГҜВјВҡ`emit_if_then_block_body_text` Г§ВҡВ„Г©В…ВҚГҘВҜВ№ГҘВ®ВһГ§ВҺВ°ГЈВҖВӮta ГӨВёВәГ§ВӣВ®ГҰВ ВҮГҰВһВ¶ГҰВһВ„Г§ВҙВўГҘВјВ•ГЈВҖВӮ */
/** if then еқ— ELF и·Ҝеҫ„пјӣM8-tail е§”жүҳ C glue pipeline_asm_emit_if_then_block_body_elf_cгҖӮ */
function emit_if_then_block_body_elf(
  arena: *ASTArena,
  elf_ctx: *ElfCodegenCtx,
  then_block_ref: i32,
  ctx: *AsmFuncCtx,
  ta: i32
): i32 {
  return pipeline_asm_emit_if_then_block_body_elf_c(arena, elf_ctx, then_block_ref, ctx, ta);
}


/** ГҘВңВЁ ctx ГҘВұВҖГ©ВғВЁ sidecar ГӨВёВӯГҰВҹВҘГҰВүВҫГҘВҗВҚГҘВӯВ—ГҜВјВҢГЁВҝВ”ГҘВӣВһГҘВҒВҸГ§В§В»ГҜВјВӣГҰВңВӘГҰВүВҫГҘВҲВ°ГЁВҝВ”ГҘВӣВһ -1ГЈВҖВӮ */
/** еңЁ ctx еұҖйғЁ sidecar дёӯжҹҘжүҫеҗҚеӯ—пјҢиҝ”еӣһеҒҸз§»пјӣM8-tail е§”жүҳ C glue pipeline_asm_local_offset_cгҖӮ */
function local_offset(ctx: *AsmFuncCtx, name: *u8, name_len: i32): i32 {
  return pipeline_asm_local_offset_c(ctx, name, name_len);
}

function arch_emit_ret_imm32(out: *CodegenOutBuf, imm: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_ret_imm32(out, imm); }
  if (ta == 2) { return arch.riscv64.emit_ret_imm32(out, imm); }
  return arch.x86_64.emit_ret_imm32(out, imm);
}
/** ГҘВ°ВҶ 64 ГӨВҪВҚГ§В«ВӢГҘВҚВіГҰВ•В°ГҜВјВҲlo/hi ГӨВёВәГӨВҪВҺ/Г©В«Вҳ 32 ГӨВҪВҚГҜВјВүГЁВЈВ…ГҘВ…ВҘ rax/x0ГЈВҖВӮГ§В”ВЁГӨВәВҺ EXPR_FLOAT_LIT ГҘВҸВ‘ГҘВ°В„ double ГӨВҪВҚГҰВЁВЎГҘВјВҸГЈВҖВӮ */
function arch_emit_mov_imm64_to_rax(out: *CodegenOutBuf, lo: i32, hi: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_mov_imm64_to_rax(out, lo, hi); }
  if (ta == 2) { return arch.riscv64.emit_mov_imm64_to_rax(out, lo, hi); }
  return arch.x86_64.emit_mov_imm64_to_rax(out, lo, hi);
}
/** 7.3ГҜВјВҡГ§В«ВӢГҘВҚВіГҰВ•В°ГҘВ…ВҘ rbx/w1ГҜВјВҢADD ГҘВ·ВҰГҰВ“ВҚГӨВҪВңГҰВ•В°ГӨВёВәГҘВӯВ—Г©ВқВўГ©ВҮВҸГҰВ—В¶ГҘВ…ВҚ push/popГЈВҖВӮ */
function arch_emit_mov_imm32_to_rbx(out: *CodegenOutBuf, imm: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_mov_imm32_to_rbx(out, imm); }
  if (ta == 2) { return arch.riscv64.emit_mov_imm32_to_rbx(out, imm); }
  return arch.x86_64.emit_mov_imm32_to_rbx(out, imm);
}
function arch_emit_neg_eax(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_neg_eax(out); }
  if (ta == 2) { return arch.riscv64.emit_neg_eax(out); }
  return arch.x86_64.emit_neg_eax(out);
}
function arch_emit_test_setz(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) {
    if (arch.arm64.emit_test_eax_eax(out) != 0) { return -1; }
    return arch.arm64.emit_setz_movzbl_eax(out);
  }
  if (ta == 2) {
    if (arch.riscv64.emit_test_eax_eax(out) != 0) { return -1; }
    return arch.riscv64.emit_setz_movzbl_eax(out);
  }
  if (arch.x86_64.emit_test_eax_eax(out) != 0) { return -1; }
  return arch.x86_64.emit_setz_movzbl_eax(out);
}

/** ГӨВ»В…ГҰВҜВ”ГЁВҫВғ rbx ГӨВёВҺ raxГҜВјВҲГ§ВҪВ®ГҰВ ВҮГҘВҝВ—/Г§В»В“ГҰВһВңГӨВҫВӣ jzГҜВјВүГЈВҖВӮmatch ГҘВҲВҶГҰВ”ВҜГ§ВӣВёГ§ВӯВүГҰВҜВ”ГЁВҫВғГ§В”ВЁГЈВҖВӮ */
function arch_emit_cmp_rbx_rax(out: *CodegenOutBuf, ta: i32): i32 {
  if (ta == 1) { return arch.arm64.emit_cmp_rbx_rax(out); }
  if (ta == 2) { return arch.riscv64.emit_cmp_rbx_rax(out); }
  return arch.x86_64.emit_cmp_rbx_rax(out);
}

/** ГҰВҜВ”ГЁВҫВғГЁВҝВҗГ§В®В—ГҜВјВҡleft ГҘВ·ВІГҘВңВЁ rbxГҜВјВҢright ГҘВңВЁ raxГҜВјВӣГҰВ В№ГҰВҚВ® cc Г§ВҪВ®Г§В»В“ГҰВһВңГӨВёВә 0/1ГЈВҖВӮcc: 0=eq, 1=ne, 2=lt, 3=le, 4=gt, 5=geГЈВҖВӮ */
function arch_emit_cmp_setcc(out: *CodegenOutBuf, cc: i32, ta: i32): i32 {
  if (ta == 1) {
    return arch.arm64.emit_cmp_setcc(out, cc);
  }
  if (ta == 2) { return arch.riscv64.emit_cmp_setcc(out, cc); }
  return arch.x86_64.emit_cmp_setcc(out, cc);
}

