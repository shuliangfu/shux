/**
 * ГҘВұВҖГ©ВғВЁГҰВ§ВҪГҰВҳВҜГҘВҗВҰГӨВёВәГЈВҖВҢГҰВҢВҮГҘВҗВ‘ temp ГҘВҢВәГҘВҜВ№ГЁВұВЎГЈВҖВҚГ§ВҡВ„ 8 ГҘВӯВ—ГЁВҠВӮГҰВҢВҮГ©В’ВҲГҜВјВҲARRAY_LIT / STRUCT_LIT ГҘВҲВқГҘВҖВјГҜВјВүГЈВҖВӮ
 * INDEX / FIELD_ACCESS ГҘВҹВәГҘВәВ•ГӨВёВә VAR ГҰВ—В¶Г©ВЎВ» load ГЁВҜВҘГҰВҢВҮГ©В’ВҲГҜВјВҢГӨВёВҚГЁВғВҪ lea ГҰВ§ВҪГҘВқВҖГЈВҖВӮ
 */
function asm_local_var_slot_holds_indirect_ptr(arena: *ASTArena, base_var: Expr, mod: *Module): i32 {
  let rtbv: i32 = base_var.resolved_type_ref;
  if (rtbv <= 0) {
    /** emit ж—¶ resolved зјәеӨұпјҡmodule еҪўеҸӮиЎЁиҜҶеҲ« *TпјҲdriver compile.sx state зӯүпјүгҖӮ */
    if (mod != 0 as *Module && base_var.kind == ExprKind.EXPR_VAR && base_var.var_name_len > 0
        && pipeline_asm_emit_func_param_is_ptr_by_name_c(arena, mod, &base_var.var_name[0], base_var.var_name_len) != 0) {
      return 1;
    }
    return 0;
  }
  let vtyp: Type = ast.ast_arena_type_get(arena, rtbv);
  /** е®ҡй•ҝ T[N] еҶ…иҒ”ж Ҳж§Ҫз”Ё leaпјӣд»… *T дёә 8B жҢҮй’Ҳж§ҪйЎ» loadгҖӮ */
  if (vtyp.kind == TypeKind.TYPE_PTR) {
    return 1;
  }
  if (vtyp.kind == TypeKind.TYPE_NAMED && mod != 0 as *Module
      && asm_module_named_type_has_struct_layout(mod, &vtyp.name[0], vtyp.name_len)) {
    return 1;
  }
  return 0;
}

/**
 * ELFГҜВјВҡГҘВұВҖГ©ВғВЁ VAR ГӨВёВәГҰВҢВҮГ©В’ВҲГҰВ—В¶Г§В”ВЁ loadГҜВјВҲГҰВ§ВҪГҘВҶВ…ГҘВҗВ«ГҰВҢВҮГҘВҗВ‘ГҘВҜВ№ГЁВұВЎГ§ВҡВ„ГҘВңВ°ГҘВқВҖГҜВјВүГҜВјВҢГҘВҗВҰГҘВҲВҷ leaГҜВјВҲГҰВ§ВҪГҘВҚВіГҘВҜВ№ГЁВұВЎ/ГҰВ•В°Г§В»В„Г©ВҰВ–ГҜВјВүГЈВҖВӮ
 * ГӨВёВҺ text ГЁВ·ВҜГҘВҫВ„ arch_emit_local_slot_ptr_or_addr ГӨВёВҖГЁВҮВҙГЈВҖВӮ
