function enc_and_rbx_rax_arch(elf_ctx: *platform.elf.ElfCodegenCtx, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_and_rbx_rax(elf_ctx); }
  if (ta == 2) { return arch.riscv64_enc.enc_and_rbx_rax(elf_ctx); }
