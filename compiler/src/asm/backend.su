/**
 * 局部槽是否为「指向 temp 区对象」的 8 字节指针（ARRAY_LIT / STRUCT_LIT 初值）。
 * INDEX / FIELD_ACCESS 基底为 VAR 时须 load 该指针，不能 lea 槽址。
 */
function asm_local_var_slot_holds_indirect_ptr(arena: *ASTArena, base_var: Expr, mod: *Module): i32 {
  let rtbv: i32 = base_var.resolved_type_ref;
  if (rtbv <= 0) {
    return 0;
  }
  let vtyp: Type = ast_arena_type_get(arena, rtbv);
  if (vtyp.kind == TypeKind.TYPE_PTR || vtyp.kind == TypeKind.TYPE_ARRAY) {
    return 1;
  }
  if (vtyp.kind == TypeKind.TYPE_NAMED && mod != 0 as *Module
      && asm_module_named_type_has_struct_layout(mod, &vtyp.name[0], vtyp.name_len)) {
    return 1;
  }
  return 0;
}

/**
 * ELF：局部 VAR 为指针时用 load（槽内含指向对象的地址），否则 lea（槽即对象/数组首）。
 * 与 text 路径 arch_emit_local_slot_ptr_or_addr 一致。
 */
function enc_local_slot_ptr_or_addr_arch(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, base_var: Expr, stack_off: i32, ta: i32, ctx: *AsmFuncCtx): i32 {
  if (asm_local_var_slot_holds_indirect_ptr(arena, base_var, ctx.module_ref) != 0) {
    return enc_load_rbp_to_rax_arch(elf_ctx, stack_off, ta);
  }
  return enc_lea_rbp_to_rax_arch(elf_ctx, stack_off, ta);
}
