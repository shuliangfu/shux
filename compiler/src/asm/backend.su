    let nl: i32 = ctx.label_counter;
    ctx.label_counter = ctx.label_counter + 1;
    let n1: i32 = format_i32_to_buf(true_buf, 9, 8, nc);
    let true_len: i32 = 9 + (n1 > 0 ? n1 : 1);
    let n2: i32 = format_i32_to_buf(end_buf, 9, 8, nl);
    let end_len: i32 = 9 + (n2 > 0 ? n2 : 1);
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_test_eax_eax_arch(elf_ctx, ta) != 0) { return -1; }
    if (enc_jnz_arch(elf_ctx, true_buf, true_len, ta) != 0) { return -1; }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_test_eax_eax_arch(elf_ctx, ta) != 0) { return -1; }
    if (enc_jnz_arch(elf_ctx, true_buf, true_len, ta) != 0) { return -1; }
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, 0, ta) != 0) { return -1; }
    if (enc_jmp_arch(elf_ctx, end_buf, end_len, ta) != 0) { return -1; }
    if (platform.elf.elf_add_label(elf_ctx, true_buf, true_len) != 0) { return -1; }
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, 1, ta) != 0) { return -1; }
    if (platform.elf.elf_add_label(elf_ctx, end_buf, end_len) != 0) { return -1; }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_ASSIGN && asm_expr_binop_left(arena, expr_ref) != 0 && asm_expr_binop_right(arena, expr_ref) != 0) {
    let left: Expr = ast_arena_expr_get(arena, asm_expr_binop_left(arena, expr_ref));
    if (left.kind == ExprKind.EXPR_FIELD_ACCESS && left.field_access_base_ref != 0 && left.field_access_is_enum_variant == 0) {
      if (emit_lvalue_eff_addr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
      if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
      if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
      let fw_e: i32 = asm_field_access_load_byte_sz(arena, asm_expr_binop_left(arena, expr_ref), ctx.module_ref);
      if (enc_pop_rbx_arch(elf_ctx, ta) != 0) { return -1; }
      return enc_store_rax_to_rbx_indirect_arch(elf_ctx, fw_e, ta);
    }
    if (left.kind == ExprKind.EXPR_INDEX && left.index_base_ref != 0 && left.index_index_ref != 0) {
      let esz_e: i32 = asm_index_elem_byte_sz(arena, asm_expr_binop_left(arena, expr_ref));
      if (emit_index_eff_addr_elf(arena, elf_ctx, left, ctx, ta, esz_e) != 0) { return -1; }
      if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
      if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
      if (enc_pop_rbx_arch(elf_ctx, ta) != 0) { return -1; }
      return enc_store_rax_to_rbx_indirect_arch(elf_ctx, esz_e, ta);
    }
    if (left.kind != ExprKind.EXPR_VAR) { return -1; }
    let off: i32 = local_offset(ctx, left.var_name, left.var_name_len);
    if (off < 0) { return -1; }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
    return enc_store_rax_to_rbp_arch(elf_ctx, off, ta);
