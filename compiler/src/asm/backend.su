    let n1: i32 = format_i32_to_buf(else_buf, 8, 8, nc);
    let else_len: i32 = 8 + (n1 > 0 ? n1 : 1);
    let n2: i32 = format_i32_to_buf(end_buf, 7, 8, nl);
    let end_len: i32 = 7 + (n2 > 0 ? n2 : 1);
    if (emit_expr_elf(arena, elf_ctx, e.if_cond_ref, ctx, ta) != 0) { return -1; }
    if (enc_jz_arch(elf_ctx, else_buf, else_len, ta) != 0) { return -1; }
    if (emit_expr_elf(arena, elf_ctx, e.if_then_ref, ctx, ta) != 0) { return -1; }
    if (enc_jmp_arch(elf_ctx, end_buf, end_len, ta) != 0) { return -1; }
    if (enc_label_arch(elf_ctx, else_buf, else_len, 0, ta) != 0) { return -1; }
    if (e.if_else_ref != 0) {
      if (emit_expr_elf(arena, elf_ctx, e.if_else_ref, ctx, ta) != 0) { return -1; }
    }
    if (enc_label_arch(elf_ctx, end_buf, end_len, 0, ta) != 0) { return -1; }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_BLOCK && e.block_ref != 0) {
    let saved_locals: i32 = ctx.num_locals;
    let saved_next: i32 = ctx.next_offset;
    fill_local_slots(ctx, arena, e.block_ref);
    let slot_base: i32 = saved_locals;
    if (emit_block_inits_elf(arena, elf_ctx, e.block_ref, ctx, ta, slot_base) != 0) { return -1; }
    let inner_blk2: Block = ast_arena_block_get(arena, e.block_ref);
    let block_val_ref: i32 = inner_blk2.final_expr_ref;
    if (block_val_ref == 0) {
      /** if 分支 `{ 10 }` 等可能落成 expr_stmt 而无 final_expr；取最后一条 expr 作块值。 */
      let nes: i32 = ast_block_num_expr_stmts(arena, e.block_ref);
      if (nes > 0) {
        let last_ex: i32 = ast_block_expr_stmt_ref(arena, e.block_ref, nes - 1);
        if (last_ex != 0) {
          let last_e: Expr = ast_arena_expr_get(arena, last_ex);
          if (last_e.kind == ExprKind.EXPR_RETURN && last_e.unary_operand_ref != 0) {
            block_val_ref = last_e.unary_operand_ref;
          } else {
            block_val_ref = last_ex;
          }
        }
      }
    }
    if (block_val_ref != 0) {
      if (emit_expr_elf(arena, elf_ctx, block_val_ref, ctx, ta) != 0) { return -1; }
    }
    ctx.num_locals = saved_locals;
    ctx.next_offset = saved_next;
    return 0;
  }
  let match_n_arms_e: i32 = 0;
  if (e.kind == ExprKind.EXPR_MATCH) {
    match_n_arms_e = pipeline_expr_match_num_arms_at(arena, expr_ref);
  }
  let match_matched_ref_elf: i32 = e.match_matched_ref;
  if (e.kind == ExprKind.EXPR_MATCH && match_matched_ref_elf == 0) {
    match_matched_ref_elf = pipeline_expr_match_matched_ref_at(arena, expr_ref);
  }
  if (e.kind == ExprKind.EXPR_MATCH && match_matched_ref_elf != 0 && match_n_arms_e > 0) {
    if (emit_expr_elf(arena, elf_ctx, match_matched_ref_elf, ctx, ta) != 0) { return -1; }
    let base: i32 = ctx.label_counter;
    ctx.label_counter = ctx.label_counter + match_n_arms_e + 1;
    let end_id: i32 = base + match_n_arms_e;
    let res_buf: [64]u8 = [];
    let end_buf: [64]u8 = [];
    let i: i32 = 0;
    while (i < match_n_arms_e && i < 16) {
      if (pipeline_expr_match_arm_is_wildcard(arena, expr_ref, i) != 0) {
        let r_ref: i32 = pipeline_expr_match_arm_result_ref(arena, expr_ref, i);
        if (r_ref != 0 && emit_expr_elf(arena, elf_ctx, r_ref, ctx, ta) != 0) { return -1; }
        let end_len: i32 = format_label_id(end_buf, 64, end_id);
        if (enc_jmp_arch(elf_ctx, end_buf, end_len, ta) != 0) { return -1; }
      } else {
        let cmp_val: i32 = pipeline_expr_match_arm_is_enum_variant(arena, expr_ref, i) != 0 ? pipeline_expr_match_arm_variant_index(arena, expr_ref, i) : pipeline_expr_match_arm_lit_val(arena, expr_ref, i);
        if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
        if (enc_mov_imm32_to_rbx_arch(elf_ctx, cmp_val, ta) != 0) { return -1; }
        if (enc_pop_rax_arch(elf_ctx, ta) != 0) { return -1; }
        if (enc_cmp_rbx_rax_arch(elf_ctx, ta) != 0) { return -1; }
        let res_len: i32 = format_label_id(res_buf, 64, base + i);
        if (enc_jeq_arch(elf_ctx, res_buf, res_len, ta) != 0) { return -1; }
      }
      i = i + 1;
    }
    i = 0;
    while (i < match_n_arms_e && i < 16) {
      let res_len: i32 = format_label_id(res_buf, 64, base + i);
      if (enc_label_arch(elf_ctx, res_buf, res_len, 0, ta) != 0) { return -1; }
      let r_ref: i32 = pipeline_expr_match_arm_result_ref(arena, expr_ref, i);
      if (r_ref != 0 && emit_expr_elf(arena, elf_ctx, r_ref, ctx, ta) != 0) { return -1; }
      let end_len: i32 = format_label_id(end_buf, 64, end_id);
      if (enc_jmp_arch(elf_ctx, end_buf, end_len, ta) != 0) { return -1; }
      i = i + 1;
    }
    let end_len: i32 = format_label_id(end_buf, 64, end_id);
    if (enc_label_arch(elf_ctx, end_buf, end_len, 0, ta) != 0) { return -1; }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_STRUCT_LIT) {
    let nf_sl_elf: i32 = pipeline_expr_struct_lit_num_fields(arena, expr_ref);
    if (nf_sl_elf > 0 && nf_sl_elf <= 8) {
    let temp_base: i32 = ctx.next_offset;
    if (enc_lea_rbp_to_rax_arch(elf_ctx, temp_base, ta) != 0) { return -1; }
    if (enc_mov_rax_to_rbx_arch(elf_ctx, ta) != 0) { return -1; }
    let fi: i32 = 0;
    while (fi < nf_sl_elf && fi < 8) {
      let init_ref: i32 = pipeline_expr_struct_lit_init_ref(arena, expr_ref, fi);
      if (init_ref != 0) {
        if (emit_expr_elf(arena, elf_ctx, init_ref, ctx, ta) != 0) { return -1; }
        if (enc_store_rax_to_rbx_offset_arch(elf_ctx, fi * 8, 8, ta) != 0) { return -1; }
      }
      fi = fi + 1;
    }
    return enc_mov_rbx_to_rax_arch(elf_ctx, ta);
    }
  }
  if (e.kind == ExprKind.EXPR_ARRAY_LIT) {
    let n_arr_elf: i32 = pipeline_expr_array_lit_num_elems_at(arena, expr_ref);
    if (n_arr_elf == 0) {
      let temp_base0: i32 = ctx.next_offset;
      return enc_lea_rbp_to_rax_arch(elf_ctx, temp_base0, ta);
    }
    if (n_arr_elf > 0 && n_arr_elf <= 16) {
    let temp_base: i32 = ctx.next_offset;
    let esz_arr_e: i32 = asm_array_lit_elem_byte_sz(arena, expr_ref);
    if (enc_lea_rbp_to_rax_arch(elf_ctx, temp_base, ta) != 0) { return -1; }
    if (enc_mov_rax_to_rbx_arch(elf_ctx, ta) != 0) { return -1; }
    let ai: i32 = 0;
    while (ai < n_arr_elf && ai < 16) {
      let elem_ref: i32 = pipeline_expr_array_lit_elem_ref(arena, expr_ref, ai);
      if (elem_ref != 0) {
        if (emit_expr_elf(arena, elf_ctx, elem_ref, ctx, ta) != 0) { return -1; }
        if (enc_store_rax_to_rbx_offset_arch(elf_ctx, ai * esz_arr_e, esz_arr_e, ta) != 0) { return -1; }
      }
      ai = ai + 1;
    }
    return enc_mov_rbx_to_rax_arch(elf_ctx, ta);
    }
  }
  if (e.kind == ExprKind.EXPR_ENUM_VARIANT) {
    return backend_enc_mov_imm32_to_w0_arch(elf_ctx, e.enum_variant_tag, ta);
  }
  if (e.const_folded_valid != 0) {
    return backend_enc_mov_imm32_to_w0_arch(elf_ctx, e.const_folded_val, ta);
  }
  driver_diagnostic_asm_unsupported_expr(expr_kind_ordinal(e.kind));
  driver_diagnostic_asm_fail_at(99);
  return -1;
}

/** ELF 路径 INDEX 有效地址装入 rax/x0（无 load）。须在 emit_expr_elf 之后定义供其调用。 */
function emit_index_eff_addr_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, ix: Expr, ctx: *AsmFuncCtx, elf_ta: i32, elem_sz: i32): i32 {
  if (ix.index_base_ref == 0 || ix.index_index_ref == 0) { return -1; }
  let base: Expr = ast_arena_expr_get(arena, ix.index_base_ref);
  /* 与 emit_index_eff_addr_text 一致：FIELD_ACCESS(VAR)+offset 作为嵌套数组首址。 */
  if (base.kind == ExprKind.EXPR_FIELD_ACCESS && base.field_access_base_ref != 0 && base.field_access_is_enum_variant == 0) {
    let fb: Expr = ast_arena_expr_get(arena, base.field_access_base_ref);
    if (fb.kind == ExprKind.EXPR_VAR) {
      let off_ef: i32 = local_offset(ctx, fb.var_name, fb.var_name_len);
      if (off_ef < 0) { return -1; }
      if (enc_local_slot_ptr_or_addr_arch(arena, elf_ctx, fb, off_ef, elf_ta, ctx) != 0) { return -1; }
      if (enc_add_imm_to_rax_arch(elf_ctx, base.field_access_offset, elf_ta) != 0) { return -1; }
    } else {
      if (emit_expr_elf(arena, elf_ctx, base.field_access_base_ref, ctx, elf_ta) != 0) { return -1; }
      if (enc_add_imm_to_rax_arch(elf_ctx, base.field_access_offset, elf_ta) != 0) { return -1; }
    }
  } else if (base.kind == ExprKind.EXPR_VAR) {
    let off: i32 = local_offset(ctx, base.var_name, base.var_name_len);
    if (off < 0) { return -1; }
    if (enc_local_slot_ptr_or_addr_arch(arena, elf_ctx, base, off, elf_ta, ctx) != 0) { return -1; }
  } else {
    if (emit_expr_elf(arena, elf_ctx, ix.index_base_ref, ctx, elf_ta) != 0) { return -1; }
  }
  if (base.resolved_type_ref != 0) {
    let bt: Type = ast_arena_type_get(arena, base.resolved_type_ref);
    if (bt.kind == TypeKind.TYPE_SLICE) {
      if (enc_load_64_from_rax_arch(elf_ctx, elf_ta) != 0) { return -1; }
    }
  }
  if (enc_push_rax_arch(elf_ctx, elf_ta) != 0) { return -1; }
  if (emit_expr_elf(arena, elf_ctx, ix.index_index_ref, ctx, elf_ta) != 0) { return -1; }
  if (enc_mov_rax_to_rbx_arch(elf_ctx, elf_ta) != 0) { return -1; }
  if (enc_pop_rax_arch(elf_ctx, elf_ta) != 0) { return -1; }
  if (elem_sz == 1) { return enc_rax_plus_rbx_scale1_arch(elf_ctx, elf_ta); }
  if (elem_sz == 8) { return enc_rax_plus_rbx_scale8_arch(elf_ctx, elf_ta); }
  return enc_rax_plus_rbx_scale4_arch(elf_ctx, elf_ta);
}

/** ELF：与 emit_lvalue_eff_addr_text 对称（链式字段左值赋值）。 */
function emit_lvalue_eff_addr_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, lval_ref: i32, ctx: *AsmFuncCtx, ta: i32): i32 {
  if (lval_ref <= 0) {
    return -1;
  }
  let cur: Expr = ast_arena_expr_get(arena, lval_ref);
  if (cur.kind == ExprKind.EXPR_VAR) {
    let off_e: i32 = local_offset(ctx, cur.var_name, cur.var_name_len);
    if (off_e < 0) {
      return -1;
    }
    return enc_local_slot_ptr_or_addr_arch(arena, elf_ctx, cur, off_e, ta, ctx);
  }
  if (cur.kind == ExprKind.EXPR_FIELD_ACCESS && cur.field_access_is_enum_variant == 0 && cur.field_access_base_ref != 0) {
    if (emit_lvalue_eff_addr_elf(arena, elf_ctx, cur.field_access_base_ref, ctx, ta) != 0) {
      return -1;
    }
    return enc_add_imm_to_rax_arch(elf_ctx, cur.field_access_offset, ta);
  }
  if (cur.kind == ExprKind.EXPR_INDEX && cur.index_base_ref != 0 && cur.index_index_ref != 0) {
    let esz_ef: i32 = asm_index_elem_byte_sz(arena, lval_ref);
    return emit_index_eff_addr_elf(arena, elf_ctx, cur, ctx, ta, esz_ef);
  }
  return -1;
}

/** ELF 路径：块的 const/let 初始化；slot_base 同 emit_block_inits。ta 0=x86_64，1=arm64。 */
function emit_block_inits_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, ctx: *AsmFuncCtx, ta: i32, slot_base: i32): i32 {
  let idx: i32 = 0;
  let i: i32 = 0;
  while (i < ast_block_num_consts(arena, block_ref) && (slot_base + idx) < ctx.num_locals) {
    let init_ref: i32 = pipeline_block_const_init_ref(arena, block_ref, i);
    if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
      if (emit_expr_elf(arena, elf_ctx, init_ref, ctx, ta) != 0) { return -1; }
      if (enc_store_rax_to_rbp_arch(elf_ctx, asm_ctx_slot_offset(ctx, slot_base + idx), ta) != 0) { return -1; }
    }
    idx = idx + 1;
    i = i + 1;
  }
  i = 0;
  while (i < ast_block_num_lets(arena, block_ref) && (slot_base + idx) < ctx.num_locals) {
    let init_ref: i32 = pipeline_block_let_init_ref(arena, block_ref, i);
    if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
      if (emit_expr_elf(arena, elf_ctx, init_ref, ctx, ta) != 0) { return -1; }
      if (enc_store_rax_to_rbp_arch(elf_ctx, asm_ctx_slot_offset(ctx, slot_base + idx), ta) != 0) { return -1; }
    }
    idx = idx + 1;
    i = i + 1;
  }
  return 0;
}

/** 两 EXPR_VAR 节点是否同名（经 pipeline 读名，避免 ast 字段撕裂）。 */
function fold_expr_var_refs_same(arena: *ASTArena, a_ref: i32, b_ref: i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, a_ref) != 3) { return 0; }
  if (pipeline_expr_kind_ord_at(arena, b_ref) != 3) { return 0; }
  let alen: i32 = pipeline_expr_var_name_len(arena, a_ref);
  let blen: i32 = pipeline_expr_var_name_len(arena, b_ref);
  if (alen <= 0 || alen != blen) { return 0; }
  let abuf: [64]u8 = [];
  let bbuf: [64]u8 = [];
  pipeline_expr_var_name_into(arena, a_ref, &abuf[0]);
  pipeline_expr_var_name_into(arena, b_ref, &bbuf[0]);
  let k: i32 = 0;
  while (k < alen) {
    if (abuf[k] != bbuf[k]) { return 0; }
    k = k + 1;
  }
  return 1;
}

/**
 * 是否为 `target = target + addend`（addend 为 EXPR_LIT 立即数）。
 * 成功时 *out_addend 写入加数；target_ref 为左值 VAR 的 expr ref。
 */
function fold_is_assign_var_add_lit(arena: *ASTArena, expr_ref: i32, target_ref: i32, out_addend: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, expr_ref) != 28) { return 0; }
  let left_ref: i32 = asm_expr_binop_left(arena, expr_ref);
  let right_ref: i32 = asm_expr_binop_right(arena, expr_ref);
  if (left_ref <= 0 || right_ref <= 0) { return 0; }
  if (fold_expr_var_refs_same(arena, left_ref, target_ref) == 0) { return 0; }
  if (pipeline_expr_kind_ord_at(arena, right_ref) != 4) { return 0; }
  let add_l: i32 = asm_expr_binop_left(arena, right_ref);
  let add_r: i32 = asm_expr_binop_right(arena, right_ref);
  if (fold_expr_var_refs_same(arena, add_l, target_ref) == 0) { return 0; }
  if (pipeline_expr_kind_ord_at(arena, add_r) != 0) { return 0; }
  if (out_addend != 0 as *i32) {
    out_addend[0] = pipeline_expr_int_val_at(arena, add_r);
  }
  return 1;
}

/** 块 stmt_order 是否含 call / 嵌套循环（不可做常量折叠）。 */
function fold_body_has_call_or_nested_loop(arena: *ASTArena, body_ref: i32): i32 {
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  let i: i32 = 0;
  while (i < nso) {
    let item_kind: u8 = ast_block_stmt_order_kind(arena, body_ref, i);
    if (item_kind == 3 || item_kind == 4) { return 1; }
    if (item_kind == 2) {
      let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, i);
      if (idx >= 0 && idx < ast_block_num_expr_stmts(arena, body_ref)) {
        let er: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
        if (er > 0) {
          let ek: i32 = pipeline_expr_kind_ord_at(arena, er);
          if (ek == 48 || ek == 49) { return 1; }
        }
      }
    }
    i = i + 1;
  }
  return 0;
}

/**
 * 解析 `while (i < n)`：左为 VAR i；右为 VAR n 或 LIT n。
 * 成功写 *out_i_ref、*out_n_is_lit、*out_n_lit（字面量时）或 *out_n_ref（变量时）。
 */
function fold_parse_while_lt_i_n(
  arena: *ASTArena, cond_ref: i32,
  out_i_ref: *i32, out_n_is_lit: *i32, out_n_lit: *i32, out_n_ref: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, cond_ref) != 16) { return 0; }
  let i_ref: i32 = asm_expr_binop_left(arena, cond_ref);
  let n_side: i32 = asm_expr_binop_right(arena, cond_ref);
  if (pipeline_expr_kind_ord_at(arena, i_ref) != 3) { return 0; }
  if (out_i_ref != 0 as *i32) {
    out_i_ref[0] = i_ref;
  }
  if (pipeline_expr_kind_ord_at(arena, n_side) == 0) {
    if (out_n_is_lit != 0 as *i32) { out_n_is_lit[0] = 1; }
    if (out_n_lit != 0 as *i32) { out_n_lit[0] = pipeline_expr_int_val_at(arena, n_side); }
    if (out_n_ref != 0 as *i32) { out_n_ref[0] = 0; }
    return 1;
  }
  if (pipeline_expr_kind_ord_at(arena, n_side) == 3) {
    if (out_n_is_lit != 0 as *i32) { out_n_is_lit[0] = 0; }
    if (out_n_lit != 0 as *i32) { out_n_lit[0] = 0; }
    if (out_n_ref != 0 as *i32) { out_n_ref[0] = n_side; }
    return 1;
  }
  return 0;
}

/**
 * 是否为 `s = s + (i + K)` 或 `s = s + f(i)`（f 为 x+K 链）；成功写 out_s_ref、out_k。
 */
function fold_affine_i_plus_k_expr(arena: *ASTArena, mod: *Module, expr_ref: i32, i_ref: i32, out_k: *i32): i32 {
  let rk: i32 = pipeline_expr_kind_ord_at(arena, expr_ref);
  if (rk == 48) {
    if (pipeline_expr_call_num_args_at(arena, expr_ref) != 1) { return 0; }
    let arg0: i32 = pipeline_expr_call_arg_ref(arena, expr_ref, 0);
    if (fold_expr_var_refs_same(arena, arg0, i_ref) == 0) { return 0; }
    let callee_ref: i32 = pipeline_expr_call_callee_ref_at(arena, expr_ref);
    if (callee_ref <= 0 || pipeline_expr_kind_ord_at(arena, callee_ref) != 3) { return 0; }
    let cname: [64]u8 = [];
    pipeline_expr_var_name_into(arena, callee_ref, &cname[0]);
    let fi: i32 = asm_module_func_index_by_name(mod, &cname[0], pipeline_expr_var_name_len(arena, callee_ref));
    if (fi < 0) { return 0; }
    let kk: i32 = fold_func_x_plus_k_chain(arena, mod, fi, 0);
    if (kk < 0) { return 0; }
    if (out_k != 0 as *i32) { out_k[0] = kk; }
    return 1;
  }
  if (fold_expr_is_add_kind(arena, expr_ref) == 0) { return 0; }
  let al: i32 = asm_expr_binop_left(arena, expr_ref);
  let ar: i32 = asm_expr_binop_right(arena, expr_ref);
  let k_lit: i32 = 0;
  if (fold_expr_var_refs_same(arena, al, i_ref) != 0 && pipeline_expr_kind_ord_at(arena, ar) == 0) {
    k_lit = pipeline_expr_int_val_at(arena, ar);
  } else if (fold_expr_var_refs_same(arena, ar, i_ref) != 0 && pipeline_expr_kind_ord_at(arena, al) == 0) {
    k_lit = pipeline_expr_int_val_at(arena, al);
  } else {
    return 0;
  }
  if (out_k != 0 as *i32) { out_k[0] = k_lit; }
  return 1;
}

function fold_is_assign_s_plus_affine_i(
  arena: *ASTArena, mod: *Module, expr_ref: i32, i_ref: i32, out_s_ref: *i32, out_k: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, expr_ref) != 28) { return 0; }
  let left_ref: i32 = asm_expr_binop_left(arena, expr_ref);
  let right_ref: i32 = asm_expr_binop_right(arena, expr_ref);
  if (pipeline_expr_kind_ord_at(arena, left_ref) != 3) { return 0; }
  let inner: i32 = right_ref;
  if (fold_expr_is_add_kind(arena, right_ref) != 0) {
    let add_l: i32 = asm_expr_binop_left(arena, right_ref);
    if (fold_expr_var_refs_same(arena, add_l, left_ref) == 0) { return 0; }
    inner = asm_expr_binop_right(arena, right_ref);
  }
  let kk: i32 = 0;
  if (fold_affine_i_plus_k_expr(arena, mod, inner, i_ref, &kk) == 0) { return 0; }
  if (out_s_ref != 0 as *i32) { out_s_ref[0] = left_ref; }
  if (out_k != 0 as *i32) { out_k[0] = kk; }
  return 1;
}

/** 解析 `s += (i+K); i++` 双语句循环体（call_boundary 等）。 */
function fold_parse_affine_sum_body(
  arena: *ASTArena, mod: *Module, body_ref: i32, i_ref: i32, out_s_ref: *i32, out_k: *i32): i32 {
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  if (nso != 2) { return 0; }
  let found_s: i32 = 0;
  let found_i: i32 = 0;
  let s_ref: i32 = 0;
  let k_v: i32 = 0;
  let j: i32 = 0;
  while (j < nso) {
    if (ast_block_stmt_order_kind(arena, body_ref, j) != 2) { return 0; }
    let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, j);
    if (idx < 0 || idx >= ast_block_num_expr_stmts(arena, body_ref)) { return 0; }
    let er: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
    if (er <= 0) { return 0; }
    let addend: i32 = 0;
    if (fold_is_assign_var_add_lit(arena, er, i_ref, &addend) != 0 && addend == 1) {
      found_i = 1;
    } else {
      let kk: i32 = 0;
      let sr: i32 = 0;
      if (fold_is_assign_s_plus_affine_i(arena, mod, er, i_ref, &sr, &kk) != 0) {
        if (found_s != 0) { return 0; }
        found_s = 1;
        s_ref = sr;
        k_v = kk;
      } else {
        return 0;
      }
    }
    j = j + 1;
  }
  if (found_s == 0 || found_i == 0) { return 0; }
  if (out_s_ref != 0 as *i32) { out_s_ref[0] = s_ref; }
  if (out_k != 0 as *i32) { out_k[0] = k_v; }
  return 1;
}

/** 表达式是否为 func 第 0 形参的字段访问（`p.a` 等）。 */
function fold_expr_is_param0_field_access(arena: *ASTArena, mod: *Module, func_idx: i32, expr_ref: i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, expr_ref) != 44) { return 0; }
  let base_ref: i32 = pipeline_expr_field_access_base_ref(arena, expr_ref);
  return fold_expr_is_func_param0(arena, mod, func_idx, base_ref);
}

/** 函数体是否为 `return p.f0 + p.f1`（两字段均来自 param0）。 */
function fold_func_returns_param0_field_sum(arena: *ASTArena, mod: *Module, func_idx: i32): i32 {
  let ret_ref: i32 = fold_func_return_operand_ref(arena, mod, func_idx);
  if (ret_ref <= 0) { return 0; }
  if (fold_expr_is_add_kind(arena, ret_ref) == 0) { return 0; }
  let al: i32 = asm_expr_binop_left(arena, ret_ref);
  let ar: i32 = asm_expr_binop_right(arena, ret_ref);
  if (fold_expr_is_param0_field_access(arena, mod, func_idx, al) == 0) { return 0; }
  if (fold_expr_is_param0_field_access(arena, mod, func_idx, ar) == 0) { return 0; }
  return 1;
}

/**
 * 若 var 在同块 let 且初值为 STRUCT_LIT，将所有 i32 字面量字段求和写入 *out_sum。
 * 用于 `let p = Pair { a: 1, b: 2 }` → 3。
 */
function fold_block_let_struct_lit_i32_sum(arena: *ASTArena, block_ref: i32, var_ref: i32, out_sum: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, var_ref) != 3) { return 0; }
  let vlen: i32 = pipeline_expr_var_name_len(arena, var_ref);
  if (vlen <= 0 || vlen > 63) { return 0; }
  let vbuf: [64]u8 = [];
  pipeline_expr_var_name_into(arena, var_ref, &vbuf[0]);
  let nlet: i32 = ast_block_num_lets(arena, block_ref);
  let li: i32 = 0;
  while (li < nlet) {
    let llen: i32 = pipeline_block_let_name_len(arena, block_ref, li);
    if (llen == vlen) {
      let is_match: i32 = 1;
      let lb: [64]u8 = [];
      pipeline_block_let_name_copy64(arena, block_ref, li, &lb[0]);
      let kk: i32 = 0;
      while (kk < vlen) {
        if (lb[kk] != vbuf[kk]) { is_match = 0; }
        kk = kk + 1;
      }
      if (is_match != 0) {
        let init_ref: i32 = pipeline_block_let_init_ref(arena, block_ref, li);
        if (init_ref <= 0 || pipeline_expr_kind_ord_at(arena, init_ref) != 45) { return 0; }
        let nf: i32 = pipeline_expr_struct_lit_num_fields(arena, init_ref);
        if (nf <= 0) { return 0; }
        let sum_v: i32 = 0;
        let fj: i32 = 0;
        while (fj < nf) {
          let fv: i32 = pipeline_expr_struct_lit_init_ref(arena, init_ref, fj);
          if (fv <= 0 || pipeline_expr_kind_ord_at(arena, fv) != 0) { return 0; }
          sum_v = sum_v + pipeline_expr_int_val_at(arena, fv);
          fj = fj + 1;
        }
        if (out_sum != 0 as *i32) { out_sum[0] = sum_v; }
        return 1;
      }
    }
    li = li + 1;
  }
  return 0;
}

/**
 * 是否为 `s = s + add_pair(p)`，且 add_pair 为 param0 字段求和、p 为 const struct lit。
 * 成功写 out_s_ref、out_step（每轮常数增量）。
 */
function fold_is_assign_s_plus_const_field_call(
  arena: *ASTArena, mod: *Module, block_ref: i32, expr_ref: i32, out_s_ref: *i32, out_step: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, expr_ref) != 28) { return 0; }
  let left_ref: i32 = asm_expr_binop_left(arena, expr_ref);
  let right_ref: i32 = asm_expr_binop_right(arena, expr_ref);
  if (pipeline_expr_kind_ord_at(arena, left_ref) != 3) { return 0; }
  let inner: i32 = right_ref;
  if (fold_expr_is_add_kind(arena, right_ref) != 0) {
    let add_l: i32 = asm_expr_binop_left(arena, right_ref);
    if (fold_expr_var_refs_same(arena, add_l, left_ref) == 0) { return 0; }
    inner = asm_expr_binop_right(arena, right_ref);
  }
  if (pipeline_expr_kind_ord_at(arena, inner) != 48) { return 0; }
  if (pipeline_expr_call_num_args_at(arena, inner) != 1) { return 0; }
  let arg0: i32 = pipeline_expr_call_arg_ref(arena, inner, 0);
  if (pipeline_expr_kind_ord_at(arena, arg0) != 3) { return 0; }
  let callee_ref: i32 = pipeline_expr_call_callee_ref_at(arena, inner);
  if (callee_ref <= 0 || pipeline_expr_kind_ord_at(arena, callee_ref) != 3) { return 0; }
  let cname: [64]u8 = [];
  pipeline_expr_var_name_into(arena, callee_ref, &cname[0]);
  let fi: i32 = asm_module_func_index_by_name(mod, &cname[0], pipeline_expr_var_name_len(arena, callee_ref));
  if (fi < 0) { return 0; }
  if (fold_func_returns_param0_field_sum(arena, mod, fi) == 0) { return 0; }
  let step_v: i32 = 0;
  if (fold_block_let_struct_lit_i32_sum(arena, block_ref, arg0, &step_v) == 0) { return 0; }
  if (out_s_ref != 0 as *i32) { out_s_ref[0] = left_ref; }
  if (out_step != 0 as *i32) { out_step[0] = step_v; }
  return 1;
}

/** 解析 `s += add_pair(const p); i++`（struct_param 等）。 */
function fold_parse_count_up_const_field_call_body(
  arena: *ASTArena, mod: *Module, block_ref: i32, body_ref: i32, i_ref: i32,
  out_s_ref: *i32, out_step: *i32): i32 {
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  if (nso != 2) { return 0; }
  let found_s: i32 = 0;
  let found_i: i32 = 0;
  let s_ref: i32 = 0;
  let step_v: i32 = 0;
  let j: i32 = 0;
  while (j < nso) {
    if (ast_block_stmt_order_kind(arena, body_ref, j) != 2) { return 0; }
    let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, j);
    if (idx < 0 || idx >= ast_block_num_expr_stmts(arena, body_ref)) { return 0; }
    let er: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
    if (er <= 0) { return 0; }
    let addend: i32 = 0;
    if (fold_is_assign_var_add_lit(arena, er, i_ref, &addend) != 0 && addend == 1) {
      found_i = 1;
    } else {
      let st: i32 = 0;
      let sr: i32 = 0;
      if (fold_is_assign_s_plus_const_field_call(arena, mod, block_ref, er, &sr, &st) != 0) {
        if (found_s != 0) { return 0; }
        found_s = 1;
        s_ref = sr;
        step_v = st;
      } else {
        return 0;
      }
    }
    j = j + 1;
  }
  if (found_s == 0 || found_i == 0) { return 0; }
  if (out_s_ref != 0 as *i32) { out_s_ref[0] = s_ref; }
  if (out_step != 0 as *i32) { out_step[0] = step_v; }
  return 1;
}

/** 解析计数循环体：仅 `s = s + step` 与 `i = i + 1` 两条赋值（顺序任意）。 */
function fold_parse_count_up_body(
  arena: *ASTArena, body_ref: i32, i_ref: i32, out_s_ref: *i32, out_step: *i32): i32 {
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  if (nso != 2) { return 0; }
  let found_s: i32 = 0;
  let found_i: i32 = 0;
  let s_ref: i32 = 0;
  let step_v: i32 = 0;
  let j: i32 = 0;
  while (j < nso) {
    if (ast_block_stmt_order_kind(arena, body_ref, j) != 2) { return 0; }
    let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, j);
    if (idx < 0 || idx >= ast_block_num_expr_stmts(arena, body_ref)) { return 0; }
    let er: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
    if (er <= 0) { return 0; }
    let addend: i32 = 0;
    if (fold_is_assign_var_add_lit(arena, er, i_ref, &addend) != 0 && addend == 1) {
      found_i = 1;
    } else {
      let addend_s: i32 = 0;
      let left_ref: i32 = asm_expr_binop_left(arena, er);
      if (fold_is_assign_var_add_lit(arena, er, left_ref, &addend_s) != 0) {
        if (found_s != 0) { return 0; }
        found_s = 1;
        s_ref = left_ref;
        step_v = addend_s;
      } else {
        return 0;
      }
    }
    j = j + 1;
  }
  if (found_s == 0 || found_i == 0) { return 0; }
  if (out_s_ref != 0 as *i32) { out_s_ref[0] = s_ref; }
  if (out_step != 0 as *i32) { out_step[0] = step_v; }
  return 1;
}

/**
 * 若 var_ref 在同块 let 绑定且初值为整数字面量，写入 *out_lit 并返回 1。
 * 用于 `let n: i32 = 1000000000; while (i < n)` 的常量传播。
 */
function fold_block_let_init_lit(arena: *ASTArena, block_ref: i32, var_ref: i32, out_lit: *i32): i32 {
  if (pipeline_expr_kind_ord_at(arena, var_ref) != 3) { return 0; }
  let vlen: i32 = pipeline_expr_var_name_len(arena, var_ref);
  if (vlen <= 0 || vlen > 63) { return 0; }
  let vbuf: [64]u8 = [];
  pipeline_expr_var_name_into(arena, var_ref, &vbuf[0]);
  let nlet: i32 = ast_block_num_lets(arena, block_ref);
  let li: i32 = 0;
  while (li < nlet) {
    let llen: i32 = pipeline_block_let_name_len(arena, block_ref, li);
    if (llen == vlen) {
      let is_match: i32 = 1;
      let lb: [64]u8 = [];
      pipeline_block_let_name_copy64(arena, block_ref, li, &lb[0]);
      let kk: i32 = 0;
      while (kk < vlen) {
        if (lb[kk] != vbuf[kk]) { is_match = 0; }
        kk = kk + 1;
      }
      if (is_match != 0) {
        let init_ref: i32 = pipeline_block_let_init_ref(arena, block_ref, li);
        if (init_ref > 0 && pipeline_expr_kind_ord_at(arena, init_ref) == 0) {
          if (out_lit != 0 as *i32) {
            out_lit[0] = pipeline_expr_int_val_at(arena, init_ref);
          }
          return 1;
        }
        return 0;
      }
    }
    li = li + 1;
  }
  return 0;
}

/** 发射 `i >= n` 分支到 exit（须紧接 cmp）；n 为字面量时用 imm cmp。 */
function fold_emit_i_ge_n_branch_exit_elf(
  elf_ctx: *platform.elf.ElfCodegenCtx, off_i: i32, off_n: i32, n_is_lit: i32, n_lit: i32,
  exit_buf: [64]u8, exit_len: i32, ta: i32): i32 {
  if (n_is_lit != 0) {
    if (enc_load_rbp_to_rax_arch(elf_ctx, off_i, ta) != 0) { return -1; }
    if (enc_cmp_w0_imm12_arch(elf_ctx, n_lit, ta) != 0) { return -1; }
  } else {
    if (enc_load_rbp_to_rax_arch(elf_ctx, off_i, ta) != 0) { return -1; }
    if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
    if (enc_load_rbp_to_rax_arch(elf_ctx, off_n, ta) != 0) { return -1; }
    if (enc_pop_rbx_arch(elf_ctx, ta) != 0) { return -1; }
    if (enc_cmp_rbx_rax_arch(elf_ctx, ta) != 0) { return -1; }
  }
  return enc_jge_arch(elf_ctx, exit_buf, exit_len, ta);
}

/**
 * ELF：尝试优化 `while (i < n) { s += step; i += 1; }`。
 * 1) n 为编译期常量且无 call → 直接把 n*step 写入 s；
 * 2) 否则若条件为 i<n → 用 cmp+jge 替代 cset 条件，再发射原循环体。
 * 返回 1=已处理，0=未匹配，-1=错误。
 */
function try_fold_count_up_while_elf(
  arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, loop_idx: i32,
  ctx: *AsmFuncCtx, ta: i32): i32 {
  let cond_ref: i32 = ast_block_while_cond_ref(arena, block_ref, loop_idx);
  let body_ref: i32 = ast_block_while_body_ref(arena, block_ref, loop_idx);
  if (cond_ref <= 0 || body_ref <= 0) { return 0; }
  let i_ref: i32 = 0;
  let n_is_lit: i32 = 0;
  let n_lit: i32 = 0;
  let n_var_ref: i32 = 0;
  if (fold_parse_while_lt_i_n(arena, cond_ref, &i_ref, &n_is_lit, &n_lit, &n_var_ref) == 0) {
    return 0;
  }
  let i_e: Expr = ast_arena_expr_get(arena, i_ref);
  let off_i: i32 = local_offset(ctx, i_e.var_name, i_e.var_name_len);
  if (off_i < 0) { return 0; }
  let off_n: i32 = -1;
  if (n_is_lit == 0) {
    let n_e: Expr = ast_arena_expr_get(arena, n_var_ref);
    off_n = local_offset(ctx, n_e.var_name, n_e.var_name_len);
    if (off_n < 0) { return 0; }
  }
  let s_ref: i32 = 0;
  let step_v: i32 = 0;
  let simple_body: i32 = fold_parse_count_up_body(arena, body_ref, i_ref, &s_ref, &step_v);
  let has_call: i32 = fold_body_has_call_or_nested_loop(arena, body_ref);
  let n_const: i32 = n_lit;
  let n_const_ok: i32 = n_is_lit;
  if (n_const_ok == 0 && n_var_ref > 0) {
    let n_from_let: i32 = 0;
    if (fold_block_let_init_lit(arena, block_ref, n_var_ref, &n_from_let) != 0) {
      n_const = n_from_let;
      n_const_ok = 1;
    }
  }
  /** 常量 n + `s += (i+K); i++`：∑(i+K)=n(n-1)/2+Kn（call_boundary 等）。 */
  let affine_s: i32 = 0;
  let affine_k: i32 = 0;
  if (n_const_ok != 0 && ctx.module_ref != 0 as *Module
      && fold_parse_affine_sum_body(arena, ctx.module_ref, body_ref, i_ref, &affine_s, &affine_k) != 0) {
    let s_ea: Expr = ast_arena_expr_get(arena, affine_s);
    let off_sa: i32 = local_offset(ctx, s_ea.var_name, s_ea.var_name_len);
    if (off_sa < 0) { return 0; }
    let nm1: i32 = n_const - 1;
    let sum_i: i32 = nm1 * n_const / 2;
    let sum_k: i32 = affine_k * n_const;
    let total: i32 = sum_i + sum_k;
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, total, ta) != 0) { return -1; }
    if (enc_store_rax_to_rbp_arch(elf_ctx, off_sa, ta) != 0) { return -1; }
    return 1;
  }
  /** 常量 n + `s += add_pair(const p); i++`：s = n * ∑fields（struct_param 等）。 */
  let struct_s: i32 = 0;
  let struct_step: i32 = 0;
  if (n_const_ok != 0 && ctx.module_ref != 0 as *Module
      && fold_parse_count_up_const_field_call_body(arena, ctx.module_ref, block_ref, body_ref, i_ref, &struct_s, &struct_step) != 0) {
    let s_es: Expr = ast_arena_expr_get(arena, struct_s);
    let off_ss: i32 = local_offset(ctx, s_es.var_name, s_es.var_name_len);
    if (off_ss < 0) { return 0; }
    let prod_s: i32 = n_const * struct_step;
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, prod_s, ta) != 0) { return -1; }
    if (enc_store_rax_to_rbp_arch(elf_ctx, off_ss, ta) != 0) { return -1; }
    return 1;
  }
  /** 常量 n + 纯递增体：折叠为 s = n * step（loop_i32 等）。 */
  if (simple_body != 0 && has_call == 0 && n_const_ok != 0) {
    let s_e: Expr = ast_arena_expr_get(arena, s_ref);
    let off_s: i32 = local_offset(ctx, s_e.var_name, s_e.var_name_len);
    if (off_s < 0) { return 0; }
    let prod: i32 = n_const * step_v;
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, prod, ta) != 0) { return -1; }
    if (enc_store_rax_to_rbp_arch(elf_ctx, off_s, ta) != 0) { return -1; }
    return 1;
  }
  /** 含 call 或非纯递增体：优化条件检查 + 原循环体（call_boundary / struct_param 等）。 */
  let loop_buf: [64]u8 = [];
  let exit_buf: [64]u8 = [];
  let loop_len: i32 = emit_next_label(ctx, loop_buf, 20);
  let exit_len: i32 = emit_next_label(ctx, exit_buf, 20);
  if (enc_label_arch(elf_ctx, loop_buf, loop_len, 0, ta) != 0) { return -1; }
  if (fold_emit_i_ge_n_branch_exit_elf(elf_ctx, off_i, off_n, n_is_lit, n_lit, exit_buf, exit_len, ta) != 0) {
    return -1;
  }
  if (ctx_push_loop_labels(ctx, exit_buf, exit_len, loop_buf, loop_len) != 0) { return -1; }
  if (emit_loop_body_content_elf(arena, elf_ctx, body_ref, ctx, ta) != 0) {
    ctx_pop_loop_labels(ctx);
    return -1;
  }
  if (enc_jmp_arch(elf_ctx, loop_buf, loop_len, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  if (enc_label_arch(elf_ctx, exit_buf, exit_len, 0, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  ctx_pop_loop_labels(ctx);
  return 1;
}

/** ELF 路径：while 循环。ta 0=x86_64，1=arm64。 */
function emit_while_loop_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, loop_idx: i32, ctx: *AsmFuncCtx, ta: i32): i32 {
  let fold_rc: i32 = try_fold_count_up_while_elf(arena, elf_ctx, block_ref, loop_idx, ctx, ta);
  if (fold_rc != 0) {
    if (fold_rc < 0) { return -1; }
    return 0;
  }
  let cond_ref: i32 = ast_block_while_cond_ref(arena, block_ref, loop_idx);
  let body_ref: i32 = ast_block_while_body_ref(arena, block_ref, loop_idx);
  let loop_buf: [64]u8 = [];
  let exit_buf: [64]u8 = [];
  let loop_len: i32 = emit_next_label(ctx, loop_buf, 20);
  let exit_len: i32 = emit_next_label(ctx, exit_buf, 20);
  if (enc_label_arch(elf_ctx, loop_buf, loop_len, 0, ta) != 0) { return -1; }
  if (emit_expr_elf(arena, elf_ctx, cond_ref, ctx, ta) != 0) { return -1; }
  if (enc_jz_arch(elf_ctx, exit_buf, exit_len, ta) != 0) { return -1; }
  if (ctx_push_loop_labels(ctx, exit_buf, exit_len, loop_buf, loop_len) != 0) { return -1; }
  if (emit_loop_body_content_elf(arena, elf_ctx, body_ref, ctx, ta) != 0) {
    ctx_pop_loop_labels(ctx);
    return -1;
  }
  if (enc_jmp_arch(elf_ctx, loop_buf, loop_len, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  if (enc_label_arch(elf_ctx, exit_buf, exit_len, 0, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  ctx_pop_loop_labels(ctx);
  return 0;
}

/** ELF 路径：for 循环。ta 0=x86_64，1=arm64。 */
function emit_for_loop_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, for_idx: i32, ctx: *AsmFuncCtx, ta: i32): i32 {
  let init_ref: i32 = ast_block_for_init_ref(arena, block_ref, for_idx);
  let cond_ref: i32 = ast_block_for_cond_ref(arena, block_ref, for_idx);
  let step_ref: i32 = ast_block_for_step_ref(arena, block_ref, for_idx);
  let body_ref: i32 = ast_block_for_body_ref(arena, block_ref, for_idx);
  if (init_ref != 0) {
    if (emit_expr_elf(arena, elf_ctx, init_ref, ctx, ta) != 0) { return -1; }
  }
  let loop_buf: [64]u8 = [];
  let exit_buf: [64]u8 = [];
  let loop_len: i32 = emit_next_label(ctx, loop_buf, 20);
  let exit_len: i32 = emit_next_label(ctx, exit_buf, 20);
  if (enc_label_arch(elf_ctx, loop_buf, loop_len, 0, ta) != 0) { return -1; }
  if (cond_ref != 0) {
    if (emit_expr_elf(arena, elf_ctx, cond_ref, ctx, ta) != 0) { return -1; }
    if (enc_jz_arch(elf_ctx, exit_buf, exit_len, ta) != 0) { return -1; }
  }
  if (ctx_push_loop_labels(ctx, exit_buf, exit_len, loop_buf, loop_len) != 0) { return -1; }
  if (emit_loop_body_content_elf(arena, elf_ctx, body_ref, ctx, ta) != 0) {
    ctx_pop_loop_labels(ctx);
    return -1;
  }
  if (step_ref != 0) {
    if (emit_expr_elf(arena, elf_ctx, step_ref, ctx, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  }
  if (enc_jmp_arch(elf_ctx, loop_buf, loop_len, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  if (enc_label_arch(elf_ctx, exit_buf, exit_len, 0, ta) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  ctx_pop_loop_labels(ctx);
  return 0;
}

/**
 * ELF 路径：按 stmt_order 发射块体（经 pipeline_glue.c 的 C for 循环 + expr 快路径）。
 * 自举 shu_asm 下 SU 的 while(i<nso) 经 shu-c -E 可能只跑一轮，导致 return 1+2 仅 emit 左操作数。
 */
function emit_block_body_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, ctx: *AsmFuncCtx, ta: i32): i32 {
  return backend_emit_block_body_sync_elf(arena, elf_ctx, block_ref, ctx, ta);
}

/**
 * 发射块的 const/let 初始化；slot_base 为该块在 ctx 局部 sidecar 中的起始下标。
 * 嵌套块在 EXPR_BLOCK 中先 fill_local_slots 再调用本函数，slot_base 为填入前的 ctx.num_locals。
 */
function emit_block_inits(arena: *ASTArena, out: *CodegenOutBuf, block_ref: i32, ctx: *AsmFuncCtx, target_arch: i32, slot_base: i32): i32 {
  let idx: i32 = 0;
  let i: i32 = 0;
  while (i < ast_block_num_consts(arena, block_ref) && (slot_base + idx) < ctx.num_locals) {
    let init_ref: i32 = pipeline_block_const_init_ref(arena, block_ref, i);
    if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
      if (emit_expr(arena, out, init_ref, ctx, target_arch) != 0) { return -1; }
      if (arch_emit_store_rax_to_rbp(out, asm_ctx_slot_offset(ctx, slot_base + idx), target_arch) != 0) { return -1; }
    }
    idx = idx + 1;
    i = i + 1;
  }
  i = 0;
  while (i < ast_block_num_lets(arena, block_ref) && (slot_base + idx) < ctx.num_locals) {
    let init_ref: i32 = pipeline_block_let_init_ref(arena, block_ref, i);
    if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
      if (emit_expr(arena, out, init_ref, ctx, target_arch) != 0) { return -1; }
      if (arch_emit_store_rax_to_rbp(out, asm_ctx_slot_offset(ctx, slot_base + idx), target_arch) != 0) { return -1; }
    }
    idx = idx + 1;
    i = i + 1;
  }
  return 0;
}

/** 生成唯一局部标签到 buf，返回长度。buf 格式为 ".L_" + 数字。 */
function emit_next_label(ctx: *AsmFuncCtx, buf: *u8, buf_size: i32): i32 {
  buf[0] = 46;
  buf[1] = 76;
  buf[2] = 95;
  let n: i32 = format_i32_to_buf(buf, 3, buf_size - 3, ctx.label_counter);
  ctx.label_counter = ctx.label_counter + 1;
  if (n <= 0) {
    n = 1;
  }
  return 3 + n;
}

/** 将 label 序号 id 格式化为 ".L_<id>" 写入 buf，返回长度（不推进 ctx.label_counter）。用于 match 多分支标签。 */
function format_label_id(buf: *u8, buf_size: i32, id: i32): i32 {
  buf[0] = 46;
  buf[1] = 76;
  buf[2] = 95;
  let n: i32 = format_i32_to_buf(buf, 3, buf_size - 3, id);
  if (n <= 0) { n = 1; }
  return 3 + n;
}

/** 将 break/continue 标签压入 8 层栈并设为当前生效标签；d>=8 时返回 -1。 */
function ctx_push_loop_labels(ctx: *AsmFuncCtx, exit_buf: *u8, exit_len: i32, loop_buf: *u8, loop_len: i32): i32 {
  let d: i32 = ctx.loop_label_depth;
  if (d >= 8) {
    return -1;
  }
  let base_off: i32 = d * 64;
  let k: i32 = 0;
  while (k < exit_len && k < 64) {
    ctx.loop_break_label_stack[base_off + k] = exit_buf[k];
    k = k + 1;
  }
  ctx.loop_break_len_stack[d] = exit_len;
  k = 0;
  while (k < loop_len && k < 64) {
    ctx.loop_continue_label_stack[base_off + k] = loop_buf[k];
    k = k + 1;
  }
  ctx.loop_continue_len_stack[d] = loop_len;
  ctx.loop_label_depth = d + 1;
  k = 0;
  while (k < exit_len && k < 64) {
    ctx.break_label[k] = exit_buf[k];
    k = k + 1;
  }
  ctx.break_len = exit_len;
  k = 0;
  while (k < loop_len && k < 64) {
    ctx.continue_label[k] = loop_buf[k];
    k = k + 1;
  }
  ctx.continue_len = loop_len;
  return 0;
}

/** 弹出循环标签栈顶，恢复外层 break/continue 或清零。 */
function ctx_pop_loop_labels(ctx: *AsmFuncCtx): void {
  if (ctx.loop_label_depth <= 0) {
    ctx.break_len = 0;
    ctx.continue_len = 0;
    return;
  }
  ctx.loop_label_depth = ctx.loop_label_depth - 1;
  let d: i32 = ctx.loop_label_depth;
  if (d <= 0) {
    ctx.break_len = 0;
    ctx.continue_len = 0;
    return;
  }
  let prev: i32 = d - 1;
  let base_off: i32 = prev * 64;
  let bl: i32 = ctx.loop_break_len_stack[prev];
  let cl: i32 = ctx.loop_continue_len_stack[prev];
  let k: i32 = 0;
  while (k < bl && k < 64) {
    ctx.break_label[k] = ctx.loop_break_label_stack[base_off + k];
    k = k + 1;
  }
  ctx.break_len = bl;
  k = 0;
  while (k < cl && k < 64) {
    ctx.continue_label[k] = ctx.loop_continue_label_stack[base_off + k];
    k = k + 1;
  }
  ctx.continue_len = cl;
}

/** ELF：循环体内 stmt_order（kind 2/3/4/5）与 final_expr。 */
function emit_loop_body_content_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, body_ref: i32, ctx: *AsmFuncCtx, ta: i32): i32 {
  let i: i32 = 0;
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  while (i < nso) {
    let item_kind: u8 = ast_block_stmt_order_kind(arena, body_ref, i);
    let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, i);
    if (item_kind == 2) {
      if (idx >= 0 && idx < ast_block_num_expr_stmts(arena, body_ref)) {
        let expr_ref: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
        if (expr_ref != 0) {
          if (emit_expr_elf(arena, elf_ctx, expr_ref, ctx, ta) != 0) { return -1; }
        }
      }
    } else if (item_kind == 3) {
      if (idx >= 0 && idx < ast_block_num_loops(arena, body_ref)) {
        if (emit_while_loop_elf(arena, elf_ctx, body_ref, idx, ctx, ta) != 0) { return -1; }
      }
    } else if (item_kind == 4) {
      if (idx >= 0 && idx < ast_block_num_for_loops(arena, body_ref)) {
        if (emit_for_loop_elf(arena, elf_ctx, body_ref, idx, ctx, ta) != 0) { return -1; }
      }
    } else if (item_kind == 5) {
      if (idx >= 0 && idx < ast_block_num_if_stmts(arena, body_ref)) {
        let cond_if: i32 = ast_block_if_cond_ref(arena, body_ref, idx);
        let then_ref: i32 = ast_block_if_then_body_ref(arena, body_ref, idx);
        let end_lb: [64]u8 = [];
        let end_ln: i32 = emit_next_label(ctx, end_lb, 20);
        if (emit_expr_elf(arena, elf_ctx, cond_if, ctx, ta) != 0) { return -1; }
        if (enc_jz_arch(elf_ctx, end_lb, end_ln, ta) != 0) { return -1; }
        if (emit_if_then_block_body_elf(arena, elf_ctx, then_ref, ctx, ta) != 0) { return -1; }
        if (enc_label_arch(elf_ctx, end_lb, end_ln, 0, ta) != 0) { return -1; }
      }
    }
    i = i + 1;
  }
  let body_blk: Block = ast_arena_block_get(arena, body_ref);
  if (body_blk.final_expr_ref != 0) {
    if (emit_expr_elf(arena, elf_ctx, body_blk.final_expr_ref, ctx, ta) != 0) { return -1; }
  }
  return 0;
}

/** 仅发射块内与循环体相关的部分：stmt_order 中 kind 2(expr)/3(while)/4(for)/5(if) 及 final_expr。 */
function emit_loop_body_content(arena: *ASTArena, out: *CodegenOutBuf, body_ref: i32, ctx: *AsmFuncCtx, target_arch: i32): i32 {
  let i: i32 = 0;
  let nso: i32 = ast_block_num_stmt_order(arena, body_ref);
  while (i < nso) {
    let item_kind: u8 = ast_block_stmt_order_kind(arena, body_ref, i);
    let idx: i32 = ast_block_stmt_order_idx(arena, body_ref, i);
    if (item_kind == 2) {
      if (idx >= 0 && idx < ast_block_num_expr_stmts(arena, body_ref)) {
        let expr_ref: i32 = ast_block_expr_stmt_ref(arena, body_ref, idx);
        if (expr_ref != 0) {
          if (emit_expr(arena, out, expr_ref, ctx, target_arch) != 0) { return -1; }
        }
      }
    } else if (item_kind == 3) {
      if (idx >= 0 && idx < ast_block_num_loops(arena, body_ref)) {
        if (emit_while_loop(arena, out, body_ref, idx, ctx, target_arch) != 0) { return -1; }
      }
    } else if (item_kind == 4) {
      if (idx >= 0 && idx < ast_block_num_for_loops(arena, body_ref)) {
        if (emit_for_loop(arena, out, body_ref, idx, ctx, target_arch) != 0) { return -1; }
      }
    } else if (item_kind == 5) {
      if (idx >= 0 && idx < ast_block_num_if_stmts(arena, body_ref)) {
        let cond_if: i32 = ast_block_if_cond_ref(arena, body_ref, idx);
        let then_ref: i32 = ast_block_if_then_body_ref(arena, body_ref, idx);
        let end_lb: [64]u8 = [];
        let end_ln: i32 = emit_next_label(ctx, end_lb, 20);
        if (emit_expr(arena, out, cond_if, ctx, target_arch) != 0) { return -1; }
        if (arch_emit_jz(out, end_lb, end_ln, target_arch) != 0) { return -1; }
        if (emit_if_then_block_body_text(arena, out, then_ref, ctx, target_arch) != 0) { return -1; }
        if (arch_emit_label(out, end_lb, end_ln, target_arch) != 0) { return -1; }
      }
    }
    i = i + 1;
  }
  let body_blk: Block = ast_arena_block_get(arena, body_ref);
  if (body_blk.final_expr_ref != 0) {
    if (emit_expr(arena, out, body_blk.final_expr_ref, ctx, target_arch) != 0) { return -1; }
  }
  return 0;
}

/** 发射 while 循环；设置 break/continue 标签并发射循环体。 */
function emit_while_loop(arena: *ASTArena, out: *CodegenOutBuf, block_ref: i32, loop_idx: i32, ctx: *AsmFuncCtx, target_arch: i32): i32 {
  let cond_ref: i32 = ast_block_while_cond_ref(arena, block_ref, loop_idx);
  let body_ref: i32 = ast_block_while_body_ref(arena, block_ref, loop_idx);
  let loop_buf: [64]u8 = [];
  let exit_buf: [64]u8 = [];
  let loop_len: i32 = emit_next_label(ctx, loop_buf, 20);
  let exit_len: i32 = emit_next_label(ctx, exit_buf, 20);
  if (arch_emit_label(out, loop_buf, loop_len, target_arch) != 0) { return -1; }
  if (emit_expr(arena, out, cond_ref, ctx, target_arch) != 0) { return -1; }
  if (arch_emit_jz(out, exit_buf, exit_len, target_arch) != 0) { return -1; }
  if (ctx_push_loop_labels(ctx, exit_buf, exit_len, loop_buf, loop_len) != 0) { return -1; }
  if (emit_loop_body_content(arena, out, body_ref, ctx, target_arch) != 0) {
    ctx_pop_loop_labels(ctx);
    return -1;
  }
  if (arch_emit_jmp(out, loop_buf, loop_len, target_arch) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  if (arch_emit_label(out, exit_buf, exit_len, target_arch) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  ctx_pop_loop_labels(ctx);
  return 0;
}

/** 发射 for 循环；设置 break/continue 并发射循环体。 */
function emit_for_loop(arena: *ASTArena, out: *CodegenOutBuf, block_ref: i32, for_idx: i32, ctx: *AsmFuncCtx, target_arch: i32): i32 {
  let init_ref: i32 = ast_block_for_init_ref(arena, block_ref, for_idx);
  let cond_ref: i32 = ast_block_for_cond_ref(arena, block_ref, for_idx);
  let step_ref: i32 = ast_block_for_step_ref(arena, block_ref, for_idx);
  let body_ref: i32 = ast_block_for_body_ref(arena, block_ref, for_idx);
  if (init_ref != 0) {
    if (emit_expr(arena, out, init_ref, ctx, target_arch) != 0) { return -1; }
  }
  let loop_buf: [64]u8 = [];
  let exit_buf: [64]u8 = [];
  let loop_len: i32 = emit_next_label(ctx, loop_buf, 20);
  let exit_len: i32 = emit_next_label(ctx, exit_buf, 20);
  if (arch_emit_label(out, loop_buf, loop_len, target_arch) != 0) { return -1; }
  if (cond_ref != 0) {
    if (emit_expr(arena, out, cond_ref, ctx, target_arch) != 0) { return -1; }
    if (arch_emit_jz(out, exit_buf, exit_len, target_arch) != 0) { return -1; }
  }
  if (ctx_push_loop_labels(ctx, exit_buf, exit_len, loop_buf, loop_len) != 0) { return -1; }
  if (emit_loop_body_content(arena, out, body_ref, ctx, target_arch) != 0) {
    ctx_pop_loop_labels(ctx);
    return -1;
  }
  if (step_ref != 0) {
    if (emit_expr(arena, out, step_ref, ctx, target_arch) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  }
  if (arch_emit_jmp(out, loop_buf, loop_len, target_arch) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  if (arch_emit_label(out, exit_buf, exit_len, target_arch) != 0) { ctx_pop_loop_labels(ctx); return -1; }
  ctx_pop_loop_labels(ctx);
  return 0;
}

/** 按 stmt_order 发射块体；target_arch 用于分派 emit_expr / store / while / for。 */
function emit_block_body(arena: *ASTArena, out: *CodegenOutBuf, block_ref: i32, ctx: *AsmFuncCtx, target_arch: i32): i32 {
  let nconst: i32 = ast_block_num_consts(arena, block_ref);
  let nlet: i32 = ast_block_num_lets(arena, block_ref);
  let slot_base: i32 = ctx.num_locals - nconst - nlet;
  if (slot_base < 0) { slot_base = 0; }
  let i: i32 = 0;
  let nso: i32 = ast_block_num_stmt_order(arena, block_ref);
  while (i < nso) {
    let item_kind: u8 = ast_block_stmt_order_kind(arena, block_ref, i);
    let idx: i32 = ast_block_stmt_order_idx(arena, block_ref, i);
    if (item_kind == 0) {
      if (idx >= 0 && idx < nconst && (slot_base + idx) < ctx.num_locals) {
        let init_ref: i32 = pipeline_block_const_init_ref(arena, block_ref, idx);
        if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
          if (emit_expr(arena, out, init_ref, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(50); return -1; }
          if (arch_emit_store_rax_to_rbp(out, asm_ctx_slot_offset(ctx, slot_base + idx), target_arch) != 0) { driver_diagnostic_asm_fail_at(50); return -1; }
        }
      }
    } else if (item_kind == 1) {
      if (idx >= 0 && idx < nlet) {
        let slot: i32 = slot_base + nconst + idx;
        if (slot < ctx.num_locals) {
          let init_ref: i32 = pipeline_block_let_init_ref(arena, block_ref, idx);
          if (init_ref != 0 && asm_init_is_empty_array_lit(arena, init_ref) == 0) {
            if (emit_expr(arena, out, init_ref, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(51); return -1; }
            if (arch_emit_store_rax_to_rbp(out, asm_ctx_slot_offset(ctx, slot), target_arch) != 0) { driver_diagnostic_asm_fail_at(51); return -1; }
          }
        }
      }
    } else if (item_kind == 2) {
      if (idx >= 0 && idx < ast_block_num_expr_stmts(arena, block_ref)) {
        let expr_ref: i32 = ast_block_expr_stmt_ref(arena, block_ref, idx);
        if (expr_ref != 0) {
          if (emit_expr(arena, out, expr_ref, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(52); return -1; }
        }
      }
    } else if (item_kind == 3) {
      if (idx >= 0 && idx < ast_block_num_loops(arena, block_ref)) {
        if (emit_while_loop(arena, out, block_ref, idx, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(53); return -1; }
      }
    } else if (item_kind == 4) {
      if (idx >= 0 && idx < ast_block_num_for_loops(arena, block_ref)) {
        if (emit_for_loop(arena, out, block_ref, idx, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(54); return -1; }
      }
    } else if (item_kind == 5) {
      if (idx >= 0 && idx < ast_block_num_if_stmts(arena, block_ref)) {
        let cond_if: i32 = ast_block_if_cond_ref(arena, block_ref, idx);
        let then_ref: i32 = ast_block_if_then_body_ref(arena, block_ref, idx);
        let end_lbb: [64]u8 = [];
        let end_lbn: i32 = emit_next_label(ctx, end_lbb, 20);
        if (emit_expr(arena, out, cond_if, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(55); return -1; }
        if (arch_emit_jz(out, end_lbb, end_lbn, target_arch) != 0) { driver_diagnostic_asm_fail_at(55); return -1; }
        if (emit_if_then_block_body_text(arena, out, then_ref, ctx, target_arch) != 0) { driver_diagnostic_asm_fail_at(55); return -1; }
        if (arch_emit_label(out, end_lbb, end_lbn, target_arch) != 0) { driver_diagnostic_asm_fail_at(55); return -1; }
      }
    }
    i = i + 1;
  }
  return 0;
}

/** 汇编后端入口：将 Module 生成汇编文本写入 out。 */
function asm_codegen_ast(module: *Module, arena: *ASTArena, out: *CodegenOutBuf, pipeline_ctx: *PipelineDepCtx): i32 {
  asm_hoist_top_level_lets_for_codegen(module, arena);
  let ta: i32 = pipeline_ctx.target_arch;
  let br_stk: [512]u8 = [];
  let co_stk: [512]u8 = [];
  let br_lens: [8]i32 = [];
  let co_lens: [8]i32 = [];
  let lbl: [64]u8 = [];
  let ctx: AsmFuncCtx = AsmFuncCtx {
    frame_size: 0, next_offset: 0, num_locals: 0, label_counter: 0,
    module_ref: 0 as *Module,
    loop_break_label_stack: br_stk, loop_break_len_stack: br_lens,
    loop_continue_label_stack: co_stk, loop_continue_len_stack: co_lens,
    break_label: lbl, break_len: 0, continue_label: lbl, continue_len: 0,
    loop_label_depth: 0, dep_pipe: 0 as *PipelineDepCtx,
    tail_join_label: lbl, tail_join_label_len: 0
  };
  let fname_buf: [64]u8 = [];
  let i: i32 = 0;
  while (i < module.num_funcs) {
    if (i == 0) {
      if (arch_emit_section_text(out, ta) != 0) {
        driver_diagnostic_asm_fail_at(1);
        return -1;
      }
    }
    if (pipeline_asm_module_func_is_extern_at(module, i) != 0) {
      i = i + 1;
      continue;
    }
    pipeline_asm_module_func_name_copy64(module, i, &fname_buf[0]);
    let fname_len: i32 = pipeline_asm_module_func_name_len_at(module, i);
    driver_diagnostic_asm_set_current_func(&fname_buf[0], fname_len);
    ctx_reset(&ctx, module);
    ctx.dep_pipe = pipeline_ctx;
    fill_param_slots(&ctx, module, i);
    if (arch_emit_globl(out, fname_buf, fname_len, ta) != 0) {
      driver_diagnostic_asm_fail_at(2);
      return -1;
    }
    if (arch_emit_label(out, fname_buf, fname_len, ta) != 0) {
      driver_diagnostic_asm_fail_at(3);
      return -1;
    }
    let body_ref: i32 = pipeline_asm_module_func_body_ref_at(module, i);
    let frame_sz: i32 = 0;
    if (body_ref != 0) {
      frame_sz = compute_frame_size(pipeline_asm_module_func_num_params_at(module, i), arena, body_ref);
      fill_local_slots(&ctx, arena, body_ref);
    }
    if (arch_emit_prologue(out, frame_sz, ta) != 0) {
      driver_diagnostic_asm_fail_at(4);
      return -1;
    }
    if (body_ref != 0) {
      ctx.tail_join_label_len = emit_next_label(&ctx, &ctx.tail_join_label[0], 64);
      if (pipeline_asm_block_num_stmt_order_at(arena, body_ref) > 0) {
        if (emit_block_body(arena, out, body_ref, &ctx, ta) != 0) {
          driver_diagnostic_asm_fail_at(5);
          return -1;
        }
        let fin_tail_ref_t: i32 = pipeline_asm_block_final_expr_ref_at(arena, body_ref);
        if (fin_tail_ref_t != 0 && pipeline_asm_block_stmt_order_has_return(arena, body_ref) == 0) {
          if (emit_expr(arena, out, fin_tail_ref_t, &ctx, ta) != 0) {
            driver_diagnostic_asm_fail_at(7);
            return -1;
          }
        }
      } else {
        let slot_base: i32 = ctx.num_locals - ast_block_num_consts(arena, body_ref) - ast_block_num_lets(arena, body_ref);
        if (slot_base < 0) { driver_diagnostic_asm_fail_at(6); return -1; }
        if (emit_block_inits(arena, out, body_ref, &ctx, ta, slot_base) != 0) {
          driver_diagnostic_asm_fail_at(6);
          return -1;
        }
      }
      if (arch_emit_label(out, ctx.tail_join_label, ctx.tail_join_label_len, ta) != 0) {
        driver_diagnostic_asm_fail_at(9);
        return -1;
      }
    }
    let result_ref: i32 = 0;
    if (body_ref == 0 || pipeline_asm_block_num_stmt_order_at(arena, body_ref) == 0) {
      result_ref = pipeline_asm_get_return_expr_ref_at(arena, module, i);
    }
    if (result_ref != 0) {
      if (emit_expr(arena, out, result_ref, &ctx, ta) != 0) {
        driver_diagnostic_asm_fail_at(7);
        return -1;
      }
    }
    if (arch_emit_epilogue(out, frame_sz, ta) != 0) {
      driver_diagnostic_asm_fail_at(8);
      return -1;
    }
    i = i + 1;
  }
  return 0;
}

/**
 * build_shu_asm SKIP_TYPECK 桩：仅 mov w0/x0/eax,#0 + epilogue，勿 fill/emit_block（大模块宿主栈 SIGSEGV）。
 */
function emit_skip_heavy_stub_elf(elf_ctx: *platform.elf.ElfCodegenCtx, ta: i32): i32 {
  if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, 0, ta) != 0) {
    return -1;
  }
  return enc_epilogue_arch(elf_ctx, ta);
}

/** 将 Module 生成机器码写入 elf_ctx。 */
function asm_codegen_ast_to_elf(module: *Module, arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, pipeline_ctx: *PipelineDepCtx): i32 {
  asm_hoist_top_level_lets_for_codegen(module, arena);
  let ta: i32 = pipeline_ctx.target_arch;
  if (ta == 1) {
    elf_ctx.e_machine = 183;
    elf_ctx.reloc_type_r_pc32 = 283;
  } else if (ta == 2) {
    elf_ctx.e_machine = 243;
    elf_ctx.reloc_type_r_pc32 = 32;
  } else {
    elf_ctx.e_machine = 62;
    elf_ctx.reloc_type_r_pc32 = 2;
  }
  let br_stk2: [512]u8 = [];
  let co_stk2: [512]u8 = [];
  let br_lens2: [8]i32 = [];
  let co_lens2: [8]i32 = [];
  let lbl2: [64]u8 = [];
  let ctx: AsmFuncCtx = AsmFuncCtx {
    frame_size: 0, next_offset: 0, num_locals: 0, label_counter: 0,
    module_ref: 0 as *Module,
    loop_break_label_stack: br_stk2, loop_break_len_stack: br_lens2,
    loop_continue_label_stack: co_stk2, loop_continue_len_stack: co_lens2,
    break_label: lbl2, break_len: 0, continue_label: lbl2, continue_len: 0,
    loop_label_depth: 0, dep_pipe: 0 as *PipelineDepCtx,
    tail_join_label: lbl2, tail_join_label_len: 0
  };
  let fname_buf2: [64]u8 = [];
  let start_skip: i32 = asm_diag_start_func_skip();
  let i: i32 = 0;
  while (i < module.num_funcs) {
    if (i < start_skip) {
      i = i + 1;
      continue;
    }
    if (pipeline_asm_module_func_is_extern_at(module, i) != 0) {
      i = i + 1;
      continue;
    }
    pipeline_asm_module_func_name_copy64(module, i, &fname_buf2[0]);
    let fname_len2: i32 = pipeline_asm_module_func_name_len_at(module, i);
    driver_diagnostic_asm_set_current_func(&fname_buf2[0], fname_len2);
    ctx_reset(&ctx, module);
    ctx.dep_pipe = pipeline_ctx;
    fill_param_slots(&ctx, module, i);
    if (enc_label_arch(elf_ctx, fname_buf2, fname_len2, 1, ta) != 0) { return -1; }
    /** build_shu_asm：大模块非白名单函数走 ret0 桩，避免 typeck/parser 全量 emit 139。 */
    if (asm_skip_heavy_module_func_body(module, arena, i) != 0) {
      if (enc_prologue_arch(elf_ctx, 0, ta) != 0) { return -1; }
      if (emit_skip_heavy_stub_elf(elf_ctx, ta) != 0) { return -1; }
      i = i + 1;
      continue;
    }
    let body_ref: i32 = pipeline_asm_module_func_body_ref_at(module, i);
    let frame_sz: i32 = 0;
    if (body_ref != 0) {
      frame_sz = compute_frame_size(pipeline_asm_module_func_num_params_at(module, i), arena, body_ref);
      /*
       * stmt_order>0 时 pipeline_asm_emit_block_body_sync_elf 会 backend_ensure_block_local_slots；
       * 勿在此重复 fill，否则 init 用新槽偏移、EXPR_VAR 仍命中旧偏移（while 中 i 与 sum 错位）。
       */
      if (pipeline_asm_block_num_stmt_order_at(arena, body_ref) == 0) {
        fill_local_slots(&ctx, arena, body_ref);
      }
    }
    if (enc_prologue_arch(elf_ctx, frame_sz, ta) != 0) { return -1; }
    if (body_ref != 0) {
      ctx.tail_join_label_len = emit_next_label(&ctx, &ctx.tail_join_label[0], 64);
      if (pipeline_asm_block_num_stmt_order_at(arena, body_ref) > 0) {
        if (emit_block_body_elf(arena, elf_ctx, body_ref, &ctx, ta) != 0) { return -1; }
        /*
         * stmt_order 路径不读 pipeline_asm_get_return_expr_ref_at；显式 return 常在 final_expr_ref
         *（while 后 return 42、let x=if..; return x）。勿重复 emit 已在 expr_stmt 中的 EXPR_RETURN。
         */
        let fin_tail_ref: i32 = pipeline_asm_block_final_expr_ref_at(arena, body_ref);
        if (fin_tail_ref != 0 && pipeline_asm_block_stmt_order_has_return(arena, body_ref) == 0) {
          if (emit_expr_elf(arena, elf_ctx, fin_tail_ref, &ctx, ta) != 0) { return -1; }
        }
      } else {
        let slot_base: i32 = ctx.num_locals - ast_block_num_consts(arena, body_ref) - ast_block_num_lets(arena, body_ref);
        if (slot_base < 0) { return -1; }
        if (emit_block_inits_elf(arena, elf_ctx, body_ref, &ctx, ta, slot_base) != 0) { return -1; }
      }
      if (enc_label_arch(elf_ctx, ctx.tail_join_label, ctx.tail_join_label_len, 0, ta) != 0) { return -1; }
    }
    let result_ref: i32 = 0;
    if (body_ref == 0 || pipeline_asm_block_num_stmt_order_at(arena, body_ref) == 0) {
      result_ref = pipeline_asm_get_return_expr_ref_at(arena, module, i);
    }
    if (result_ref != 0) {
      if (emit_expr_elf(arena, elf_ctx, result_ref, &ctx, ta) != 0) { return -1; }
    }
    if (enc_epilogue_arch(elf_ctx, ta) != 0) { return -1; }
    i = i + 1;
  }
  return 0;
}
