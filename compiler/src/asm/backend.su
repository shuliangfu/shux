// backend.su — 汇编后端：AST 遍历、lowering 分派、架构分派
//
// 职责：CodegenOutBuf 与 AsmFuncCtx 的使用、按 AST 结点类型分派到架构相关 emit（x86_64/arm64）；对外入口 asm_codegen_ast。
// 依赖：ast（Module/ASTArena/Func、PipelineDepCtx）、codegen（CodegenOutBuf）、types、x86_64、arm64、elf、arch.x86_64_enc（.o 路径）。
// 后续优化（7.3）：简单寄存器分配，减少固定 rax/rbx 带来的 push/pop；窥孔可合并相邻 mov/算术。

import ast;
import codegen;
import asm.types;
import arch.x86_64;
import arch.arm64;
import arch.riscv64;
import platform.elf;
import arch.x86_64_enc;
import arch.arm64_enc;
import arch.riscv64_enc;

/** 诊断：asm 不支持的 ExprKind 时由 runtime.c 打印，便于定位 rc=-6。 */
extern function driver_diagnostic_asm_unsupported_expr(kind: i32): void;
/** 诊断：return -1 前调用，loc 1=section_text 2=globl 3=label 4=prologue 5=block_body 6=block_inits 7=emit_expr 8=epilogue 9=tail_join_label。 */
extern function driver_diagnostic_asm_fail_at(loc: i32): void;
/** 诊断：记录当前正在 emit 的 ExprKind 序数，供 fail_at 时打印。 */
extern function driver_diagnostic_asm_set_last_expr_kind(k: i32): void;
/** 诊断：EXPR_VAR 未找到时调用；first_slot/first_len 为 ctx 首槽名（num_locals>0 时传 ctx.locals[0]）。 */
extern function driver_diagnostic_asm_var_not_found(name: *u8, name_len: i32, num_locals: i32, first_slot: *u8, first_len: i32): void;
/** 诊断：每函数 codegen 前设置当前函数名，供 var_not_found 打印。 */
extern function driver_diagnostic_asm_set_current_func(name: *u8, name_len: i32): void;
/** 与 codegen：import 路径转 C ABI 符号前缀（实现在 codegen.su：codegen_import_path_to_c_prefix_into）。 */
/** parser_gen / C ABI：将 cur_mod 第 i 条 import 的逻辑路径写入 out_buf（至多 64 字节，含 NUL）。 */
extern function parser_get_module_import_path(mod: *Module, i: i32, out_buf: [64]u8): void;
/** 驱动：部分 std/c shim 调用在 AST 中与真实 C 原型实参个数不一致，由 C 侧校正。 */
extern function driver_call_num_args_override(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, num_args: i32): i32;

/** 将 ExprKind 转为序数 (0..60)，供诊断打印；typeck 暂不支持 enum as i32，故用分支显式映射。 */
function expr_kind_ordinal(k: ExprKind): i32 {
  if (k == ExprKind.EXPR_LIT) { return 0; }
  if (k == ExprKind.EXPR_FLOAT_LIT) { return 1; }
  if (k == ExprKind.EXPR_BOOL_LIT) { return 2; }
  if (k == ExprKind.EXPR_VAR) { return 3; }
  if (k == ExprKind.EXPR_ADD) { return 4; }
  if (k == ExprKind.EXPR_SUB) { return 5; }
  if (k == ExprKind.EXPR_MUL) { return 6; }
  if (k == ExprKind.EXPR_DIV) { return 7; }
  if (k == ExprKind.EXPR_MOD) { return 8; }
  if (k == ExprKind.EXPR_SHL) { return 9; }
  if (k == ExprKind.EXPR_SHR) { return 10; }
  if (k == ExprKind.EXPR_BITAND) { return 11; }
  if (k == ExprKind.EXPR_BITOR) { return 12; }
  if (k == ExprKind.EXPR_BITXOR) { return 13; }
  if (k == ExprKind.EXPR_EQ) { return 14; }
  if (k == ExprKind.EXPR_NE) { return 15; }
  if (k == ExprKind.EXPR_LT) { return 16; }
  if (k == ExprKind.EXPR_LE) { return 17; }
  if (k == ExprKind.EXPR_GT) { return 18; }
  if (k == ExprKind.EXPR_GE) { return 19; }
  if (k == ExprKind.EXPR_LOGAND) { return 20; }
  if (k == ExprKind.EXPR_LOGOR) { return 21; }
  if (k == ExprKind.EXPR_NEG) { return 22; }
  if (k == ExprKind.EXPR_BITNOT) { return 23; }
  if (k == ExprKind.EXPR_LOGNOT) { return 24; }
  if (k == ExprKind.EXPR_IF) { return 25; }
  if (k == ExprKind.EXPR_BLOCK) { return 26; }
  if (k == ExprKind.EXPR_TERNARY) { return 27; }
  if (k == ExprKind.EXPR_ASSIGN) { return 28; }
  if (k == ExprKind.EXPR_ADD_ASSIGN) { return 29; }
  if (k == ExprKind.EXPR_SUB_ASSIGN) { return 30; }
  if (k == ExprKind.EXPR_MUL_ASSIGN) { return 31; }
  if (k == ExprKind.EXPR_DIV_ASSIGN) { return 32; }
  if (k == ExprKind.EXPR_MOD_ASSIGN) { return 33; }
  if (k == ExprKind.EXPR_BITAND_ASSIGN) { return 34; }
  if (k == ExprKind.EXPR_BITOR_ASSIGN) { return 35; }
  if (k == ExprKind.EXPR_BITXOR_ASSIGN) { return 36; }
  if (k == ExprKind.EXPR_SHL_ASSIGN) { return 37; }
  if (k == ExprKind.EXPR_SHR_ASSIGN) { return 38; }
  if (k == ExprKind.EXPR_BREAK) { return 39; }
  if (k == ExprKind.EXPR_CONTINUE) { return 40; }
  if (k == ExprKind.EXPR_RETURN) { return 41; }
  if (k == ExprKind.EXPR_PANIC) { return 42; }
  if (k == ExprKind.EXPR_MATCH) { return 43; }
  if (k == ExprKind.EXPR_FIELD_ACCESS) { return 44; }
  if (k == ExprKind.EXPR_STRUCT_LIT) { return 45; }
  if (k == ExprKind.EXPR_ARRAY_LIT) { return 46; }
  if (k == ExprKind.EXPR_INDEX) { return 47; }
  if (k == ExprKind.EXPR_CALL) { return 48; }
  if (k == ExprKind.EXPR_METHOD_CALL) { return 49; }
  if (k == ExprKind.EXPR_ENUM_VARIANT) { return 50; }
  if (k == ExprKind.EXPR_BINOP) { return 51; }
  if (k == ExprKind.EXPR_AS) { return 52; }
  return -1;
}

/** ELF enc 按 target_arch 分派：ta 0=x86_64，1=arm64，2=riscv64。 */
function enc_label_arch(elf_ctx: *platform.elf.ElfCodegenCtx, name: [64]u8, name_len: i32, is_func: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_label(elf_ctx, name, name_len, is_func); }
  if (ta == 2) { return arch.riscv64_enc.enc_label(elf_ctx, name, name_len, is_func); }
  return arch.x86_64_enc.enc_label(elf_ctx, name, name_len, is_func);
}
function enc_prologue_arch(elf_ctx: *platform.elf.ElfCodegenCtx, frame_sz: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_prologue(elf_ctx, frame_sz); }
  if (ta == 2) { return arch.riscv64_enc.enc_prologue(elf_ctx, frame_sz); }
  return arch.x86_64_enc.enc_prologue(elf_ctx, frame_sz);
}
function enc_epilogue_arch(elf_ctx: *platform.elf.ElfCodegenCtx, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_epilogue(elf_ctx); }
  if (ta == 2) { return arch.riscv64_enc.enc_epilogue(elf_ctx); }
  return arch.x86_64_enc.enc_epilogue(elf_ctx);
}
function enc_ret_imm32_arch(elf_ctx: *platform.elf.ElfCodegenCtx, imm32: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_ret_imm32(elf_ctx, imm32); }
  if (ta == 2) { return arch.riscv64_enc.enc_ret_imm32(elf_ctx, imm32); }
  return arch.x86_64_enc.enc_ret_imm32(elf_ctx, imm32);
}
function enc_mov_imm32_to_rbx_arch(elf_ctx: *platform.elf.ElfCodegenCtx, imm32: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_mov_imm32_to_rbx(elf_ctx, imm32); }
  if (ta == 2) { return arch.riscv64_enc.enc_mov_imm32_to_rbx(elf_ctx, imm32); }
  return arch.x86_64_enc.enc_mov_imm32_to_rbx(elf_ctx, imm32);
}
/** 将 64 位立即数装入 rax/x0，用于 EXPR_FLOAT_LIT（double 位模式）。 */
function enc_mov_imm64_to_rax_arch(elf_ctx: *platform.elf.ElfCodegenCtx, lo: i32, hi: i32, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_mov_imm64_to_rax(elf_ctx, lo, hi); }
  if (ta == 2) { return arch.riscv64_enc.enc_mov_imm64_to_rax(elf_ctx, lo, hi); }
  return arch.x86_64_enc.enc_mov_imm64_to_rax(elf_ctx, lo, hi);
}
