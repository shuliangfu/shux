extern function backend_emit_block_body_sync_elf(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, block_ref: i32, ctx: *AsmFuncCtx, ta: i32): i32;
/** Block 侧车字段经 C 读，避免 ast_arena_block_get 撕裂 num_stmt_order / final_expr_ref。 */
extern function pipeline_asm_block_num_stmt_order_at(arena: *ASTArena, block_ref: i32): i32;
