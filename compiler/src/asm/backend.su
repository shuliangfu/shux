    }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_pop_rbx_arch(elf_ctx, ta) != 0) { return -1; }
    return enc_xor_rbx_rax_arch(elf_ctx, ta);
  }
  if (e.kind == ExprKind.EXPR_SHL && asm_expr_binop_left(arena, expr_ref) != 0 && asm_expr_binop_right(arena, expr_ref) != 0) {
    if (asm_expr_binop_right(arena, expr_ref) != 0) {
      let re: Expr = ast_arena_expr_get(arena, asm_expr_binop_right(arena, expr_ref));
      if (re.kind == ExprKind.EXPR_LIT) {
        if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
        if (enc_mov_imm32_to_rbx_arch(elf_ctx, re.int_val, ta) != 0) { return -1; }
        if (enc_mov_rbx_to_ecx_arch(elf_ctx, ta) != 0) { return -1; }
        return enc_shl_cl_eax_arch(elf_ctx, ta);
      }
    }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_push_rax_arch(elf_ctx, ta) != 0) { return -1; }
    if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_right(arena, expr_ref), ctx, ta) != 0) { return -1; }
    if (enc_pop_rbx_arch(elf_ctx, ta) != 0) { return -1; }
    if (enc_mov_rbx_to_ecx_arch(elf_ctx, ta) != 0) { return -1; }
    return enc_shl_cl_eax_arch(elf_ctx, ta);
  }
  if (e.kind == ExprKind.EXPR_SHR && asm_expr_binop_left(arena, expr_ref) != 0 && asm_expr_binop_right(arena, expr_ref) != 0) {
    if (asm_expr_binop_right(arena, expr_ref) != 0) {
      let re: Expr = ast_arena_expr_get(arena, asm_expr_binop_right(arena, expr_ref));
      if (re.kind == ExprKind.EXPR_LIT) {
        if (emit_expr_elf(arena, elf_ctx, asm_expr_binop_left(arena, expr_ref), ctx, ta) != 0) { return -1; }
