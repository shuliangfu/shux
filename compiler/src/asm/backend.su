    if (enc_jz_arch(elf_ctx, false_buf, false_len, ta) != 0) { return -1; }
    if (backend_enc_mov_imm32_to_w0_arch(elf_ctx, 1, ta) != 0) { return -1; }
    if (enc_jmp_arch(elf_ctx, end_buf, end_len, ta) != 0) { return -1; }
