// backend.su — 汇编后端：AST 遍历、lowering 分派、架构分派
//
// 职责：CodegenOutBuf 与 AsmFuncCtx 的使用、按 AST 结点类型分派到架构相关 emit（x86_64/arm64）；对外入口 asm_codegen_ast。
// 依赖：ast（Module/ASTArena/Func、PipelineDepCtx）、codegen（CodegenOutBuf）、types、x86_64、arm64、elf、arch.x86_64_enc（.o 路径）。
// 后续优化（7.3）：简单寄存器分配，减少固定 rax/rbx 带来的 push/pop；窥孔可合并相邻 mov/算术。

import ast;
import codegen;
import asm.types;
import arch.x86_64;
import arch.arm64;
import arch.riscv64;
import platform.elf;
import arch.x86_64_enc;
import arch.arm64_enc;
import arch.riscv64_enc;

/** 诊断：asm 不支持的 ExprKind 时由 runtime.c 打印，便于定位 rc=-6。 */
extern function driver_diagnostic_asm_unsupported_expr(kind: i32): void;
/** C 桩：将 imm32 装入 w0/eax/a0，不发射 epilogue（避免与 enc_ret_imm32 在 arm64 上提前 ret）。 */
extern function backend_enc_mov_imm32_to_w0_arch(elf_ctx: *platform.elf.ElfCodegenCtx, imm32: i32, ta: i32): i32;
/** 诊断：return -1 前调用，loc 1=section_text 2=globl 3=label 4=prologue 5=block_body 6=block_inits 7=emit_expr 8=epilogue 9=tail_join_label。 */
extern function driver_diagnostic_asm_fail_at(loc: i32): void;
/** 诊断：记录当前正在 emit 的 ExprKind 序数，供 fail_at 时打印。 */
extern function driver_diagnostic_asm_set_last_expr_kind(k: i32): void;
/** 诊断：EXPR_VAR 未找到时调用；first_slot/first_len 为 ctx 首槽名（num_locals>0 时传 asm_ctx_local 首槽）。 */
extern function driver_diagnostic_asm_var_not_found(name: *u8, name_len: i32, num_locals: i32, first_slot: *u8, first_len: i32): void;
/** 诊断：每函数 codegen 前设置当前函数名，供 var_not_found 打印。 */
extern function driver_diagnostic_asm_set_current_func(name: *u8, name_len: i32): void;
/** build_shu_asm：大模块桩 emit 判定（ast_pool.c；须先 asm_skip_heavy_set_pipeline_ctx）。 */
extern function asm_skip_heavy_module_func_body(module: *Module, arena: *ASTArena, func_index: i32): i32;
/** SHU_ASM_START_FUNC：跳过 module 前 N 个函数的 emit（调试用）。 */
extern function asm_diag_start_func_skip(): i32;
/** parser_gen / C ABI：将 cur_mod 第 i 条 import 的逻辑路径写入 out_buf（至多 64 字节，含 NUL）。 */
extern function parser_get_module_import_path(mod: *Module, i: i32, out_buf: [64]u8): void;
/** codegen：部分 std/c shim 调用在 AST 中与真实 C 原型实参个数不一致，由 codegen.su 校正。 */
extern function codegen_call_num_args_override(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, num_args: i32): i32;
/** Module import 路径/绑定 sidecar（ast_pool.c）。 */
extern function pipeline_module_import_path_len(module: *Module, idx: i32): i32;
/**
 * 将 module 顶层 let/const 按序并入 main 函数体（块内 let），供 asm 在栈槽初始化。
 * 与 C codegen 的 static+init_globals 等价；须在 asm_codegen_ast* 编函数前调用（ast_pool.c）。
 */
extern function pipeline_module_hoist_top_level_lets_into_main(module: *Module, arena: *ASTArena): void;

/** asm 编当前 module 前：若有顶层 let 且存在 main，则并入 main 体块。 */
function asm_hoist_top_level_lets_for_codegen(module: *Module, arena: *ASTArena): void {
  if (module.num_top_level_lets > 0 && module.main_func_index >= 0) {
    pipeline_module_hoist_top_level_lets_into_main(module, arena);
  }
}
