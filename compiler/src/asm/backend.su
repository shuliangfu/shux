/**
 * ELF：局部 VAR 为指针时用 load（槽内含指向对象的地址），否则 lea（槽即对象/数组首）。
 * 与 text 路径 arch_emit_local_slot_ptr_or_addr 一致。
 */
function enc_local_slot_ptr_or_addr_arch(arena: *ASTArena, elf_ctx: *platform.elf.ElfCodegenCtx, base_var: Expr, stack_off: i32, ta: i32): i32 {
  let rtbv: i32 = base_var.resolved_type_ref;
  if (rtbv > 0) {
    let vtyp: Type = ast_arena_type_get(arena, rtbv);
    if (vtyp.kind == TypeKind.TYPE_PTR) {
      return enc_load_rbp_to_rax_arch(elf_ctx, stack_off, ta);
    }
  }
  return enc_lea_rbp_to_rax_arch(elf_ctx, stack_off, ta);
}
function enc_rax_plus_rbx_scale4_arch(elf_ctx: *platform.elf.ElfCodegenCtx, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_rax_plus_rbx_scale4(elf_ctx); }
  if (ta == 2) { return arch.riscv64_enc.enc_rax_plus_rbx_scale4(elf_ctx); }
  return arch.x86_64_enc.enc_rax_plus_rbx_scale4(elf_ctx);
}
/** INDEX 偏移：rbx×1（u8）。 */
function enc_rax_plus_rbx_scale1_arch(elf_ctx: *platform.elf.ElfCodegenCtx, ta: i32): i32 {
  if (ta == 1) { return arch.arm64_enc.enc_rax_plus_rbx_scale1(elf_ctx); }
