  buf[4] = platform.elf.elf_to_u8(imm >> 16);
  buf[5] = platform.elf.elf_to_u8(imm >> 24);
  return platform.elf.append_elf_bytes(ctx, buf, 6);
}

/** imull $imm, %ebx（INDEX 读路径 var*lit 下标在 rbx）。 */
function enc_imul_imm_to_ebx(ctx: *ElfCodegenCtx, imm: i32): i32 {
