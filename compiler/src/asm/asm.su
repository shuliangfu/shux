// asm.su — 汇编后端对外入口（供 pipeline 调用）
//
// 职责：导出 asm_codegen_ast(module, arena, out, ctx)，供 pipeline 在 -backend asm 时调用；ctx.target_arch 决定架构。
// 依赖：ast、codegen、types、backend、elf、macho、coff。

import ast;
import codegen;
import asm.types;
import backend;
import peephole;
import platform.elf;
import platform.macho;
import platform.coff;

/** 与 pipeline 对齐：若非 0 则跳过 dep 0 的机器码编码（宿主已提供等价 .o）。 */
extern function driver_skip_codegen_dep_0_get(): i32;
/** CALL 前缀：当前正在为第 j 个 dep 编码时须指向 dep 池 import 路径；入口模块前须置 NULL。 */
extern function driver_set_current_dep_path_for_codegen(path: *u8): void;

/**
 * 汇编后端入口：将 AST 生成汇编文本写入 out（与 codegen 共用 CodegenOutBuf）。
 * M8b：勿写 `if (backend.foo(...) != 0)`——.su parser 会丢整函数；用 let 累加后 return。
 */
function asm_codegen_ast(module: *Module, arena: *ASTArena, out: *CodegenOutBuf, ctx: *PipelineDepCtx): i32 {
  let err: i32 = backend.asm_codegen_ast(module, arena, out, ctx);
  let err2: i32 = peephole.peephole_run(out);
  return err + err2;
}

/**
 * 将 AST 生成机器码并写出 .o 到 out；elf_ctx 由调用方提供并在此处重置。返回 0 成功。
 * build_shu_asm（ENTRY_MODULE_ONLY）下 dep 机器码由其它 build_asm/*.o 提供，不在此编 dep 循环。
 * M8b：勿 `if (module.foo()!=0)` / `if { return err + platform.coff... }`（.su parser 会丢函数）；
 * 用 let + 单条 return 累加；Darwin 仅设 macho_leading_underscore，写出暂统一 ELF（B-strict Linux 路径）。
 */
function asm_codegen_elf_o(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx, elf_ctx: *ElfCodegenCtx, out: *CodegenOutBuf): i32 {
  platform.elf.elf_ctx_reset(elf_ctx);
  if (ctx.use_macho_o != 0) {
    elf_ctx.macho_leading_underscore = 1;
  }
  let e1: i32 = backend.asm_codegen_ast_to_elf(module, arena, elf_ctx, ctx);
  if (e1 != 0) {
    return -1;
  }
  let e2: i32 = peephole.peephole_elf_run(elf_ctx);
  if (e2 != 0) {
    return -1;
  }
  let e3: i32 = platform.elf.elf_resolve_patches(elf_ctx);
  if (e3 != 0) {
    return -1;
  }
  if (platform.elf.write_elf_o_to_buf(elf_ctx, out) < 0) {
    return -1;
  }
  return 0;
}
