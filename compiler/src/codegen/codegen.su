        if (base.kind == ExprKind.EXPR_VAR && base.var_name_len > 0 && base.var_name_len <= 63) {
          let j: i32 = 0;
          while (j < cur_mod.num_imports && j < ctx.ndep && j < 32) {
            if (cur_mod.import_kinds[j] == 1 && cur_mod.import_binding_name_len[j] == base.var_name_len && ctx.dep_paths[j] != 0 as *u8) {
              let eq: bool = true;
              let kk: i32 = 0;
