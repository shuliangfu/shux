                let pl: i32 = 0;
                while (pl < 128 && cur_pre[pl] != 0) {
                  pl = pl + 1;
                }
                if (pl > 0 && emit_bytes_from_ptr(out, &cur_pre[0], pl) != 0) {
                  return -1;
                }
                if (emit_bytes_64(out, callee2.var_name, callee2.var_name_len) != 0) {
                  return -1;
                }
                if (append_byte(out, 40) != 0) {
                  return -1;
                }
                let n_cur: i32 = driver_call_num_args_override(&cur_pre[0], pl, callee2.var_name, callee2.var_name_len, e.call_num_args);
                let fmt_i32_second_cur: i32 = 0;
                if (e.call_num_args == 2 && n_cur == 1 && callee2.var_name_len == 7 && callee2.var_name[0] == 102 && callee2.var_name[1] == 109 && callee2.var_name[2] == 116 && callee2.var_name[3] == 95 && callee2.var_name[4] == 105 && callee2.var_name[5] == 51 && callee2.var_name[6] == 50) {
                  if (ref_is_null(e.call_arg_refs[0])) {
                    fmt_i32_second_cur = 1;
                  }
                }
                let ai: i32 = 0;
                while (ai < n_cur && ai < 16) {
                  if (ai > 0) {
                    let comma: [3]u8 = [44, 32, 0];
                    if (emit_bytes_3(out, comma, 2) != 0) {
