        let ai: i32 = 0;
        while (ai < e.call_num_args && ai < 16) {
          if (ai > 0) {
            let comma: [3]u8 = [44, 32, 0];
            if (emit_bytes_3(out, comma, 2) != 0) {
              return -1;
            }
          }
          if (ref_is_null(e.call_arg_refs[ai])) {
            if (append_byte(out, 48) != 0) {
              return -1;
            }
          } else if (emit_expr(arena, out, e.call_arg_refs[ai], ctx) != 0) {
