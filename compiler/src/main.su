// main.su — 与 main.c 一一对应：程序入口与驱动编排（6.2 逻辑全在 .su）
//
// 职责：提供 main(argc, argv)；-su -E 的 argv 解析与执行（读文件、预处理、pipeline、写 stdout）全部在 .su 实现。
//
// 为何仍保留少量 C 原语（见下方 extern）：
// - driver_get_argv_i：argv 在 C 里是 char**，.su 只有 *u8，无法在 .su 里安全地「从 argv 取第 i 个指针」再读字符串，故必须由 C 提供。
// - run_compiler_c：已迁 .su（本文件内桩实现 return 1）；C 在 SHU_USE_SU_DRIVER 下不定义，由 driver_gen.c 的 run_compiler_c 包装转调 main_run_compiler_c。
// - run_compiler_su_path：默认走 ASM（driver_run_compiler_full）；`-backend c` 且无 `-o` 时走 .su pipeline 出 C 文本 stdout。
// - pipeline_run_su_pipeline_impl：实现位于 pipeline.su→pipeline_gen.c，main.su 仅 extern 调用，无法迁入 .su。

import ast;
import codegen;
import preprocess;
import std.fs;
/** 子命令：build/run 在 main_cmd_build / main_cmd_run 内实现；fmt/check/test 仍由 src/driver/*.su 提供（extern driver_cmd_*）。 */
extern function driver_cmd_fmt(argc: i32, argv: *u8): i32;
extern function driver_cmd_check(argc: i32, argv: *u8): i32;
extern function driver_cmd_test(argc: i32, argv: *u8): i32;

/** -su -E 解析结果：路径与 -L 库根、是否用 asm 后端、目标架构，由 driver_argv_parse_su / driver_argv_parse_su_path 填充。 */
struct DriverSuEmitState {
  path_buf: [512]u8;
  path_len: i32;
  /** 非 0 表示 -E-extern：仅类型 + 入口库形态 C，与 C 路径 emit_extern_imports 一致。 */
  emit_extern_imports: i32;
  /** 非 0 表示 asm 后端（默认 1）；`-backend c` 置 0 表示 pipeline 出 C 文本。 */
  use_asm_backend: i32;
  /** 目标架构：0=x86_64，1=arm64，2=riscv64；按 -target aarch64/arm64/riscv64 设置。 */
  target_arch: i32;
  /** `-o` 且写 codegen 缓冲区时使用；ASM 默认路径下多为 driver_run_compiler_full 处理，此项仍供 driver_run_su_emit_su（`-backend c`）写文件。 */
  out_path_buf: [512]u8;
  out_path_len: i32;
}

/** driver -L 库根 grow 池（ast_pool.c）；DriverSuEmitState 指针作键。 */
extern function driver_emit_lib_root_reset(state: *u8): void;
extern function driver_emit_append_lib_root(state: *u8, path: *u8, len: i32): i32;
extern function driver_emit_lib_root_count(state: *u8): i32;
extern function driver_emit_lib_root_len(state: *u8, i: i32): i32;
extern function driver_emit_lib_root_copy(state: *u8, i: i32, dst: *u8, cap: i32): void;

/** DriverSuEmitState 指针作 sidecar 键。 */
function driver_emit_state_key(state: *DriverSuEmitState): *u8 {
  return state as *u8;
}

/** 从 argv[arg_i] 读取路径并追加到 emit lib_root 池；成功返回 1。 */
function driver_emit_try_append_lib_from_argv(argc: i32, argv: *u8, arg_i: i32, state: *DriverSuEmitState): i32 {
  let tmp: [256]u8 = [];
  let llen: i32 = driver_get_argv_i(argc, argv, arg_i, &tmp[0], 256);
  if (llen >= 0 && driver_emit_append_lib_root(driver_emit_state_key(state), &tmp[0], llen) >= 0) {
    return 1;
  }
  return 0;
}

/** 若无 -L 则默认 "." 库根（与 C driver 一致）。 */
function driver_emit_ensure_default_lib_root(state: *DriverSuEmitState): void {
  if (driver_emit_lib_root_count(driver_emit_state_key(state)) == 0) {
    let dot: [1]u8 = [46];
    driver_emit_append_lib_root(driver_emit_state_key(state), &dot[0], 1);
  }
}

/** 将 emit lib_root 池灌入 PipelineDepCtx（-backend c 烟测路径）。 */
function driver_emit_copy_lib_roots_to_ctx(state: *DriverSuEmitState, ctx: *PipelineDepCtx): void {
  let k: i32 = 0;
  let n: i32 = driver_emit_lib_root_count(driver_emit_state_key(state));
  let tmp: [256]u8 = [];
  while (k < n) {
    let llen: i32 = driver_emit_lib_root_len(driver_emit_state_key(state), k);
    if (llen > 0) {
      driver_emit_lib_root_copy(driver_emit_state_key(state), k, &tmp[0], 256);
      ast_pipeline_ctx_append_lib_root(ctx, &tmp[0], llen);
    }
    k = k + 1;
  }
}

/**
 * 默认 DriverSuEmitState：struct 字面量最多 8 字段（parser/AST 限制），
 * out_path_buf/out_path_len 等余下字段依赖零初始化。
 */
function driver_emit_state_default(): DriverSuEmitState {
  return DriverSuEmitState {
    path_buf: [],
    path_len: 0,
    emit_extern_imports: 0,
    use_asm_backend: 1,
    target_arch: 0
  };
}

/**
 * -su -E emit 路径用 PipelineDepCtx 零基线（8 字段字面量 + 显式填 backend/index 等）。
 */
function pipeline_dep_ctx_for_emit(use_asm: i32, target: i32): PipelineDepCtx {
  let ctx: PipelineDepCtx = PipelineDepCtx {
    ndep: 0,
    entry_dir_buf: [],
    entry_dir_len: 0,
    num_lib_roots: 0
  };
  ctx.use_asm_backend = use_asm;
  ctx.target_arch = target;
  ctx.current_func_index = -1;
  ctx.current_func_single_empty_param_index = -1;
  return ctx;
}

/** C 极薄原语：将 argv[i] 复制到 buf[0..max-1]，NUL 结尾，返回长度；越界或失败 -1。必须 C：.su 无 char** 与 argv 索引能力。 */
extern function driver_get_argv_i(argc: i32, argv: *u8, i: i32, buf: *u8, max: i32): i32;
/**
 * C 极薄原语：子命令路由时去掉 argv[1]（子命令名），保留 argv[0] 与 argv[2..] 连续放入静态槽；返回的指针与 char** 同址。
 * 生命周期：下次调用本函数前有效（单线程 main）。
 */
extern function driver_argv_drop_subcommand(argc: i32, argv: *u8): *u8;
/** C runtime.c：无参 `shu build` 时在当前目录找 build.su，编译后执行 ./a.out。 */
extern function driver_build_build_su(): i32;
/** C runtime.c：`shu run` 编译成功后 fork/exec 产物（扫描 `-o` 或默认 a.out）。 */
extern function driver_exec_compiled(argc: i32, argv: *u8): i32;
/** C 极薄原语：以 path[0..path_len-1] 为路径打开读文件，返回 fd，失败 -1。供 driver_run_su_emit_su 读入口文件，避免 -E-extern 生成顺序导致 path_buf 未填就调 open。 */
extern function driver_fs_open_read_path(path: *u8, path_len: i32): i32;
/** C 提供静态 arena/module 缓冲（arena 32MiB / module 512KiB 级，须 ≥ sizeof(ast_ASTArena)），避免栈上超大数组。 */
extern function driver_arena_buf(): *u8;
extern function driver_module_buf(): *u8;
/** C 极薄原语：以 path[0..path_len-1] 为路径打开写文件（O_WRONLY|O_CREAT|O_TRUNC），返回 fd，失败 -1。供 -backend asm -o 时写 -o 文件。 */
extern function driver_fs_open_write(path: *u8, path_len: i32): i32;
/** 诊断：pipeline 返回非 0 时打印 rc 到 stderr；rc==-7（resolve 失败）时 path 为尝试过的路径（以 0 结尾），否则 path 可忽略。 */
extern function driver_pipeline_fail_code(rc: i32, path: *u8): void;
/** 无 -o 时在 pipeline 成功后向 stderr 打印烟测两行（前缀仍含 parse OK / typeck OK）。 */
extern function driver_print_su_smoke_summary(module: *u8, codegen_len: usize): void;

/** -su -E 多文件：将 path 与 -L 库根灌入 C 侧，再调 driver_run_su_emit_c 走完整 deps+main 路径（.su 的 driver_run_su_emit_su 仅单文件无 import）。 */
extern function driver_run_su_emit_c_set_path(path: *u8, path_len: i32): i32;
extern function driver_run_su_emit_c_set_lib(i: i32, buf: *u8, len: i32): i32;
extern function driver_run_su_emit_c_set_n_lib_roots(n: i32): i32;
/** -E-extern 时置 1，供 C 侧 driver_run_su_emit_c 走与 run_compiler_c 一致的瘦 C 生成。 */
extern function driver_run_su_emit_c_set_emit_extern(v: i32): i32;
extern function driver_run_su_emit_c(): i32;

/** 全 .su 前端入口（非 -su -E 时由 entry 经 run_compiler_su_path_impl 调用）；.su 内实现为转调 run_compiler_su_path_impl，不再依赖 C。 */
function run_compiler_su_path(argc: i32, argv: *u8): i32 {
  return run_compiler_su_path_impl(argc, argv);
}

/** pipeline 实现入口（.su 内以 source_data/source_len 调 parse_into_with_init_buf）。形参顺序 (module, arena) 与调用时 (module_buf, arena_buf) 一致。 */
extern function pipeline_run_su_pipeline_impl(module: *u8, arena: *u8, source_data: *u8, source_len: usize, out_buf: *CodegenOutBuf, ctx: *PipelineDepCtx): i32;
/** dep 池：lib_root 追加（C ast_pool；driver -E-extern 生成 ast_pipeline_ 前缀符号）。 */
extern function ast_pipeline_ctx_append_lib_root(ctx: *PipelineDepCtx, path: *u8, len: i32): i32;

/** C 侧完整编译实现：解析 -o/-L/-O、读文件、pipeline、cc 生成可执行文件。供 r==1/r==2 时（如带 -o）从 .su 路径转调。 */
extern function driver_run_compiler_full(argc: i32, argv: *u8): i32;
/** 原 C 侧完整编译实现（-o/import 等复杂路径）；现转调 C 的 driver_run_compiler_full，使带 -o 的 shu 能产出可执行文件。 */
function run_compiler_c_impl(argc: i32, argv: *u8): i32 {
  return driver_run_compiler_full(argc, argv);
}
/** 原 run_compiler_c：转调 run_compiler_c_impl，供 r==1/r==2 时走 C 的完整编译路径（-o、多文件等）。 */
function run_compiler_c(argc: i32, argv: *u8): i32 {
  return run_compiler_c_impl(argc, argv);
}

/**
 * runtime.c 在 SHU_USE_SU_DRIVER 下定义 run_compiler_c() 并 extern 调用本符号。
 * 全 asm 链 build_shu_asm.sh 不链 driver_gen.c 时，须由 main.o 导出，否则链接 runtime_driver 报 undefined。
 */
function main_run_compiler_c(argc: i32, argv: *u8): i32 {
  return run_compiler_c(argc, argv);
}

/** 比较 buf 与 "-L"（2 字节），相等返回 1 否则 0。 */
function eq_minus_L(buf: *u8, len: i32): i32 {
  if (len < 2) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 76) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-su"（3 字节）。 */
function eq_minus_su(buf: *u8, len: i32): i32 {
  if (len < 3) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 115 && buf[2] == 117) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-E"（2 字节）。 */
function eq_minus_E(buf: *u8, len: i32): i32 {
  if (len < 2) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 69) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-E-extern"（9 字节）；与 C 侧 -E-extern 一致，供 -su -E 在取入口路径前跳过。 */
function eq_minus_E_extern(buf: *u8, len: i32): i32 {
  if (len < 9) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 69 && buf[2] == 45 && buf[3] == 101 && buf[4] == 120 && buf[5] == 116 && buf[6] == 101 && buf[7] == 114 && buf[8] == 110) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-backend"（8 字节）。 */
function eq_minus_backend(buf: *u8, len: i32): i32 {
  if (len < 8) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 98 && buf[2] == 97 && buf[3] == 99 && buf[4] == 107 && buf[5] == 101 && buf[6] == 110 && buf[7] == 100) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "asm"（3 字节）。 */
function eq_asm(buf: *u8, len: i32): i32 {
  if (len < 3) {
    return 0;
  }
  if (buf[0] == 97 && buf[1] == 115 && buf[2] == 109) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "--lsp"（5 字节）；LSP 模式入口。 */
function eq_minus_lsp(buf: *u8, len: i32): i32 {
  if (len < 5) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 45 && buf[2] == 108 && buf[3] == 115 && buf[4] == 112) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-target"（7 字节）。 */
function eq_minus_target(buf: *u8, len: i32): i32 {
  if (len < 7) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 116 && buf[2] == 97 && buf[3] == 114 && buf[4] == 103 && buf[5] == 101 && buf[6] == 116) {
    return 1;
  }
  return 0;
}

/** 通用字节串比较：a[0..a_len-1] 与 b[0..b_len-1] 长度相同且逐字节相等返回 1，否则 0（用于子命令名匹配）。 */
function str_eq(a: *u8, a_len: i32, b: *u8, b_len: i32): i32 {
  if (a_len != b_len) {
    return 0;
  }
  let i: i32 = 0;
  while (i < a_len) {
    if (a[i] != b[i]) {
      return 0;
    }
    i = i + 1;
  }
  return 1;
}

/** 若 buf[0..len-1] 中含子串 "aarch64" 或 "arm64" 返回 1，否则 0（用于 -target 选 arm64）。 */
function target_contains_arm(buf: *u8, len: i32): i32 {
  let start: i32 = 0;
  while (start + 7 <= len) {
    if (buf[start] == 97 && buf[start + 1] == 97 && buf[start + 2] == 114 && buf[start + 3] == 99 && buf[start + 4] == 104 && buf[start + 5] == 54 && buf[start + 6] == 52) {
      return 1;
    }
    start = start + 1;
  }
  start = 0;
  while (start + 5 <= len) {
    if (buf[start] == 97 && buf[start + 1] == 114 && buf[start + 2] == 109 && buf[start + 3] == 54 && buf[start + 4] == 52) {
      return 1;
    }
    start = start + 1;
  }
  return 0;
}

/** 若 buf[0..len-1] 中含子串 "riscv64" 返回 1，否则 0（用于 -target 选 riscv64）。 */
function target_contains_riscv(buf: *u8, len: i32): i32 {
  let start: i32 = 0;
  while (start + 7 <= len) {
    if (buf[start] == 114 && buf[start + 1] == 105 && buf[start + 2] == 115 && buf[start + 3] == 99 && buf[start + 4] == 118 && buf[start + 5] == 54 && buf[start + 6] == 52) {
      return 1;
    }
    start = start + 1;
  }
  return 0;
}

/**
 * 解析 argv 为「非 -su -E」的编译请求：填 state.path_buf/path_len、可选 -o 输出路径与 lib_root_*。
 * 返回 0 表示已填 state；默认 use_asm_backend=1 走 run_compiler_c_impl（全量流水线）；`-backend c` 且无 `-o` 时才走 driver_run_su_emit_su 烟测（勿默认 0，否则 main.o 栈上 PipelineDepCtx+双 4MiB 缓冲区撑爆线程栈）。
 * 返回 1 表示需走 C 实现（当前仅 -o 缺少输出路径参数时）。
 * 无输入路径返回 2。
 */
function driver_argv_parse_su_path(argc: i32, argv: *u8, state: *DriverSuEmitState): i32 {
  state.path_len = 0;
  driver_emit_lib_root_reset(driver_emit_state_key(state));
  state.emit_extern_imports = 0;
  /** 默认 1：走 run_compiler_c_impl；勿 0（会默认进 driver_run_su_emit_su 栈溢出）。 */
  state.use_asm_backend = 1;
  state.target_arch = 0;
  state.out_path_len = 0;
  if (argc < 2) {
    return 2;
  }
  let arg_buf: [512]u8 = [];
  let i: i32 = 1;
  let has_o: i32 = 0;
  while (i < argc) {
    let len: i32 = driver_get_argv_i(argc, argv, i, arg_buf, 512);
    if (len < 0) {
      i = i + 1;
      continue;
    }
    if (eq_minus_target(arg_buf, len) != 0 && i + 1 < argc) {
      let tlen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      if (tlen >= 0 && target_contains_arm(arg_buf, tlen) != 0) {
        state.target_arch = 1;
      }
      if (tlen >= 0 && target_contains_riscv(arg_buf, tlen) != 0) {
        state.target_arch = 2;
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_L(arg_buf, len) != 0) {
      if (i + 1 >= argc) {
        return 2;
      }
      driver_emit_try_append_lib_from_argv(argc, argv, i + 1, state);
      i = i + 2;
      continue;
    }
    if (eq_minus_backend(arg_buf, len) != 0 && i + 1 < argc) {
      let vlen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      /* `-backend c`：烟测走 driver_run_su_emit_su；`-backend asm`：与默认一致（全量 run_compiler_c_impl）。 */
      if (vlen >= 0 && vlen == 1 && arg_buf[0] == 99) {
        state.use_asm_backend = 0;
      }
      if (vlen >= 0 && eq_asm(arg_buf, vlen) != 0) {
        state.use_asm_backend = 1;
      }
      i = i + 2;
      continue;
    }
    /* -o <path>：须写入 state，否则 has_o→返回 1 会误走 C 流水线，typeck 负例在 run-typeck.sh（带 -o）下无法 grep stderr。 */
    if (len == 2 && arg_buf[0] == 45 && arg_buf[1] == 111) {
      if (i + 1 < argc) {
        let olen: i32 = driver_get_argv_i(argc, argv, i + 1, state.out_path_buf, 512);
        if (olen >= 0) {
          state.out_path_len = olen;
        }
        i = i + 2;
      } else {
        has_o = 1;
        i = i + 1;
      }
      continue;
    }
    if (len == 2 && arg_buf[0] == 45 && arg_buf[1] == 79) {
      i = i + 1;
      if (i < argc) {
        i = i + 1;
      }
      continue;
    }
    if (eq_minus_su(arg_buf, len) != 0) {
      i = i + 1;
      continue;
    }
    if (state.path_len == 0 && len > 0) {
      let k: i32 = 0;
      while (k < len && k < 512) {
        state.path_buf[k] = arg_buf[k];
        k = k + 1;
      }
      state.path_len = len;
    }
    i = i + 1;
  }
  if (has_o != 0) {
    return 1;
  }
  if (state.path_len == 0) {
    return 2;
  }
  /* 与 C 一致：无 -L 时默认库根为 "." */
  driver_emit_ensure_default_lib_root(state);
  return 0;
}

/**
 * 在 .su 内解析 argv：若存在 -su -E <path> 则填充 state（path + 此前 -L 的库根），返回 1；否则返回 0。
 */
function driver_argv_parse_su(argc: i32, argv: *u8, state: *DriverSuEmitState): i32 {
  state.path_len = 0;
  driver_emit_lib_root_reset(driver_emit_state_key(state));
  state.emit_extern_imports = 0;
  state.use_asm_backend = 0;
  state.target_arch = 0;
  state.out_path_len = 0;
  if (argc < 4) {
    return 0;
  }
  let arg_buf: [512]u8 = [];
  let i: i32 = 1;
  while (i < argc) {
    let len: i32 = driver_get_argv_i(argc, argv, i, arg_buf, 512);
    if (len < 0) {
      i = i + 1;
      continue;
    }
    if (eq_minus_L(arg_buf, len) != 0 && i + 1 < argc) {
      driver_emit_try_append_lib_from_argv(argc, argv, i + 1, state);
      i = i + 2;
      continue;
    }
    if (eq_minus_backend(arg_buf, len) != 0 && i + 1 < argc) {
      let vlen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      if (vlen >= 0 && eq_asm(arg_buf, vlen) != 0) {
        state.use_asm_backend = 1;
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_target(arg_buf, len) != 0 && i + 1 < argc) {
      let tlen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      if (tlen >= 0 && target_contains_arm(arg_buf, tlen) != 0) {
        state.target_arch = 1;
      }
      if (tlen >= 0 && target_contains_riscv(arg_buf, tlen) != 0) {
        state.target_arch = 2;
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_su(arg_buf, len) != 0 && i + 2 < argc) {
      let elen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      if (eq_minus_E(arg_buf, elen) != 0) {
        /* 跳过 -E 后面的 -L <path> 对，同时采集库根到 state */
        let pi: i32 = i + 2;
        while (pi < argc) {
          let plen_temp: i32 = driver_get_argv_i(argc, argv, pi, arg_buf, 512);
          if (plen_temp > 0 && eq_minus_L(arg_buf, plen_temp) != 0 && pi + 1 < argc) {
            driver_emit_try_append_lib_from_argv(argc, argv, pi + 1, state);
            pi = pi + 2;
            continue;
          }
          break;
        }
        if (pi < argc) {
          let opt_len: i32 = driver_get_argv_i(argc, argv, pi, arg_buf, 512);
          if (opt_len >= 0 && eq_minus_E_extern(arg_buf, opt_len) != 0) {
            state.emit_extern_imports = 1;
            pi = pi + 1;
          }
        }
        if (pi < argc) {
          let plen: i32 = driver_get_argv_i(argc, argv, pi, state.path_buf, 512);
          if (plen >= 0) {
            state.path_len = plen;
            return 1;
          }
        }
      }
      i = i + 1;
      continue;
    }
    i = i + 1;
  }
  return 0;
}

/**
 * 在 .su 内执行 -su -E：读 state.path_buf 文件、预处理、跑 pipeline、写 stdout。
 * 使用固定缓冲与 ctx；仅无 import 单文件时正确（deps 为 0）。
 */
function driver_run_su_emit_su(state: *DriverSuEmitState): i32 {
  /* 用 C 原语按 state.path_buf/len 打开，避免 -E-extern 生成顺序把 open 提到 path_buf 填充之前 */
  let fd: i32 = driver_fs_open_read_path(state.path_buf, state.path_len);
  if (fd < 0) {
    return 1;
  }
  let loaded_buf: [4194304]u8 = [];
  let cap: usize = 4194304;
  let n: isize = fs_read(fd, loaded_buf, cap);
  if (fd >= 0) {
    fs_close(fd);
  }
  if (n < 0) {
    return 1;
  }
  let preprocess_buf: [4194304]u8 = [];
  let out_len: i32 = preprocess_su_buf(loaded_buf, n, preprocess_buf, 4194304);
  if (out_len < 0) {
    return 1;
  }
  /* arena/module 由 C 提供静态缓冲；池扩大后 ast_ASTArena codegen 约 ~90MiB（arm64），runtime 用 128MiB 静态区 */
  let arena_buf: *u8 = driver_arena_buf();
  let module_buf: *u8 = driver_module_buf();
  let ctx: PipelineDepCtx = pipeline_dep_ctx_for_emit(state.use_asm_backend, state.target_arch);
  let last_slash: i32 = -1;
  let k: i32 = 0;
  while (k < state.path_len && k < 512) {
    if (state.path_buf[k] == 47) {
      last_slash = k;
    }
    k = k + 1;
  }
  if (last_slash >= 0) {
    k = 0;
    while (k < last_slash && k < 511) {
      ctx.entry_dir_buf[k] = state.path_buf[k];
      k = k + 1;
    }
    ctx.entry_dir_buf[k] = 0;
    ctx.entry_dir_len = k;
  } else {
    ctx.entry_dir_buf[0] = 46;
    ctx.entry_dir_buf[1] = 0;
    ctx.entry_dir_len = 1;
  }
  ctx.num_lib_roots = 0;
  driver_emit_copy_lib_roots_to_ctx(state, &ctx);
  let out: CodegenOutBuf = CodegenOutBuf { data: [], len: 0 };
  let source_len: usize = out_len;
  let rc: i32 = pipeline_run_su_pipeline_impl(module_buf, arena_buf, preprocess_buf, source_len, &out, &ctx);
  if (rc != 0) {
    driver_pipeline_fail_code(rc, &ctx.path_buf[0]);
    return 1;
  }
  /** out.len 为 i32；与 fs_write 返回值 isize 比较时用 i32，勿 usize（typeck 失败）。 */
  let len: i32 = out.len;
  if (state.out_path_len == 0) {
    driver_print_su_smoke_summary(module_buf, len as usize);
  }
  if (state.out_path_len > 0) {
    let fd: i32 = driver_fs_open_write(state.out_path_buf, state.out_path_len);
    if (fd < 0) {
      return 1;
    }
    if (len > 262144) {
      let written: isize = fs_write(fd, out.data, 262144);
      fs_close(fd);
      if (written < 0 || (written as i32) != 262144) {
        return 1;
      }
    } else {
      let written: isize = fs_write(fd, out.data, len as usize);
      fs_close(fd);
      if (written < 0 || (written as i32) != len) {
        return 1;
      }
    }
  } else {
    if (len > 262144) {
      let written: isize = fs_write(1, out.data, 262144);
      if (written < 0 || (written as i32) != 262144) {
        return 1;
      }
    } else {
      let written: isize = fs_write(1, out.data, len as usize);
      if (written < 0 || (written as i32) != len) {
        return 1;
      }
    }
  }
  return 0;
}

/**
 * 非 -su -E 时的编译入口：默认走 ASM（driver_run_compiler_full → driver_run_asm_backend）；`-backend c` 且无 `-o` 时走 driver_run_su_emit_su 出 C。
 * 返回 0 成功，1 错误，或 C 的返回值。
 */
function run_compiler_su_path_impl(argc: i32, argv: *u8): i32 {
  let state: DriverSuEmitState = driver_emit_state_default();
  let r: i32 = driver_argv_parse_su_path(argc, argv, &state);
  if (r == 1) {
    return run_compiler_c_impl(argc, argv);
  }
  if (r == 2) {
    return run_compiler_c_impl(argc, argv);
  }
  if (state.use_asm_backend != 0) {
    return run_compiler_c_impl(argc, argv);
  }
  /*
   * 含 `-o` 的可执行文件/目标产物必须经 C 的 driver_run_compiler_full：临时 .c + cc/strip，
   * * 链接 std/io、std/time、panic 等 .o。.su-only 的 driver_run_su_emit_su 只是把 codegen 缓冲区
   * * 写入路径（等同导出 C，不链接），run-std/run-time/import 会一直失败甚至得到空文件。
   * * 无 `-o` 时仍走 driver_run_su_emit_su：stderr 打印 parse/typeck OK、stdout 可出 C。
   */
  if (state.out_path_len > 0) {
    return run_compiler_c_impl(argc, argv);
  }
  return driver_run_su_emit_su(&state);
}

/**
 * `shu build`：子命令已从 argv 剥离后，argc==1 表示除程序名外无额外参数 → 走当前目录 build.su（C）；否则编译指定 .su。
 */
function main_cmd_build(argc: i32, argv: *u8): i32 {
  if (argc < 2) {
    return driver_build_build_su();
  }
  return run_compiler_su_path_impl(argc, argv);
}

/**
 * `shu run`：编译 .su 到产物，成功则 exec 运行（与 driver/run.su 行为一致；`rc == 0` 分支再调 C 的 driver_exec_compiled，避免与 import ast 同编时 typeck 对 check_block 的误报）。
 */
function main_cmd_run(argc: i32, argv: *u8): i32 {
  if (argc < 2) {
    return 1;
  }
  let rc: i32 = run_compiler_su_path_impl(argc, argv);
  if (rc == 0) {
    return driver_exec_compiled(argc, argv);
  }
  return rc;
}

/** LSP 主循环由 lsp.su 实现，编译为 lsp_gen.c 时以 typeck_ 为前缀导出，故此处 extern 直接调 typeck_lsp_main，不再依赖 lsp_wrapper.c。 */
extern function typeck_lsp_main(): i32;

/**
 * 程序入口：与 main.c 的 main() 对应；C 的 main() 仅做 return main_entry(argc, argv)。
 * 6.2：-su -E 的解析与执行全部在 .su；否则默认 ASM（run_compiler_su_path_impl → driver_run_compiler_full）；`-backend c` 且无 `-o` 时为烟测 C stdout。
 * LSP：若任一参数为 --lsp 则进入 LSP 主循环（typeck_lsp_main），不再走编译。
 * 子命令：首参非 `-` 且为 build/run/fmt/check/test 时，去掉该令牌后转发 main_cmd_build / main_cmd_run / driver_cmd_*（与直编共存：首参以 `-` 开头仍走下方默认路径）。
 */
function entry(argc: i32, argv: *u8): i32 {
  let arg_buf: [64]u8 = [];
  let i: i32 = 1;
  while (i < argc) {
    let len: i32 = driver_get_argv_i(argc, argv, i, arg_buf, 64);
    if (len >= 0 && eq_minus_lsp(arg_buf, len) != 0) {
      return typeck_lsp_main();
    }
    i = i + 1;
  }
  /* build/run/fmt/check/test：关键字与典型 CLI 子命令一致，首字不为 `-` 以免与 `-su` 等标志冲突。 */
  if (argc >= 2) {
    let alen: i32 = driver_get_argv_i(argc, argv, 1, arg_buf, 64);
    if (alen > 0 && arg_buf[0] != 45) {
      let w_build: [5]u8 = [98, 117, 105, 108, 100];
      let w_run: [3]u8 = [114, 117, 110];
      let w_fmt: [3]u8 = [102, 109, 116];
      let w_check: [5]u8 = [99, 104, 101, 99, 107];
      let w_test: [4]u8 = [116, 101, 115, 116];
      if (str_eq(&arg_buf[0], alen, &w_build[0], 5) != 0) {
        return main_cmd_build(argc - 1, driver_argv_drop_subcommand(argc, argv));
      }
      if (str_eq(&arg_buf[0], alen, &w_run[0], 3) != 0) {
        return main_cmd_run(argc - 1, driver_argv_drop_subcommand(argc, argv));
      }
      if (str_eq(&arg_buf[0], alen, &w_fmt[0], 3) != 0) {
        return driver_cmd_fmt(argc - 1, driver_argv_drop_subcommand(argc, argv));
      }
      if (str_eq(&arg_buf[0], alen, &w_check[0], 5) != 0) {
        return driver_cmd_check(argc - 1, driver_argv_drop_subcommand(argc, argv));
      }
      if (str_eq(&arg_buf[0], alen, &w_test[0], 4) != 0) {
        return driver_cmd_test(argc - 1, driver_argv_drop_subcommand(argc, argv));
      }
    }
  }
  let state: DriverSuEmitState = driver_emit_state_default();
  if (driver_argv_parse_su(argc, argv, &state) != 0) {
    /* -su -E：走 C 的 driver_run_su_emit_c，支持多文件（deps+main）；.su 的 driver_run_su_emit_su 仅单文件无 import。 */
    /* 显式设置 emit_extern 标志；.su 无 C 的 (void) 丢弃写法，void 在括号内非合法 primary，故用裸调用表达式语句。 */
    driver_run_su_emit_c_set_emit_extern(state.emit_extern_imports);
    driver_run_su_emit_c_set_path(state.path_buf, state.path_len);
    let k: i32 = 0;
    let n_roots: i32 = driver_emit_lib_root_count(driver_emit_state_key(&state));
    let lib_tmp: [256]u8 = [];
    while (k < n_roots) {
      let llen: i32 = driver_emit_lib_root_len(driver_emit_state_key(&state), k);
      driver_emit_lib_root_copy(driver_emit_state_key(&state), k, &lib_tmp[0], 256);
      driver_run_su_emit_c_set_lib(k, &lib_tmp[0], llen);
      k = k + 1;
    }
    driver_run_su_emit_c_set_n_lib_roots(n_roots);
    return driver_run_su_emit_c();
  }
  /* 裸 `shu file.su` 仅编译；执行产物须显式 `shu run file.su`（run-*.sh 在编译后自行运行 -o 产物）。 */
  return run_compiler_su_path_impl(argc, argv);
}
