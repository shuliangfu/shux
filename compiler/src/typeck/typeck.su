// typeck.su — 类型检查（纯 .su，完全自举）
//
// 职责：对 .su AST（Module + Arena）做类型检查，全部逻辑在 .su；阶段 5.2 跨模块调用时通过 extern 取 dep 模块。
// 内容：main 校验、const/let 类型与初值一致、while/for 条件须 bool、if/三元条件须 bool、
//       赋值左右类型一致、块末表达式类型与函数返回类型一致、return 操作数类型一致；EXPR_CALL 在本模块或 deps 中解析 callee 并设 resolved_type_ref。
// 依赖：import ast。

import ast;

/** 将 double 的位模式拆成低/高 32 位，供 EXPR_FLOAT_LIT 填写 float_bits_lo/hi（.su 无 union，由 C 实现）。 */
extern function typeck_float64_bits_lo(d: f64): i32;
extern function typeck_float64_bits_hi(d: f64): i32;

/** 比较两段名字（字节序列）是否相等；长度相等且逐字节相等返回 true。 */
function name_equal(a: *u8, a_len: i32, b: *u8, b_len: i32): bool {
  if (a_len != b_len || a_len <= 0) {
    return false;
  }
  let i: i32 = 0;
  while (i < a_len) {
    if (a[i] != b[i]) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

/** 从 module 的 struct_layouts 中按类型名与字段名查字段偏移；未找到返回 -1。 */
function get_field_offset_from_layout(module: *Module, type_name: *u8, type_name_len: i32, field_name: *u8, field_name_len: i32): i32 {
  let k: i32 = 0;
  while (k < module.num_struct_layouts && k < 32) {
    let sl: StructLayout = module.struct_layouts[k];
    if (name_equal(sl.name, sl.name_len, type_name, type_name_len)) {
      let j: i32 = 0;
      while (j < sl.num_fields && j < 8) {
        if (name_equal(sl.field_names[j], sl.field_lens[j], field_name, field_name_len)) {
          return sl.field_offsets[j];
        }
        j = j + 1;
      }
      return -1;
    }
    k = k + 1;
  }
  return -1;
}

/** 将 STRUCT_LIT 对应的结构体布局加入 module（若尚未存在）；偏移按每字段 8 字节。 */
function ensure_struct_layout_from_struct_lit(module: *Module, e: Expr): i32 {
  if (e.struct_lit_num_fields <= 0 || e.struct_lit_num_fields > 8) {
    return 0;
  }
  let name_len: i32 = e.struct_lit_struct_name_len;
  if (name_len <= 0 || name_len > 63) {
    return 0;
  }
  let k: i32 = 0;
  while (k < module.num_struct_layouts && k < 32) {
    let sl: StructLayout = module.struct_layouts[k];
    if (name_equal(sl.name, sl.name_len, e.struct_lit_struct_name, name_len)) {
      return 0;
    }
    k = k + 1;
  }
  if (module.num_struct_layouts >= 32) {
    return -1;
  }
  let idx: i32 = module.num_struct_layouts;
  module.num_struct_layouts = module.num_struct_layouts + 1;
  let i: i32 = 0;
  while (i < 64) {
    module.struct_layouts[idx].name[i] = e.struct_lit_struct_name[i];
    i = i + 1;
  }
  module.struct_layouts[idx].name_len = name_len;
  module.struct_layouts[idx].num_fields = e.struct_lit_num_fields;
  let off: i32 = 0;
  let j: i32 = 0;
  while (j < e.struct_lit_num_fields && j < 8) {
    let fi: i32 = 0;
    while (fi < 64) {
      module.struct_layouts[idx].field_names[j][fi] = e.struct_lit_field_names[j][fi];
      fi = fi + 1;
    }
    module.struct_layouts[idx].field_lens[j] = e.struct_lit_field_lens[j];
    module.struct_layouts[idx].field_offsets[j] = off;
    off = off + 8;
    j = j + 1;
  }
  return 0;
}

/** 比较模块中某函数名与 arena 中某 VAR 表达式的 var_name 是否相等。避免取址语法。 */
function expr_var_name_equal_func(arena: *ASTArena, callee_expr_ref: i32, mod: *Module, func_index: i32): bool {
  if (callee_expr_ref <= 0 || callee_expr_ref > arena.num_exprs) {
    return false;
  }
  let callee: Expr = ast_arena_expr_get(arena, callee_expr_ref);
  if (callee.kind != ExprKind.EXPR_VAR) {
    return false;
  }
  let b_len: i32 = callee.var_name_len;
  if (func_index < 0 || func_index >= mod.num_funcs) {
    return false;
  }
  let ff: Func = mod.funcs[func_index];
  let a_len: i32 = ff.name_len;
  if (a_len != b_len || a_len <= 0 || a_len > 63) {
    return false;
  }
  let i: i32 = 0;
  while (i < a_len) {
    if (ff.name[i] != callee.var_name[i]) {
      return false;
    }
    i = i + 1;
  }
  return true;
}

/** 在 arena 中按名查找或分配 TYPE_NAMED，返回 type_ref；供 struct literal 设 resolved_type_ref，使 if-expr 能取到 else 分支类型。 */
function find_or_alloc_named_type_ref(arena: *ASTArena, name: *u8, name_len: i32): i32 {
  if (name_len <= 0 || name_len > 63) {
    return 0;
  }
  let k: i32 = 1;
  while (k <= arena.num_types) {
    let tk: Type = ast_arena_type_get(arena, k);
    if (tk.kind == TypeKind.TYPE_NAMED && name_equal(tk.name, tk.name_len, name, name_len)) {
      return k;
    }
    k = k + 1;
  }
  let new_ref: i32 = ast_arena_type_alloc(arena);
  if (new_ref == 0) {
    return 0;
  }
  let ti: Type = ast_arena_type_get(arena, new_ref);
  ti.kind = TypeKind.TYPE_NAMED;
  ti.name_len = name_len;
  let i: i32 = 0;
  while (i < 64) {
    if (i < name_len) {
      ti.name[i] = name[i];
    } else {
      ti.name[i] = 0;
    }
    i = i + 1;
  }
  ti.elem_type_ref = 0;
  ti.array_size = 0;
  ast_arena_type_set(arena, new_ref, ti);
  return new_ref;
}

/** 在当前 arena 中取或分配 TYPE_I32，返回其 type_ref；供跨模块调用时 dep 返回 i32 时复用本 arena 的类型。 */
function ensure_i32_type_ref(arena: *ASTArena): i32 {
  let k: i32 = 1;
  while (k <= arena.num_types) {
    let tk: Type = ast_arena_type_get(arena, k);
    if (tk.kind == TypeKind.TYPE_I32) {
      return k;
    }
    k = k + 1;
  }
  let new_ref: i32 = ast_arena_type_alloc(arena);
  if (new_ref == 0) {
    return 0;
  }
  let ti: Type = ast_arena_type_get(arena, new_ref);
  ti.kind = TypeKind.TYPE_I32;
  ti.name_len = 0;
  ti.elem_type_ref = 0;
  ti.array_size = 0;
  ast_arena_type_set(arena, new_ref, ti);
  return new_ref;
}

/** 按 dep 下标取 arena 并在 caller_arena 中得到对应 return_type_ref；ctx 由 typeck 入口传入。 */
function get_dep_return_type_in_caller_arena(from_dep_index: i32, dep_return_type_ref: i32, caller_arena: *ASTArena, ctx: *PipelineDepCtx): i32 {
  if (from_dep_index < 0 || from_dep_index >= 32) {
    return 0;
  }
  let dep_arena: *ASTArena = ctx.dep_arenas[from_dep_index];
  return dep_return_type_to_caller_arena(dep_arena, dep_return_type_ref, caller_arena);
}

/** 在 caller_arena 中取或分配 TYPE_I64，返回 type_ref；供 dep_return_type_to_caller_arena 调用。 */
function ensure_i64_type_ref(caller_arena: *ASTArena): i32 {
  let k: i32 = 1;
  while (k <= caller_arena.num_types) {
    let tk: Type = ast_arena_type_get(caller_arena, k);
    if (tk.kind == TypeKind.TYPE_I64) {
      return k;
    }
    k = k + 1;
  }
  let new_ref: i32 = ast_arena_type_alloc(caller_arena);
  if (new_ref == 0) {
    return 0;
  }
  let ti: Type = ast_arena_type_get(caller_arena, new_ref);
  ti.kind = TypeKind.TYPE_I64;
  ti.name_len = 0;
  ti.elem_type_ref = 0;
  ti.array_size = 0;
  ast_arena_type_set(caller_arena, new_ref, ti);
  return new_ref;
}

/** 从 dep 的 return_type_ref 在当前 arena 中取或分配同类型，返回 ref；仅支持 TYPE_I32/TYPE_I64。 */
function dep_return_type_to_caller_arena(dep_arena: *ASTArena, dep_return_type_ref: i32, caller_arena: *ASTArena): i32 {
  let tt: Type = ast_arena_type_get(dep_arena, dep_return_type_ref);
  if (tt.kind == TypeKind.TYPE_I32) {
    return ensure_i32_type_ref(caller_arena);
  }
  if (tt.kind == TypeKind.TYPE_I64) {
    return ensure_i64_type_ref(caller_arena);
  }
  return 0;
}

/** 在给定模块中按名字查找函数，返回 return_type_ref（当前 arena 内有效），未找到返回 0。from_dep_index<0 表示当前模块，>=0 表示 dep 下标时需 ctx。 */
function find_func_return_type_in_module(mod: *Module, mod_arena: *ASTArena, caller_arena: *ASTArena, callee_arena: *ASTArena, callee_expr_ref: i32, from_dep_index: i32, ctx: *PipelineDepCtx): i32 {
  let j: i32 = 0;
  while (j < mod.num_funcs) {
    if (j >= 256) {
      break;
    }
    let f: Func = mod.funcs[j];
    if (expr_var_name_equal_func(callee_arena, callee_expr_ref, mod, j)) {
      if (from_dep_index < 0) {
        return f.return_type_ref;
      }
      return get_dep_return_type_in_caller_arena(from_dep_index, f.return_type_ref, caller_arena, ctx);
    }
    j = j + 1;
  }
  return 0;
}

/** 在模块中按名字（字节+长度）查找函数，返回 return_type_ref；from_dep_index>=0 时通过 ctx 转成 caller_arena。供绑定/解构 import 解析调用。 */
function find_func_return_type_in_module_by_name(mod: *Module, caller_arena: *ASTArena, name: *u8, name_len: i32, from_dep_index: i32, ctx: *PipelineDepCtx): i32 {
  if (name_len <= 0 || name_len > 63) {
    return 0;
  }
  let j: i32 = 0;
  while (j < mod.num_funcs && j < 256) {
    let f: Func = mod.funcs[j];
    if (f.name_len == name_len && name_equal(f.name, f.name_len, name, name_len)) {
      if (from_dep_index < 0) {
        return f.return_type_ref;
      }
      return get_dep_return_type_in_caller_arena(from_dep_index, f.return_type_ref, caller_arena, ctx);
    }
    j = j + 1;
  }
  return 0;
}

/** 解析调用目标：先本模块，再 ctx.dep_modules(0..ctx.ndep-1)；callee_expr_ref 为 CALL 的 call_callee_ref。
 * 支持绑定 import（const x = import path）：callee 为 EXPR_FIELD_ACCESS(base=VAR "x", field）时按 import_binding_name 找 dep 再按字段名找函数。
 * 支持解构 import（const { f } = import path）：callee 为 EXPR_VAR 且 dep 的 import_kinds[i]==SELECT 且名字在 import_select_names 中时按该 dep 解析。 */
function resolve_call_callee_return_type(module: *Module, arena: *ASTArena, callee_expr_ref: i32, ctx: *PipelineDepCtx): i32 {
  if (callee_expr_ref <= 0 || callee_expr_ref > arena.num_exprs) {
    return 0;
  }
  let callee: Expr = ast_arena_expr_get(arena, callee_expr_ref);
  /* 绑定形式 process.getenv：callee 为 FIELD_ACCESS，base 为 VAR "process" */
  if (callee.kind == ExprKind.EXPR_FIELD_ACCESS && callee.field_access_base_ref > 0 && callee.field_access_base_ref <= arena.num_exprs) {
    let base: Expr = ast_arena_expr_get(arena, callee.field_access_base_ref);
    if (base.kind == ExprKind.EXPR_VAR && base.var_name_len > 0 && base.var_name_len <= 63) {
      let ii: i32 = 0;
      while (ii < module.num_imports && ii < ctx.ndep && ii < 32) {
        if (module.import_kinds[ii] == 1 && module.import_binding_name_len[ii] == base.var_name_len && name_equal(&module.import_binding_name[ii][0], module.import_binding_name_len[ii], base.var_name, base.var_name_len)) {
          let dm: *Module = ctx.dep_modules[ii];
          if (dm != 0 as *Module) {
            let ret: i32 = find_func_return_type_in_module_by_name(dm, arena, callee.field_access_field_name, callee.field_access_field_len, ii, ctx);
            if (ret != 0) {
              return ret;
            }
          }
          break;
        }
        ii = ii + 1;
      }
    }
  }
  let minus_one: i32 = 0 - 1;
  let ret: i32 = find_func_return_type_in_module(module, arena, arena, arena, callee_expr_ref, minus_one, ctx);
  if (ret != 0) {
    return ret;
  }
  let i: i32 = 0;
  while (i < ctx.ndep) {
    if (i >= 32) {
      break;
    }
    let dm: *Module = ctx.dep_modules[i];
    ret = find_func_return_type_in_module(dm, arena, arena, arena, callee_expr_ref, i, ctx);
    if (ret != 0) {
      return ret;
    }
    /* 解构形式 const { getenv } = import std.process；裸名 getenv 在 dep i 的 import_select_names 中 */
    if (i < module.num_imports && module.import_kinds[i] == 2 && callee.kind == ExprKind.EXPR_VAR && callee.var_name_len > 0) {
      let k: i32 = 0;
      while (k < module.import_select_count[i] && k < 8) {
        if (module.import_select_name_lens[i][k] == callee.var_name_len && name_equal(&module.import_select_names[i][k][0], module.import_select_name_lens[i][k], callee.var_name, callee.var_name_len)) {
          if (dm != 0 as *Module) {
            ret = find_func_return_type_in_module_by_name(dm, arena, callee.var_name, callee.var_name_len, i, ctx);
            if (ret != 0) {
              return ret;
            }
          }
          break;
        }
        k = k + 1;
      }
    }
    i = i + 1;
  }
  return 0;
}

/** 取表达式的类型池下标（内部）；仅在 ref 已通过 null/边界检查后调用。 */
function expr_type_ref_impl(arena: *ASTArena, expr_ref: i32): i32 {
  let e: Expr = ast_arena_expr_get(arena, expr_ref);
  return e.resolved_type_ref;
}

/** 取表达式的类型池下标；ref 为 0 或无效时返回 0。 */
function expr_type_ref(arena: *ASTArena, expr_ref: i32): i32 {
  if (ref_is_null(expr_ref)) {
    return 0;
  }
  if (expr_ref <= 0 || expr_ref > arena.num_exprs) {
    return 0;
  }
  return expr_type_ref_impl(arena, expr_ref);
}

/** 判断类型池下标是否为 bool（内部）；仅在 type_ref 已通过 null/边界检查后调用。 */
function type_ref_is_bool_impl(arena: *ASTArena, type_ref: i32): bool {
  let t: Type = ast_arena_type_get(arena, type_ref);
  return t.kind == TypeKind.TYPE_BOOL;
}

/** 判断类型池下标是否为 bool 类型。 */
function type_ref_is_bool(arena: *ASTArena, type_ref: i32): bool {
  if (ref_is_null(type_ref)) {
    return false;
  }
  if (type_ref <= 0 || type_ref > arena.num_types) {
    return false;
  }
  return type_ref_is_bool_impl(arena, type_ref);
}

/** 内部实现：在 a、b 已非 null 且 a!=b 时调用，避免 codegen 将 type_get 提升到 null 检查前导致 type_get(arena,0) panic。 */
function type_refs_equal_impl(arena: *ASTArena, a: i32, b: i32): bool {
  let ta: Type = ast_arena_type_get(arena, a);
  let tb: Type = ast_arena_type_get(arena, b);
  if (ta.kind != tb.kind) {
    return false;
  }
  if (ta.kind == TypeKind.TYPE_NAMED && ta.name_len == tb.name_len) {
    let i: i32 = 0;
    while (i < ta.name_len) {
      if (ta.name[i] != tb.name[i]) {
        return false;
      }
      i = i + 1;
    }
    return true;
  }
  if (ta.kind == TypeKind.TYPE_PTR || ta.kind == TypeKind.TYPE_SLICE) {
    return type_refs_equal(arena, ta.elem_type_ref, tb.elem_type_ref);
  }
  if (ta.kind == TypeKind.TYPE_ARRAY) {
    return ta.array_size == tb.array_size && type_refs_equal(arena, ta.elem_type_ref, tb.elem_type_ref);
  }
  return true;
}

/** 判断两个类型池下标是否表示同一类型（相等）。 */
function type_refs_equal(arena: *ASTArena, a: i32, b: i32): bool {
  if (ref_is_null(a) || ref_is_null(b)) {
    return a == b;
  }
  if (a == b) {
    return true;
  }
  return type_refs_equal_impl(arena, a, b);
}

/**
 * 递归检查表达式（内部）：仅在 expr_ref 已通过 null/边界检查后调用，避免 codegen 将 expr_get 提升到检查前导致 panic。
 * module 用于阶段 5.2 跨模块 EXPR_CALL 时解析 callee。
 */
function check_expr_impl(module: *Module, arena: *ASTArena, expr_ref: i32, return_type_ref: i32, ctx: *PipelineDepCtx): i32 {
  let e: Expr = ast_arena_expr_get(arena, expr_ref);
  /* EXPR_FLOAT_LIT：填写 64 位位模式供 asm 后端发射 double 立即数（常量池/位模式）。 */
  if (e.kind == ExprKind.EXPR_FLOAT_LIT) {
    e.float_bits_lo = typeck_float64_bits_lo(e.float_val);
    e.float_bits_hi = typeck_float64_bits_hi(e.float_val);
    ast_arena_expr_set(arena, expr_ref, e);
  }
  if (e.kind == ExprKind.EXPR_IF || e.kind == ExprKind.EXPR_TERNARY) {
    if (!ref_is_null(e.if_cond_ref)) {
      if (!type_ref_is_bool(arena, expr_type_ref(arena, e.if_cond_ref))) {
        return -1;
      }
    }
    if (check_expr(module, arena, e.if_then_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    if (!ref_is_null(e.if_else_ref) && check_expr(module, arena, e.if_else_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    /* if 表达式：两分支均为 NAMED（struct）时须类型一致；一侧 struct 一侧标量时取 struct 以便 __tmp 声明正确 */
    let ty_t: i32 = expr_type_ref(arena, e.if_then_ref);
    let ty_e: i32 = expr_type_ref(arena, e.if_else_ref);
    let t_named: bool = false;
    let e_named: bool = false;
    if (!ref_is_null(ty_t) && ty_t > 0 && ty_t <= arena.num_types) {
      let tt: Type = ast_arena_type_get(arena, ty_t);
      t_named = (tt.kind == TypeKind.TYPE_NAMED);
    }
    if (!ref_is_null(ty_e) && ty_e > 0 && ty_e <= arena.num_types) {
      let te: Type = ast_arena_type_get(arena, ty_e);
      e_named = (te.kind == TypeKind.TYPE_NAMED);
    }
    if (!ref_is_null(ty_t) && !ref_is_null(ty_e) && t_named && e_named && !type_refs_equal(arena, ty_t, ty_e)) {
      return -1;
    }
    if (!ref_is_null(ty_t) && !ref_is_null(ty_e)) {
      e.resolved_type_ref = (e_named && !t_named) ? ty_e : ty_t;
      ast_arena_expr_set(arena, expr_ref, e);
    } else if (!ref_is_null(ty_t)) {
      e.resolved_type_ref = ty_t;
      ast_arena_expr_set(arena, expr_ref, e);
    } else if (!ref_is_null(ty_e)) {
      e.resolved_type_ref = ty_e;
      ast_arena_expr_set(arena, expr_ref, e);
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_BLOCK) {
    if (check_block(module, arena, e.block_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    /* 块类型：有 final_expr 用其类型；否则若仅一条赋值语句则用赋值 RHS 类型（如 else { __tmp = (struct ast_Type){0} }），供 if 表达式取 else 分支 struct 类型 */
    if (e.block_ref > 0 && e.block_ref <= arena.num_blocks) {
      let b: Block = ast_arena_block_get(arena, e.block_ref);
      if (!ref_is_null(b.final_expr_ref)) {
        e.resolved_type_ref = expr_type_ref(arena, b.final_expr_ref);
        ast_arena_expr_set(arena, expr_ref, e);
      } else if (b.num_expr_stmts == 1 && b.expr_stmt_refs[0] > 0 && b.expr_stmt_refs[0] <= arena.num_exprs) {
        let st: Expr = ast_arena_expr_get(arena, b.expr_stmt_refs[0]);
        if ((st.kind == ExprKind.EXPR_ASSIGN || st.kind == ExprKind.EXPR_ADD_ASSIGN || st.kind == ExprKind.EXPR_SUB_ASSIGN || st.kind == ExprKind.EXPR_MUL_ASSIGN || st.kind == ExprKind.EXPR_DIV_ASSIGN || st.kind == ExprKind.EXPR_MOD_ASSIGN || st.kind == ExprKind.EXPR_BITAND_ASSIGN || st.kind == ExprKind.EXPR_BITOR_ASSIGN || st.kind == ExprKind.EXPR_BITXOR_ASSIGN || st.kind == ExprKind.EXPR_SHL_ASSIGN || st.kind == ExprKind.EXPR_SHR_ASSIGN) && !ref_is_null(st.binop_right_ref)) {
          e.resolved_type_ref = expr_type_ref(arena, st.binop_right_ref);
          ast_arena_expr_set(arena, expr_ref, e);
        }
      }
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_ASSIGN || e.kind == ExprKind.EXPR_ADD_ASSIGN || e.kind == ExprKind.EXPR_SUB_ASSIGN || e.kind == ExprKind.EXPR_MUL_ASSIGN || e.kind == ExprKind.EXPR_DIV_ASSIGN || e.kind == ExprKind.EXPR_MOD_ASSIGN || e.kind == ExprKind.EXPR_BITAND_ASSIGN || e.kind == ExprKind.EXPR_BITOR_ASSIGN || e.kind == ExprKind.EXPR_BITXOR_ASSIGN || e.kind == ExprKind.EXPR_SHL_ASSIGN || e.kind == ExprKind.EXPR_SHR_ASSIGN) {
    let left_ref: i32 = e.binop_left_ref;
    let right_ref: i32 = e.binop_right_ref;
    if (!ref_is_null(left_ref) && !ref_is_null(right_ref)) {
      let lt: i32 = expr_type_ref(arena, left_ref);
      let rt: i32 = expr_type_ref(arena, right_ref);
      if (!ref_is_null(lt) && !ref_is_null(rt) && !type_refs_equal(arena, lt, rt)) {
        return -1;
      }
    }
    if (check_expr(module, arena, left_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    if (check_expr(module, arena, right_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_RETURN) {
    if (!ref_is_null(return_type_ref)) {
      let op_ref: i32 = e.unary_operand_ref;
      if (!ref_is_null(op_ref)) {
        if (!type_refs_equal(arena, expr_type_ref(arena, op_ref), return_type_ref)) {
          return -1;
        }
      }
    }
    return check_expr(module, arena, e.unary_operand_ref, return_type_ref, ctx);
  }
  if (e.kind == ExprKind.EXPR_PANIC) {
    return check_expr(module, arena, e.unary_operand_ref, return_type_ref, ctx);
  }
  if (e.kind == ExprKind.EXPR_MATCH) {
    if (check_expr(module, arena, e.match_matched_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    let i: i32 = 0;
    while (i < e.match_num_arms) {
      if (i >= 16) {
        break;
      }
      if (check_expr(module, arena, e.match_arm_result_refs[i], return_type_ref, ctx) != 0) {
        return -1;
      }
      i = i + 1;
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_FIELD_ACCESS) {
    if (check_expr(module, arena, e.field_access_base_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    let base: Expr = ast_arena_expr_get(arena, e.field_access_base_ref);
    if (!ref_is_null(base.resolved_type_ref) && base.resolved_type_ref > 0 && base.resolved_type_ref <= arena.num_types) {
      let bt: Type = ast_arena_type_get(arena, base.resolved_type_ref);
      if (bt.kind == TypeKind.TYPE_NAMED && bt.name_len > 0) {
        let off: i32 = get_field_offset_from_layout(module, bt.name, bt.name_len, e.field_access_field_name, e.field_access_field_len);
        if (off >= 0) {
          e.field_access_offset = off;
          ast_arena_expr_set(arena, expr_ref, e);
        }
      }
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_INDEX) {
    if (check_expr(module, arena, e.index_base_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    return check_expr(module, arena, e.index_index_ref, return_type_ref, ctx);
  }
  if (e.kind == ExprKind.EXPR_CALL) {
    let j: i32 = 0;
    while (j < e.call_num_args) {
      if (j >= 16) {
        break;
      }
      if (check_expr(module, arena, e.call_arg_refs[j], return_type_ref, ctx) != 0) {
        return -1;
      }
      j = j + 1;
    }
    /* 阶段 5.2：解析 callee（本模块或 deps），设置 CALL 的 resolved_type_ref 为被调函数返回类型 */
    if (!ref_is_null(e.call_callee_ref)) {
      let callee: Expr = ast_arena_expr_get(arena, e.call_callee_ref);
      if (callee.kind == ExprKind.EXPR_VAR && callee.var_name_len > 0 && callee.var_name_len <= 63) {
        let ret_ty: i32 = resolve_call_callee_return_type(module, arena, e.call_callee_ref, ctx);
        if (ret_ty != 0) {
          e.resolved_type_ref = ret_ty;
          ast_arena_expr_set(arena, expr_ref, e);
        }
      }
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_METHOD_CALL) {
    if (check_expr(module, arena, e.method_call_base_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    let j: i32 = 0;
    while (j < e.method_call_num_args) {
      if (j >= 16) {
        break;
      }
      if (check_expr(module, arena, e.method_call_arg_refs[j], return_type_ref, ctx) != 0) {
        return -1;
      }
      j = j + 1;
    }
    return 0;
  }
  if (e.kind == ExprKind.EXPR_ADD || e.kind == ExprKind.EXPR_SUB || e.kind == ExprKind.EXPR_MUL || e.kind == ExprKind.EXPR_DIV || e.kind == ExprKind.EXPR_MOD
      || e.kind == ExprKind.EXPR_SHL || e.kind == ExprKind.EXPR_SHR || e.kind == ExprKind.EXPR_BITAND || e.kind == ExprKind.EXPR_BITOR || e.kind == ExprKind.EXPR_BITXOR
      || e.kind == ExprKind.EXPR_EQ || e.kind == ExprKind.EXPR_NE || e.kind == ExprKind.EXPR_LT || e.kind == ExprKind.EXPR_LE || e.kind == ExprKind.EXPR_GT || e.kind == ExprKind.EXPR_GE
      || e.kind == ExprKind.EXPR_LOGAND || e.kind == ExprKind.EXPR_LOGOR) {
    if (check_expr(module, arena, e.binop_left_ref, return_type_ref, ctx) != 0) {
      return -1;
    }
    return check_expr(module, arena, e.binop_right_ref, return_type_ref, ctx);
  }
  if (e.kind == ExprKind.EXPR_NEG || e.kind == ExprKind.EXPR_BITNOT || e.kind == ExprKind.EXPR_LOGNOT) {
    return check_expr(module, arena, e.unary_operand_ref, return_type_ref, ctx);
  }
  if (e.kind == ExprKind.EXPR_VAR && ctx.current_block_ref != 0 && ctx.current_block_ref <= arena.num_blocks) {
    let b: Block = ast_arena_block_get(arena, ctx.current_block_ref);
    let i: i32 = 0;
    while (i < b.num_consts && i < 64) {
      let cd: ConstDecl = b.const_decls[i];
      if (!ref_is_null(cd.type_ref) && name_equal(cd.name, cd.name_len, e.var_name, e.var_name_len)) {
        e.resolved_type_ref = cd.type_ref;
        ast_arena_expr_set(arena, expr_ref, e);
        return 0;
      }
      i = i + 1;
    }
    i = 0;
    while (i < b.num_lets && i < 64) {
      let ld: LetDecl = b.let_decls[i];
      if (!ref_is_null(ld.type_ref) && name_equal(ld.name, ld.name_len, e.var_name, e.var_name_len)) {
        e.resolved_type_ref = ld.type_ref;
        ast_arena_expr_set(arena, expr_ref, e);
        return 0;
      }
      i = i + 1;
    }
  }
  /* 未在块内找到时，从当前函数的形参解析（供库函数如 token_is_eof(t: Token) 使用） */
  if (e.kind == ExprKind.EXPR_VAR && ctx.current_func_index >= 0 && ctx.current_func_index < module.num_funcs) {
    let f: Func = module.funcs[ctx.current_func_index];
    let pi: i32 = 0;
    while (pi < f.num_params && pi < 16) {
      let p: Param = f.params[pi];
      if (!ref_is_null(p.type_ref) && name_equal(p.name, p.name_len, e.var_name, e.var_name_len)) {
        e.resolved_type_ref = p.type_ref;
        ast_arena_expr_set(arena, expr_ref, e);
        return 0;
      }
      pi = pi + 1;
    }
  }
  if (e.kind == ExprKind.EXPR_STRUCT_LIT) {
    let fi: i32 = 0;
    while (fi < e.struct_lit_num_fields && fi < 8) {
      if (!ref_is_null(e.struct_lit_init_refs[fi]) && check_expr(module, arena, e.struct_lit_init_refs[fi], return_type_ref, ctx) != 0) {
        return -1;
      }
      fi = fi + 1;
    }
    if (ensure_struct_layout_from_struct_lit(module, e) != 0) {
      return -1;
    }
    /* 为结构体字面量设 resolved_type_ref，使 if-expr 的 then/else 类型推断正确，避免 codegen 生成 int __tmp = (struct X){0} */
    let tr: i32 = find_or_alloc_named_type_ref(arena, e.struct_lit_struct_name, e.struct_lit_struct_name_len);
    if (tr != 0) {
      e.resolved_type_ref = tr;
      ast_arena_expr_set(arena, expr_ref, e);
    }
    return 0;
  }
  return 0;
}

/**
 * 递归检查表达式：if/三元 条件须 bool；assign 左右类型一致；block 递归块；return 操作数类型与 return_type_ref 一致。
 * return_type_ref 为 0 时不校验返回类型。返回 0 通过，-1 失败。
 */
function check_expr(module: *Module, arena: *ASTArena, expr_ref: i32, return_type_ref: i32, ctx: *PipelineDepCtx): i32 {
  if (ref_is_null(expr_ref)) {
    return 0;
  }
  if (expr_ref <= 0 || expr_ref > arena.num_exprs) {
    return 0;
  }
  return check_expr_impl(module, arena, expr_ref, return_type_ref, ctx);
}

/**
 * 检查块（内部）：仅在 block_ref 已通过 null/边界检查后调用，避免 codegen 将 block_get 提升到检查前导致 panic。
 */
function check_block_impl(module: *Module, arena: *ASTArena, block_ref: i32, return_type_ref: i32, ctx: *PipelineDepCtx): i32 {
  let saved_block_ref: i32 = ctx.current_block_ref;
  ctx.current_block_ref = block_ref;
  let b: Block = ast_arena_block_get(arena, block_ref);
  let i: i32 = 0;
  while (i < b.num_consts) {
    if (i >= 64) {
      break;
    }
    let cd: ConstDecl = b.const_decls[i];
    if (check_expr(module, arena, cd.init_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (!ref_is_null(cd.init_ref) && !ref_is_null(cd.type_ref)) {
      let init_ty: i32 = expr_type_ref(arena, cd.init_ref);
      if (!ref_is_null(init_ty) && !type_refs_equal(arena, cd.type_ref, init_ty)) {
        ctx.current_block_ref = saved_block_ref;
        return -1;
      }
    }
    i = i + 1;
  }
  i = 0;
  while (i < b.num_lets) {
    if (i >= 64) {
      break;
    }
    let ld: LetDecl = b.let_decls[i];
    if (check_expr(module, arena, ld.init_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (!ref_is_null(ld.init_ref) && !ref_is_null(ld.type_ref)) {
      let init_ty: i32 = expr_type_ref(arena, ld.init_ref);
      if (!ref_is_null(init_ty) && !type_refs_equal(arena, ld.type_ref, init_ty)) {
        ctx.current_block_ref = saved_block_ref;
        return -1;
      }
    }
    i = i + 1;
  }
  i = 0;
  while (i < b.num_loops) {
    if (i >= 8) {
      break;
    }
    let w: WhileLoop = b.loops[i];
    if (!ref_is_null(w.cond_ref) && !type_ref_is_bool(arena, expr_type_ref(arena, w.cond_ref))) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_expr(module, arena, w.cond_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_block(module, arena, w.body_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    i = i + 1;
  }
  i = 0;
  while (i < b.num_for_loops) {
    if (i >= 8) {
      break;
    }
    let fl: ForLoop = b.for_loops[i];
    if (!ref_is_null(fl.cond_ref) && !type_ref_is_bool(arena, expr_type_ref(arena, fl.cond_ref))) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_expr(module, arena, fl.init_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_expr(module, arena, fl.cond_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_expr(module, arena, fl.step_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    if (check_block(module, arena, fl.body_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    i = i + 1;
  }
  i = 0;
  while (i < b.num_expr_stmts) {
    if (i >= 32) {
      break;
    }
    if (check_expr(module, arena, b.expr_stmt_refs[i], return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    i = i + 1;
  }
  if (!ref_is_null(b.final_expr_ref)) {
    if (check_expr(module, arena, b.final_expr_ref, return_type_ref, ctx) != 0) {
      ctx.current_block_ref = saved_block_ref;
      return -1;
    }
    /* 仅当块末表达式类型已解析时才与 return_type_ref 比较；未解析（如跨模块 call 未解析到返回类型）时不判失败，避免库模块 std.io 等 typeck -5。 */
    if (!ref_is_null(return_type_ref)) {
      let got: i32 = expr_type_ref(arena, b.final_expr_ref);
      if (!ref_is_null(got) && !type_refs_equal(arena, got, return_type_ref)) {
        ctx.current_block_ref = saved_block_ref;
        return -1;
      }
    }
  }
  ctx.current_block_ref = saved_block_ref;
  return 0;
}

/**
 * 检查块：const/let 类型与初值一致；while/for 条件须 bool；表达式语句与块末表达式递归检查；块末类型与函数返回类型一致。
 * return_type_ref 为 0 时不校验块末类型。
 */
function check_block(module: *Module, arena: *ASTArena, block_ref: i32, return_type_ref: i32, ctx: *PipelineDepCtx): i32 {
  if (ref_is_null(block_ref)) {
    return 0;
  }
  if (block_ref <= 0 || block_ref > arena.num_blocks) {
    return 0;
  }
  return check_block_impl(module, arena, block_ref, return_type_ref, ctx);
}

/**
 * 类型检查入口（内部）：在 main_func_index 已校验后调用，避免 codegen 将 funcs[main_func_index] 提升到 guard 前导致 panic。
 * 失败时返回负值：-1 is_extern，-2 body_ref null，-3 return_type_ref null，-4 ret_ty 非 i32/i64，-5 check_block 失败。
 */
function typeck_su_ast_impl(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx): i32 {
  let main_f: Func = module.funcs[module.main_func_index];
  /* 仅当明确为 extern（is_extern==1 且无体）时报错；避免 C/.su 布局或未初始化使 is_extern 非 0 时误拒有体 main。 */
  if (main_f.is_extern == 1 && ref_is_null(main_f.body_ref)) {
    return -1;
  }
  if (ref_is_null(main_f.body_ref) && ref_is_null(main_f.body_expr_ref)) {
    return -2;
  }
  if (ref_is_null(main_f.return_type_ref)) {
    return -3;
  }
  let ret_ty: Type = ast_arena_type_get(arena, main_f.return_type_ref);
  if (ret_ty.kind != TypeKind.TYPE_I32 && ret_ty.kind != TypeKind.TYPE_I64) {
    return -4;
  }
  let i: i32 = 0;
  while (i < module.num_funcs) {
    if (i >= 256) {
      break;
    }
    ctx.current_func_index = i;
    let f: Func = module.funcs[i];
    if (!ref_is_null(f.body_ref) && f.is_extern == 0) {
      if (check_block(module, arena, f.body_ref, f.return_type_ref, ctx) != 0) {
        ctx.current_func_index = -1;
        return -5;
      }
    }
    ctx.current_func_index = -1;
    i = i + 1;
  }
  return 0;
}

/**
 * 库模块类型检查：无 main 时仅遍历所有有体函数做 check_block，供 -backend asm -o xxx.o 编库用。
 * 返回 0 通过，-5 为 check_block 失败。
 */
function typeck_su_ast_library(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx): i32 {
  let i: i32 = 0;
  while (i < module.num_funcs) {
    if (i >= 256) {
      break;
    }
    ctx.current_func_index = i;
    let f: Func = module.funcs[i];
    if (!ref_is_null(f.body_ref) && f.is_extern == 0) {
      if (check_block(module, arena, f.body_ref, f.return_type_ref, ctx) != 0) {
        ctx.current_func_index = -1;
        return -5;
      }
    }
    ctx.current_func_index = -1;
    i = i + 1;
  }
  return 0;
}

/**
 * 类型检查入口：校验 main 存在且合法（非 extern、有体、返回 i32）；遍历所有有体函数，检查块与返回类型一致。
 * 返回 0 通过，-1 失败。
 */
function typeck_su_ast(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx): i32 {
  /* 失败码：-10 main_func_index<0，-11 main_func_index>=num_funcs，-1/-2/... 为 impl 内检查 */
  if (module.main_func_index < 0) {
    return -10;
  }
  if (module.main_func_index >= module.num_funcs) {
    return -11;
  }
  return typeck_su_ast_impl(module, arena, ctx);
}
