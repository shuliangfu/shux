  if (r.tok.kind != TokenKind.TOKEN_COLON) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) { lex_from_next_into(&lex, r); }
  out.pos = lex.pos; out.line = lex.line; out.col = lex.col;
}
function skip_one_extern_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) {
