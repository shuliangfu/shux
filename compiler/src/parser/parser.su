          ck = ck + 1;
        }
        let z: u8 = 0;
        while (ck < 64) {
          ve.var_name[ck] = z;
          ck = ck + 1;
        }
        ve.binop_left_ref = 0;
        ve.binop_right_ref = 0;
        ve.unary_operand_ref = 0;
        ve.if_cond_ref = 0;
        ve.if_then_ref = 0;
        ve.if_else_ref = 0;
        ve.block_ref = 0;
        ve.match_matched_ref = 0;
        ve.match_num_arms = 0;
