      ne.field_access_is_enum_variant = 0;
      ne.field_access_offset = 0;
      ne.index_base_ref = 0;
      ne.index_index_ref = 0;
      ne.index_base_is_slice = 0;
      ne.call_callee_ref = 0;
      ne.call_num_args = 0;
      ne.method_call_base_ref = 0;
      ne.method_call_name_len = 0;
      ne.method_call_num_args = 0;
      ne.const_folded_val = 0;
      ne.const_folded_valid = 0;
      ne.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, neg_ref, ne);
      final_expr_ref = neg_ref;
    }
    /* 阶段 5：return ident(); 无参调用，构建 EXPR_VAR(callee) + EXPR_CALL，供多文件 main 中 return bar(); */
    if (res.has_call_expr && res.return_expr_ref == 0 && res.call_callee_len > 0 && res.call_callee_len <= 63) {
      let callee_ref: i32 = ast_arena_expr_alloc(arena);
      if (callee_ref != 0) {
        let ve: Expr = ast_arena_expr_get(arena, callee_ref);
        ve.kind = ExprKind.EXPR_VAR;
        ve.resolved_type_ref = 0;
        ve.line = 0;
        ve.col = 0;
        ve.var_name_len = res.call_callee_len;
        let ck: i32 = 0;
        while (ck < res.call_callee_len && ck < 64) {
          ve.var_name[ck] = res.call_callee_name[ck];
          ck = ck + 1;
        }
        let z: u8 = 0;
        while (ck < 64) {
          ve.var_name[ck] = z;
          ck = ck + 1;
        }
        ve.binop_left_ref = 0;
        ve.binop_right_ref = 0;
        ve.unary_operand_ref = 0;
        ve.if_cond_ref = 0;
        ve.if_then_ref = 0;
        ve.if_else_ref = 0;
        ve.block_ref = 0;
        ve.match_matched_ref = 0;
        ve.match_num_arms = 0;
        ast.expr_init_match_enum(&ve);
        ve.field_access_base_ref = 0;
        ve.field_access_field_len = 0;
        ve.field_access_is_enum_variant = 0;
        ve.field_access_offset = 0;
        ve.index_base_ref = 0;
        ve.index_index_ref = 0;
        ve.index_base_is_slice = 0;
        ve.call_callee_ref = 0;
        ve.call_num_args = 0;
        ve.method_call_base_ref = 0;
        ve.method_call_name_len = 0;
        ve.method_call_num_args = 0;
        ve.const_folded_val = 0;
        ve.const_folded_valid = 0;
        ve.index_proven_in_bounds = 0;
        ast_arena_expr_set(arena, callee_ref, ve);
        let call_ref: i32 = ast_arena_expr_alloc(arena);
        if (call_ref != 0) {
          let ce: Expr = ast_arena_expr_get(arena, call_ref);
          ce.kind = ExprKind.EXPR_CALL;
          ce.resolved_type_ref = type_ref;
          ce.line = 0;
          ce.col = 0;
          ce.call_callee_ref = callee_ref;
          /* 有参调用：res.call_num_args>0 为解析得到的整型实参（如 return add(1,2)），否则用当前函数形参名 */
          if (res.call_num_args > 0) {
            ce.call_num_args = res.call_num_args;
            if (ce.call_num_args > 16) { ce.call_num_args = 16; }
          } else {
            ce.call_num_args = res.num_params;
            if (ce.call_num_args > 16) { ce.call_num_args = 16; }
          }
          let arg_i: i32 = 0;
          while (arg_i < 16) {
            ce.call_arg_refs[arg_i] = 0;
            arg_i = arg_i + 1;
          }
          arg_i = 0;
          while (arg_i < ce.call_num_args && arg_i < 64) {
            let arg_ref: i32 = ast_arena_expr_alloc(arena);
            if (arg_ref != 0) {
              let ae: Expr = ast_arena_expr_get(arena, arg_ref);
              ae.resolved_type_ref = 0;
              ae.line = 0;
              ae.col = 0;
              ae.binop_left_ref = 0;
              if (res.call_num_args > 0 && arg_i < res.call_num_args) {
                ae.kind = ExprKind.EXPR_LIT;
                ae.int_val = res.call_arg_vals[arg_i];
              } else {
                ae.kind = ExprKind.EXPR_VAR;
                ae.var_name_len = res.param_name_lens[arg_i];
                let k: i32 = 0;
                while (k < res.param_name_lens[arg_i] && k < 64) {
                  ae.var_name[k] = res.param_names[arg_i][k];
                  k = k + 1;
                }
                let z: u8 = 0;
                while (k < 64) {
                  ae.var_name[k] = z;
                  k = k + 1;
                }
              }
              ae.binop_left_ref = 0;
              ae.binop_right_ref = 0;
              ae.unary_operand_ref = 0;
              ae.if_cond_ref = 0;
              ae.if_then_ref = 0;
              ae.if_else_ref = 0;
              ae.block_ref = 0;
              ae.match_matched_ref = 0;
              ae.match_num_arms = 0;
              ast.expr_init_match_enum(&ae);
              ae.field_access_base_ref = 0;
              ae.field_access_field_len = 0;
              ae.field_access_is_enum_variant = 0;
              ae.field_access_offset = 0;
              ae.index_base_ref = 0;
              ae.index_index_ref = 0;
              ae.index_base_is_slice = 0;
              ae.call_callee_ref = 0;
              ae.call_num_args = 0;
              ae.method_call_base_ref = 0;
              ae.method_call_name_len = 0;
              ae.method_call_num_args = 0;
              ae.const_folded_val = 0;
              ae.const_folded_valid = 0;
              ae.index_proven_in_bounds = 0;
              ast_arena_expr_set(arena, arg_ref, ae);
              ce.call_arg_refs[arg_i] = arg_ref;
            }
            arg_i = arg_i + 1;
          }
          ce.binop_left_ref = 0;
          ce.binop_right_ref = 0;
          ce.unary_operand_ref = 0;
          ce.if_cond_ref = 0;
          ce.if_then_ref = 0;
          ce.if_else_ref = 0;
          ce.block_ref = 0;
          ce.match_matched_ref = 0;
          ce.match_num_arms = 0;
          ast.expr_init_match_enum(&ce);
          ce.field_access_base_ref = 0;
          ce.field_access_field_len = 0;
          ce.field_access_is_enum_variant = 0;
          ce.field_access_offset = 0;
          ce.index_base_ref = 0;
          ce.index_index_ref = 0;
          ce.index_base_is_slice = 0;
          ce.method_call_base_ref = 0;
          ce.method_call_name_len = 0;
          ce.method_call_num_args = 0;
          ce.const_folded_val = 0;
          ce.const_folded_valid = 0;
          ce.index_proven_in_bounds = 0;
          ast_arena_expr_set(arena, call_ref, ce);
          final_expr_ref = call_ref;
        }
      }
    }

    let block_ref: i32 = ast_arena_block_alloc(arena);
    if (block_ref == 0) {
      return ParseIntoResult { ok: -1, main_idx: -1010 }
    }
    let b: Block = ast_arena_block_get(arena, block_ref);
    b.num_consts = res.num_consts;
    b.num_lets = res.num_lets;
    b.num_early_lets = 0;
    b.num_loops = res.num_loops;
    b.num_for_loops = res.num_for_loops;
    b.num_if_stmts = res.num_if_stmts;
    b.num_defers = 0;
    b.num_labeled_stmts = 0;
    b.num_expr_stmts = 0;
    /* 将解析得到的返回值表达式包装为 EXPR_RETURN，供给 codegen（解析阶段已强制显式 return）。 */
    let return_wrap: i32 = ast_arena_expr_alloc(arena);
    if (return_wrap != 0) {
      let rwe: Expr = ast_arena_expr_get(arena, return_wrap);
      rwe.kind = ExprKind.EXPR_RETURN;
      rwe.resolved_type_ref = type_ref;
      rwe.line = 0;
      rwe.col = 0;
      rwe.int_val = 0;
      rwe.binop_left_ref = 0;
      rwe.binop_right_ref = 0;
      rwe.unary_operand_ref = final_expr_ref;
      rwe.if_cond_ref = 0;
      rwe.if_then_ref = 0;
      rwe.if_else_ref = 0;
      rwe.block_ref = 0;
      rwe.match_matched_ref = 0;
      rwe.match_num_arms = 0;
      ast.expr_init_match_enum(&rwe);
      rwe.field_access_base_ref = 0;
      rwe.field_access_field_len = 0;
      rwe.field_access_is_enum_variant = 0;
      rwe.field_access_offset = 0;
      rwe.index_base_ref = 0;
      rwe.index_index_ref = 0;
      rwe.index_base_is_slice = 0;
      rwe.call_callee_ref = 0;
      rwe.call_num_args = 0;
      rwe.method_call_base_ref = 0;
      rwe.method_call_name_len = 0;
      rwe.method_call_num_args = 0;
      rwe.const_folded_val = 0;
      rwe.const_folded_valid = 0;
      rwe.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, return_wrap, rwe);
      final_expr_ref = return_wrap;
    }
    b.final_expr_ref = final_expr_ref;
    b.num_stmt_order = 0;
    let const_i: i32 = 0;
    while (const_i < res.num_consts && const_i < 256) {
      let cinit_ref: i32 = ast_arena_expr_alloc(arena);
      if (cinit_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let ce: Expr = ast_arena_expr_get(arena, cinit_ref);
      ce.kind = ExprKind.EXPR_LIT;
      ce.resolved_type_ref = type_ref;
      ce.line = 0;
      ce.col = 0;
      ce.int_val = res.const_init_vals[const_i];
      ce.binop_left_ref = 0;
      ce.binop_right_ref = 0;
      ce.unary_operand_ref = 0;
      ce.if_cond_ref = 0;
      ce.if_then_ref = 0;
      ce.if_else_ref = 0;
      ce.block_ref = 0;
      ce.match_matched_ref = 0;
      ce.match_num_arms = 0;
      ast.expr_init_match_enum(&ce);
      ce.field_access_base_ref = 0;
      ce.field_access_field_len = 0;
      ce.field_access_is_enum_variant = 0;
      ce.field_access_offset = 0;
      ce.index_base_ref = 0;
      ce.index_index_ref = 0;
      ce.index_base_is_slice = 0;
      ce.call_callee_ref = 0;
      ce.call_num_args = 0;
      ce.method_call_base_ref = 0;
      ce.method_call_name_len = 0;
      ce.method_call_num_args = 0;
      ce.const_folded_val = 0;
      ce.const_folded_valid = 0;
      ce.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, cinit_ref, ce);
      let cd: ConstDecl = b.const_decls[const_i];
      let ck: i32 = 0;
      while (ck < res.const_name_lens[const_i] && ck < 64) {
        let const_row: [64]u8 = res.const_names[const_i];
        cd.name[ck] = const_row[ck];
        ck = ck + 1;
      }
      let zero_const: u8 = 0;
      while (ck < 64) {
        cd.name[ck] = zero_const;
        ck = ck + 1;
      }
      cd.name_len = res.const_name_lens[const_i];
      cd.type_ref = type_ref;
      cd.init_ref = cinit_ref;
      b.const_decls[const_i] = cd;
      const_i = const_i + 1;
    }
    let let_i: i32 = 0;
    while (let_i < res.num_lets && let_i < 256) {
      let let_decl_ty: i32 = type_ref;
      if (res.let_type_refs[let_i] != 0) {
        let_decl_ty = res.let_type_refs[let_i];
      }
      let init_ref: i32 = 0;
      if (res.let_init_refs[let_i] != 0) {
        init_ref = res.let_init_refs[let_i];
      } else {
        init_ref = ast_arena_expr_alloc(arena);
        if (init_ref == 0) {
          return ParseIntoResult { ok: -1, main_idx: -1 }
        }
        let le: Expr = ast_arena_expr_get(arena, init_ref);
        le.kind = ExprKind.EXPR_LIT;
        le.resolved_type_ref = let_decl_ty;
        le.line = 0;
        le.col = 0;
        le.int_val = res.let_init_vals[let_i];
      le.binop_left_ref = 0;
      le.binop_right_ref = 0;
      le.unary_operand_ref = 0;
      le.if_cond_ref = 0;
      le.if_then_ref = 0;
      le.if_else_ref = 0;
      le.block_ref = 0;
      le.match_matched_ref = 0;
      le.match_num_arms = 0;
      ast.expr_init_match_enum(&le);
      le.field_access_base_ref = 0;
      le.field_access_field_len = 0;
      le.field_access_is_enum_variant = 0;
      le.field_access_offset = 0;
      le.index_base_ref = 0;
      le.index_index_ref = 0;
      le.index_base_is_slice = 0;
      le.call_callee_ref = 0;
      le.call_num_args = 0;
      le.method_call_base_ref = 0;
      le.method_call_name_len = 0;
      le.method_call_num_args = 0;
      le.const_folded_val = 0;
      le.const_folded_valid = 0;
      le.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, init_ref, le);
      }
      let ld: LetDecl = b.let_decls[let_i];
      let lk: i32 = 0;
      while (lk < res.let_name_lens[let_i] && lk < 64) {
        let let_row: [64]u8 = res.let_names[let_i];
        ld.name[lk] = let_row[lk];
        lk = lk + 1;
      }
      let zero_let: u8 = 0;
      while (lk < 64) {
        ld.name[lk] = zero_let;
        lk = lk + 1;
      }
      ld.name_len = res.let_name_lens[let_i];
      ld.type_ref = let_decl_ty;
      ld.init_ref = init_ref;
      b.let_decls[let_i] = ld;
      let_i = let_i + 1;
    }
    let loop_fill_i: i32 = 0;
    while (loop_fill_i < res.num_loops && loop_fill_i < 8) {
      b.loops[loop_fill_i].cond_ref = res.loop_cond_refs[loop_fill_i];
      b.loops[loop_fill_i].body_ref = res.loop_body_refs[loop_fill_i];
      loop_fill_i = loop_fill_i + 1;
    }
    let for_fill_i: i32 = 0;
    while (for_fill_i < res.num_for_loops && for_fill_i < 8) {
      b.for_loops[for_fill_i].init_ref = res.for_init_refs[for_fill_i];
      b.for_loops[for_fill_i].cond_ref = res.for_cond_refs[for_fill_i];
      b.for_loops[for_fill_i].step_ref = res.for_step_refs[for_fill_i];
      b.for_loops[for_fill_i].body_ref = res.for_body_refs[for_fill_i];
      for_fill_i = for_fill_i + 1;
    }
    let if_fill_i: i32 = 0;
    while (if_fill_i < res.num_if_stmts && if_fill_i < 16) {
      b.if_stmts[if_fill_i].cond_ref = res.if_cond_refs[if_fill_i];
      b.if_stmts[if_fill_i].then_body_ref = res.if_then_body_refs[if_fill_i];
      if_fill_i = if_fill_i + 1;
    }
    /* stmt_order：优先用 parse_one_function_impl 按源码累计的序（含 expr;），否则按批回退 */
    if (res.num_src_stmt_order > 0) {
      let exj: i32 = 0;
      while (exj < res.num_src_body_expr_stmts && exj < 32) {
        b.expr_stmt_refs[exj] = res.src_body_expr_stmt_refs[exj];
        exj = exj + 1;
      }
      b.num_expr_stmts = res.num_src_body_expr_stmts;
      let sj: i32 = 0;
      while (sj < res.num_src_stmt_order && sj < 96) {
        b.stmt_order[sj].kind = res.src_stmt_kind[sj];
        b.stmt_order[sj].idx = res.src_stmt_idx[sj];
        sj = sj + 1;
      }
      b.num_stmt_order = sj;
    } else {
    let so: i32 = 0;
    let ci: i32 = 0;
    while (ci < b.num_consts && so < 96) {
      b.stmt_order[so].kind = 0;
      b.stmt_order[so].idx = ci;
      so = so + 1;
      ci = ci + 1;
    }
    let li: i32 = 0;
    while (li < b.num_lets && so < 96) {
      b.stmt_order[so].kind = 1;
      b.stmt_order[so].idx = li;
      so = so + 1;
      li = li + 1;
    }
    let loop_i: i32 = 0;
    while (loop_i < b.num_loops && so < 96) {
      b.stmt_order[so].kind = 3;
      b.stmt_order[so].idx = loop_i;
      so = so + 1;
      loop_i = loop_i + 1;
    }
    let for_i: i32 = 0;
    while (for_i < b.num_for_loops && so < 96) {
      b.stmt_order[so].kind = 4;
      b.stmt_order[so].idx = for_i;
      so = so + 1;
      for_i = for_i + 1;
    }
    let if_oi: i32 = 0;
    while (if_oi < b.num_if_stmts && so < 96) {
      b.stmt_order[so].kind = 5;
      b.stmt_order[so].idx = if_oi;
      so = so + 1;
      if_oi = if_oi + 1;
    }
    /* 仅有 final_expr（如单条 print_str(...) 等非 return 收尾）时，当作一条 expr_stmt 填入 stmt_order，供 codegen emit_block 输出；随后清空 final_expr_ref 以便补默认 return。 */
    if (!ref_is_null(b.final_expr_ref) && b.num_expr_stmts == 0 && so < 96) {
      b.expr_stmt_refs[0] = b.final_expr_ref;
      b.num_expr_stmts = 1;
      b.final_expr_ref = 0;
      b.stmt_order[so].kind = 2;
      b.stmt_order[so].idx = 0;
      so = so + 1;
    }
    b.num_stmt_order = so;
    }
    /* 已有 expr_stmt_refs 时，final_expr_ref 常为解析副产品；清空以免与 stmt_order 中尾语句重复经过 typeck/codegen（void 赋值尾尤为典型）。 */
    if (b.num_expr_stmts > 0) {
      b.final_expr_ref = 0;
    }
    ast_arena_block_set(arena, block_ref, b);

    /*
     * 勿 let f: Func = module.funcs[i]：Func 体量较大时按值读/写在当前 codegen 路径上可能丢字段，
     * 会直接抹掉刚写入的 return_type_ref（typeck dep 上出现 return_type_ref==0）。
     */
    let fi: i32 = module.num_funcs;
    module.funcs[fi].is_extern = 0;
    let k: i32 = 0;
    while (k < res.name_len && k < 64) {
      module.funcs[fi].name[k] = res.name[k];
      k = k + 1;
    }
    let zero_u8: u8 = 0;
    while (k < 64) {
      module.funcs[fi].name[k] = zero_u8;
      k = k + 1;
    }
    module.funcs[fi].name_len = res.name_len;
    module.funcs[fi].num_params = res.num_params;
    /** 形参表：须 pipeline_module_func_param_write 写槽；勿 Param 按值读写给 module（asm 下会丢 type_ref）。 */
    let p: i32 = 0;
    while (p < res.num_params && p < 16) {
      pipeline_module_func_param_write(module, fi, p, &res.param_names[p][0], res.param_name_lens[p], res.param_type_refs[p]);
      p = p + 1;
    }
    module.funcs[fi].return_type_ref = type_ref;
    module.funcs[fi].body_ref = block_ref;
    module.funcs[fi].is_extern = 0;
    if (is_main_storage[0] != 0) {
      main_idx = module.num_funcs;
    }
    module.num_funcs = module.num_funcs + 1;
    lex_from_onefunc_next_into(&lex, &res);
  }
  /* 库模块（仅 enum/struct/extern，无 function）：返回 ok 0、main_idx -1，供 pipeline 走 typeck_su_ast_library；-backend asm -o xxx.o 编单模块依赖此路径。 */
  if (module.num_funcs == 0) {
    return ParseIntoResult { ok: 0, main_idx: -1 }
  }
  /* 无 "main" 时保持 main_idx=-1，走 typeck_su_ast_library（-backend asm -o xxx.o 编库模块依赖此路径）；有 "main" 时返回其下标。 */
  let out_idx_storage: [1]i32 = [];
  out_idx_storage[0] = main_idx;
  return ParseIntoResult { ok: 0, main_idx: out_idx_storage[0] }
}

/**
 * 解析一条顶层 let 或 const：lex 为消费掉 LET/CONST 后的位置，期望「ident : type = expr ;」。
 * 成功时写 module.top_level_let_*、arena 中 type/expr，并设置 out.ok=true、out.next_lex；失败时 out.ok=false。
 */
function parse_one_top_level_let_into(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8, is_const: bool, out: *TopLevelLetResult): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    out.ok = false;
    return;
  }
  let name_len: i32 = r.tok.ident_len;
  if (name_len <= 0 || name_len > 63) {
    out.ok = false;
    return;
  }
  if (module.num_top_level_lets >= 32) {
    out.ok = false;
    return;
  }
  let n: i32 = module.num_top_level_lets;
  /** LET 绑定名 IDENT：token_start 含偏移 0，勿与「未初始化」共用哨兵。 */
  copy_slice_to_name64(source, r.token_start, name_len, module.top_level_let_names[n]);
  module.top_level_let_name_lens[n] = name_len;
  lex_from_result_ptr_into(&lex, &r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    out.ok = false;
    return;
  }
  lex_from_result_ptr_into(&lex, &r);
  lexer_next_into(&r, lex, source);
  /* 解析类型：* ident | i32 | i64 | bool | u8 | u32 | u64 | usize | void | ident */
  let type_ref: i32 = 0;
  if (r.tok.kind == TokenKind.TOKEN_STAR) {
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      out.ok = false;
      return;
    }
    let elem_ref: i32 = ast_arena_type_alloc(arena);
    if (elem_ref == 0) {
      out.ok = false;
      return;
    }
    let te: Type = ast_arena_type_get(arena, elem_ref);
    te.kind = TypeKind.TYPE_NAMED;
    te.name_len = r.tok.ident_len;
    if (te.name_len > 63) { te.name_len = 63; }
    let si: i32 = 0;
    while (si < te.name_len && si < 64) {
      if (r.token_start + (si as usize) < source.length) {
        te.name[si] = source[r.token_start + (si as usize)];
      }
      si = si + 1;
    }
    te.elem_type_ref = 0;
    te.array_size = 0;
    ast_arena_type_set(arena, elem_ref, te);
    type_ref = ast_arena_type_alloc(arena);
    if (type_ref != 0) {
      let t: Type = ast_arena_type_get(arena, type_ref);
      t.kind = TypeKind.TYPE_PTR;
      t.elem_type_ref = elem_ref;
      t.name_len = 0;
      t.array_size = 0;
      ast_arena_type_set(arena, type_ref, t);
    }
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
  } else if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_U8 || r.tok.kind == TokenKind.TOKEN_U32 || r.tok.kind == TokenKind.TOKEN_U64 || r.tok.kind == TokenKind.TOKEN_USIZE || r.tok.kind == TokenKind.TOKEN_ISIZE || r.tok.kind == TokenKind.TOKEN_VOID || r.tok.kind == TokenKind.TOKEN_IDENT) {
    type_ref = ast_arena_type_alloc(arena);
    if (type_ref != 0) {
      let t: Type = ast_arena_type_get(arena, type_ref);
      if (r.tok.kind == TokenKind.TOKEN_I32) {
        t.kind = TypeKind.TYPE_I32;
      } else if (r.tok.kind == TokenKind.TOKEN_I64) {
        t.kind = TypeKind.TYPE_I64;
      } else if (r.tok.kind == TokenKind.TOKEN_BOOL) {
        t.kind = TypeKind.TYPE_BOOL;
      } else if (r.tok.kind == TokenKind.TOKEN_U8) {
        t.kind = TypeKind.TYPE_U8;
      } else if (r.tok.kind == TokenKind.TOKEN_U32) {
        t.kind = TypeKind.TYPE_U32;
      } else if (r.tok.kind == TokenKind.TOKEN_U64) {
        t.kind = TypeKind.TYPE_U64;
      } else if (r.tok.kind == TokenKind.TOKEN_USIZE) {
        t.kind = TypeKind.TYPE_USIZE;
      } else if (r.tok.kind == TokenKind.TOKEN_ISIZE) {
        t.kind = TypeKind.TYPE_ISIZE;
      } else if (r.tok.kind == TokenKind.TOKEN_VOID) {
        t.kind = TypeKind.TYPE_VOID;
      } else {
        t.kind = TypeKind.TYPE_NAMED;
        t.name_len = r.tok.ident_len;
        if (t.name_len > 63) { t.name_len = 63; }
        let si2: i32 = 0;
        while (si2 < t.name_len && si2 < 64) {
          if (r.token_start + (si2 as usize) < source.length) {
            t.name[si2] = source[r.token_start + (si2 as usize)];
          }
          si2 = si2 + 1;
        }
      }
      t.elem_type_ref = 0;
      t.array_size = 0;
      ast_arena_type_set(arena, type_ref, t);
    }
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
  } else {
    out.ok = false;
    return;
  }
  if (r.tok.kind != TokenKind.TOKEN_ASSIGN) {
    out.ok = false;
    return;
  }
  lex_from_result_ptr_into(&lex, &r);
  let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
  parse_expr_into(arena, lex, source, &expr_res);
  if (!expr_res.ok) {
    out.ok = false;
    return;
  }
  lex = expr_res.next_lex;
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
    out.ok = false;
    return;
  }
  module.top_level_let_type_refs[n] = type_ref;
  module.top_level_let_init_refs[n] = expr_res.expr_ref;
  if (is_const) {
    module.top_level_let_is_const[n] = 1;
  } else {
    module.top_level_let_is_const[n] = 0;
  }
  module.num_top_level_lets = module.num_top_level_lets + 1;
  lex_from_next_into(&out.next_lex, r);
  out.ok = true;
}

/**
 * 与 parse_into 等价，接受 (data: *u8, len) 供无 slice 的 buf 路径使用；collect_imports 走 slice lexer_next_into；主循环用 lexer_next_buf_into 避免 LexerResult 按值 ABI 损坏。
 */
function parse_into_buf(arena: *ASTArena, module: *Module, data: *u8, len: i32): ParseIntoResult {
  let lex: Lexer = lexer_init();
  let main_idx: i32 = -1;
  let import_res: CollectImportsResult = CollectImportsResult { lex: lex };
  collect_imports_buf(lex, data, len, module, &import_res);
  copy_lex_from_import_into(&lex, &import_res);
  let loop_count_buf: i32 = 0;
  while (true) {
    /* 与 parse_into 一致：loop 上限 + 先读 token 再前进 lex，避免 extern 后停滞在 EOF */
    if (loop_count_buf >= 131072) {
      return ParseIntoResult { ok: -1, main_idx: -1003 }
    }
    loop_count_buf = loop_count_buf + 1;
    let iter_start_buf: Lexer = lex;
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
    lexer_next_buf_into(&r, lex, data, len);
    lex_from_next_into(&lex, r);
    if (r.tok.kind == TokenKind.TOKEN_STRUCT) {
      let slice_st: []u8 = parser_slice_from_buf(data, len);
      let lex_kw: Lexer = iter_start_buf;
      if (parse_struct_record_layout_into(arena, module, lex, slice_st, &lex) != 0) {
        skip_one_struct_into_buf(&lex, lex_kw, data, len);
      }
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_ENUM) {
      skip_one_enum_into_buf(&lex, iter_start_buf, data, len);
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_TRAIT) {
      skip_one_trait_into_buf(&lex, iter_start_buf, data, len);
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_IMPL) {
      skip_one_impl_into_buf(&lex, iter_start_buf, data, len);
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_EXTERN) {
      parse_one_extern_and_add_into_buf(arena, module, iter_start_buf, data, len, &lex);
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        skip_one_extern_into_buf(&lex, iter_start_buf, data, len);
      }
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    /* 顶层 let/const：与 C 流水线同步支持，供自举与 toplevel-let 测试 */
    if (r.tok.kind == TokenKind.TOKEN_LET || r.tok.kind == TokenKind.TOKEN_CONST) {
      let slice_tl: []u8 = parser_slice_from_buf(data, len);
      let toplevel_res: TopLevelLetResult = TopLevelLetResult { ok: false, next_lex: lex };
      parse_one_top_level_let_into(arena, module, r.next_lex, slice_tl, r.tok.kind == TokenKind.TOKEN_CONST, &toplevel_res);
      if (toplevel_res.ok) {
        lex = toplevel_res.next_lex;
        continue;
      }
    }
    if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
      let try_res: TrySkipAllowResult = TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
      parse_into_try_skip_allow_into_buf(&try_res, lex, r, data, len);
      if (try_res.skipped != 0) {
        lex_from_try_skip_into(&lex, try_res);
        if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
          lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
        }
        continue;
      }
      /* 非 function 且未 skip：可能是注释等，前进一个 token 再试，避免文件开头的注释导致 0 函数；EOF 时下面会处理。 */
      if (r.tok.kind == TokenKind.TOKEN_EOF) {
        break;
      }
      if (lex.pos == iter_start_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    /* 库模块或正常结束：break 后若为 EOF 则直接返回成功，避免在 EOF 处当作 function 解析导致死循环。 */
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      if (module.num_funcs == 0) {
        return ParseIntoResult { ok: 0, main_idx: -1 }
      }
      let out_idx_storage: [1]i32 = [];
      out_idx_storage[0] = main_idx;
      return ParseIntoResult { ok: 0, main_idx: out_idx_storage[0] }
    }
    /* 与 parse_into 完全一致：捕获 library 锚点后再次 lex_from_next_into(&lex, r)，避免 buf 路径上 LexerResult ABI 偶发 lex 滞后于 r.next_lex 导致 impl 误判失败。 */
    let lex_at_function_buf: Lexer = lex;
    lex_from_next_into(&lex, r);
    /* lex 当前在 function 之后，供 parse_one_function_impl 解析函数体 */
    /* 用 _into 避免 OneFuncResult 按值返回导致 ARM64 ABI 崩溃 */
    let empty64_buf: [64]u8 = [];
    let empty32_buf: [32]u8 = [];
    let dummy_pnames_buf: [16][32]u8 = [empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf, empty32_buf];
    let dummy_const_names_buf: [256][64]u8 = [];
    let dummy_const_lens_buf: [256]i32 = [];
    let dummy_const_vals_buf: [256]i32 = [];
    let dummy_let_names_buf: [256][64]u8 = [];
    let dummy_let_lens_buf: [256]i32 = [];
    let dummy_let_vals_buf: [256]i32 = [];
    let dummy_refs_buf: [256]i32 = [];
    let dummy_ltrefs_buf: [256]i32 = [];
    let dummy_loop_refs_buf: [8]i32 = [];
    let dummy_for_refs_buf: [8]i32 = [];
    let dummy_if_refs_buf: [16]i32 = [];
    let dummy_call_arg_vals_buf: [16]i32 = [];
    let res: OneFuncResult = OneFuncResult { ok: false, next_lex: lex, name: empty64_buf, name_len: 0, num_params: 0, param_names: dummy_pnames_buf, param_name_lens: [], param_type_refs: [], num_consts: 0, const_names: dummy_const_names_buf, const_name_lens: dummy_const_lens_buf, const_init_vals: dummy_const_vals_buf, num_lets: 0, let_names: dummy_let_names_buf, let_name_lens: dummy_let_lens_buf, let_init_vals: dummy_let_vals_buf, let_init_refs: dummy_refs_buf, let_type_refs: dummy_ltrefs_buf, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, if_cond_expr_ref: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, binop_left_param_idx: -1, binop_right_param_idx: -1, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: empty64_buf, call_callee_len: 0, return_var_name: [], return_var_name_len: 0, return_expr_ref: 0, call_num_args: 0, call_arg_vals: dummy_call_arg_vals_buf, num_loops: 0, loop_cond_refs: dummy_loop_refs_buf, loop_body_refs: dummy_loop_refs_buf, num_for_loops: 0, for_init_refs: dummy_for_refs_buf, for_cond_refs: dummy_for_refs_buf, for_step_refs: dummy_for_refs_buf, for_body_refs: dummy_for_refs_buf, num_if_stmts: 0, if_cond_refs: dummy_if_refs_buf, if_then_body_refs: dummy_if_refs_buf, num_src_stmt_order: 0, src_stmt_kind: [], src_stmt_idx: [], num_src_body_expr_stmts: 0, src_body_expr_stmt_refs: [], func_return_type_ref: 0 };
    let slice_for_impl: []u8 = parser_slice_from_buf(data, len);
    /* 与 parse_into（slice）一致：library 优先，避免 impl 抢走 token_is_eof 类形态 */
    let lib_buf_first: LibraryParseResult = parse_one_function_library_buf(arena, module, lex_at_function_buf, data, len);
    if (lib_buf_first.ok) {
      lex_from_library_into(&lex, lib_buf_first);
      continue;
    }
    parse_one_function_impl(&res, arena, lex, slice_for_impl);
    if (!res.ok) {
      parse_one_function_buf_into(&res, lex_at_function_buf, data, len);
    }
    if (!res.ok) {
      skip_one_function_full_into_buf(&lex, lex_at_function_buf, data, len);
      if (lex.pos == lex_at_function_buf.pos && lex.pos < (len as usize)) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    let is_main_storage: [1]i32 = [];
    if (res.name_len == 4 && res.name[0] == 109 && res.name[1] == 97 && res.name[2] == 105 && res.name[3] == 110) {
      is_main_storage[0] = 1;
    }
    if (module.num_funcs >= 256) {
      return ParseIntoResult { ok: -1, main_idx: -1 }
    }
    /* Buf 路径与 parse_into 一致：沿用签名 Ty，0 时再回退 i32 */
    let type_ref: i32 = res.func_return_type_ref;
    if (type_ref == 0) {
      type_ref = ast_arena_type_alloc(arena);
      if (type_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let t_fb: Type = ast_arena_type_get(arena, type_ref);
      t_fb.kind = TypeKind.TYPE_I32;
      t_fb.name_len = 0;
      t_fb.elem_type_ref = 0;
      t_fb.array_size = 0;
      ast_arena_type_set(arena, type_ref, t_fb);
    }

    let expr_ref: i32 = ast_arena_expr_alloc(arena);
    if (expr_ref == 0) {
      return ParseIntoResult { ok: -1, main_idx: -1 }
    }
    let e: Expr = ast_arena_expr_get(arena, expr_ref);
    if (res.return_var_name_len > 0) {
      /* return ident; 生成 EXPR_VAR 以便 codegen 输出变量名；类型须由 typeck 从形参/let/const 绑定，勿预设为返回类型否则漏报未定义名 */
      e.kind = ExprKind.EXPR_VAR;
      e.var_name_len = res.return_var_name_len;
      let rvi: i32 = 0;
      while (rvi < res.return_var_name_len && rvi < 64) {
        e.var_name[rvi] = res.return_var_name[rvi];
        rvi = rvi + 1;
      }
      let rvz: u8 = 0;
      while (rvi < 64) { e.var_name[rvi] = rvz; rvi = rvi + 1; }
      e.int_val = 0;
      e.resolved_type_ref = 0;
    } else {
      e.kind = ExprKind.EXPR_LIT;
      e.int_val = res.return_val;
      e.resolved_type_ref = type_ref;
    }
    e.line = 0;
    e.col = 0;
    e.binop_left_ref = 0;
    e.binop_right_ref = 0;
    e.unary_operand_ref = 0;
    e.if_cond_ref = 0;
    e.if_then_ref = 0;
    e.if_else_ref = 0;
    e.block_ref = 0;
    e.match_matched_ref = 0;
    e.match_num_arms = 0;
    ast.expr_init_match_enum(&e);
    e.field_access_base_ref = 0;
    e.field_access_field_len = 0;
    e.field_access_is_enum_variant = 0;
    e.field_access_offset = 0;
    e.index_base_ref = 0;
    e.index_index_ref = 0;
    e.index_base_is_slice = 0;
    e.call_callee_ref = 0;
    e.call_num_args = 0;
    e.method_call_base_ref = 0;
    e.method_call_name_len = 0;
    e.method_call_num_args = 0;
    e.const_folded_val = 0;
    e.const_folded_valid = 0;
    e.index_proven_in_bounds = 0;
    ast_arena_expr_set(arena, expr_ref, e);

    let final_expr_ref: i32 = expr_ref;
    if (res.return_expr_ref != 0) {
      final_expr_ref = res.return_expr_ref;
    }
    if (res.has_mul && !res.has_binop) {
      let mul_right_ref: i32 = ast_arena_expr_alloc(arena);
      if (mul_right_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let mre: Expr = ast_arena_expr_get(arena, mul_right_ref);
      mre.kind = ExprKind.EXPR_LIT;
      mre.resolved_type_ref = type_ref;
      mre.line = 0;
      mre.col = 0;
      mre.int_val = res.mul_right_val;
      mre.binop_left_ref = 0;
      mre.binop_right_ref = 0;
      mre.unary_operand_ref = 0;
      mre.if_cond_ref = 0;
      mre.if_then_ref = 0;
      mre.if_else_ref = 0;
      mre.block_ref = 0;
      mre.match_matched_ref = 0;
      mre.match_num_arms = 0;
      ast.expr_init_match_enum(&mre);
      mre.field_access_base_ref = 0;
      mre.field_access_field_len = 0;
      mre.field_access_is_enum_variant = 0;
      mre.field_access_offset = 0;
      mre.index_base_ref = 0;
      mre.index_index_ref = 0;
      mre.index_base_is_slice = 0;
      mre.call_callee_ref = 0;
      mre.call_num_args = 0;
      mre.method_call_base_ref = 0;
      mre.method_call_name_len = 0;
      mre.method_call_num_args = 0;
      mre.const_folded_val = 0;
      mre.const_folded_valid = 0;
      mre.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, mul_right_ref, mre);
      let mul_ref: i32 = ast_arena_expr_alloc(arena);
      if (mul_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let me: Expr = ast_arena_expr_get(arena, mul_ref);
      me.kind = ExprKind.EXPR_BINOP;
      me.resolved_type_ref = type_ref;
      me.line = 0;
      me.col = 0;
      me.int_val = 0;
      me.binop_left_ref = expr_ref;
      me.binop_right_ref = mul_right_ref;
      me.unary_operand_ref = 0;
      me.if_cond_ref = 0;
      me.if_then_ref = 0;
      me.if_else_ref = 0;
      me.block_ref = 0;
      me.match_matched_ref = 0;
      me.match_num_arms = 0;
      ast.expr_init_match_enum(&me);
      me.field_access_base_ref = 0;
      me.field_access_field_len = 0;
      me.field_access_is_enum_variant = 0;
      me.field_access_offset = 0;
      me.index_base_ref = 0;
      me.index_index_ref = 0;
      me.index_base_is_slice = 0;
      me.call_callee_ref = 0;
      me.call_num_args = 0;
      me.method_call_base_ref = 0;
      me.method_call_name_len = 0;
      me.method_call_num_args = 0;
      me.const_folded_val = 0;
      me.const_folded_valid = 0;
      me.index_proven_in_bounds = 0;
      ast_arena_expr_set(arena, mul_ref, me);
      ast_arena_expr_set(arena, expr_ref, e);
    }
    /* buf 路径须与 parse_into 一致构建 return if(...)：否则 if_cond_expr_ref 丢失，if (1) 等非 bool 条件漏过 typeck */
    if (res.has_if_expr) {
      let cond_ref: i32 = 0;
      if (res.if_cond_expr_ref != 0) {
        cond_ref = res.if_cond_expr_ref;
      } else {
      let bool_type_ref: i32 = ast_arena_type_alloc(arena);
      if (bool_type_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1005 }
      }
      let bt: Type = ast_arena_type_get(arena, bool_type_ref);
      bt.kind = TypeKind.TYPE_BOOL;
      bt.name_len = 0;
      bt.elem_type_ref = 0;
      bt.array_size = 0;
      ast_arena_type_set(arena, bool_type_ref, bt);
      cond_ref = ast_arena_expr_alloc(arena);
      if (cond_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let ce: Expr = ast_arena_expr_get(arena, cond_ref);
      ce.kind = ExprKind.EXPR_BOOL_LIT;
      ce.resolved_type_ref = bool_type_ref;
      ce.line = 0;
      ce.col = 0;
      if (res.if_cond_true) {
        ce.int_val = 1;
      } else {
        ce.int_val = 0;
      }
      ce.binop_left_ref = 0;
      ce.binop_right_ref = 0;
      ce.unary_operand_ref = 0;
      ce.if_cond_ref = 0;
      ce.if_then_ref = 0;
      ce.if_else_ref = 0;
      ce.block_ref = 0;
      ce.match_matched_ref = 0;
      ce.match_num_arms = 0;
      ast.expr_init_match_enum(&ce);
      ce.field_access_base_ref = 0;
      ce.field_access_field_len = 0;
      ce.field_access_is_enum_variant = 0;
      ce.field_access_offset = 0;
      ce.index_base_ref = 0;
      ce.index_index_ref = 0;
