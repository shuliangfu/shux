    /* 与 parse_into 一致：return ident(...); 有参/无参调用时构建 EXPR_CALL，供 buf 路径多文件 std.io print_str */
    if (res.has_call_expr && res.return_expr_ref == 0 && res.call_callee_len > 0 && res.call_callee_len <= 63) {
