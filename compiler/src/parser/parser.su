// parser.su — 自举 9.1：最小语法分析器（.su 实现，与 parser.c 并存）
// 职责：消费 Token 流，解析最小程序「function main(): i32 { return <int>; }」，并产出 .su AST（Arena + Module）。
// 依赖：lexer、token、ast（Arena/Module/Type/Expr/Block/Func）、std.fs。
// 全部逻辑在 .su：不调 C 构建 AST，为完全自举第一步。

import lexer;
import token;
import ast;
import std.fs;
/** 极简 parse(return <expr>) 非字面量时用堆上 ASTArena，`pipeline_sizeof_arena()` 与 driver 静态缓冲同口径。 */
import std.heap;

/** 从 (data, len) 构造 []u8 slice，供 parse_into_buf 内调 parse_one_function_impl 时使用；实现由 pipeline_glue.c 提供。 */
extern function parser_slice_from_buf(data: *u8, len: i32): []u8;
/** 将 struct_layouts[idx] 整槽清零后由 set_name/set_field 写入（AArch64 下避免 Module 大成员逐字节赋值失效）。 */
extern function pipeline_module_struct_layout_reset_slot(module: *Module, idx: i32): void;
extern function pipeline_module_struct_layout_set_name(module: *Module, idx: i32, bytes: *u8, len: i32): void;
extern function pipeline_module_struct_layout_set_field(module: *Module, layout_idx: i32, j: i32, fname: *u8, fname_len: i32,
  ftype_ref: i32, foff: i32): void;
/** 将单个形参写入 module.funcs[fi].params[pi]，避免 Param 按值拷贝导致 asm 下 type_ref 丢失。 */
extern function pipeline_module_func_param_write(module: *Module, func_index: i32, param_index: i32, name_bytes: *u8, name_len: i32, type_ref: i32): void;
/** 将形参写入 ASTArena 的 func 池槽位（func_ref 1-based），供 parse_into_buf 路径。 */
extern function pipeline_arena_func_param_write(arena: *ASTArena, func_ref: i32, param_index: i32, name_bytes: *u8, name_len: i32, type_ref: i32): void;
/** 清零 Module 顶层解析计数（实现 pipeline_glue.c）；多 import 合并时避免对 module.num_* 的 SU 赋值 LHS 类型为 ?。 */
extern function pipeline_module_reset_parse_counters(module: *Module): void;
/** 与 C `pipeline_sizeof_arena` 一致：`sizeof(ast_ASTArena)`；堆/静态 arena 缓冲须 ≥此值。 */
extern function pipeline_sizeof_arena(): usize;

/** 单函数解析结果：须在任意 `function ... OneFuncResult` 之前定义，使 parse_struct 先写入 struct_layouts，避免前向引用导致 FIELD_ACCESS 无类型。 */
allow(padding) struct OneFuncResult {
  ok: bool;
  next_lex: Lexer;
  name: [64]u8;
  name_len: i32;
  num_params: i32;
  param_names: [16][32]u8;
  param_name_lens: [16]i32;
  /** 每参类型在 arena 的 type 池 ref，0 表示未解析；供 parse_into_buf expr-only 路径写入 f.params，避免 codegen 将指针形参误为 int32_t。 */
  param_type_refs: [16]i32;
  num_consts: i32;
  const_names: [256][64]u8;
  const_name_lens: [256]i32;
  const_init_vals: [256]i32;
  num_lets: i32;
  let_names: [256][64]u8;
  let_name_lens: [256]i32;
  let_init_vals: [256]i32;
  /** 非 0 时表示该 let 的初值为 arena 中的 expr ref（如 EXPR_ARRAY_LIT、EXPR_CALL），block 构建时优先用此而非 let_init_vals。 */
  let_init_refs: [256]i32;
  /** 解析 `let name: Ty = ...` 中 Ty 的 arena type ref；非 0 时 fill_block / parse_into 写 LetDecl.type_ref（避免一律用占位 i32 导致 INDEX 赋值 typeck 失败）。 */
  let_type_refs: [256]i32;
  has_if_expr: bool;
  if_cond_true: bool;
  if_then_val: i32;
  if_else_val: i32;
  /** return if (cond) 且 cond 非 true/false 字面量时：arena 内条件表达式 ref；0 表示由 if_cond_true 造 EXPR_BOOL_LIT。 */
  if_cond_expr_ref: i32;
  has_mul: bool;
  mul_right_val: i32;
  has_binop: bool;
  binop_right_val: i32;
  /** return ident + ident 且两 ident 为形参时，左/右操作数对应的形参下标（0/1）；-1 表示非形参（用 return_val/binop_right_val） */
  binop_left_param_idx: i32;
  binop_right_param_idx: i32;
  has_unary_neg: bool;
  return_val: i32;
  /** 阶段 5 多文件：return ident(); 无参/有参调用时为 true，call_callee_name/len 为被调名 */
  has_call_expr: bool;
  call_callee_name: [64]u8;
  call_callee_len: i32;
  /** return ident; 时记录变量名（非整数字面量）；return_var_name_len>0 时 parse_into 生成 EXPR_VAR */
  return_var_name: [64]u8;
  return_var_name_len: i32;
  /** 非 0：return 子表达式已在 arena（如 return foo(buffers[0].ptr,1)）；parse_into 用其作 final，勿再走 has_call_expr。 */
  return_expr_ref: i32;
  /** 有参调用时解析得到的实参个数（如 return add(1,2) 为 2）；0 表示无参或沿用当前函数形参个数 */
  call_num_args: i32;
  /** 有参调用且实参为整数字面量时的值，供 parse_into 构建 EXPR_LIT 实参；最多 16 个（与 Expr.int_val 一致用 i32） */
  call_arg_vals: [16]i32;
  /** 块内 while 循环数（最多 8）；cond/body 池下标，0 表示占位（未解析） */
  num_loops: i32;
  loop_cond_refs: [8]i32;
  loop_body_refs: [8]i32;
  /** 块内 for 循环数（最多 8）；init/cond/step/body 池下标，0 表示占位（未解析） */
  num_for_loops: i32;
  for_init_refs: [8]i32;
  for_cond_refs: [8]i32;
  for_step_refs: [8]i32;
  for_body_refs: [8]i32;
  /** parse_one_function_impl 与 parse_into 块体：if(cond){ block } 链（最多 16），池下标 */
  num_if_stmts: i32;
  if_cond_refs: [16]i32;
  if_then_body_refs: [16]i32;
  /**
   * parse_one_function_impl 按源码顺序累计的 stmt_order（与 C 侧 push_stmt_order 一致：
   * 0=const, 1=let, 2=expr_stmt, 3=loop, 4=for, 5=if）。>0 时 parse_into 直接写入 Block，避免仅按批
   * 次 const/let/loop 重建顺序导致与 C 解析器/codegen 不一致。
   */
  num_src_stmt_order: i32;
  src_stmt_kind: [96]u8;
  src_stmt_idx: [96]i32;
  /** kind=2 时 idx 为本数组下标；最多 32 条，与 Block.expr_stmt_refs 一致 */
  num_src_body_expr_stmts: i32;
  src_body_expr_stmt_refs: [32]i32;
  /** parse_one_function_impl 在 `): Ty` 处解析得到的返回类型 arena ref；parse_intoBuf 必须用其写入 Func.return_type_ref，勿一律造 TYPE_I32（否则 deps 如 std.time 的 i64 API 在 Caller 中被误为 i64，let/跨模块调用 typeck 失败）。为 0 时 parse_into 回退分配 TYPE_I32。 */
  func_return_type_ref: i32;
}

/** 最小解析结果：ok 表示整句解析成功，return_val 为 return 后的整数字面量值。 */
struct ParseResult {
  ok: bool;
  return_val: i32;
}

/** parse_into 返回：ok 0 成功 -1 失败，main_idx 为 main 函数下标（供调用方写回 module.main_func_index，避免 codegen 提升）。 */
struct ParseIntoResult {
  ok: i32;
  main_idx: i32;
}

/** 单条顶层 let/const 解析结果：供 parse_into_buf 在见到 TOKEN_LET/TOKEN_CONST 时调用 parse_one_top_level_let_into，通过 out 返回 ok 与 next_lex。 */
allow(padding) struct TopLevelLetResult {
  ok: bool;
  next_lex: Lexer;
}

/** collect_imports 的输出：通过 out 参数返回跳过 import 后的 Lexer，避免按值返回结构体（ABI 导致有 import 时返回值错误）。 */
struct CollectImportsResult {
  lex: Lexer;
}
/** 从 CollectImportsResult 取 lex 写入 out，避免 ABI 下 lex = import_res.lex 未正确写回。 */
function copy_lex_from_import_into(out: *Lexer, res: *CollectImportsResult): void {
  out.pos = res.lex.pos;
  out.line = res.lex.line;
  out.col = res.lex.col;
}

/** 从 LexerResult 取 next_lex 写入 out，避免 ABI 下结构体返回/赋值未写回导致 lex 不前进。 */
function lex_from_next_into(out: *Lexer, r: LexerResult): void {
  out.pos = r.next_lex.pos;
  out.line = r.next_lex.line;
  out.col = r.next_lex.col;
}
/** 从 *LexerResult 取 next_lex 写入 out_lex，供需要传指针处用，避免 C 解析器不支持 *out 解引用。 */
function lex_from_result_ptr_into(out_lex: *Lexer, r: *LexerResult): void {
  out_lex.pos = r.next_lex.pos;
  out_lex.line = r.next_lex.line;
  out_lex.col = r.next_lex.col;
}
/** 从 *OneFuncResult 取 next_lex 写入 out，避免整颗 OneFuncResult 按值传入（ARM64 大结构体 ABI）。 */
function lex_from_onefunc_next_into(out: *Lexer, res: *OneFuncResult): void {
  out.pos = res.next_lex.pos;
  out.line = res.next_lex.line;
  out.col = res.next_lex.col;
}

/** 由 token 结束位置与长度反推起点（避免在 if 条件内写 (nlen as usize) 触发 C 解析歧义）。 */
function lexer_pos_before_run(end_pos: usize, run_len: i32): usize {
  let rl: i32 = run_len;
  let start: usize = end_pos - (rl as usize);
  return start;
}

/**
 * 从 LexerResult 当前 token 起点构造 Lexer，供语句级 parse_expr / parse_cond_expr 从 r.tok 重读。
 */
function lex_at_token_from_result(r: LexerResult): Lexer {
  let p: usize = r.token_start;
  if (p == 0) {
    if (r.tok.kind == TokenKind.TOKEN_IDENT && r.tok.ident_len > 0) {
      p = lexer_pos_before_run(r.next_lex.pos, r.tok.ident_len);
    } else {
      p = r.next_lex.pos - 1;
    }
  }
  return Lexer { pos: p, line: r.tok.line, col: r.tok.col };
}

/**
 * 表达式初值/条件解析后同步到分号之后：next_lex 可能止于 ; 或已越过 ;（下一 token 为 let/return 等）。
 * 返回 1 成功，0 表示遇到非法后继 token。
 */
function advance_past_stmt_semicolon_into(r_out: *LexerResult, lex: Lexer, source: []u8): i32 {
  lexer_next_into(r_out, lex, source);
  if (r_out.tok.kind == TokenKind.TOKEN_SEMICOLON) {
    let lex_after: Lexer = Lexer { pos: r_out.next_lex.pos, line: r_out.next_lex.line, col: r_out.next_lex.col };
    lexer_next_into(r_out, lex_after, source);
    return 1;
  }
  if (r_out.tok.kind == TokenKind.TOKEN_LET || r_out.tok.kind == TokenKind.TOKEN_CONST
      || r_out.tok.kind == TokenKind.TOKEN_RETURN || r_out.tok.kind == TokenKind.TOKEN_IF
      || r_out.tok.kind == TokenKind.TOKEN_WHILE || r_out.tok.kind == TokenKind.TOKEN_FOR
      || r_out.tok.kind == TokenKind.TOKEN_RBRACE) {
    return 1;
  }
  return 0;
}

/**
 * 解析 if/while 条件后同步到右括号之后：next_lex 可能止于 ) 或已越过 )。
 */
function advance_past_cond_rparen_into(r_out: *LexerResult, lex: Lexer, source: []u8): i32 {
  lexer_next_into(r_out, lex, source);
  if (r_out.tok.kind == TokenKind.TOKEN_RPAREN) {
    let lex_after: Lexer = Lexer { pos: r_out.next_lex.pos, line: r_out.next_lex.line, col: r_out.next_lex.col };
    lexer_next_into(r_out, lex_after, source);
    return 1;
  }
  if (r_out.tok.kind == TokenKind.TOKEN_LBRACE) {
    return 1;
  }
  return 0;
}

/**
 * 在 `out.ok` / `copy_onefunc_into` 等之前执行：注册 OneFuncResult 首段 STRUCT_LIT（≤8 字段）并触发 typeck 填充 field_type_refs；
 * 后续同名字面量由 ensure_struct_layout_from_struct_lit **合并**补全余下字段名（AST 单字面量上限 8）。
 */
function onefunc_result_layout_prime(): void {
  let z64: [64]u8 = [];
  let z32: [32]u8 = [];
  let zp: [16][32]u8 = [z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32, z32];
  let zpl: [16]i32 = [];
  let zpt: [16]i32 = [];
  /** 仅 8 个字段：AST 单结构字面量上限 8；num_consts 起由 prime_b 合并 */
  let _prime: OneFuncResult = OneFuncResult {
    ok: false,
    next_lex: lexer_init(),
    name: z64,
    name_len: 0,
    num_params: 0,
    param_names: zp,
    param_name_lens: zpl,
    param_type_refs: zpt
  };
  /*
   * 勿整结构自赋值：.su typeck 展开后易触发「一侧 ?」。用常量写回一字段即可拴住字面量并过检。
   */
  _prime.name_len = 0;
}

/** 写失败结果到 out，避免 ABI 下 OneFuncResult 按值返回/赋值错误；调用方仅用 out.ok 与 out.next_lex。 */
function set_onefunc_fail(out: *OneFuncResult, next_lex: Lexer): void {
  out.ok = false;
  out.next_lex = next_lex;
}

/**
 * 合并第二段字段进 struct_layouts（num_consts…let_init_refs），供 copy_onefunc_into 中 FIELD_ACCESS 类型解析。
 */
function onefunc_result_layout_prime_b(): void {
  let dc: [256][64]u8 = [];
  let dcl: [256]i32 = [];
  let dcv: [256]i32 = [];
  let dl: [256][64]u8 = [];
  let dll: [256]i32 = [];
  let dlv: [256]i32 = [];
  let dir: [256]i32 = [];
  let _q2: OneFuncResult = OneFuncResult {
    num_consts: 0,
    const_names: dc,
    const_name_lens: dcl,
    const_init_vals: dcv,
    num_lets: 0,
    let_names: dl,
    let_name_lens: dll,
    let_init_vals: dlv,
    let_init_refs: dir
  };
  _q2.num_consts = 0;
}

/**
 * 合并第三段（let_type_refs…if_cond_expr_ref）。
 */
function onefunc_result_layout_prime_c(): void {
  let dlt: [256]i32 = [];
  let _q3: OneFuncResult = OneFuncResult {
    let_type_refs: dlt,
    has_if_expr: false,
    if_cond_true: false,
    if_then_val: 0,
    if_else_val: 0,
    if_cond_expr_ref: 0,
    has_mul: false,
    mul_right_val: 0
  };
  _q3.if_cond_expr_ref = 0;
}

/**
 * 合并第四段（has_binop…call_callee_name）。
 */
function onefunc_result_layout_prime_d(): void {
  let ccn: [64]u8 = [];
  let _q4: OneFuncResult = OneFuncResult {
    has_binop: false,
    binop_right_val: 0,
    binop_left_param_idx: -1,
    binop_right_param_idx: -1,
    has_unary_neg: false,
    return_val: 0,
    has_call_expr: false,
    call_callee_name: ccn
  };
  _q4.binop_left_param_idx = -1;
}

/**
 * 合并第五段（call_callee_len…loop_cond_refs）。
 */
function onefunc_result_layout_prime_d_b(): void {
  let rvn: [64]u8 = [];
  let cargs: [16]i32 = [];
  let lc: [8]i32 = [];
  let _q4b: OneFuncResult = OneFuncResult {
    call_callee_len: 0,
    return_var_name: rvn,
    return_var_name_len: 0,
    return_expr_ref: 0,
    call_num_args: 0,
    call_arg_vals: cargs,
    num_loops: 0,
    loop_cond_refs: lc
  };
  _q4b.call_num_args = 0;
}

/**
 * 合并第六段（loop_body_refs…if_cond_refs）。
 */
function onefunc_result_layout_prime_e(): void {
  let lb: [8]i32 = [];
  let fi: [8]i32 = [];
  let fc: [8]i32 = [];
  let fs: [8]i32 = [];
  let fb: [8]i32 = [];
  let ic: [16]i32 = [];
  let _q5: OneFuncResult = OneFuncResult {
    loop_body_refs: lb,
    num_for_loops: 0,
    for_init_refs: fi,
    for_cond_refs: fc,
    for_step_refs: fs,
    for_body_refs: fb,
    num_if_stmts: 0,
    if_cond_refs: ic
  };
  _q5.num_if_stmts = 0;
}

/**
 * 合并第七段（if_then_body_refs…func_return_type_ref）。
 */
function onefunc_result_layout_prime_f(): void {
  let it: [16]i32 = [];
  let sk: [96]u8 = [];
  let si: [96]i32 = [];
  let sr: [32]i32 = [];
  let _q6: OneFuncResult = OneFuncResult {
    if_then_body_refs: it,
    num_src_stmt_order: 0,
    src_stmt_kind: sk,
    src_stmt_idx: si,
    num_src_body_expr_stmts: 0,
    src_body_expr_stmt_refs: sr,
    func_return_type_ref: 0
  };
  _q6.func_return_type_ref = 0;
}

/** 将 src 逐字段拷到 dst，避免 *dst = src 在部分解析器下被误解析；用于 parse_one_function_impl 成功路径写回。 */
function copy_onefunc_into(dst: *OneFuncResult, src: *OneFuncResult): void {
  /* 字面量常省略 func_return_type_ref（视作 0）：保留 dst 已由 parse_one_function_impl 填入的 ): Ty arena ref */
  let preserved_func_ret_ty: i32 = dst.func_return_type_ref;
  dst.ok = src.ok;
  dst.next_lex = src.next_lex;
  dst.name_len = src.name_len;
  let ni: i32 = 0;
  while (ni < 64) {
    if (ni < src.name_len) { dst.name[ni] = src.name[ni]; }
    ni = ni + 1;
  }
  dst.num_params = src.num_params;
  let pi: i32 = 0;
  while (pi < 16) {
    let pj: i32 = 0;
    while (pj < 32) { dst.param_names[pi][pj] = src.param_names[pi][pj]; pj = pj + 1; }
    pi = pi + 1;
  }
  let pli: i32 = 0;
  while (pli < 16) { dst.param_name_lens[pli] = src.param_name_lens[pli]; pli = pli + 1; }
  let ptri: i32 = 0;
  while (ptri < 16) { dst.param_type_refs[ptri] = src.param_type_refs[ptri]; ptri = ptri + 1; }
  dst.num_consts = src.num_consts;
  let ci: i32 = 0;
  while (ci < 256) {
    let cj: i32 = 0;
    while (cj < 64) { dst.const_names[ci][cj] = src.const_names[ci][cj]; cj = cj + 1; }
    ci = ci + 1;
  }
  let cli: i32 = 0;
  while (cli < 256) { dst.const_name_lens[cli] = src.const_name_lens[cli]; cli = cli + 1; }
  let cvi: i32 = 0;
  while (cvi < 256) { dst.const_init_vals[cvi] = src.const_init_vals[cvi]; cvi = cvi + 1; }
  dst.num_lets = src.num_lets;
  let li: i32 = 0;
  while (li < 256) {
    let lj: i32 = 0;
    while (lj < 64) { dst.let_names[li][lj] = src.let_names[li][lj]; lj = lj + 1; }
    li = li + 1;
  }
  let lli: i32 = 0;
  while (lli < 256) { dst.let_name_lens[lli] = src.let_name_lens[lli]; lli = lli + 1; }
  let lvi: i32 = 0;
  while (lvi < 256) { dst.let_init_vals[lvi] = src.let_init_vals[lvi]; lvi = lvi + 1; }
  let lri: i32 = 0;
  while (lri < 256) { dst.let_init_refs[lri] = src.let_init_refs[lri]; lri = lri + 1; }
  let lti: i32 = 0;
  while (lti < 256) { dst.let_type_refs[lti] = src.let_type_refs[lti]; lti = lti + 1; }
  dst.has_if_expr = src.has_if_expr;
  dst.if_cond_true = src.if_cond_true;
  dst.if_then_val = src.if_then_val;
  dst.if_else_val = src.if_else_val;
  dst.if_cond_expr_ref = src.if_cond_expr_ref;
  dst.has_mul = src.has_mul;
  dst.mul_right_val = src.mul_right_val;
  dst.has_binop = src.has_binop;
  dst.binop_right_val = src.binop_right_val;
  dst.binop_left_param_idx = src.binop_left_param_idx;
  dst.binop_right_param_idx = src.binop_right_param_idx;
  dst.has_unary_neg = src.has_unary_neg;
  dst.return_val = src.return_val;
  /* return ident（非调用）：须拷入 out，否则 typeck 收不到 EXPR_VAR 与未定义名诊断 */
  dst.return_var_name_len = src.return_var_name_len;
  let rvni: i32 = 0;
  while (rvni < 64) {
    dst.return_var_name[rvni] = src.return_var_name[rvni];
    rvni = rvni + 1;
  }
  dst.return_expr_ref = src.return_expr_ref;
  dst.has_call_expr = src.has_call_expr;
  dst.call_callee_len = src.call_callee_len;
  let cci: i32 = 0;
  while (cci < 64) { dst.call_callee_name[cci] = src.call_callee_name[cci]; cci = cci + 1; }
  dst.call_num_args = src.call_num_args;
  let cavi: i32 = 0;
  while (cavi < 16) { dst.call_arg_vals[cavi] = src.call_arg_vals[cavi]; cavi = cavi + 1; }
  dst.num_loops = src.num_loops;
  let lri2: i32 = 0;
  while (lri2 < 8) { dst.loop_cond_refs[lri2] = src.loop_cond_refs[lri2]; dst.loop_body_refs[lri2] = src.loop_body_refs[lri2]; lri2 = lri2 + 1; }
  dst.num_for_loops = src.num_for_loops;
  let fri: i32 = 0;
  while (fri < 8) { dst.for_init_refs[fri] = src.for_init_refs[fri]; dst.for_cond_refs[fri] = src.for_cond_refs[fri]; dst.for_step_refs[fri] = src.for_step_refs[fri]; dst.for_body_refs[fri] = src.for_body_refs[fri]; fri = fri + 1; }
  dst.num_if_stmts = src.num_if_stmts;
  let ifi: i32 = 0;
  while (ifi < 16) {
    dst.if_cond_refs[ifi] = src.if_cond_refs[ifi];
    dst.if_then_body_refs[ifi] = src.if_then_body_refs[ifi];
    ifi = ifi + 1;
  }
  if (src.func_return_type_ref != 0) {
    dst.func_return_type_ref = src.func_return_type_ref;
  } else {
    dst.func_return_type_ref = preserved_func_ret_ty;
  }
  /* src_stmt_order_* / src_body_expr_* 由 parse_one_function_impl 直接写 out，不由本函数覆盖 */
}

/**
 * 向 out 追加一条源码顺序记录；与 C parser push_stmt_order 对齐（kind 0–5，idx 为对应池下标）。
 */
function onefunc_push_src_stmt(out: *OneFuncResult, kind: u8, idx: i32): void {
  if (out.num_src_stmt_order >= 96) {
    return;
  }
  let n: i32 = out.num_src_stmt_order;
  out.src_stmt_kind[n] = kind;
  out.src_stmt_idx[n] = idx;
  out.num_src_stmt_order = out.num_src_stmt_order + 1;
}

/** 单表达式解析结果：ok 为真时 expr_ref 有效且 next_lex 为表达式之后的 lex。 */
struct ParseExprResult {
  ok: bool;
  expr_ref: i32;
  next_lex: Lexer;
}

/**
 * 将 Expr 的子树引用与语义辅助字段清零（不写 kind/int_val/var_name/float_* 字面数据）。
 * 须在写入 binop_* / unary_operand_ref / index_* / field_access_* / call_* 等变体指针之前调用；若先赋值再调用本函数会把子引用清掉。
 */
function expr_set_common_zeros(e: *Expr): void {
  e.resolved_type_ref = 0;
  e.binop_left_ref = 0;
  e.binop_right_ref = 0;
  e.unary_operand_ref = 0;
  e.if_cond_ref = 0;
  e.if_then_ref = 0;
  e.if_else_ref = 0;
  e.block_ref = 0;
  e.match_matched_ref = 0;
  e.match_num_arms = 0;
  ast.expr_init_match_enum(e);
  e.field_access_base_ref = 0;
  e.field_access_field_len = 0;
  e.field_access_is_enum_variant = 0;
  e.field_access_offset = 0;
  e.index_base_ref = 0;
  e.index_index_ref = 0;
  e.index_base_is_slice = 0;
  e.call_callee_ref = 0;
  e.call_num_args = 0;
  e.method_call_base_ref = 0;
  e.method_call_name_len = 0;
  e.method_call_num_args = 0;
  e.const_folded_val = 0;
  e.const_folded_valid = 0;
  e.index_proven_in_bounds = 0;
  e.as_operand_ref = 0;
  e.as_target_type_ref = 0;
}

/**
 * 解析 primary：INT | TRUE | FALSE | BREAK | CONTINUE | IDENT | ( expr )；成功时写 out.expr_ref、out.next_lex，失败时 out.ok = false。
 */
function parse_primary_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_INT) {
    let ref: i32 = ast_arena_expr_alloc(arena);
    if (ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, ref);
    e.kind = ExprKind.EXPR_LIT;
    e.line = 0;
    e.col = 0;
    e.int_val = r.tok.int_val;
    expr_set_common_zeros(&e);
    ast_arena_expr_set(arena, ref, e);
    out.ok = true;
    out.expr_ref = ref;
    out.next_lex = r.next_lex;
    return;
  }
  if (r.tok.kind == TokenKind.TOKEN_TRUE || r.tok.kind == TokenKind.TOKEN_FALSE) {
    let ref: i32 = ast_arena_expr_alloc(arena);
    if (ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, ref);
    e.kind = ExprKind.EXPR_BOOL_LIT;
    if (r.tok.kind == TokenKind.TOKEN_TRUE) {
      e.int_val = 1;
    } else {
      e.int_val = 0;
    }
    e.line = 0;
    e.col = 0;
    expr_set_common_zeros(&e);
    ast_arena_expr_set(arena, ref, e);
    out.ok = true;
    out.expr_ref = ref;
    out.next_lex = r.next_lex;
    return;
  }
  /* break / continue：与 C 端 parser 一致，作为独立 primary，供 for 体等处的控制流表达式使用 */
  if (r.tok.kind == TokenKind.TOKEN_BREAK || r.tok.kind == TokenKind.TOKEN_CONTINUE) {
    let ref: i32 = ast_arena_expr_alloc(arena);
    if (ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, ref);
    if (r.tok.kind == TokenKind.TOKEN_BREAK) {
      e.kind = ExprKind.EXPR_BREAK;
    } else {
      e.kind = ExprKind.EXPR_CONTINUE;
    }
    e.line = 0;
    e.col = 0;
    expr_set_common_zeros(&e);
    ast_arena_expr_set(arena, ref, e);
    out.ok = true;
    out.expr_ref = ref;
    out.next_lex = r.next_lex;
    return;
  }
  if (r.tok.kind == TokenKind.TOKEN_IDENT) {
    let ref: i32 = ast_arena_expr_alloc(arena);
    if (ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, ref);
    e.kind = ExprKind.EXPR_VAR;
    e.var_name_len = r.tok.ident_len;
    if (e.var_name_len > 63) {
      e.var_name_len = 63;
    }
    /** lexer_next_body_into 已为 IDENT 填 token_start；偏移 0 合法，不可用 !=0 判定。*/
    let start: usize = r.token_start;
    let i: i32 = 0;
    while (i < e.var_name_len && start + i < source.length) {
      e.var_name[i] = source[start + i];
      i = i + 1;
    }
    while (i < 64) {
      e.var_name[i] = 0;
      i = i + 1;
    }
    e.line = 0;
    e.col = 0;
    expr_set_common_zeros(&e);
    ast_arena_expr_set(arena, ref, e);
    out.ok = true;
    out.expr_ref = ref;
    lex = r.next_lex;

    /* 后缀链：处理 .field / [index] */
    while (true) {
      lexer_next_into(&r, lex, source);
      if (r.tok.kind == TokenKind.TOKEN_DOT) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_IDENT) {
          out.next_lex = lex; return;
        }
        let fa_ref: i32 = ast_arena_expr_alloc(arena);
        if (fa_ref == 0) { out.ok = false; return; }
        let fe: Expr = ast_arena_expr_get(arena, fa_ref);
        fe.kind = ExprKind.EXPR_FIELD_ACCESS;
        fe.line = 0;
        fe.col = 0;
        expr_set_common_zeros(&fe);
        fe.field_access_base_ref = out.expr_ref;
        fe.field_access_field_len = r.tok.ident_len;
        if (fe.field_access_field_len > 63) { fe.field_access_field_len = 63; }
        /** 字段名 IDENT：与 VAR/形参同源，必须用 token_start（buf/slice Lexer next_lex.pos - len 不可靠；偏移 0 合法）。 */
        let fstart: usize = r.token_start;
        let fi: i32 = 0;
        while (fi < fe.field_access_field_len && (fstart + (fi as usize)) < source.length) {
          fe.field_access_field_name[fi] = source[fstart + (fi as usize)];
          fi = fi + 1;
        }
        while (fi < 64) { fe.field_access_field_name[fi] = 0; fi = fi + 1; }
        ast_arena_expr_set(arena, fa_ref, fe);
        out.expr_ref = fa_ref;
        lex = r.next_lex;
      } else if (r.tok.kind == TokenKind.TOKEN_LBRACKET) {
        let base_ref_saved: i32 = out.expr_ref;
        lex_from_next_into(&lex, r);
        parse_expr_into(arena, lex, source, out);
        if (!out.ok) { return; }
        let idx_ref_2: i32 = out.expr_ref;
        lex = out.next_lex;
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_RBRACKET) {
          out.ok = false; return;
        }
        lex = r.next_lex;
        let idx_ref: i32 = ast_arena_expr_alloc(arena);
        if (idx_ref == 0) { out.ok = false; return; }
        let ie: Expr = ast_arena_expr_get(arena, idx_ref);
        expr_set_common_zeros(&ie);
        ie.kind = ExprKind.EXPR_INDEX;
        ie.index_base_ref = base_ref_saved;
        ie.index_index_ref = idx_ref_2;
        ie.index_base_is_slice = 0;
        ie.line = 0; ie.col = 0;
        ast_arena_expr_set(arena, idx_ref, ie);
        out.expr_ref = idx_ref;
      } else if (r.tok.kind == TokenKind.TOKEN_LPAREN) {
        /* 后缀调用 callee(...)，供 if (ref_is_null(x))、foo(a, b) 等；此前仅 . / [] 导致库函数体解析失败。 */
        let callee_ref: i32 = out.expr_ref;
        lex = r.next_lex;
        let num_args: i32 = 0;
        let arg_refs: [16]i32 = [];
        let ai0: i32 = 0;
        while (ai0 < 16) {
          arg_refs[ai0] = 0;
          ai0 = ai0 + 1;
        }
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
          while (num_args < 16) {
            let arg_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
            parse_expr_into(arena, lex, source, &arg_res);
            if (!arg_res.ok) {
              out.ok = false;
              return;
            }
            arg_refs[num_args] = arg_res.expr_ref;
            num_args = num_args + 1;
            lex = arg_res.next_lex;
            lexer_next_into(&r, lex, source);
            if (r.tok.kind == TokenKind.TOKEN_COMMA) {
              lex = r.next_lex;
              continue;
            }
            if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
              lex = r.next_lex;
              break;
            }
            out.ok = false;
            return;
          }
        } else {
          lex = r.next_lex;
        }
        let call_ref: i32 = ast_arena_expr_alloc(arena);
        if (call_ref == 0) {
          out.ok = false;
          return;
        }
        let ce: Expr = ast_arena_expr_get(arena, call_ref);
        ce.kind = ExprKind.EXPR_CALL;
        ce.line = 0;
        ce.col = 0;
        expr_set_common_zeros(&ce);
        ce.call_callee_ref = callee_ref;
        ce.call_num_args = num_args;
        let ai1: i32 = 0;
        while (ai1 < 16) {
          ce.call_arg_refs[ai1] = arg_refs[ai1];
          ai1 = ai1 + 1;
        }
        ast_arena_expr_set(arena, call_ref, ce);
        out.expr_ref = call_ref;
      } else {
        out.next_lex = lex;
        return;
      }
    }
  }
  if (r.tok.kind == TokenKind.TOKEN_LPAREN) {
    lex_from_next_into(&lex, r);
    parse_expr_into(arena, lex, source, out);
    if (!out.ok) {
      return;
    }
    lex = out.next_lex;
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
      out.ok = false;
      return;
    }
    out.next_lex = r.next_lex;
    return;
  }
  out.ok = false;
}

/**
 * 解析紧贴 primary 的零个或多个「as type」（与 C parse_cast 一致；未遇到 as 时不前进 lex）。
 * 假定 out 已由 parse_primary_into 成功填充。
 */
function parse_as_suffix_into(arena: *ASTArena, source: []u8, out: *ParseExprResult): void {
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_AS) {
      out.next_lex = lex_cur;
      return;
    }
    lex_from_next_into(&lex_cur, r);
    lexer_next_into(&r, lex_cur, source);
    let type_ref: i32 = 0;
    if (r.tok.kind == TokenKind.TOKEN_STAR) {
      lex_from_result_ptr_into(&lex_cur, &r);
      lexer_next_into(&r, lex_cur, source);
      let elem_ref: i32 = alloc_pointee_type_ref_from_tok(arena, source, &r);
      if (elem_ref == 0) {
        out.ok = false;
        return;
      }
      type_ref = ast_arena_type_alloc(arena);
      if (type_ref != 0) {
        let tptr: Type = ast_arena_type_get(arena, type_ref);
        tptr.kind = TypeKind.TYPE_PTR;
        tptr.elem_type_ref = elem_ref;
        tptr.name_len = 0;
        tptr.array_size = 0;
        ast_arena_type_set(arena, type_ref, tptr);
      }
      lex_from_result_ptr_into(&lex_cur, &r);
      lexer_next_into(&r, lex_cur, source);
    } else if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_U8 || r.tok.kind == TokenKind.TOKEN_U32 || r.tok.kind == TokenKind.TOKEN_U64 || r.tok.kind == TokenKind.TOKEN_USIZE || r.tok.kind == TokenKind.TOKEN_ISIZE || r.tok.kind == TokenKind.TOKEN_VOID || r.tok.kind == TokenKind.TOKEN_IDENT) {
      type_ref = ast_arena_type_alloc(arena);
      if (type_ref != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref);
        if (r.tok.kind == TokenKind.TOKEN_I32) {
          t.kind = TypeKind.TYPE_I32;
        } else if (r.tok.kind == TokenKind.TOKEN_I64) {
          t.kind = TypeKind.TYPE_I64;
        } else if (r.tok.kind == TokenKind.TOKEN_BOOL) {
          t.kind = TypeKind.TYPE_BOOL;
        } else if (r.tok.kind == TokenKind.TOKEN_U8) {
          t.kind = TypeKind.TYPE_U8;
        } else if (r.tok.kind == TokenKind.TOKEN_U32) {
          t.kind = TypeKind.TYPE_U32;
        } else if (r.tok.kind == TokenKind.TOKEN_U64) {
          t.kind = TypeKind.TYPE_U64;
        } else if (r.tok.kind == TokenKind.TOKEN_USIZE) {
          t.kind = TypeKind.TYPE_USIZE;
        } else if (r.tok.kind == TokenKind.TOKEN_ISIZE) {
          t.kind = TypeKind.TYPE_ISIZE;
        } else if (r.tok.kind == TokenKind.TOKEN_VOID) {
          t.kind = TypeKind.TYPE_VOID;
        } else {
          t.kind = TypeKind.TYPE_NAMED;
          t.name_len = r.tok.ident_len;
          if (t.name_len > 63) {
            t.name_len = 63;
          }
          let si2: i32 = 0;
          while (si2 < t.name_len && (r.token_start + (si2 as usize)) < source.length) {
            t.name[si2] = source[r.token_start + (si2 as usize)];
            si2 = si2 + 1;
          }
        }
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref, t);
      }
      lex_from_result_ptr_into(&lex_cur, &r);
      lexer_next_into(&r, lex_cur, source);
    } else {
      out.ok = false;
      return;
    }
    if (type_ref == 0) {
      out.ok = false;
      return;
    }
    let inner_ref: i32 = out.expr_ref;
    let as_ref: i32 = ast_arena_expr_alloc(arena);
    if (as_ref == 0) {
      out.ok = false;
      return;
    }
    let ae: Expr = ast_arena_expr_get(arena, as_ref);
    ae.kind = ExprKind.EXPR_AS;
    ae.line = 0;
    ae.col = 0;
    expr_set_common_zeros(&ae);
    ae.as_operand_ref = inner_ref;
    ae.as_target_type_ref = type_ref;
    ast_arena_expr_set(arena, as_ref, ae);
    out.expr_ref = as_ref;
    lex_cur = r.next_lex;
  }
}

/**
 * 解析 unary：(-|!) unary | primary；成功时写 out.expr_ref、out.next_lex。
 */
function parse_unary_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_MINUS) {
    lex_from_next_into(&lex, r);
    parse_unary_into(arena, lex, source, out);
    if (!out.ok) {
      return;
    }
    let op_ref: i32 = ast_arena_expr_alloc(arena);
    if (op_ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, op_ref);
    expr_set_common_zeros(&e);
    e.kind = ExprKind.EXPR_NEG;
    e.unary_operand_ref = out.expr_ref;
    e.line = 0;
    e.col = 0;
    ast_arena_expr_set(arena, op_ref, e);
    out.expr_ref = op_ref;
    return;
  }
  if (r.tok.kind == TokenKind.TOKEN_BANG) {
    lex_from_next_into(&lex, r);
    parse_unary_into(arena, lex, source, out);
    if (!out.ok) {
      return;
    }
    let op_ref: i32 = ast_arena_expr_alloc(arena);
    if (op_ref == 0) {
      out.ok = false;
      return;
    }
    let e: Expr = ast_arena_expr_get(arena, op_ref);
    expr_set_common_zeros(&e);
    e.kind = ExprKind.EXPR_LOGNOT;
    e.unary_operand_ref = out.expr_ref;
    e.line = 0;
    e.col = 0;
    ast_arena_expr_set(arena, op_ref, e);
    out.expr_ref = op_ref;
    return;
  }
  parse_primary_into(arena, lex, source, out);
}

/**
 * 解析 cast：unary (as type)*；as 优先级高于 ==/+/，与 C 一致（如 0 == 0 as *u8、if (0 as *u8)）。
 */
function parse_cast_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_unary_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  parse_as_suffix_into(arena, source, out);
}

/**
 * 解析 term：cast ( (*|/|%) cast )*；成功时写 out.expr_ref、out.next_lex。
 */
function parse_term_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_cast_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    let kind: ExprKind = ExprKind.EXPR_LIT;
    if (r.tok.kind == TokenKind.TOKEN_STAR) {
      kind = ExprKind.EXPR_MUL;
    } else if (r.tok.kind == TokenKind.TOKEN_SLASH) {
      kind = ExprKind.EXPR_DIV;
    } else if (r.tok.kind == TokenKind.TOKEN_PERCENT) {
      kind = ExprKind.EXPR_MOD;
    } else {
      out.next_lex = lex_cur;
      return;
    }
    let left_ref: i32 = out.expr_ref;
    lex_from_next_into(&lex_cur, r);
    parse_cast_into(arena, lex_cur, source, out);
    if (!out.ok) {
      return;
    }
    let right_ref: i32 = out.expr_ref;
    let bin_ref: i32 = ast_arena_expr_alloc(arena);
    if (bin_ref == 0) {
      out.ok = false;
      return;
    }
    let be: Expr = ast_arena_expr_get(arena, bin_ref);
    expr_set_common_zeros(&be);
    be.kind = kind;
    be.binop_left_ref = left_ref;
    be.binop_right_ref = right_ref;
    be.line = 0;
    be.col = 0;
    ast_arena_expr_set(arena, bin_ref, be);
    out.expr_ref = bin_ref;
    lex_cur = out.next_lex;
  }
}

/**
 * 解析 addsub：term ( (+|-) term )*；成功时写 out.expr_ref、out.next_lex。
 */
function parse_addsub_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_term_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    let kind: ExprKind = ExprKind.EXPR_LIT;
    if (r.tok.kind == TokenKind.TOKEN_PLUS) {
      kind = ExprKind.EXPR_ADD;
    } else if (r.tok.kind == TokenKind.TOKEN_MINUS) {
      kind = ExprKind.EXPR_SUB;
    } else {
      out.next_lex = lex_cur;
      return;
    }
    let left_ref: i32 = out.expr_ref;
    lex_from_next_into(&lex_cur, r);
    parse_term_into(arena, lex_cur, source, out);
    if (!out.ok) {
      return;
    }
    let right_ref: i32 = out.expr_ref;
    let bin_ref: i32 = ast_arena_expr_alloc(arena);
    if (bin_ref == 0) {
      out.ok = false;
      return;
    }
    let be: Expr = ast_arena_expr_get(arena, bin_ref);
    expr_set_common_zeros(&be);
    be.kind = kind;
    be.binop_left_ref = left_ref;
    be.binop_right_ref = right_ref;
    be.line = 0;
    be.col = 0;
    ast_arena_expr_set(arena, bin_ref, be);
    out.expr_ref = bin_ref;
    lex_cur = out.next_lex;
  }
}

/**
 * 解析 compare：addsub ( (<|<=|>|>=|==|!=) addsub )*；成功时写 out.expr_ref、out.next_lex。
 */
function parse_compare_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_addsub_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    let kind: ExprKind = ExprKind.EXPR_EQ;
    if (r.tok.kind == TokenKind.TOKEN_EQ) {
      kind = ExprKind.EXPR_EQ;
    } else if (r.tok.kind == TokenKind.TOKEN_NE) {
      kind = ExprKind.EXPR_NE;
    } else if (r.tok.kind == TokenKind.TOKEN_LT) {
      kind = ExprKind.EXPR_LT;
    } else if (r.tok.kind == TokenKind.TOKEN_LE) {
      kind = ExprKind.EXPR_LE;
    } else if (r.tok.kind == TokenKind.TOKEN_GT) {
      kind = ExprKind.EXPR_GT;
    } else if (r.tok.kind == TokenKind.TOKEN_GE) {
      kind = ExprKind.EXPR_GE;
    } else {
      out.next_lex = lex_cur;
      return;
    }
    let left_ref: i32 = out.expr_ref;
    lex_from_next_into(&lex_cur, r);
    parse_addsub_into(arena, lex_cur, source, out);
    if (!out.ok) {
      return;
    }
    let right_ref: i32 = out.expr_ref;
    let bin_ref: i32 = ast_arena_expr_alloc(arena);
    if (bin_ref == 0) {
      out.ok = false;
      return;
    }
    let be: Expr = ast_arena_expr_get(arena, bin_ref);
    expr_set_common_zeros(&be);
    be.kind = kind;
    be.binop_left_ref = left_ref;
    be.binop_right_ref = right_ref;
    be.line = 0;
    be.col = 0;
    ast_arena_expr_set(arena, bin_ref, be);
    out.expr_ref = bin_ref;
    lex_cur = out.next_lex;
  }
}

/**
 * 解析 logand：compare ( && compare )*；成功时写 out.expr_ref、out.next_lex。
 */
function parse_logand_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_compare_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_AMPAMP) {
      out.next_lex = lex_cur;
      return;
    }
    let left_ref: i32 = out.expr_ref;
    lex_from_next_into(&lex_cur, r);
    parse_compare_into(arena, lex_cur, source, out);
    if (!out.ok) {
      return;
    }
    let right_ref: i32 = out.expr_ref;
    let bin_ref: i32 = ast_arena_expr_alloc(arena);
    if (bin_ref == 0) {
      out.ok = false;
      return;
    }
    let be: Expr = ast_arena_expr_get(arena, bin_ref);
    expr_set_common_zeros(&be);
    be.kind = ExprKind.EXPR_LOGAND;
    be.binop_left_ref = left_ref;
    be.binop_right_ref = right_ref;
    be.line = 0;
    be.col = 0;
    ast_arena_expr_set(arena, bin_ref, be);
    out.expr_ref = bin_ref;
    lex_cur = out.next_lex;
  }
}

/**
 * 解析 logor：logand ( || logand )*；成功时写 out.expr_ref、out.next_lex。
 */
function parse_logor_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_logand_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  while (true) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_PIPEPIPE) {
      out.next_lex = lex_cur;
      return;
    }
    let left_ref: i32 = out.expr_ref;
    lex_from_next_into(&lex_cur, r);
    parse_logand_into(arena, lex_cur, source, out);
    if (!out.ok) {
      return;
    }
    let right_ref: i32 = out.expr_ref;
    let bin_ref: i32 = ast_arena_expr_alloc(arena);
    if (bin_ref == 0) {
      out.ok = false;
      return;
    }
    let be: Expr = ast_arena_expr_get(arena, bin_ref);
    expr_set_common_zeros(&be);
    be.kind = ExprKind.EXPR_LOGOR;
    be.binop_left_ref = left_ref;
    be.binop_right_ref = right_ref;
    be.line = 0;
    be.col = 0;
    ast_arena_expr_set(arena, bin_ref, be);
    out.expr_ref = bin_ref;
    lex_cur = out.next_lex;
  }
}

/** 判断是否为复合赋值 token（+= … >>=），与 C 端 is_compound_assign_token 一致。 */
function is_compound_assign_token(kind: TokenKind): bool {
  return kind == TokenKind.TOKEN_PLUS_EQ || kind == TokenKind.TOKEN_MINUS_EQ || kind == TokenKind.TOKEN_STAR_EQ
    || kind == TokenKind.TOKEN_SLASH_EQ || kind == TokenKind.TOKEN_PERCENT_EQ || kind == TokenKind.TOKEN_AMP_EQ
    || kind == TokenKind.TOKEN_PIPE_EQ || kind == TokenKind.TOKEN_CARET_EQ || kind == TokenKind.TOKEN_LSHIFT_EQ
    || kind == TokenKind.TOKEN_RSHIFT_EQ;
}

/** 映射实现见 pipeline_glue.c（C 内比对 TokenKind），避免 .su typeck 对 `return ExprKind.*` 失败。 */
extern function compound_assign_token_to_expr_kind_from_glue(kind: TokenKind): ExprKind;

/** 复合赋值 token 映射到 ExprKind；仅当 kind 为复合赋值 token 时调用（不含单 =）。 */
function compound_assign_token_to_expr_kind(kind: TokenKind): ExprKind {
  return compound_assign_token_to_expr_kind_from_glue(kind);
}

/** 左值判定由 pipeline_glue.c 直读池中 kind/is_enum_variant，与 shu-c 生成 struct 访问一致；勿在 SU 内 `let e: Expr = get` 后比较 e.kind（.su typeck 会失败）。 */
extern function pipeline_expr_ref_is_assign_lvalue(arena: *ASTArena, expr_ref: i32): bool;

/**
 * 表达式 ref 是否为可赋值左值（VAR / INDEX / 非枚举变体的 FIELD_ACCESS），与 C 端 expr_is_lvalue 一致。
 * 非左值时遇到 = 不消费赋值符，由上层继续解析（与 parse_assign 一致）。
 */
function expr_ref_is_assign_lvalue(arena: *ASTArena, expr_ref: i32): bool {
  return pipeline_expr_ref_is_assign_lvalue(arena, expr_ref);
}

/**
 * 赋值层：logor (('='|'+='|…) logor)?；右结合；仅左值为 VAR/INDEX/字段时消费赋值符。
 * 此前 parse_expr_into 仅到 logor，for 步进里 x = true 只解析成 x，.su typeck 漏报与 C 路径不一致。
 */
function parse_assign_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_logor_into(arena, lex, source, out);
  if (!out.ok) {
    return;
  }
  let lex_cur: Lexer = out.next_lex;
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex_cur, source);
  let tok: TokenKind = r.tok.kind;
  if (tok != TokenKind.TOKEN_ASSIGN && !is_compound_assign_token(tok)) {
    out.next_lex = lex_cur;
    return;
  }
  if (!expr_ref_is_assign_lvalue(arena, out.expr_ref)) {
    out.next_lex = lex_cur;
    return;
  }
  let left_ref: i32 = out.expr_ref;
  let assign_kind: ExprKind = ExprKind.EXPR_ASSIGN;
  if (tok != TokenKind.TOKEN_ASSIGN) {
    assign_kind = compound_assign_token_to_expr_kind(tok);
  }
  lex_from_next_into(&lex_cur, r);
  parse_logor_into(arena, lex_cur, source, out);
  if (!out.ok) {
    return;
  }
  let right_ref: i32 = out.expr_ref;
  let bin_ref: i32 = ast_arena_expr_alloc(arena);
  if (bin_ref == 0) {
    out.ok = false;
    return;
  }
  let be: Expr = ast_arena_expr_get(arena, bin_ref);
  expr_set_common_zeros(&be);
  be.kind = assign_kind;
  be.binop_left_ref = left_ref;
  be.binop_right_ref = right_ref;
  be.line = 0;
  be.col = 0;
  ast_arena_expr_set(arena, bin_ref, be);
  out.expr_ref = bin_ref;
}

/** 表达式解析入口：赋值层（内含 logor）；成功时写 out.expr_ref、out.next_lex。 */
function parse_expr_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_assign_into(arena, lex, source, out);
}

/**
 * 解析 if/while 条件或表达式语句；若以 int 开头且紧跟 as，从 int 起点 parse_expr（与 return 0 as T 一致）。
 * 无 as 时从 lex_start 解析，避免误用 next_lex.pos-1 截断多位整数（如 if (10)）。
 */
function parse_cond_expr_into(arena: *ASTArena, lex_start: Lexer, source: []u8, out: *ParseExprResult): void {
  let rpeek: LexerResult = LexerResult { next_lex: lex_start, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&rpeek, lex_start, source);
  if (rpeek.tok.kind == TokenKind.TOKEN_INT) {
    let int_start: usize = rpeek.token_start;
    if (int_start == 0) {
      int_start = rpeek.next_lex.pos - 1;
    }
    let int_lex: Lexer = Lexer { pos: int_start, line: lex_start.line, col: lex_start.col };
    let r_as: LexerResult = LexerResult { next_lex: rpeek.next_lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
    lexer_next_into(&r_as, rpeek.next_lex, source);
    if (r_as.tok.kind == TokenKind.TOKEN_AS) {
      parse_expr_into(arena, int_lex, source, out);
      return;
    }
    parse_expr_into(arena, lex_start, source, out);
    return;
  }
  parse_expr_into(arena, lex_start, source, out);
}

/** 兼容旧名：与 parse_cond_expr_into 相同。 */
function parse_expr_with_leading_int_as_into(arena: *ASTArena, lex_start: Lexer, source: []u8, out: *ParseExprResult): void {
  parse_cond_expr_into(arena, lex_start, source, out);
}

/** 单块解析结果：ok 为真时 block_ref 有效且 next_lex 为块闭合 } 之后的 lex。 */
struct ParseBlockResult {
  ok: bool;
  block_ref: i32;
  next_lex: Lexer;
}

/**
 * 根据 OneFuncResult 的 const/let 填写块的 const_decls、let_decls 及 init 表达式；type_ref 可为 0（由 typeck 后填）。
 * 返回 true 成功，false 表示 arena 分配失败。
 */
function fill_block_const_let_from_res(arena: *ASTArena, block_ref: i32, res: *OneFuncResult, type_ref: i32): bool {
  let b: Block = ast_arena_block_get(arena, block_ref);
  b.num_consts = res.num_consts;
  b.num_lets = res.num_lets;
  let const_i: i32 = 0;
  while (const_i < res.num_consts && const_i < 256) {
    let cinit_ref: i32 = ast_arena_expr_alloc(arena);
    if (cinit_ref == 0) {
      return false;
    }
    let ce: Expr = ast_arena_expr_get(arena, cinit_ref);
    ce.kind = ExprKind.EXPR_LIT;
    ce.resolved_type_ref = type_ref;
    ce.line = 0;
    ce.col = 0;
    ce.int_val = res.const_init_vals[const_i];
    expr_set_common_zeros(&ce);
    ast_arena_expr_set(arena, cinit_ref, ce);
    let cd: ConstDecl = b.const_decls[const_i];
    let ck: i32 = 0;
    while (ck < res.const_name_lens[const_i] && ck < 64) {
      let const_row: [64]u8 = res.const_names[const_i];
      cd.name[ck] = const_row[ck];
      ck = ck + 1;
    }
    let zero_const: u8 = 0;
    while (ck < 64) {
      cd.name[ck] = zero_const;
      ck = ck + 1;
    }
    cd.name_len = res.const_name_lens[const_i];
    cd.type_ref = type_ref;
    cd.init_ref = cinit_ref;
    b.const_decls[const_i] = cd;
    const_i = const_i + 1;
  }
  let let_i: i32 = 0;
  while (let_i < res.num_lets && let_i < 256) {
    /* 优先使用 parse_body_lets_into 记录的 let 源码类型（如 [4]u8），否则回退占位 type_ref（函数返回类型的 i32）。 */
    let let_decl_ty: i32 = type_ref;
    if (res.let_type_refs[let_i] != 0) {
      let_decl_ty = res.let_type_refs[let_i];
    }
    let init_ref: i32 = 0;
    if (res.let_init_refs[let_i] != 0) {
      init_ref = res.let_init_refs[let_i];
    } else {
      init_ref = ast_arena_expr_alloc(arena);
      if (init_ref == 0) {
        return false;
      }
      let le: Expr = ast_arena_expr_get(arena, init_ref);
      le.kind = ExprKind.EXPR_LIT;
      le.resolved_type_ref = let_decl_ty;
      le.line = 0;
      le.col = 0;
      le.int_val = res.let_init_vals[let_i];
      expr_set_common_zeros(&le);
      ast_arena_expr_set(arena, init_ref, le);
    }
    let ld: LetDecl = b.let_decls[let_i];
    let lk: i32 = 0;
    while (lk < res.let_name_lens[let_i] && lk < 64) {
      let let_row: [64]u8 = res.let_names[let_i];
      ld.name[lk] = let_row[lk];
      lk = lk + 1;
    }
    let zero_let: u8 = 0;
    while (lk < 64) {
      ld.name[lk] = zero_let;
      lk = lk + 1;
    }
    ld.name_len = res.let_name_lens[let_i];
    ld.type_ref = let_decl_ty;
    ld.init_ref = init_ref;
    b.let_decls[let_i] = ld;
    let_i = let_i + 1;
  }
  ast_arena_block_set(arena, block_ref, b);
  return true;
}

/**
 * 解析块体：lex 为 { 之后的第一个 token；解析 const* let* (while)* (for)* (if (expr) { block })* 可选最终表达式，期望以 } 结束。
 * 成功时写 out.block_ref、out.next_lex（在 } 之后），type_ref 用于 const/let 初值类型，可为 0。
 */
function parse_block_into(arena: *ASTArena, lex_after_lbrace: Lexer, source: []u8, type_ref: i32, out: *ParseBlockResult): void {
  let blk_empty32: [32]u8 = [];
  let blk_empty64: [64]u8 = [];
  let blk_dummy_p: [16][32]u8 = [blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32, blk_empty32];
  let blk_dummy_plens: [16]i32 = [];
  let blk_dummy_ptrefs: [16]i32 = [];
  let blk_dummy_c: [256][64]u8 = [];
  let blk_dummy_clens: [256]i32 = [];
  let blk_dummy_cvals: [256]i32 = [];
  let blk_dummy_ln: [256][64]u8 = [];
  let blk_dummy_llens: [256]i32 = [];
  let blk_dummy_lvals: [256]i32 = [];
  let blk_dummy_let_refs: [256]i32 = [];
  /* 与 blk_dummy_let_refs 分列，parse_block_into 临时 OneFuncResult 两字段互不别名。 */
  let blk_dummy_ltrefs: [256]i32 = [];
  let blk_dummy_loop_refs: [8]i32 = [];
  let blk_dummy_for_refs: [8]i32 = [];
  let blk_dummy_if_refs: [16]i32 = [];
  let blk_dummy_call_arg_vals: [16]i32 = [];
  let temp: OneFuncResult = OneFuncResult { ok: true, next_lex: lex_after_lbrace, name: blk_empty64, name_len: 0, num_params: 0, param_names: blk_dummy_p, param_name_lens: blk_dummy_plens, param_type_refs: blk_dummy_ptrefs, num_consts: 0, const_names: blk_dummy_c, const_name_lens: blk_dummy_clens, const_init_vals: blk_dummy_cvals, num_lets: 0, let_names: blk_dummy_ln, let_name_lens: blk_dummy_llens, let_init_vals: blk_dummy_lvals, let_init_refs: blk_dummy_let_refs, let_type_refs: blk_dummy_ltrefs, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, if_cond_expr_ref: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, binop_left_param_idx: -1, binop_right_param_idx: -1, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: blk_empty64, call_callee_len: 0, return_var_name: [], return_var_name_len: 0, return_expr_ref: 0, call_num_args: 0, call_arg_vals: blk_dummy_call_arg_vals, num_loops: 0, loop_cond_refs: blk_dummy_loop_refs, loop_body_refs: blk_dummy_loop_refs, num_for_loops: 0, for_init_refs: blk_dummy_for_refs, for_cond_refs: blk_dummy_for_refs, for_step_refs: blk_dummy_for_refs, for_body_refs: blk_dummy_for_refs, num_if_stmts: 0, if_cond_refs: blk_dummy_if_refs, if_then_body_refs: blk_dummy_if_refs, num_src_stmt_order: 0, src_stmt_kind: [], src_stmt_idx: [], num_src_body_expr_stmts: 0, src_body_expr_stmt_refs: [], func_return_type_ref: 0 };
  let lex_cur: Lexer = lex_after_lbrace;
  parse_body_lets_into(arena, lex_after_lbrace, source, &temp, &lex_cur);
  let block_ref: i32 = ast_arena_block_alloc(arena);
  if (block_ref == 0) {
    out.ok = false;
    return;
  }
  let b: Block = ast_arena_block_get(arena, block_ref);
  b.num_loops = 0;
  b.num_for_loops = 0;
  b.num_if_stmts = 0;
  b.num_defers = 0;
  b.num_labeled_stmts = 0;
  b.num_expr_stmts = 0;
  b.final_expr_ref = 0;
  b.num_stmt_order = 0;
  ast_arena_block_set(arena, block_ref, b);
  if (!fill_block_const_let_from_res(arena, block_ref, &temp, type_ref)) {
    out.ok = false;
    return;
  }
  b = ast_arena_block_get(arena, block_ref);
  let so: i32 = 0;
  let ci: i32 = 0;
  while (ci < b.num_consts && so < 96) {
    b.stmt_order[so].kind = 0;
    b.stmt_order[so].idx = ci;
    so = so + 1;
    ci = ci + 1;
  }
  let li: i32 = 0;
  while (li < b.num_lets && so < 96) {
    b.stmt_order[so].kind = 1;
    b.stmt_order[so].idx = li;
    so = so + 1;
    li = li + 1;
  }
  let r: LexerResult = LexerResult { next_lex: lex_cur, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  /*
   * 预读首 token：若首 token 是 return/while/for/if，各专用 while 会从「关键字所在位置」再起 lex 消费，
   * 故勿把 lex_cur 挪到 r.next_lex。若误将「赋值/调用/break 等 expr;」的起点挪过后面的 token，
   * 则下方 parse_expr_into 会从错误位置起手，整块（含 loop body）解析失败，parse_into 会跳过整函数、num_funcs=0。
   */
  let lex_final_expr_start: Lexer = lex_cur;
  lexer_next_into(&r, lex_cur, source);
  while (r.tok.kind == TokenKind.TOKEN_WHILE && b.num_loops < 8) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let loop_cond_start: Lexer = lex_cur;
    let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: loop_cond_start };
    parse_cond_expr_into(arena, loop_cond_start, source, &expr_res);
    if (!expr_res.ok) {
      out.ok = false;
      return;
    }
    let cond_ref: i32 = expr_res.expr_ref;
    lex_cur = expr_res.next_lex;
    if (advance_past_cond_rparen_into(&r, lex_cur, source) == 0) {
      out.ok = false;
      return;
    }
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let block_res: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex_cur };
    parse_block_into(arena, lex_cur, source, type_ref, &block_res);
    if (!block_res.ok) {
      out.ok = false;
      return;
    }
    b.loops[b.num_loops].cond_ref = cond_ref;
    b.loops[b.num_loops].body_ref = block_res.block_ref;
    b.num_loops = b.num_loops + 1;
    if (so < 96) {
      b.stmt_order[so].kind = 3;
      b.stmt_order[so].idx = b.num_loops - 1;
      so = so + 1;
    }
    lex_cur = block_res.next_lex;
    lex_final_expr_start = lex_cur;
    lexer_next_into(&r, lex_cur, source);
  }
  while (r.tok.kind == TokenKind.TOKEN_FOR && b.num_for_loops < 8) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let init_ref: i32 = 0;
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      let expr_res_fi: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex_cur };
      parse_expr_into(arena, lex_cur, source, &expr_res_fi);
      if (!expr_res_fi.ok) {
        out.ok = false;
        return;
      }
      init_ref = expr_res_fi.expr_ref;
      lex_cur = expr_res_fi.next_lex;
      lexer_next_into(&r, lex_cur, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let cond_ref: i32 = 0;
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      let expr_res_fc: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex_cur };
      parse_expr_into(arena, lex_cur, source, &expr_res_fc);
      if (!expr_res_fc.ok) {
        out.ok = false;
        return;
      }
      cond_ref = expr_res_fc.expr_ref;
      lex_cur = expr_res_fc.next_lex;
      lexer_next_into(&r, lex_cur, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let step_ref: i32 = 0;
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
      let expr_res_fs: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex_cur };
      parse_expr_into(arena, lex_cur, source, &expr_res_fs);
      if (!expr_res_fs.ok) {
        out.ok = false;
        return;
      }
      step_ref = expr_res_fs.expr_ref;
      lex_cur = expr_res_fs.next_lex;
      lexer_next_into(&r, lex_cur, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let block_res: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex_cur };
    parse_block_into(arena, lex_cur, source, type_ref, &block_res);
    if (!block_res.ok) {
      out.ok = false;
      return;
    }
    if (cond_ref == 0) {
      let cond_expr_ref: i32 = ast_arena_expr_alloc(arena);
      if (cond_expr_ref != 0) {
        let ce: Expr = ast_arena_expr_get(arena, cond_expr_ref);
        ce.kind = ExprKind.EXPR_BOOL_LIT;
        ce.int_val = 1;
        ce.line = 0;
        ce.col = 0;
        expr_set_common_zeros(&ce);
        ast_arena_expr_set(arena, cond_expr_ref, ce);
        cond_ref = cond_expr_ref;
      }
    }
    b.for_loops[b.num_for_loops].init_ref = init_ref;
    b.for_loops[b.num_for_loops].cond_ref = cond_ref;
    b.for_loops[b.num_for_loops].step_ref = step_ref;
    b.for_loops[b.num_for_loops].body_ref = block_res.block_ref;
    b.num_for_loops = b.num_for_loops + 1;
    if (so < 96) {
      b.stmt_order[so].kind = 4;
      b.stmt_order[so].idx = b.num_for_loops - 1;
      so = so + 1;
    }
    lex_cur = block_res.next_lex;
    lex_final_expr_start = lex_cur;
    lexer_next_into(&r, lex_cur, source);
  }
  /* if ( cond ) { block }：与 while/for 并列，then 无 else；最多 16 条，写入 if_stmts 与 stmt_order kind=5 */
  while (r.tok.kind == TokenKind.TOKEN_IF && b.num_if_stmts < 16) {
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let blk_if_cond_start: Lexer = lex_cur;
    let expr_if: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: blk_if_cond_start };
    parse_cond_expr_into(arena, blk_if_cond_start, source, &expr_if);
    if (!expr_if.ok) {
      out.ok = false;
      return;
    }
    let if_cond: i32 = expr_if.expr_ref;
    lex_cur = expr_if.next_lex;
    if (advance_past_cond_rparen_into(&r, lex_cur, source) == 0) {
      out.ok = false;
      return;
    }
    if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
      out.ok = false;
      return;
    }
    lex_cur = r.next_lex;
    let if_block_res: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex_cur };
    parse_block_into(arena, lex_cur, source, type_ref, &if_block_res);
    if (!if_block_res.ok) {
      out.ok = false;
      return;
    }
    b.if_stmts[b.num_if_stmts].cond_ref = if_cond;
    b.if_stmts[b.num_if_stmts].then_body_ref = if_block_res.block_ref;
    b.num_if_stmts = b.num_if_stmts + 1;
    if (so < 96) {
      b.stmt_order[so].kind = 5;
      b.stmt_order[so].idx = b.num_if_stmts - 1;
      so = so + 1;
    }
    lex_cur = if_block_res.next_lex;
    lex_final_expr_start = lex_cur;
    lexer_next_into(&r, lex_cur, source);
  }
  /* return expr; 语句：写入 expr_stmt_refs 为 EXPR_RETURN，供 if/while 块体内 return（此前仅支持块尾裸表达式）。 */
  while (r.tok.kind == TokenKind.TOKEN_RETURN && b.num_expr_stmts < 32) {
    lex_from_next_into(&lex_cur, r);
    let ret_val_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex_cur };
    lexer_next_into(&r, lex_cur, source);
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      parse_expr_into(arena, lex_cur, source, &ret_val_res);
      if (!ret_val_res.ok) {
        out.ok = false;
        return;
      }
      lex_cur = ret_val_res.next_lex;
      lexer_next_into(&r, lex_cur, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      out.ok = false;
      return;
    }
    let ret_ref: i32 = ast_arena_expr_alloc(arena);
    if (ret_ref == 0) {
      out.ok = false;
      return;
    }
    let re: Expr = ast_arena_expr_get(arena, ret_ref);
    re.kind = ExprKind.EXPR_RETURN;
    re.line = 0;
    re.col = 0;
    expr_set_common_zeros(&re);
    if (ret_val_res.ok) {
      re.unary_operand_ref = ret_val_res.expr_ref;
    }
    ast_arena_expr_set(arena, ret_ref, re);
    b.expr_stmt_refs[b.num_expr_stmts] = ret_ref;
    b.num_expr_stmts = b.num_expr_stmts + 1;
    if (so < 96) {
      b.stmt_order[so].kind = 2;
      b.stmt_order[so].idx = b.num_expr_stmts - 1;
      so = so + 1;
    }
    lex_cur = r.next_lex;
    lex_final_expr_start = lex_cur;
    lexer_next_into(&r, lex_cur, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
    let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex_cur };
    parse_expr_into(arena, lex_final_expr_start, source, &expr_res);
    if (expr_res.ok) {
      b.final_expr_ref = expr_res.expr_ref;
      lex_cur = expr_res.next_lex;
      lexer_next_into(&r, lex_cur, source);
    }
  }
  if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
    out.ok = false;
    return;
  }
  b.num_stmt_order = so;
  ast_arena_block_set(arena, block_ref, b);
  out.ok = true;
  out.block_ref = block_ref;
  out.next_lex = r.next_lex;
}

/**
 * 解析最小程序：function main(): i32 { return <expr>; }（返回类型用 :）
 * return 后：`TOKEN_INT` 走快路径；否则在**堆上**分配一块与 `runtime.c driver_arena_static` 同量级的缓冲区，
 * 经 `parse_expr_into` 解析（bootstrap-parse-file 第二段可与宿主 shu 同写 `return (1+2)*3+-1`）。
 * `return_val` 在解析器常量折叠命中时填入，否则成功仍可为 0（联调只看 ok）。
 */
function parse(source: []u8): ParseResult {
  let arena_heap_bytes: usize = pipeline_sizeof_arena();
  let lex: Lexer = lexer_init();
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_I32) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RETURN) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  let lex_at_expr_start: Lexer = lex;
  lexer_next_into(&r, lex, source);
  let ret_val: i32 = 0;
  if (r.tok.kind == TokenKind.TOKEN_INT) {
    ret_val = r.tok.int_val;
    lex_from_next_into(&lex, r);
  } else {
    let raw_arena: *u8 = alloc_zeroed(arena_heap_bytes);
    if (raw_arena == 0 as *u8) {
      return ParseResult { ok: false, return_val: 0 }
    }
    let heap_arena: *ASTArena = raw_arena as *ASTArena;
    ast_arena_init(heap_arena);
    let expr_out: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
    parse_expr_into(heap_arena, lex_at_expr_start, source, &expr_out);
    if (!expr_out.ok || expr_out.expr_ref <= 0) {
      free(raw_arena);
      return ParseResult { ok: false, return_val: 0 }
    }
    let e_read: Expr = ast_arena_expr_get(heap_arena, expr_out.expr_ref);
    if (e_read.const_folded_valid != 0) {
      ret_val = e_read.const_folded_val;
    }
    lex = expr_out.next_lex;
    free(raw_arena);
  }
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
    return ParseResult { ok: false, return_val: 0 }
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EOF) {
    return ParseResult { ok: false, return_val: 0 }
  }
  return ParseResult { ok: true, return_val: ret_val }
}

/**
 * 诊断用：返回 source 首 token 的 kind（整型），失败时便于 main 打印。
 */
function first_token_kind(source: []u8): i32 {
  let lex: Lexer = lexer_init();
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  return r.tok.kind;
}

/**
 * 诊断用：返回首 IDENT（函数名）的 ident_len，用于确认 lexer 是否正确填充。
 */
function diag_first_ident_len(source: []u8): i32 {
  let lex: Lexer = lexer_init();
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return -2;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return -3;
  }
  return r.tok.ident_len;
}

/**
 * 诊断用：从 body 首 token 起跳过所有 let/const，写入 out，避免 LexerResult 按值返回 ABI 问题。
 */
function diag_skip_let_const_into(out: *LexerResult, lex: Lexer, source: []u8): void {
  lexer_next_into(out, lex, source);
  while (out.tok.kind == TokenKind.TOKEN_LET || out.tok.kind == TokenKind.TOKEN_CONST) {
    lex_from_result_ptr_into(&lex, out);
    lexer_next_into(out, lex, source);
    if (out.tok.kind != TokenKind.TOKEN_IDENT) {
      return;
    }
    lex_from_result_ptr_into(&lex, out);
    lexer_next_into(out, lex, source);
    if (out.tok.kind != TokenKind.TOKEN_COLON) {
      return;
    }
    lex_from_result_ptr_into(&lex, out);
    lexer_next_into(out, lex, source);
    if (out.tok.kind == TokenKind.TOKEN_STAR) {
      lex_from_result_ptr_into(&lex, out);
      lexer_next_into(out, lex, source);
      if (out.tok.kind != TokenKind.TOKEN_IDENT) {
        return;
      }
      lex_from_result_ptr_into(&lex, out);
      lexer_next_into(out, lex, source);
    } else if (out.tok.kind == TokenKind.TOKEN_I32 || out.tok.kind == TokenKind.TOKEN_BOOL || out.tok.kind == TokenKind.TOKEN_I64 || out.tok.kind == TokenKind.TOKEN_VOID || out.tok.kind == TokenKind.TOKEN_IDENT) {
      lex_from_result_ptr_into(&lex, out);
      lexer_next_into(out, lex, source);
    } else {
      return;
    }
    if (out.tok.kind != TokenKind.TOKEN_ASSIGN) {
      return;
    }
    lex_from_result_ptr_into(&lex, out);
    lexer_next_into(out, lex, source);
    while (out.tok.kind != TokenKind.TOKEN_SEMICOLON && out.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_result_ptr_into(&lex, out);
      lexer_next_into(out, lex, source);
    }
    if (out.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return;
    }
    lex_from_result_ptr_into(&lex, out);
    lexer_next_into(out, lex, source);
  }
}

/** 兼容：返回 LexerResult，内部调 diag_skip_let_const_into 再写回（仍有 return 的 ABI 风险，优先用 _into）。 */
function diag_skip_let_const(lex: Lexer, source: []u8): LexerResult {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  diag_skip_let_const_into(&r, lex, source);
  return r;
}

/** 与 diag_skip_let_const 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function diag_skip_let_const_buf(lex: Lexer, data: *u8, len: i32): LexerResult {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  while (r.tok.kind == TokenKind.TOKEN_LET || r.tok.kind == TokenKind.TOKEN_CONST) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return r;
    }
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_COLON) {
      return r;
    }
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_STAR) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        return r;
      }
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
    } else if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_VOID || r.tok.kind == TokenKind.TOKEN_IDENT) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
    } else {
      return r;
    }
    if (r.tok.kind != TokenKind.TOKEN_ASSIGN) {
      return r;
    }
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return r;
    }
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
  }
  return r;
}

/**
 * 从 body 首 token 起先跳过 let/const，再跳过所有 if，结果写入 out，避免 LexerResult 按值返回 ABI。
 */
function body_skip_let_const_then_if_into(out: *LexerResult, lex: Lexer, source: []u8): void {
  diag_skip_let_const_into(out, lex, source);
  while (out.tok.kind == TokenKind.TOKEN_IF) {
    skip_one_if_statement_into(out, out.next_lex, source);
  }
}

/**
 * 从 body 首 token（{ 之后）起解析 let 声明，填充 out.num_lets、out.let_names、out.let_name_lens、
 * out.let_type_refs（冒号与等号间的类型 arena ref）、out.let_init_vals、out.let_init_refs（数组字面量或调用时在 arena 中构建并写 ref）。
 * 返回第一个非 let/const 的 token 对应的 lex（即该 token 起始位置），供调用方继续解析 return/if 等。
 * 支持的 init：整数字面量（写 let_init_vals，let_init_refs=0）、[ int , ... ]（EXPR_ARRAY_LIT）、
 * ident ( ident , int )（EXPR_CALL，如 print_str(msg, 12)）。
 */
/** 将 parse_body_lets 结果写入 lex_out 指针，避免 ARM64 下 Lexer 按值返回 ABI 错误（返回 void 即直接写入 out 参数）。 */
function parse_body_lets_into(arena: *ASTArena, lex: Lexer, source: []u8, out: *OneFuncResult, lex_out: *Lexer): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  while (r.tok.kind == TokenKind.TOKEN_LET || r.tok.kind == TokenKind.TOKEN_CONST) {
    if (out.num_lets >= 256) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    let is_let: bool = r.tok.kind == TokenKind.TOKEN_LET;
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    let name_len: i32 = r.tok.ident_len;
    if (name_len <= 0 || name_len > 63) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    /* token_start 在 slice 内为真实起点，偏移 0 合法（勿用 token_start!=0 作哨兵）。 */
    let name_start: usize = r.token_start;
    let name_row: [64]u8 = [];
    let ni: i32 = 0;
    while (ni < name_len && ni < 64) {
      if (name_start + ni < source.length) {
        name_row[ni] = source[name_start + ni];
      }
      ni = ni + 1;
    }
    let zi: i32 = ni;
    while (zi < 64) {
      name_row[zi] = 0;
      zi = zi + 1;
    }
    if (is_let) {
      let copy_k: i32 = 0;
      while (copy_k < 64) {
        out.let_names[out.num_lets][copy_k] = name_row[copy_k];
        copy_k = copy_k + 1;
      }
      out.let_name_lens[out.num_lets] = name_len;
    }
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_COLON) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    lex_from_result_ptr_into(&lex, &r);
    /* 解析 `:` 与 `=` 之间的类型（与形参同一套）；成功则记入 out.let_type_refs，供 INDEX 等对 let 变量的 typeck。 */
    let let_ty_ref: i32 = parse_type_ref_for_arena_into(arena, lex, source, &lex);
    if (let_ty_ref == 0) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    if (is_let) {
      out.let_type_refs[out.num_lets] = let_ty_ref;
    }
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_ASSIGN) {
      lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
    }
    lex_from_result_ptr_into(&lex, &r);
    lexer_next_into(&r, lex, source);
    /* 解析 init：[ int , ... ] | ident ( ident , int ) | int；仅 LET 时写 out.let_init_* */
    if (is_let) {
      out.let_init_refs[out.num_lets] = 0;
      out.let_init_vals[out.num_lets] = 0;
    }
    let cast_init_semi_done: bool = false;
    if (r.tok.kind == TokenKind.TOKEN_LBRACKET) {
      /* 数组字面量 [ int , int , ... ]，最多 16 个元素 */
      lex_from_result_ptr_into(&lex, &r);
      lexer_next_into(&r, lex, source);
      let elem_refs: [16]i32 = [];
      let n_elems: i32 = 0;
      while (r.tok.kind != TokenKind.TOKEN_RBRACKET && n_elems < 16) {
        if (r.tok.kind == TokenKind.TOKEN_INT) {
          let er: i32 = ast_arena_expr_alloc(arena);
          if (er != 0) {
            let ee: Expr = ast_arena_expr_get(arena, er);
            ee.kind = ExprKind.EXPR_LIT;
            ee.resolved_type_ref = 0;
            ee.line = 0;
            ee.col = 0;
            ee.int_val = r.tok.int_val;
            ee.binop_left_ref = 0;
            ee.binop_right_ref = 0;
            ee.unary_operand_ref = 0;
            ee.if_cond_ref = 0;
            ee.if_then_ref = 0;
            ee.if_else_ref = 0;
            ee.block_ref = 0;
            ee.match_matched_ref = 0;
            ee.match_num_arms = 0;
            ast.expr_init_match_enum(&ee);
            ee.field_access_base_ref = 0;
            ee.field_access_field_len = 0;
            ee.field_access_is_enum_variant = 0;
            ee.field_access_offset = 0;
            ee.index_base_ref = 0;
            ee.index_index_ref = 0;
            ee.index_base_is_slice = 0;
            ee.call_callee_ref = 0;
            ee.call_num_args = 0;
            ee.method_call_base_ref = 0;
            ee.method_call_name_len = 0;
            ee.method_call_num_args = 0;
            ee.const_folded_val = 0;
            ee.const_folded_valid = 0;
            ee.index_proven_in_bounds = 0;
            ast_arena_expr_set(arena, er, ee);
            elem_refs[n_elems] = er;
            n_elems = n_elems + 1;
          }
          lex_from_result_ptr_into(&lex, &r);
          lexer_next_into(&r, lex, source);
        } else if (r.tok.kind == TokenKind.TOKEN_COMMA) {
          lex_from_result_ptr_into(&lex, &r);
          lexer_next_into(&r, lex, source);
        } else {
          break;
        }
      }
      if (r.tok.kind == TokenKind.TOKEN_RBRACKET && n_elems > 0) {
        let arr_ref: i32 = ast_arena_expr_alloc(arena);
        if (arr_ref != 0) {
          let ae: Expr = ast_arena_expr_get(arena, arr_ref);
          ae.kind = ExprKind.EXPR_ARRAY_LIT;
          ae.resolved_type_ref = 0;
          ae.line = 0;
          ae.col = 0;
          ae.array_lit_num_elems = n_elems;
          let ei: i32 = 0;
          while (ei < 16) {
            ae.array_lit_elem_refs[ei] = ei < n_elems ? elem_refs[ei] : 0;
            ei = ei + 1;
          }
          ae.binop_left_ref = 0;
          ae.binop_right_ref = 0;
          ae.unary_operand_ref = 0;
          ae.if_cond_ref = 0;
          ae.if_then_ref = 0;
          ae.if_else_ref = 0;
          ae.block_ref = 0;
          ae.match_matched_ref = 0;
          ae.match_num_arms = 0;
          ast.expr_init_match_enum(&ae);
          ae.field_access_base_ref = 0;
          ae.field_access_field_len = 0;
          ae.field_access_is_enum_variant = 0;
          ae.field_access_offset = 0;
          ae.index_base_ref = 0;
          ae.index_index_ref = 0;
          ae.index_base_is_slice = 0;
          ae.call_callee_ref = 0;
          ae.call_num_args = 0;
          ae.method_call_base_ref = 0;
          ae.method_call_name_len = 0;
          ae.method_call_num_args = 0;
          ae.const_folded_val = 0;
          ae.const_folded_valid = 0;
          ae.index_proven_in_bounds = 0;
          ast_arena_expr_set(arena, arr_ref, ae);
          if (is_let) {
            out.let_init_refs[out.num_lets] = arr_ref;
          }
        }
        lex_from_result_ptr_into(&lex, &r);
        lexer_next_into(&r, lex, source);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_IDENT) {
      /* RHS 以 ident 开头：从 ident 起点 parse_expr_into（含 foo()、foo(a,b)、buffers[0].handle、单变量） */
      let rhs_ilen: i32 = r.tok.ident_len;
      let rhs_ident_start: usize = r.next_lex.pos - (rhs_ilen as usize);
      lex_from_result_ptr_into(&lex, &r);
      let expr_lex: Lexer = Lexer { pos: rhs_ident_start, line: 1, col: 1 };
      let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: expr_lex };
      parse_expr_into(arena, expr_lex, source, &expr_res);
      if (!expr_res.ok) {
        lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
      }
      if (is_let) {
        out.let_init_refs[out.num_lets] = expr_res.expr_ref;
      }
      lex = expr_res.next_lex;
      lexer_next_into(&r, lex, source);
    } else if (r.tok.kind == TokenKind.TOKEN_TRUE || r.tok.kind == TokenKind.TOKEN_FALSE) {
      /* bool 字面量：创建 EXPR_BOOL_LIT 表达式并写入 arena，使 typeck 可以检查 let x: i32 = true 的类型不匹配 */
      if (is_let) {
        let bool_ref: i32 = ast_arena_expr_alloc(arena);
        if (bool_ref != 0) {
          let be: Expr = ast_arena_expr_get(arena, bool_ref);
          be.kind = ExprKind.EXPR_BOOL_LIT;
          be.resolved_type_ref = 0;
          be.line = 0;
          be.col = 0;
          be.int_val = (if (r.tok.kind == TokenKind.TOKEN_TRUE) { 1 } else { 0 });
          ast.expr_init_match_enum(&be);
          be.binop_left_ref = 0;
          be.binop_right_ref = 0;
          be.unary_operand_ref = 0;
          be.if_cond_ref = 0;
          be.if_then_ref = 0;
          be.if_else_ref = 0;
          be.block_ref = 0;
          be.field_access_base_ref = 0;
          be.field_access_field_len = 0;
          be.field_access_is_enum_variant = 0;
          be.field_access_offset = 0;
          be.index_base_ref = 0;
          be.index_index_ref = 0;
          be.index_base_is_slice = 0;
          be.call_callee_ref = 0;
          be.call_num_args = 0;
          be.method_call_base_ref = 0;
          be.method_call_name_len = 0;
          be.method_call_num_args = 0;
          be.const_folded_val = 0;
          be.const_folded_valid = 0;
          be.index_proven_in_bounds = 0;
          ast_arena_expr_set(arena, bool_ref, be);
          out.let_init_refs[out.num_lets] = bool_ref;
        }
      }
      lex_from_result_ptr_into(&lex, &r);
      lexer_next_into(&r, lex, source);
    } else if (r.tok.kind == TokenKind.TOKEN_INT) {
      /* 初值可能为 0 as *u8 等：遇 as 时用 parse_expr_into，勿仅记整数字面量。 */
      let int_val_saved: i32 = r.tok.int_val;
      let int_start: usize = r.token_start;
      if (int_start == 0) {
        int_start = r.next_lex.pos - 1;
      }
      let int_lex: Lexer = Lexer { pos: int_start, line: lex.line, col: lex.col };
      lex_from_result_ptr_into(&lex, &r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind == TokenKind.TOKEN_AS) {
        let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: int_lex };
        parse_expr_into(arena, int_lex, source, &expr_res);
        if (!expr_res.ok) {
          lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
        }
        if (is_let) {
          out.let_init_refs[out.num_lets] = expr_res.expr_ref;
        }
        lex = expr_res.next_lex;
        if (advance_past_stmt_semicolon_into(&r, lex, source) == 0) {
          lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
        }
        lex_from_result_ptr_into(&lex, &r);
        cast_init_semi_done = true;
      } else if (is_let) {
        out.let_init_vals[out.num_lets] = int_val_saved;
      }
    }
    if (!cast_init_semi_done) {
      if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
        lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col; return;
      }
      lex_from_result_ptr_into(&lex, &r);
      lexer_next_into(&r, lex, source);
    }
    if (is_let) {
      out.num_lets = out.num_lets + 1;
    }
  }
  lex_out.pos = lex.pos; lex_out.line = lex.line; lex_out.col = lex.col;
}

/** 兼容：返回 LexerResult，内部调 _into（仍有 return 的 ABI 风险）。 */
function body_skip_let_const_then_if(lex: Lexer, source: []u8): LexerResult {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  body_skip_let_const_then_if_into(&r, lex, source);
  return r;
}

/** 与 body_skip_let_const_then_if 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function body_skip_let_const_then_if_buf(lex: Lexer, data: *u8, len: i32): LexerResult {
  let r: LexerResult = diag_skip_let_const_buf(lex, data, len);
  while (r.tok.kind == TokenKind.TOKEN_IF) {
    r = skip_one_if_statement_buf(r.next_lex, data, len);
  }
  return r;
}

/**
 * 从 lex（已消费开括号）起跳过匹配的括号，返回匹配的 ) 之后的 lex 状态；用于跳过 if ( ... ) 中的条件。
 */
function skip_balanced_parens(lex: Lexer, source: []u8): Lexer {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_LPAREN) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
      depth = depth - 1;
      if (depth == 0) {
        return r.next_lex;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      return lex;
    }
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/** 直接在 out 指针写结果，避免 ARM64 下 Lexer 按值返回 ABI 错误。供 parse_one_function_impl 等热路径使用。 */
function skip_balanced_parens_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
    lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_LPAREN) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
      depth = depth - 1;
      if (depth == 0) {
        out.pos = r.next_lex.pos;
        out.line = r.next_lex.line;
        out.col = r.next_lex.col;
        return;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      out.pos = lex.pos;
      out.line = lex.line;
      out.col = lex.col;
      return;
    }
    lex_from_next_into(&lex, r);
  }
  out.pos = lex.pos;
  out.line = lex.line;
  out.col = lex.col;
}

/** 与 skip_balanced_parens 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
/** skip_balanced_parens_buf 的 _into_buf 变体。 */
function skip_balanced_parens_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_LPAREN) { depth = depth + 1; }
    else if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
      depth = depth - 1;
      if (depth == 0) { out.pos = r.next_lex.pos; out.line = r.next_lex.line; out.col = r.next_lex.col; return; }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
    lex_from_next_into(&lex, r);
  }
  out.pos = lex.pos; out.line = lex.line; out.col = lex.col;
}

function skip_balanced_parens_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_LPAREN) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
      depth = depth - 1;
      if (depth == 0) {
        return r.next_lex;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      return lex;
    }
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/**
 * 从 lex（已消费开大括号）起跳过匹配的大括号，返回匹配的 } 之后的 lex 状态；用于跳过 if { ... } 块。
 */
function skip_balanced_braces(lex: Lexer, source: []u8): Lexer {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      depth = depth - 1;
      if (depth == 0) {
        return r.next_lex;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      return lex;
    }
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/** 直接在 out 指针写结果，避免 ARM64 下 Lexer 按值返回 ABI 错误。 */
function skip_balanced_braces_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
    lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      depth = depth - 1;
      if (depth == 0) {
        out.pos = r.next_lex.pos;
        out.line = r.next_lex.line;
        out.col = r.next_lex.col;
        return;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      out.pos = lex.pos;
      out.line = lex.line;
      out.col = lex.col;
      return;
    }
    lex_from_next_into(&lex, r);
  }
  out.pos = lex.pos;
  out.line = lex.line;
  out.col = lex.col;
}

/** skip_balanced_braces_buf 的 _into_buf 变体。 */
function skip_balanced_braces_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_LBRACE) { depth = depth + 1; }
    else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      depth = depth - 1;
      if (depth == 0) { out.pos = r.next_lex.pos; out.line = r.next_lex.line; out.col = r.next_lex.col; return; }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
    lex_from_next_into(&lex, r);
  }
  out.pos = lex.pos; out.line = lex.line; out.col = lex.col;
}

/** 与 skip_balanced_braces 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function skip_balanced_braces_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let depth: i32 = 1;
  while (depth > 0) {
    let r: LexerResult = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
      depth = depth + 1;
    } else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      depth = depth - 1;
      if (depth == 0) {
        return r.next_lex;
      }
    }
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      return lex;
    }
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/**
 * 从「function」前 lex 起跳过整条函数（含签名与体），返回 } 之后的 lex；用于 parse_into 在 parse 与 library 均失败时跳过该函数继续下一项。
 */
/** 从「function」前 lex 起跳过整条函数（含签名与体），通过 out 避免 ABI。 */
function skip_one_function_full_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_parens_into(&lex, r.next_lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  while (r.tok.kind != TokenKind.TOKEN_LBRACE && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into(out, r.next_lex, source);
}
function skip_one_function_full(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return lex;
  }
  lex = skip_balanced_parens(r.next_lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  while (r.tok.kind != TokenKind.TOKEN_LBRACE && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/** skip_one_function_full_buf 的 _into_buf 变体。 */
function skip_one_function_full_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_parens_into_buf(&lex, r.next_lex, data, len);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  while (r.tok.kind != TokenKind.TOKEN_LBRACE && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into_buf(out, r.next_lex, data, len);
}

/** 与 skip_one_function_full 等价，接受 (data: *u8, len) 供 parse_into_buf 使用。 */
function skip_one_function_full_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return lex;
  }
  lex = skip_balanced_parens_buf(r.next_lex, data, len);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  while (r.tok.kind != TokenKind.TOKEN_LBRACE && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/**
 * 跳过 if 的 ( ) 与紧跟的 { } 或单句；lex 为消费掉 if 后的状态（下一 token 为 (）。
 * 单独成函数避免 codegen 将 while(ELSE) 与 return r 提到本逻辑前，导致未处理 LPAREN 就返回。
 * 返回跳过后的 LexerResult。
 */
function skip_one_if_core(lex: Lexer, source: []u8): LexerResult {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return r;
  }
  lex = skip_balanced_parens(r.next_lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
    lex = skip_balanced_braces(r.next_lex, source);
    lexer_next_into(&r, lex, source);
  } else {
    while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
    }
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
    }
  }
  return r;
}

/**
 * 跳过一条 if 语句（含 else / else if）；lex 为消费掉 if 后的状态（下一 token 为 (）。
 * 返回跳过后的 LexerResult，供 parse_one_function 与诊断在 body 内跳过 if 继续解析。
 * 通过调用 skip_one_if_core 保证 LPAREN 处理在 return 前执行，避免 codegen 重排。
 */
function skip_one_if_statement(lex: Lexer, source: []u8): LexerResult {
  /* 用 _into 避免 ARM64 下 LexerResult 按值返回/赋值的 ABI 错误 */
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  skip_one_if_core_into(&r, lex, source);
  while (r.tok.kind == TokenKind.TOKEN_ELSE) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_IF) {
      lex_from_next_into(&lex, r);
      skip_one_if_core_into(&r, lex, source);
    } else {
      if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
        lex = skip_balanced_braces(r.next_lex, source);
        lexer_next_into(&r, lex, source);
      } else {
        while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
          lex_from_next_into(&lex, r);
          lexer_next_into(&r, lex, source);
        }
        if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
          lex_from_next_into(&lex, r);
          lexer_next_into(&r, lex, source);
        }
      }
    }
  }
  return r;
}

/** skip_one_if_statement 的 _into 变体：直接在 out 指针输出避免 ARM64 下 LexerResult 按值返回 ABI 错误。 */
function skip_one_if_statement_into(out: *LexerResult, lex: Lexer, source: []u8): void {
  skip_one_if_core_into(out, lex, source);
  while (out.tok.kind == TokenKind.TOKEN_ELSE) {
    lex_from_next_into(&lex, *out);
    lexer_next_into(out, lex, source);
    if (out.tok.kind == TokenKind.TOKEN_IF) {
      lex_from_next_into(&lex, *out);
      skip_one_if_core_into(out, lex, source);
    } else {
      if (out.tok.kind == TokenKind.TOKEN_LBRACE) {
        skip_balanced_braces_into(&lex, out.next_lex, source);
        lexer_next_into(out, lex, source);
      } else {
        while (out.tok.kind != TokenKind.TOKEN_SEMICOLON && out.tok.kind != TokenKind.TOKEN_EOF) {
          lex_from_next_into(&lex, *out);
          lexer_next_into(out, lex, source);
        }
        if (out.tok.kind == TokenKind.TOKEN_SEMICOLON) {
          lex_from_next_into(&lex, *out);
          lexer_next_into(out, lex, source);
        }
      }
    }
  }
}

/** skip_one_if_core 的 _into 变体：直接在 out 指针输出。 */
function skip_one_if_core_into(out: *LexerResult, lex: Lexer, source: []u8): void {
  lexer_next_into(out, lex, source);
  if (out.tok.kind != TokenKind.TOKEN_LPAREN) {
    return;
  }
  skip_balanced_parens_into(&lex, out.next_lex, source);
  lexer_next_into(out, lex, source);
  if (out.tok.kind == TokenKind.TOKEN_LBRACE) {
    skip_balanced_braces_into(&lex, out.next_lex, source);
    lexer_next_into(out, lex, source);
  } else {
    while (out.tok.kind != TokenKind.TOKEN_SEMICOLON && out.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_next_into(&lex, *out);
      lexer_next_into(out, lex, source);
    }
    if (out.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, *out);
      lexer_next_into(out, lex, source);
    }
  }
}

/** 与 skip_one_if_core 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function skip_one_if_core_buf(lex: Lexer, data: *u8, len: i32): LexerResult {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return r;
  }
  lex = skip_balanced_parens_buf(r.next_lex, data, len);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
    lex = skip_balanced_braces_buf(r.next_lex, data, len);
    r = lexer_next_buf(lex, data, len);
  } else {
    while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
    }
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
    }
  }
  return r;
}

/** 与 skip_one_if_statement 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
function skip_one_if_statement_buf(lex: Lexer, data: *u8, len: i32): LexerResult {
  let r: LexerResult = skip_one_if_core_buf(lex, data, len);
  while (r.tok.kind == TokenKind.TOKEN_ELSE) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind == TokenKind.TOKEN_IF) {
      lex_from_next_into(&lex, r);
      r = skip_one_if_core_buf(lex, data, len);
    } else {
      if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
        lex = skip_balanced_braces_buf(r.next_lex, data, len);
        r = lexer_next_buf(lex, data, len);
      } else {
        while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
          lex_from_next_into(&lex, r);
          r = lexer_next_buf(lex, data, len);
        }
        if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
          lex_from_next_into(&lex, r);
          r = lexer_next_buf(lex, data, len);
        }
      }
    }
  }
  return r;
}

/**
 * 诊断用：按 parse_one_function 顺序检查，返回首次失败时的 token kind（成功返回 -1）。
 * 便于精确定位是哪个 token 导致解析失败。
 */
/** 诊断用：返回「跳过顶层 import 后的 lex」；单独成函数确保 codegen 先执行 skip_imports 再被 diag_fail 使用。 */
function diag_lex_after_imports(source: []u8): Lexer {
  let lex: Lexer = lexer_init();
  return skip_imports(lex, source);
}

/** 诊断用：在给定 lex 上取 token 并跳过 struct，返回第一个非 struct 的 LexerResult。 */
function diag_after_imports_then_structs(lex: Lexer, source: []u8): LexerResult {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  while (r.tok.kind == TokenKind.TOKEN_STRUCT) {
    lex = skip_one_struct(lex, source);
    lexer_next_into(&r, lex, source);
  }
  return r;
}

function diag_fail_at_token_kind(source: []u8): i32 {
  let lex: Lexer = diag_lex_after_imports(source);
  let r: LexerResult = diag_after_imports_then_structs(lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return r.tok.kind;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return r.tok.kind;
  }
  /* 直接使用 r.tok.ident_len 避免 codegen 将 nlen 提升到函数顶导致读到 FUNCTION 的 ident_len(0) */
  if (r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
    return r.tok.kind;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return r.tok.kind;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  } else {
    /* 有参数：循环接受 (IDENT COLON 类型) 直到 RPAREN */
    while (r.tok.kind == TokenKind.TOKEN_IDENT) {
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind != TokenKind.TOKEN_COLON) {
        return r.tok.kind;
      }
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_U8 || r.tok.kind == TokenKind.TOKEN_U32 || r.tok.kind == TokenKind.TOKEN_U64 || r.tok.kind == TokenKind.TOKEN_USIZE || r.tok.kind == TokenKind.TOKEN_VOID || r.tok.kind == TokenKind.TOKEN_IDENT) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
      } else if (r.tok.kind == TokenKind.TOKEN_STAR) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (!is_pointee_type_token(r.tok.kind)) {
          return r.tok.kind;
        }
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
      } else if (r.tok.kind == TokenKind.TOKEN_LBRACKET) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_INT) {
          return r.tok.kind;
        }
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_RBRACKET) {
          return r.tok.kind;
        }
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_U8) {
          return r.tok.kind;
        }
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
      } else {
        return r.tok.kind;
      }
      if (r.tok.kind == TokenKind.TOKEN_COMMA) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
      }
    }
    if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
      return r.tok.kind;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  }
  /* 此处 r 为 COLON（空参数时已读过）或 RPAREN 后的 token（有参数时） */
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return r.tok.kind;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_U8 || r.tok.kind == TokenKind.TOKEN_U32 || r.tok.kind == TokenKind.TOKEN_U64 || r.tok.kind == TokenKind.TOKEN_USIZE || r.tok.kind == TokenKind.TOKEN_VOID || r.tok.kind == TokenKind.TOKEN_IDENT) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  } else if (r.tok.kind == TokenKind.TOKEN_STAR) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (!is_pointee_type_token(r.tok.kind)) {
      return r.tok.kind;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  } else {
    return r.tok.kind;
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return r.tok.kind;
  }
  lex_from_next_into(&lex, r);
  body_skip_let_const_then_if_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_INT) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
      return r.tok.kind;
    }
    return -1;
  }
  if (r.tok.kind == TokenKind.TOKEN_RETURN) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_INT) {
      return r.tok.kind;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_RBRACE && r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return r.tok.kind;
    }
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
        return r.tok.kind;
      }
    }
    return -1;
  }
  return r.tok.kind;
}

/**
 * 从 source[start..start+nlen] 复制到 out[0..nlen-1]，避免 codegen 将复制循环提升到 FUNCTION 分支前。
 * 调用方在分支内传入 name（C 中数组按指针传递），保证复制在正确控制流下执行。
 */
function copy_slice_to_name64(source: []u8, start: usize, nlen: i32, out: [64]u8): void {
  let i: i32 = 0;
  while (i < nlen) {
    if (start + i < source.length) {
      out[i] = source[start + i];
    }
    i = i + 1;
  }
}

/** 从 source 的 [end_pos-nlen..end_pos) 复制到 out，供 scan 内调用避免在调用处写 as usize 触发解析歧义。 */
function copy_slice_to_name64_at_end(source: []u8, end_pos: usize, nlen: i32, out: [64]u8): void {
  let start: usize = end_pos - (nlen as usize);
  copy_slice_to_name64(source, start, nlen, out);
}

/** 从 source 的 [start..start+nlen) 复制到 out[0..31]，供 parser 用 lexer 的 token_start 复制形参名。 */
function copy_slice_to_param32(source: []u8, start: usize, nlen: i32, out: [32]u8): void {
  let i: i32 = 0;
  while (i < 32) {
    if (i < nlen && start + (i as usize) < source.length) {
      out[i] = source[start + (i as usize)];
    } else {
      out[i] = 0;
    }
    i = i + 1;
  }
}

/** 从 source 的 [end_pos-nlen..end_pos) 复制到 out[0..31]，供 scan 内 param_name 复制，避免 source[pos-len+pi] 在 C 中类型/越界。 */
function copy_slice_to_param32_at_end(source: []u8, end_pos: usize, nlen: i32, out: [32]u8): void {
  let start: usize = end_pos - (nlen as usize);
  copy_slice_to_param32(source, start, nlen, out);
}

/** 与 copy_slice_to_name64 等价，接受 (source: *u8, source_len) 供 buf 路径使用。调用方须保证 start + nlen 在 source 范围内。 */
function copy_slice_to_name64_buf(source: *u8, source_len: i32, start: usize, nlen: i32, out: [64]u8): void {
  let i: i32 = 0;
  while (i < nlen) {
    out[i] = source[start + i];
    i = i + 1;
  }
}

/** 从 buf 的 [end_pos-nlen..end_pos) 复制到 out，供 parse_one_extern_skip_buf 使用，避免调用处 as usize 解析歧义。 */
function copy_slice_to_name64_at_end_buf(source: *u8, source_len: i32, end_pos: usize, nlen: i32, out: [64]u8): void {
  let start: usize = end_pos - (nlen as usize);
  copy_slice_to_name64_buf(source, source_len, start, nlen, out);
}

/** 从 buf 的 [end_pos-nlen..end_pos) 复制到 out[0..31]，供 parse_one_function_library_scan_buf 内 param_name 复制。 */
function copy_slice_to_param32_at_end_buf(source: *u8, source_len: i32, end_pos: usize, nlen: i32, out: [32]u8): void {
  let start: usize = end_pos - (nlen as usize);
  let i: i32 = 0;
  while (i < 32) {
    if (i < nlen && start + (i as usize) < (source_len as usize)) {
      out[i] = source[start + (i as usize)];
    } else {
      out[i] = 0;
    }
    i = i + 1;
  }
}

/**
 * 解析一个最小函数：function <ident>( [ <name>: i32 [, ...] ] ): i32 { [ let ... ; ] return <int>; }。
 * 当前 lex 必须指向 TOKEN_FUNCTION；成功时写 ok=true、函数名、参数列表、let 列表（含 let_init_refs）、return 值及消费后的 next_lex 到 out；否则写 ok=false 与 next_lex。
 * arena 用于在 parse_body_lets_into 中构建 let 的 init 表达式（数组字面量、调用等）。
 */
function parse_one_function_impl(out: *OneFuncResult, arena: *ASTArena, lex: Lexer, source: []u8): void {
  let out_ref: *OneFuncResult = out;
  let dummy_name: [64]u8 = [];
  let empty32: [32]u8 = [];
  let dummy_pnames: [16][32]u8 = [empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32];
  let dummy_plens: [16]i32 = [];
  let num_params: i32 = 0;
  let param_names: [16][32]u8 = dummy_pnames;
  let param_name_lens: [16]i32 = dummy_plens;
  let param_type_refs: [16]i32 = [];
  let empty64: [64]u8 = [];
  let dummy_const_names: [256][64]u8 = [];
  let dummy_const_lens: [256]i32 = [];
  let dummy_const_vals: [256]i32 = [];
  let dummy_let_names: [256][64]u8 = [];
  let dummy_let_lens: [256]i32 = [];
  let dummy_let_vals: [256]i32 = [];
  let dummy_let_refs: [256]i32 = [];
  let dummy_let_type_refs: [256]i32 = [];
  let dummy_loop_refs: [8]i32 = [];
  let dummy_call_arg_vals: [16]i32 = [];
  let num_loops: i32 = 0;
  let loop_cond_refs: [8]i32 = dummy_loop_refs;
  let loop_body_refs: [8]i32 = dummy_loop_refs;
  let dummy_for_refs: [8]i32 = [];
  let dummy_if_refs: [16]i32 = [];
  let num_for_loops: i32 = 0;
  let for_init_refs: [8]i32 = dummy_for_refs;
  let for_cond_refs: [8]i32 = dummy_for_refs;
  let for_step_refs: [8]i32 = dummy_for_refs;
  let for_body_refs: [8]i32 = dummy_for_refs;
  let num_if_stmts: i32 = 0;
  let if_cond_refs: [16]i32 = [];
  let if_then_body_refs: [16]i32 = [];
  let num_consts: i32 = 0;
  let const_names: [256][64]u8 = dummy_const_names;
  let const_name_lens: [256]i32 = dummy_const_lens;
  let const_init_vals: [256]i32 = dummy_const_vals;
  let num_lets: i32 = 0;
  let let_names: [256][64]u8 = dummy_let_names;
  let let_name_lens: [256]i32 = dummy_let_lens;
  let let_init_vals: [256]i32 = dummy_let_vals;
  let let_init_refs: [256]i32 = dummy_let_refs;
  let let_type_refs: [256]i32 = dummy_let_type_refs;
  let has_if_expr: bool = false;
  let if_cond_expr_ref: i32 = 0;
  let if_cond_true: bool = false;
  let if_then_val: i32 = 0;
  let if_else_val: i32 = 0;
  let has_mul: bool = false;
  let mul_right_val: i32 = 0;
  let has_binop: bool = false;
  let binop_right_val: i32 = 0;
  let binop_left_param_idx: i32 = -1;
  let binop_right_param_idx: i32 = -1;
  let has_unary_neg: bool = false;
  let ret_val: i32 = 0;
  let has_call_expr: bool = false;
  let call_callee_name: [64]u8 = dummy_name;
  let call_callee_len: i32 = 0;
  /** 有参 return ident(1,2); 时解析得到的实参个数与整型值，供 parse_into 构建 EXPR_LIT */
  let call_num_args: i32 = 0;
  let call_arg_vals: [16]i32 = [];
  /** return x（无括号）时变量名缓冲，写入 OneFuncResult 供 parse_into 建 EXPR_VAR */
  let return_type_is_bool: bool = false;
  /** return ident(...) 经 parse_expr_into 写入 arena 时的 expr ref；0 表示走 return_val / has_call_expr 等 legacy。 */
  let return_expr_ref_storage: i32 = 0;
  /* 先声明，避免 codegen 将 name_start 提升到首 token 初始化；FUNCTION 分支内再赋值。
   * 用 func_name_len_storage[0] 存函数名长度，避免与 plen 等复用导致被 i32 的 ident_len(3) 覆盖。 */
  let name_start: usize = 0;
  let func_name_len_storage: [1]i32 = [];
  /* 用 lexer_next_into 取首 token，避免 LexerResult 按值返回/赋值的 ABI 导致 r.tok 读错 */
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  /* parse_into 调用时已消费 "function"，首 token 为 IDENT（函数名）；否则首 token 须为 FUNCTION 再消费得 IDENT */
  if (r.tok.kind == TokenKind.TOKEN_IDENT) {
    /* 调用方已消费 FUNCTION，r 即为函数名 token，直接用作 name */
  } else {
    if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
      set_onefunc_fail(out, lex); return;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      set_onefunc_fail(out, lex); return;
    }
  }
  func_name_len_storage[0] = r.tok.ident_len;
  if (func_name_len_storage[0] <= 0 || func_name_len_storage[0] > 63) {
    set_onefunc_fail(out, lex); return;
  }
  /* IDENT 起点 = token 结束位置 - 长度，避免用 lex.pos（指向空格）导致复制出 " mai" */
  name_start = r.next_lex.pos - func_name_len_storage[0];
  let name: [64]u8 = dummy_name;
  copy_slice_to_name64(source, name_start, func_name_len_storage[0], name);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
    lex_from_next_into(&lex, r);
  } else {
    while (true) {
      if (num_params >= 16) {
        set_onefunc_fail(out_ref, lex); return;
      }
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        set_onefunc_fail(out_ref, lex); return;
      }
      let plen: i32 = r.tok.ident_len;
      if (plen <= 0 || plen > 31) {
        set_onefunc_fail(out_ref, lex); return;
      }
      /* IDENT 字节起点：仅用 token_start（含偏移 0），与 lexer_next_into 约定一致。 */
      copy_slice_to_param32(source, r.token_start, plen, param_names[num_params]);
      param_name_lens[num_params] = plen;
      num_params = num_params + 1;
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind != TokenKind.TOKEN_COLON) {
        set_onefunc_fail(out_ref, lex); return;
      }
      lex_from_next_into(&lex, r);
      let lex_before_type: Lexer = lex;
      /* 参数类型：统一走 parse_type_ref_for_arena_into（含 *u8、*CodegenOutBuf、[N]u8 等），写入 param_type_refs。 */
      let pidx: i32 = num_params - 1;
      let type_ref_param: i32 = parse_type_ref_for_arena_into(arena, lex_before_type, source, &lex);
      if (type_ref_param == 0) {
        set_onefunc_fail(out_ref, lex); return;
      }
      param_type_refs[pidx] = type_ref_param;
      lexer_next_into(&r, lex, source);
      /* 若上面已 consume 则 r 已推进；否则需与原逻辑一致，此处仅写 param_type_refs，原 consume 已并入上列分支 */
      if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
        lex_from_next_into(&lex, r);
        break;
      }
      if (r.tok.kind != TokenKind.TOKEN_COMMA) {
        set_onefunc_fail(out_ref, lex); return;
      }
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
    }
  }
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    set_onefunc_fail(out_ref, lex); return;
  }
  lex_from_next_into(&lex, r);
  let lex_before_ret: Lexer = lex;
  /* 返回类型：标量 / 命名 / *u8 / *Ident 等，与形参类型同一套 parse_type_ref_for_arena_into。 */
  let ret_type_ref: i32 = parse_type_ref_for_arena_into(arena, lex_before_ret, source, &lex);
  if (ret_type_ref == 0) {
    set_onefunc_fail(out, lex); return;
  }
  /* 写入 OneFuncResult，供 parse_into/parse_into_buf 填充 Func.return_type_ref（与其它模块 i64/CALL 对齐）。 */
  out.func_return_type_ref = ret_type_ref;
  if (ret_type_ref != 0) {
    let rt: Type = ast_arena_type_get(arena, ret_type_ref);
    if (rt.kind == TypeKind.TYPE_BOOL) {
      return_type_is_bool = true;
    }
  }
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    set_onefunc_fail(out, lex); return;
  }
  /* 消费 {，解析 body 内 let/const 并填充 out.num_lets、let_init_refs 等，再跳过 if，得到 return/int 等 token */
  if (r.tok.kind == TokenKind.TOKEN_LBRACE) {
    lex_from_next_into(&lex, r);
    /* 与 C 侧 parse_block 一致：在函数体里按源码累计 stmt_order（含 let 与 while 之间的 expr;） */
    out.num_src_stmt_order = 0;
    out.num_src_body_expr_stmts = 0;
    parse_body_lets_into(arena, lex, source, out, &lex);
    lexer_next_into(&r, lex, source);
    /* 将 out 中由 parse_body_lets_into 填写的 let 相关字段同步到局部变量，以便后续 tmp_success/copy_onefunc_into 写回时保留 */
    num_lets = out.num_lets;
    let lri: i32 = 0;
    while (lri < 256) {
      let_init_refs[lri] = out.let_init_refs[lri];
      let_type_refs[lri] = out.let_type_refs[lri];
      let_init_vals[lri] = out.let_init_vals[lri];
      let_name_lens[lri] = out.let_name_lens[lri];
      let copy_k: i32 = 0;
      while (copy_k < 64) {
        let_names[lri][copy_k] = out.let_names[lri][copy_k];
        copy_k = copy_k + 1;
      }
      lri = lri + 1;
    }
    let lsr: i32 = 0;
    while (lsr < num_lets) {
      onefunc_push_src_stmt(out, 1, lsr);
      lsr = lsr + 1;
    }
    /* while / for / if / expr; 交错：与 C parser parse_block 主循环对齐，避免仅批处理 loop 导致 stmt_order 与 codegen 顺序错乱 */
    while (true) {
      /* 块尾 } 或 return 结束 stmt 循环；勿把语句首 int（如 0 as *u8;、if (0 as *u8)）误判为块尾裸表达式。 */
      if (r.tok.kind == TokenKind.TOKEN_RETURN || r.tok.kind == TokenKind.TOKEN_RBRACE) {
        break;
      }
      /* if/while/for 之后仍可跟 let/const：首段仅 parse_body_lets_into({ 后…) 吃掉连续 let，此处不认 TOKEN_LET 会落入 expr 分支失败 */
      if (r.tok.kind == TokenKind.TOKEN_LET || r.tok.kind == TokenKind.TOKEN_CONST) {
        let n_before_mid: i32 = out.num_lets;
        /* expr; 后进 let：上一轮 lex_from_result_ptr 把 lex 指在 r.next_lex（关键字已跨过），不能直接作 parse_body_lets 起点。
         * 关键字 token_start 常为 0，lex_at_token_from_result 亦非多字符关键字；用语义长度回溯到「let」「const」首字节。 */
        let kw_back: i32 = 3;
        if (r.tok.kind == TokenKind.TOKEN_CONST) {
          kw_back = 5;
        }
        let lex_mid_let: Lexer = Lexer { pos: lexer_pos_before_run(r.next_lex.pos, kw_back), line: r.tok.line, col: r.tok.col };
        parse_body_lets_into(arena, lex_mid_let, source, out, &lex);
        let push_mi: i32 = n_before_mid;
        while (push_mi < out.num_lets) {
          onefunc_push_src_stmt(out, 1, push_mi);
          push_mi = push_mi + 1;
        }
        num_lets = out.num_lets;
        let syn_i: i32 = 0;
        while (syn_i < 256) {
          let_init_refs[syn_i] = out.let_init_refs[syn_i];
          let_type_refs[syn_i] = out.let_type_refs[syn_i];
          let_init_vals[syn_i] = out.let_init_vals[syn_i];
          let_name_lens[syn_i] = out.let_name_lens[syn_i];
          let copy_km: i32 = 0;
          while (copy_km < 64) {
            let_names[syn_i][copy_km] = out.let_names[syn_i][copy_km];
            copy_km = copy_km + 1;
          }
          syn_i = syn_i + 1;
        }
        lexer_next_into(&r, lex, source);
        continue;
      }
      if (r.tok.kind == TokenKind.TOKEN_WHILE && num_loops < 8) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let while_cond_start: Lexer = lex;
        let expr_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: while_cond_start };
        parse_cond_expr_into(arena, while_cond_start, source, &expr_res);
        if (!expr_res.ok) {
          set_onefunc_fail(out, lex); return;
        }
        let cond_ref: i32 = expr_res.expr_ref;
        lex = expr_res.next_lex;
        if (advance_past_cond_rparen_into(&r, lex, source) == 0) {
          set_onefunc_fail(out, lex); return;
        }
        if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let block_res: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex };
        parse_block_into(arena, lex, source, 0, &block_res);
        if (!block_res.ok) {
          set_onefunc_fail(out, lex); return;
        }
        loop_cond_refs[num_loops] = cond_ref;
        loop_body_refs[num_loops] = block_res.block_ref;
        num_loops = num_loops + 1;
        onefunc_push_src_stmt(out, 3, num_loops - 1);
        lex = block_res.next_lex;
        lexer_next_into(&r, lex, source);
        continue;
      }
      if (r.tok.kind == TokenKind.TOKEN_FOR && num_for_loops < 8) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let init_ref: i32 = 0;
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
          let expr_res_fi: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
          parse_expr_into(arena, lex, source, &expr_res_fi);
          /* 须有完整表达式（含赋值等），否则 step 留 0、typeck 跳过 for-step 报错，与 shu-c 不一致 */
          if (!expr_res_fi.ok) {
            set_onefunc_fail(out, lex); return;
          }
          init_ref = expr_res_fi.expr_ref;
          lex = expr_res_fi.next_lex;
          lexer_next_into(&r, lex, source);
        }
        if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let for_cond_ref: i32 = 0;
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
          let expr_res_fc: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
          parse_expr_into(arena, lex, source, &expr_res_fc);
          if (!expr_res_fc.ok) {
            set_onefunc_fail(out, lex); return;
          }
          for_cond_ref = expr_res_fc.expr_ref;
          lex = expr_res_fc.next_lex;
          lexer_next_into(&r, lex, source);
        }
        if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let step_ref: i32 = 0;
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
          let expr_res_fs: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: lex };
          parse_expr_into(arena, lex, source, &expr_res_fs);
          if (!expr_res_fs.ok) {
            set_onefunc_fail(out, lex); return;
          }
          step_ref = expr_res_fs.expr_ref;
          lex = expr_res_fs.next_lex;
          lexer_next_into(&r, lex, source);
        }
        if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let block_res_f: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex };
        parse_block_into(arena, lex, source, 0, &block_res_f);
        if (!block_res_f.ok) {
          set_onefunc_fail(out, lex); return;
        }
        if (for_cond_ref == 0) {
          let cond_expr_ref: i32 = ast_arena_expr_alloc(arena);
          if (cond_expr_ref != 0) {
            let ce: Expr = ast_arena_expr_get(arena, cond_expr_ref);
            ce.kind = ExprKind.EXPR_BOOL_LIT;
            ce.int_val = 1;
            ce.line = 0;
            ce.col = 0;
            expr_set_common_zeros(&ce);
            ast_arena_expr_set(arena, cond_expr_ref, ce);
            for_cond_ref = cond_expr_ref;
          }
        }
        for_init_refs[num_for_loops] = init_ref;
        for_cond_refs[num_for_loops] = for_cond_ref;
        for_step_refs[num_for_loops] = step_ref;
        for_body_refs[num_for_loops] = block_res_f.block_ref;
        num_for_loops = num_for_loops + 1;
        onefunc_push_src_stmt(out, 4, num_for_loops - 1);
        lex = block_res_f.next_lex;
        lexer_next_into(&r, lex, source);
        continue;
      }
      if (r.tok.kind == TokenKind.TOKEN_IF && num_if_stmts < 16) {
        lex_from_next_into(&lex, r);
        lexer_next_into(&r, lex, source);
        if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let cond_start: Lexer = lex;
        let expr_if_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: cond_start };
        parse_cond_expr_into(arena, cond_start, source, &expr_if_res);
        if (!expr_if_res.ok) {
          set_onefunc_fail(out, lex); return;
        }
        let if_cref: i32 = expr_if_res.expr_ref;
        lex = expr_if_res.next_lex;
        if (advance_past_cond_rparen_into(&r, lex, source) == 0) {
          set_onefunc_fail(out, lex); return;
        }
        if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
          set_onefunc_fail(out, lex); return;
        }
        lex = r.next_lex;
        let if_blk: ParseBlockResult = ParseBlockResult { ok: false, block_ref: 0, next_lex: lex };
        parse_block_into(arena, lex, source, 0, &if_blk);
        if (!if_blk.ok) {
          set_onefunc_fail(out, lex); return;
        }
        if_cond_refs[num_if_stmts] = if_cref;
        if_then_body_refs[num_if_stmts] = if_blk.block_ref;
        num_if_stmts = num_if_stmts + 1;
        onefunc_push_src_stmt(out, 5, num_if_stmts - 1);
        lex = if_blk.next_lex;
        lexer_next_into(&r, lex, source);
        continue;
      }
      /* 表达式语句 expr ;（从 r.tok 起点解析，兼容 (1 as T) 与裸 INT+AS） */
      lex_from_result_ptr_into(&lex, &r);
      let stmt_start: Lexer = lex_at_token_from_result(r);
      let expr_stmt_res: ParseExprResult = ParseExprResult { ok: false, expr_ref: 0, next_lex: stmt_start };
      if (r.tok.kind == TokenKind.TOKEN_INT) {
        parse_cond_expr_into(arena, stmt_start, source, &expr_stmt_res);
      } else {
        parse_expr_into(arena, stmt_start, source, &expr_stmt_res);
      }
      if (!expr_stmt_res.ok) {
        set_onefunc_fail(out, lex); return;
      }
      lex = expr_stmt_res.next_lex;
      /* 非 void 函数的返回值一律须 `return expr;`，块尾不作为返回值（`;`/`}` 规则见 advance_past_stmt_semicolon_into） */
      if (advance_past_stmt_semicolon_into(&r, lex, source) == 0) {
        set_onefunc_fail(out, lex); return;
      }
      lex_from_result_ptr_into(&lex, &r);
      if (out.num_src_body_expr_stmts >= 32) {
        set_onefunc_fail(out, lex); return;
      }
      let ex_i: i32 = out.num_src_body_expr_stmts;
      out.src_body_expr_stmt_refs[ex_i] = expr_stmt_res.expr_ref;
      out.num_src_body_expr_stmts = out.num_src_body_expr_stmts + 1;
      onefunc_push_src_stmt(out, 2, ex_i);
      continue;
    }
  } else {
    set_onefunc_fail(out, lex); return;
  }
  if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
