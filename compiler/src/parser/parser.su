/** extern 解析结果：成功时 name_len>=0 且 next_lex 为分号后；失败时 name_len<0，调用方 fallback 到 skip。显式 _pad 满足 typeck 对齐。 */
struct ExternParseResult {
  next_lex: Lexer;
  name: [64]u8;
  name_len: i32;
  _pad: [4]u8;
}
/** 仅解析 extern function 到分号，返回 name 与 next_lex；失败 name_len=-1。拆出以避免 codegen 重排。 */
function parse_one_extern_skip(lex: Lexer, source: []u8): ExternParseResult {
  let empty64: [64]u8 = [];
  let empty4: [4]u8 = [];
  let fail_res: ExternParseResult = ExternParseResult { next_lex: lex, name: empty64, name_len: -1, _pad: empty4 };
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return fail_res;
  }
  let name_len: i32 = r.tok.ident_len;
  if (name_len <= 0 || name_len > 63) {
    return fail_res;
  }
  let name_buf: [64]u8 = [];
  copy_slice_to_name64_at_end(source, r.next_lex.pos, name_len, name_buf);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lex = skip_balanced_parens(lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  let pad4: [4]u8 = [];
  return ExternParseResult { next_lex: lex, name: name_buf, name_len: name_len, _pad: pad4 };
}

/**
 * 解析一条 extern function 声明并加入 module（name、is_extern=1、无 body），使 codegen 能为其生成 extern 声明。
 * 先调 parse_one_extern_skip 再按结果写 module，避免 -E 生成 C 时重排导致逻辑错乱。
 */
/** parse_one_extern_and_add 的 _into 变体：通过 lex_out 指针写结果。 */
function parse_one_extern_and_add_into(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8, lex_out: *Lexer): void {
  let res: ExternParseResult = parse_one_extern_skip(lex, source);
  if (res.name_len < 0) {
    skip_one_extern_into(lex_out, lex, source); return;
  }
  if (module.num_funcs >= 256) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  let type_ref: i32 = ast_arena_type_alloc(arena);
  if (type_ref == 0) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  let t: Type = ast_arena_type_get(arena, type_ref);
  t.kind = TypeKind.TYPE_I32; t.name_len = 0; t.elem_type_ref = 0; t.array_size = 0;
  ast_arena_type_set(arena, type_ref, t);
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) {
      f.name[ki] = res.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = res.name_len; f.num_params = 0; f.return_type_ref = type_ref;
  f.body_ref = 0; f.body_expr_ref = 0; f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col;
}
function parse_one_extern_and_add(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8): Lexer {
  let res: ExternParseResult = parse_one_extern_skip(lex, source);
  if (res.name_len < 0) {
    return skip_one_extern(lex, source);
  }
  if (module.num_funcs >= 256) {
    return res.next_lex;
  }
  let type_ref: i32 = ast_arena_type_alloc(arena);
  if (type_ref == 0) {
    return res.next_lex;
  }
  let t: Type = ast_arena_type_get(arena, type_ref);
  t.kind = TypeKind.TYPE_I32;
  t.name_len = 0;
  t.elem_type_ref = 0;
  t.array_size = 0;
  ast_arena_type_set(arena, type_ref, t);
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) {
    return res.next_lex;
  }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) {
      f.name[ki] = res.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = res.name_len;
  f.num_params = 0;
  f.return_type_ref = type_ref;
  f.body_ref = 0;
  f.body_expr_ref = 0;
  f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  return res.next_lex;
}

/** 与 skip_one_extern 等价，接受 (data: *u8, len) 供 parse_into_buf 使用。 */
/** skip_one_extern_buf 的 _into_buf 变体。 */
function skip_one_extern_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_parens_into_buf(&lex, r.next_lex, data, len);
