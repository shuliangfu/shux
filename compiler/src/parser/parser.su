          let bi: i32 = 0;
          while (bi < 64) {
            if (bi < r2.tok.ident_len && (bind_start + bi) < source.length) {
              module.import_binding_name[n][bi] = source[bind_start + bi];
            } else {
              module.import_binding_name[n][bi] = 0;
            }
            bi = bi + 1;
          }
          module.import_binding_name_len[n] = r2.tok.ident_len;
          module.import_select_count[n] = 0;
          out.lex = r3.next_lex;
          lexer_next_into(&r, out.lex, source);
          if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
            return;
          }
          lex_from_next_into(&out.lex, r);
          path_len = 0;
          lexer_next_into(&r, out.lex, source);
          if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
            return;
          }
          let ident_start: usize = r.token_start;
          copy_slice_to_name64(source, ident_start, r.tok.ident_len, path_buf);
          path_len = r.tok.ident_len;
          lex_from_next_into(&out.lex, r);
          lexer_next_into(&r, out.lex, source);
          while (r.tok.kind == TokenKind.TOKEN_DOT) {
            if (path_len >= 63) {
              return;
            }
            let dot_u8: u8 = 46;
            path_buf[path_len] = dot_u8;
            path_len = path_len + 1;
            lex_from_next_into(&out.lex, r);
            lexer_next_into(&r, out.lex, source);
            if (r.tok.kind != TokenKind.TOKEN_IDENT || path_len + r.tok.ident_len > 63) {
              return;
            }
            let i: i32 = 0;
            while (i < r.tok.ident_len) {
              if (r.token_start + (i as usize) < source.length) {
                path_buf[path_len + i] = source[r.token_start + (i as usize)];
              }
              i = i + 1;
            }
            path_len = path_len + r.tok.ident_len;
            lex_from_next_into(&out.lex, r);
            lexer_next_into(&r, out.lex, source);
          }
          if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
            return;
          }
          let base: i32 = module.num_imports * 64;
          let j: i32 = 0;
          while (j < 64) {
            if (j < path_len) {
              module.import_path_data[base + j] = path_buf[j];
            } else {
              module.import_path_data[base + j] = 0;
            }
            j = j + 1;
          }
          module.import_path_lens[module.num_imports] = path_len;
          module.import_kinds[module.num_imports] = 1;
          module.num_imports = module.num_imports + 1;
          lex_from_next_into(&out.lex, r);
          continue;
        }
      }
      /* const { a, b } = import path; */
      if (r2.tok.kind == TokenKind.TOKEN_LBRACE) {
        let n: i32 = module.num_imports;
        if (n >= 32) {
          return;
        }
        module.import_binding_name_len[n] = 0;
        out.lex = r2.next_lex;
        let nsel: i32 = 0;
        r = r2;
        lex_from_next_into(&out.lex, r);
        lexer_next_into(&r, out.lex, source);
        while (r.tok.kind == TokenKind.TOKEN_IDENT && nsel < 8) {
          let sel_start: usize = r.token_start;
          if (r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
            return;
          }
          let si: i32 = 0;
          while (si < 64) {
            if (si < r.tok.ident_len && (sel_start + si) < source.length) {
              module.import_select_names[n][nsel][si] = source[sel_start + si];
            } else {
              module.import_select_names[n][nsel][si] = 0;
            }
            si = si + 1;
          }
          module.import_select_name_lens[n][nsel] = r.tok.ident_len;
          nsel = nsel + 1;
          lex_from_next_into(&out.lex, r);
          lexer_next_into(&r, out.lex, source);
          if (r.tok.kind == TokenKind.TOKEN_COMMA) {
            lex_from_next_into(&out.lex, r);
            lexer_next_into(&r, out.lex, source);
          } else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
            break;
          } else {
            return;
          }
        }
        if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
          return;
        }
        lex_from_next_into(&out.lex, r);
        lexer_next_into(&r, out.lex, source);
        if (r.tok.kind != TokenKind.TOKEN_ASSIGN) {
          return;
        }
        lex_from_next_into(&out.lex, r);
        lexer_next_into(&r, out.lex, source);
        if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
          return;
        }
        lex_from_next_into(&out.lex, r);
        path_len = 0;
        lexer_next_into(&r, out.lex, source);
        if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
          return;
        }
        let ident_start: usize = r.token_start;
        copy_slice_to_name64(source, ident_start, r.tok.ident_len, path_buf);
        path_len = r.tok.ident_len;
        lex_from_next_into(&out.lex, r);
        lexer_next_into(&r, out.lex, source);
        while (r.tok.kind == TokenKind.TOKEN_DOT) {
          if (path_len >= 63) {
            return;
          }
          let dot_u8: u8 = 46;
          path_buf[path_len] = dot_u8;
          path_len = path_len + 1;
          lex_from_next_into(&out.lex, r);
          lexer_next_into(&r, out.lex, source);
          if (r.tok.kind != TokenKind.TOKEN_IDENT || path_len + r.tok.ident_len > 63) {
            return;
          }
          let i: i32 = 0;
          while (i < r.tok.ident_len) {
            if (r.token_start + (i as usize) < source.length) {
              path_buf[path_len + i] = source[r.token_start + (i as usize)];
            }
            i = i + 1;
          }
          path_len = path_len + r.tok.ident_len;
          lex_from_next_into(&out.lex, r);
          lexer_next_into(&r, out.lex, source);
        }
        if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
          return;
        }
        let base: i32 = module.num_imports * 64;
        let j: i32 = 0;
        while (j < 64) {
          if (j < path_len) {
            module.import_path_data[base + j] = path_buf[j];
          } else {
            module.import_path_data[base + j] = 0;
          }
          j = j + 1;
        }
        module.import_path_lens[module.num_imports] = path_len;
        module.import_select_count[module.num_imports] = nsel;
        module.import_kinds[module.num_imports] = 2;
        module.num_imports = module.num_imports + 1;
        lex_from_next_into(&out.lex, r);
        continue;
      }
      return;
    }
    if (r.tok.kind != TokenKind.TOKEN_IMPORT) {
      return;
    }
    lex_from_next_into(&out.lex, r);
    /* 解析 path：ident 或 ident.ident */
    path_len = 0;
    lexer_next_into(&r, out.lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return;
    }
    if (r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
      return;
    }
    /* ident 起点：lexer_next_body_into 填 token_start（含偏移 0） */
    let ident_start: usize = r.token_start;
    copy_slice_to_name64(source, ident_start, r.tok.ident_len, path_buf);
    path_len = r.tok.ident_len;
    lex_from_next_into(&out.lex, r);
    lexer_next_into(&r, out.lex, source);
    while (r.tok.kind == TokenKind.TOKEN_DOT) {
      if (path_len >= 63) {
        return;
      }
      let dot_u8: u8 = 46;
      path_buf[path_len] = dot_u8;
      path_len = path_len + 1;
      lex_from_next_into(&out.lex, r);
      lexer_next_into(&r, out.lex, source);
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        return;
      }
      if (path_len + r.tok.ident_len > 63) {
        return;
      }
      let i: i32 = 0;
      while (i < r.tok.ident_len) {
        if (r.token_start + (i as usize) < source.length) {
          path_buf[path_len + i] = source[r.token_start + (i as usize)];
        }
        i = i + 1;
      }
      path_len = path_len + r.tok.ident_len;
      lex_from_next_into(&out.lex, r);
      lexer_next_into(&r, out.lex, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      return;
    }
    if (module.num_imports >= 32) {
      return;
    }
    let base: i32 = module.num_imports * 64;
    let j: i32 = 0;
    while (j < 64) {
      if (j < path_len) {
        module.import_path_data[base + j] = path_buf[j];
      } else {
        let z: u8 = 0;
        module.import_path_data[base + j] = z;
      }
      j = j + 1;
    }
    module.import_path_lens[module.num_imports] = path_len;
    /** import path; — 显式设为 IMPORT_WHOLE（整包）；与 C parser AST_IMPORT_KIND_WHOLE 一致。 */
    module.import_kinds[module.num_imports] = ImportKind.IMPORT_WHOLE;
    module.num_imports = module.num_imports + 1;
    lex_from_next_into(&out.lex, r);
  }
}

/**
 * buf 形式的 collect_imports：委托 slice 路径 collect_imports。
 * 原实现大量使用 lexer_next_buf 按值返回 LexerResult，在 AArch64/Mac 宿主 ABI 下会破坏 tok/next_lex，
 * 导致 parse_into_buf 第一轮 token（含 struct/layout）不可靠。
 */
function collect_imports_buf(lex: Lexer, data: *u8, len: i32, module: *Module, out: *CollectImportsResult): void {
  let source: []u8 = parser_slice_from_buf(data, len);
  collect_imports(lex, source, module, out);
}

/**
 * 跳过一条顶层 struct 定义：struct <ident> { ... }；lex 为 struct 前的位置。
 * 返回跳过后的 lex，供 parse_into 在解析 function 前跳过 codegen.su 等文件中的 struct。
 */
/** 跳过一条顶层 struct 定义：struct <ident> { ... }；lex 为 struct 前的位置。与 skip_one_struct 等价 + _into 避免 ABI。 */
function skip_one_struct_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) {
    out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return;
  }
  skip_balanced_braces_into(out, r.next_lex, source);
}

function skip_one_struct(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/**
 * 跳过一条顶层 enum 定义：enum <ident> { ... }；lex 为 enum 前的位置。
 * 供 parse_into 在解析 function 前跳过 token.su 等文件中的 enum。
 */
/** 跳过一条顶层 enum 定义：enum <ident> { ... }；通过 out 避免 ABI。 */
function skip_one_enum_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_ENUM) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into(out, r.next_lex, source);
}
function skip_one_enum(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_ENUM) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/**
 * 跳过一条顶层 trait 定义：trait <ident> { ... }；供 parse_into 在解析 function 前跳过 std.io 等文件中的 trait。
 */
/** 跳过一条顶层 trait 定义：trait <ident> { ... }；通过 out 避免 ABI。 */
function skip_one_trait_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_TRAIT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into(out, r.next_lex, source);
}
function skip_one_trait(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_TRAIT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/**
 * 跳过一条顶层 impl 块：impl [<ident> for ] <ident> { ... }；供 parse_into 在解析 function 前跳过 std.io 等文件中的 impl。
 */
/** 跳过一条顶层 impl 块：impl [<ident> for ] <ident> { ... }；通过 out 避免 ABI。 */
function skip_one_impl_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IMPL) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_FOR) {
    lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
    lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into(out, r.next_lex, source);
}
function skip_one_impl(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IMPL) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  /* impl [Ident for] Ident { ... }：至少一个 ident，可能 for Ident，然后 { */
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_FOR) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return lex;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces(r.next_lex, source);
  return lex;
}

/** 与 skip_one_enum 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
/** 与 skip_one_enum 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
/** skip_one_enum_buf 的 _into_buf 变体。 */
function skip_one_enum_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_ENUM) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into_buf(out, r.next_lex, data, len);
}
function skip_one_enum_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_ENUM) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/** 与 skip_one_trait 等价，供 parse_into_buf 使用。 */
/** skip_one_trait_buf 的 _into_buf 变体。 */
function skip_one_trait_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_TRAIT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into_buf(out, r.next_lex, data, len);
}
function skip_one_trait_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_TRAIT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/** 与 skip_one_impl 等价，供 parse_into_buf 使用。 */
/** skip_one_impl_buf 的 _into_buf 变体。 */
function skip_one_impl_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IMPL) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind == TokenKind.TOKEN_FOR) {
    lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
    lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into_buf(out, r.next_lex, data, len);
}
function skip_one_impl_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IMPL) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind == TokenKind.TOKEN_FOR) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_IDENT) {
      return lex;
    }
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/**
 * 跳过一条顶层 extern function 声明：extern function <ident>( ... ): <type> ;。
 * 供 parse_into 在解析 function 前跳过 main.su 等文件中的 extern 声明。
 */
/** 跳过一条顶层 extern function 声明：通过 out 避免 ABI。 */
function skip_one_extern_into(out: *Lexer, lex: Lexer, source: []u8): void {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_parens_into(&lex, r.next_lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r); lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) { lex_from_next_into(&lex, r); }
  out.pos = lex.pos; out.line = lex.line; out.col = lex.col;
}
function skip_one_extern(lex: Lexer, source: []u8): Lexer {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return lex;
  }
  lex = skip_balanced_parens(r.next_lex, source);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
  }
  if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/**
 * extern 声明解析快照：与普通 function 共用「(name: Ty,…)」语法；return_ty_ref 为 `): Ty` 的 arena ref（含 void）。
 * 失败时 name_len=-1，其余字段无意义。
 */
allow(padding) struct ExternParseResult {
  next_lex: Lexer;
  name: [64]u8;
  name_len: i32;
  /** 紧跟 `)` 后的返回类型；仅供 parse_one_extern_and_add；失败或未解析时为 0。 */
  return_ty_ref: i32;
  num_params: i32;
  param_names: [16][32]u8;
  param_name_lens: [16]i32;
  param_type_refs: [16]i32;
}

/**
 * 将 ExternParseResult 中的形参表写入已从 arena 拉取的 Func（调用方已填好 name）。
 * 逐字段复制，避免 Param 字面量嵌套数组导致 pipeline 生成 C 赋值的非法数组赋值。
 */
function extern_parse_attach_params(f_in: Func, res: ExternParseResult): Func {
  let f: Func = f_in;
  f.num_params = res.num_params;
  let qi: i32 = 0;
  while (qi < res.num_params) {
    let pi: i32 = qi;
    let pkn: i32 = 0;
    while (pkn < 32) {
      f.params[pi].name[pkn] = res.param_names[pi][pkn];
      pkn = pkn + 1;
    }
    f.params[pi].name_len = res.param_name_lens[pi];
    f.params[pi].type_ref = res.param_type_refs[pi];
    qi = qi + 1;
  }
  return f;
}

/** 仅解析 extern function 到分号，返回 name、形参表、return_ty_ref 与 next_lex；失败 name_len=-1。拆出以避免 codegen 重排。 */
function parse_one_extern_skip(arena: *ASTArena, lex: Lexer, source: []u8): ExternParseResult {
  let empty64: [64]u8 = [];
  let zp: [32]u8 = [];
  let dn: [16][32]u8 = [zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp, zp];
  let zi_pl: [16]i32 = [];
  let zi_pt: [16]i32 = [];
  let fail_res: ExternParseResult = ExternParseResult { next_lex: lex, name: empty64, name_len: -1, return_ty_ref: 0, num_params: 0, param_names: dn, param_name_lens: zi_pl, param_type_refs: zi_pt };
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return fail_res;
  }
  let name_len: i32 = r.tok.ident_len;
  if (name_len <= 0 || name_len > 63) {
    return fail_res;
  }
  let name_buf: [64]u8 = [];
  copy_slice_to_name64_at_end(source, r.next_lex.pos, name_len, name_buf);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  let e32: [32]u8 = [];
  let dp_ex: [16][32]u8 = [e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32, e32];
  let n_ex: i32 = 0;
  let pn_ex: [16][32]u8 = dp_ex;
  let pl_ex: [16]i32 = [];
  let pt_ex: [16]i32 = [];
  if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
    lex_from_next_into(&lex, r);
  } else {
    while (true) {
      if (n_ex >= 16) {
        return fail_res;
      }
      if (r.tok.kind != TokenKind.TOKEN_IDENT) {
        return fail_res;
      }
      let plen_ex: i32 = r.tok.ident_len;
      if (plen_ex <= 0 || plen_ex > 31) {
        return fail_res;
      }
      copy_slice_to_param32(source, r.token_start, plen_ex, pn_ex[n_ex]);
      pl_ex[n_ex] = plen_ex;
      n_ex = n_ex + 1;
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
      if (r.tok.kind != TokenKind.TOKEN_COLON) {
        return fail_res;
      }
      lex_from_next_into(&lex, r);
      let lex_before_pt: Lexer = lex;
      let pidx_ex: i32 = n_ex - 1;
      let ty_pex: i32 = parse_type_ref_for_arena_into(arena, lex_before_pt, source, &lex);
      if (ty_pex == 0) {
        return fail_res;
      }
      pt_ex[pidx_ex] = ty_pex;
      lexer_next_into(&r, lex, source);
      if (r.tok.kind == TokenKind.TOKEN_RPAREN) {
        lex_from_next_into(&lex, r);
        break;
      }
      if (r.tok.kind != TokenKind.TOKEN_COMMA) {
        return fail_res;
      }
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
    }
  }
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  let lex_before_ret: Lexer = lex;
  let ret_ty: i32 = parse_type_ref_for_arena_into(arena, lex_before_ret, source, &lex);
  if (ret_ty == 0) {
    return fail_res;
  }
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
    return fail_res;
  }
  lex_from_next_into(&lex, r);
  return ExternParseResult { next_lex: lex, name: name_buf, name_len: name_len, return_ty_ref: ret_ty, num_params: n_ex, param_names: pn_ex, param_name_lens: pl_ex, param_type_refs: pt_ex };
}

/**
 * 解析一条 extern function 声明并加入 module（name、is_extern=1、无 body），使 codegen 能为其生成 extern 声明。
 * 先调 parse_one_extern_skip 再按结果写 module，避免 -E 生成 C 时重排导致逻辑错乱。
 */
/** parse_one_extern_and_add 的 _into 变体：通过 lex_out 指针写结果。 */
function parse_one_extern_and_add_into(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8, lex_out: *Lexer): void {
  let res: ExternParseResult = parse_one_extern_skip(arena, lex, source);
  if (res.name_len < 0) {
    skip_one_extern_into(lex_out, lex, source); return;
  }
  if (module.num_funcs >= 256) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  /** return_ty_ref 由 parse_one_extern_skip 内 parse_type_ref 写入 arena，勿再强制 TYPE_I32（否则 extern (): i64 与包装函数不匹配）。 */
  let type_ref: i32 = res.return_ty_ref;
  if (type_ref == 0) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) {
    lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return;
  }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) {
      f.name[ki] = res.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = res.name_len;
  f = extern_parse_attach_params(f, res);
  f.return_type_ref = type_ref;
  f.body_ref = 0; f.body_expr_ref = 0; f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col;
}
function parse_one_extern_and_add(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8): Lexer {
  let res: ExternParseResult = parse_one_extern_skip(arena, lex, source);
  if (res.name_len < 0) {
    return skip_one_extern(lex, source);
  }
  if (module.num_funcs >= 256) {
    return res.next_lex;
  }
  let type_ref: i32 = res.return_ty_ref;
  if (type_ref == 0) {
    return res.next_lex;
  }
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) {
    return res.next_lex;
  }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) {
      f.name[ki] = res.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = res.name_len;
  f = extern_parse_attach_params(f, res);
  f.return_type_ref = type_ref;
  f.body_ref = 0;
  f.body_expr_ref = 0;
  f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  return res.next_lex;
}

/** 与 skip_one_extern 等价，接受 (data: *u8, len) 供 parse_into_buf 使用。 */
/** skip_one_extern_buf 的 _into_buf 变体。 */
function skip_one_extern_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_parens_into_buf(&lex, r.next_lex, data, len);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) { lex_from_next_into(&lex, r); }
  out.pos = lex.pos; out.line = lex.line; out.col = lex.col;
}
function skip_one_extern_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_EXTERN) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return lex;
  }
  lex = skip_balanced_parens_buf(r.next_lex, data, len);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
  }
  if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
    lex_from_next_into(&lex, r);
  }
  return lex;
}

/** 与 parse_one_extern_skip 等价，接受 (data, len) 供 parse_into_buf 使用；委托 parser_slice_from_buf，与 parse_one_function_library_buf 同策略。 */
function parse_one_extern_skip_buf(arena: *ASTArena, lex: Lexer, data: *u8, len: i32): ExternParseResult {
  let slice: []u8 = parser_slice_from_buf(data, len);
  return parse_one_extern_skip(arena, lex, slice);
}

/**
 * 解析一条 extern function 声明并加入 module（buf 路径）；与 parse_one_extern_and_add 对称。
 * 先调 parse_one_extern_skip_buf 再按结果写 module，失败则 fallback 到 skip_one_extern_buf。
 */
/** parse_one_extern_and_add_buf 的 _into_buf 变体。 */
function parse_one_extern_and_add_into_buf(arena: *ASTArena, module: *Module, lex: Lexer, data: *u8, len: i32, lex_out: *Lexer): void {
  let res: ExternParseResult = parse_one_extern_skip_buf(arena, lex, data, len);
  if (res.name_len < 0) { skip_one_extern_into_buf(lex_out, lex, data, len); return; }
  if (module.num_funcs >= 256) { lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return; }
  let type_ref: i32 = res.return_ty_ref;
  if (type_ref == 0) { lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return; }
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) { lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col; return; }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) { f.name[ki] = res.name[ki]; }
    else { f.name[ki] = 0; }
    ki = ki + 1;
  }
  f.name_len = res.name_len;
  f = extern_parse_attach_params(f, res);
  f.return_type_ref = type_ref;
  f.body_ref = 0; f.body_expr_ref = 0; f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  lex_out.pos = res.next_lex.pos; lex_out.line = res.next_lex.line; lex_out.col = res.next_lex.col;
}

function parse_one_extern_and_add_buf(arena: *ASTArena, module: *Module, lex: Lexer, data: *u8, len: i32): Lexer {
  let res: ExternParseResult = parse_one_extern_skip_buf(arena, lex, data, len);
  if (res.name_len < 0) {
    return skip_one_extern_buf(lex, data, len);
  }
  if (module.num_funcs >= 256) {
    return res.next_lex;
  }
  let type_ref: i32 = res.return_ty_ref;
  if (type_ref == 0) {
    return res.next_lex;
  }
  let func_ref: i32 = ast_arena_func_alloc(arena);
  if (func_ref == 0) {
    return res.next_lex;
  }
  let f: Func = ast_arena_func_get(arena, func_ref);
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < res.name_len) {
      f.name[ki] = res.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = res.name_len;
  f = extern_parse_attach_params(f, res);
  f.return_type_ref = type_ref;
  f.body_ref = 0;
  f.body_expr_ref = 0;
  f.is_extern = 1;
  ast_arena_func_set(arena, func_ref, f);
  module.funcs[module.num_funcs] = f;
  module.func_refs[module.num_funcs] = func_ref;
  module.num_funcs = module.num_funcs + 1;
  return res.next_lex;
}

/**
 * 尝试跳过 allow(padding) struct ...；lex 为 "allow" 之后的位置。
 * 若下一 token 为 ( 则跳过整段并返回 (new_lex, 1)，否则返回 (lex, 0)。主循环仅在此返回 1 时 advance。
 * 显式 padding 满足 typeck 对布局的要求。
 */
struct TrySkipAllowResult {
  lex: Lexer;
  skipped: i32;
  _pad: [4]u8;
}

/** 库函数解析结果：parse_one_function_library 成功时返回 ok、next_lex 及函数名，供 parse_into 继续循环。显式 _pad 满足 next_lex 对齐，避免 typeck 报隐式 padding。 */
struct LibraryParseResult {
  ok: bool;
  _pad: [4]u8;
  next_lex: Lexer;
  name: [64]u8;
  name_len: i32;
  _pad_tail: [4]u8;
}
/** 从 TrySkipAllowResult 取 lex 写入 out，避免 ABI 下结构体赋值未写回。 */
function lex_from_try_skip_into(out: *Lexer, t: TrySkipAllowResult): void {
  out.pos = t.lex.pos;
  out.line = t.lex.line;
  out.col = t.lex.col;
}
/** 从 LibraryParseResult 取 next_lex 写入 out，同上。 */
function lex_from_library_into(out: *Lexer, lib: LibraryParseResult): void {
  out.pos = lib.next_lex.pos;
  out.line = lib.next_lex.line;
  out.col = lib.next_lex.col;
}
/** 兼容：返回 Lexer。 */
function lex_from_try_skip(t: TrySkipAllowResult): Lexer {
  return Lexer { pos: t.lex.pos, line: t.lex.line, col: t.lex.col };
}
/** 兼容：返回 Lexer。 */
function lex_from_library(lib: LibraryParseResult): Lexer {
  return Lexer { pos: lib.next_lex.pos, line: lib.next_lex.line, col: lib.next_lex.col };
}

/** 库函数“仅解析”中间结果：由 parse_one_function_library_scan 按步写入，避免 -E 代码生成把变量提升到函数顶导致错序。显式 _pad 满足对齐。 */
struct LibraryParseScanResult {
  ok: bool;
  _pad: [4]u8;
  next_lex: Lexer;
  name: [64]u8;
  name_len: i32;
  param_name: [32]u8;
  param_name_len: i32;
  param_type_name: [64]u8;
  param_type_len: i32;
  field_name: [64]u8;
  field_len: i32;
  _pad_tail: [4]u8;
  _pad_tail2: [4]u8;
}

/**
 * 仅做 token 序列解析并写入 result，不建 AST；每步检查后立即写 result，避免代码生成器提升变量导致错序。
 * 成功返回 true，失败返回 false 并写 result.next_lex / result.ok。
 */
function parse_one_function_library_scan(lex: Lexer, source: []u8, result: *LibraryParseScanResult): bool {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  result.name_len = r.tok.ident_len;
  if (result.name_len <= 0 || result.name_len > 63) {
    result.ok = false;
    lex_from_next_into(&result.next_lex, r);
    return false;
  }
  copy_slice_to_name64_at_end(source, r.next_lex.pos, result.name_len, result.name);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  result.param_name_len = r.tok.ident_len;
  if (result.param_name_len <= 0 || result.param_name_len > 31) {
    result.ok = false;
    lex_from_next_into(&result.next_lex, r);
    return false;
  }
  let pnlen: i32 = result.param_name_len;
  copy_slice_to_param32(source, r.token_start, pnlen, result.param_name);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  result.param_type_len = r.tok.ident_len;
  if (result.param_type_len <= 0 || result.param_type_len > 63) {
    result.ok = false;
    lex_from_next_into(&result.next_lex, r);
    return false;
  }
  let ptlen: i32 = result.param_type_len;
  copy_slice_to_name64(source, r.token_start, ptlen, result.param_type_name);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  /* 返回类型须为 bool：接受 TOKEN_BOOL，或 TOKEN_IDENT 且长度为 4（视为 "bool"，避免 slice/pos 边界导致误判） */
  if (r.tok.kind != TokenKind.TOKEN_BOOL) {
    if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len != 4) {
      result.ok = false;
      result.next_lex = lex;
      return false;
    }
    /* 原逐字节比对 source[pos..pos+4]=="bool" 在部分生成代码下可能误判，改为仅信 ident_len==4 */
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RETURN) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  /* 若 return 后非 ident（严格形态），则 fallback：跳过至 ; 再 }，用默认 field "kind" 以便建 AST */
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    while (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_EOF) {
      lex_from_next_into(&lex, r);
      lexer_next_into(&r, lex, source);
    }
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
      result.ok = false;
      result.next_lex = lex;
      return false;
    }
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
      result.ok = false;
      result.next_lex = lex;
      return false;
    }
    result.field_len = 4;
    result.field_name[0] = 107;
    result.field_name[1] = 105;
    result.field_name[2] = 110;
    result.field_name[3] = 100;
    result.ok = true;
    lex_from_next_into(&result.next_lex, r);
    return true;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_DOT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  result.field_len = r.tok.ident_len;
  if (result.field_len <= 0 || result.field_len > 63) {
    result.ok = false;
    lex_from_next_into(&result.next_lex, r);
    return false;
  }
  copy_slice_to_name64_at_end(source, r.next_lex.pos, result.field_len, result.field_name);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_EQ) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_DOT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_SEMICOLON) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
    result.ok = false;
    result.next_lex = lex;
    return false;
  }
  result.ok = true;
  lex_from_next_into(&result.next_lex, r);
  return true;
}

/** 判断 module 中是否已有同名 struct layout（避免重复注册）。 */
function struct_layout_name_exists_arr(module: *Module, nm: [64]u8, nlen: i32): bool {
  let k: i32 = 0;
  while (k < module.num_struct_layouts && k < 32) {
    /** 勿拷贝整 StructLayout：与 typeck 布局查询同源 bug，Memcpy 不完整会导致误判重名或漏占位。 */
    if (module.struct_layouts[k].name_len == nlen && nlen > 0) {
      let ii: i32 = 0;
      let same: bool = true;
      while (ii < nlen && ii < 64) {
        if (module.struct_layouts[k].name[ii] != nm[ii]) {
          same = false;
        }
        ii = ii + 1;
      }
      if (same) {
        return true;
      }
    }
    k = k + 1;
  }
  return false;
}

/** 返回首个与 nm 同名的 struct_layouts 下标，无则 -1。 */
function struct_layout_first_name_match_idx(module: *Module, nm: [64]u8, nlen: i32): i32 {
  let k: i32 = 0;
  while (k < module.num_struct_layouts && k < 32) {
    if (module.struct_layouts[k].name_len == nlen && nlen > 0) {
      let ii: i32 = 0;
      let same: bool = true;
      while (ii < nlen && ii < 64) {
        if (module.struct_layouts[k].name[ii] != nm[ii]) {
          same = false;
        }
        ii = ii + 1;
      }
      if (same) {
        return k;
      }
    }
    k = k + 1;
  }
  return -1;
}

/**
 * 是否存在与 nm 同名的「占位」layout：parse_one_function_library 可能先注册 num_fields=1 且 field_lens[0]==0 的条目，
 * 后续顶层 struct 应按真实成员覆盖该槽位，否则 typeck 只能通过下一槽位兜底。
 */
function struct_layout_placeholder_idx(module: *Module, nm: [64]u8, nlen: i32): i32 {
  let k: i32 = 0;
  while (k < module.num_struct_layouts && k < 32) {
    if (module.struct_layouts[k].name_len == nlen && nlen > 0) {
      let ii: i32 = 0;
      let same: bool = true;
      while (ii < nlen && ii < 64) {
        if (module.struct_layouts[k].name[ii] != nm[ii]) {
          same = false;
        }
        ii = ii + 1;
      }
      if (same) {
        if (module.struct_layouts[k].num_fields == 0) {
          return k;
        }
        if (module.struct_layouts[k].num_fields == 1 && module.struct_layouts[k].field_lens[0] == 0) {
          return k;
        }
        /* library parse_one_function_library 占位：单假字段且无 field_type_ref，可被后续顶层 struct 覆盖。*/
        if (module.struct_layouts[k].num_fields == 1 && module.struct_layouts[k].field_type_refs[0] == 0) {
          return k;
        }
      }
    }
    k = k + 1;
  }
  return -1;
}

/**
 * 解析库中“单参 + 返回 bool + return 单表达式”形态：function <name>(<param>: <Type>): bool { return <param>.<field> == <Enum>.<variant>; }。
 * 先调 parse_one_function_library_scan 取解析结果，再按 result 建 AST，避免 -E 生成 C 时变量提升导致错序。
 */
function parse_one_function_library(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8): LibraryParseResult {
  let empty64: [64]u8 = [];
  let fail: LibraryParseResult = LibraryParseResult { ok: false, _pad: [], next_lex: lex, name: empty64, name_len: 0, _pad_tail: [] };
  let empty32: [32]u8 = [];
  let scan: LibraryParseScanResult = LibraryParseScanResult { ok: false, _pad: [], next_lex: lex, name: empty64, name_len: 0, param_name: empty32, param_name_len: 0, param_type_name: empty64, param_type_len: 0, field_name: empty64, field_len: 0, _pad_tail: [], _pad_tail2: [] };
  if (!parse_one_function_library_scan(lex, source, &scan)) {
    return LibraryParseResult { ok: false, _pad: [], next_lex: scan.next_lex, name: empty64, name_len: 0, _pad_tail: [] };
  }

  /* 构建 AST：仅从 scan 读取，不再依赖 lex/source 顺序 */
  let bool_type_ref: i32 = ast_arena_type_alloc(arena);
  if (bool_type_ref == 0) {
    return fail;
  }
  let bt: Type = ast_arena_type_get(arena, bool_type_ref);
  bt.kind = TypeKind.TYPE_BOOL;
  bt.name_len = 0;
  bt.elem_type_ref = 0;
  bt.array_size = 0;
  ast_arena_type_set(arena, bool_type_ref, bt);

  let token_type_ref: i32 = ast_arena_type_alloc(arena);
  if (token_type_ref == 0) {
    return fail;
  }
  let tt: Type = ast_arena_type_get(arena, token_type_ref);
  tt.kind = TypeKind.TYPE_NAMED;
  tt.name_len = scan.param_type_len;
  let ti: i32 = 0;
  while (ti < 64) {
    if (ti < scan.param_type_len) {
      tt.name[ti] = scan.param_type_name[ti];
    } else {
      tt.name[ti] = 0;
    }
    ti = ti + 1;
  }
  tt.elem_type_ref = 0;
  tt.array_size = 0;
  ast_arena_type_set(arena, token_type_ref, tt);

  let var_ref: i32 = ast_arena_expr_alloc(arena);
  if (var_ref == 0) {
    return fail;
  }
  let ve: Expr = ast_arena_expr_get(arena, var_ref);
  ve.kind = ExprKind.EXPR_VAR;
  ve.resolved_type_ref = token_type_ref;
  ve.line = 0;
  ve.col = 0;
  ve.var_name_len = scan.param_name_len;
  let vi: i32 = 0;
  while (vi < 64) {
    if (vi < 32) {
      ve.var_name[vi] = scan.param_name[vi];
    } else {
      ve.var_name[vi] = 0;
    }
    vi = vi + 1;
  }
  ast.expr_init_match_enum(&ve);
  ve.field_access_base_ref = 0;
  ve.field_access_field_len = 0;
  ve.field_access_is_enum_variant = 0;
  ve.field_access_offset = 0;
  ast_arena_expr_set(arena, var_ref, ve);

  let field_ref: i32 = ast_arena_expr_alloc(arena);
  if (field_ref == 0) {
    return fail;
  }
  let fe: Expr = ast_arena_expr_get(arena, field_ref);
  fe.kind = ExprKind.EXPR_FIELD_ACCESS;
  fe.resolved_type_ref = 0;
  fe.line = 0;
  fe.col = 0;
  fe.field_access_base_ref = var_ref;
  fe.field_access_field_len = scan.field_len;
  let fi: i32 = 0;
  while (fi < 64) {
    if (fi < scan.field_len) {
      fe.field_access_field_name[fi] = scan.field_name[fi];
    } else {
      fe.field_access_field_name[fi] = 0;
    }
    fi = fi + 1;
  }
  fe.field_access_is_enum_variant = 0;
  fe.field_access_offset = 0;
  ast.expr_init_match_enum(&fe);
  fe.binop_left_ref = 0;
  fe.binop_right_ref = 0;
  ast_arena_expr_set(arena, field_ref, fe);

  let enum_ref: i32 = ast_arena_expr_alloc(arena);
  if (enum_ref == 0) {
    return fail;
  }
  let ene: Expr = ast_arena_expr_get(arena, enum_ref);
  ene.kind = ExprKind.EXPR_ENUM_VARIANT;
  ene.resolved_type_ref = 0;
  ene.line = 0;
  ene.col = 0;
  ene.enum_variant_tag = 0;
  ast.expr_init_match_enum(&ene);
  ene.field_access_base_ref = 0;
  ene.field_access_field_len = 0;
  ast_arena_expr_set(arena, enum_ref, ene);

  let eq_ref: i32 = ast_arena_expr_alloc(arena);
  if (eq_ref == 0) {
    return fail;
  }
  let eqe: Expr = ast_arena_expr_get(arena, eq_ref);
  eqe.kind = ExprKind.EXPR_EQ;
  eqe.resolved_type_ref = bool_type_ref;
  eqe.line = 0;
  eqe.col = 0;
  eqe.binop_left_ref = field_ref;
  eqe.binop_right_ref = enum_ref;
  ast.expr_init_match_enum(&eqe);
  eqe.field_access_base_ref = 0;
  eqe.field_access_field_len = 0;
  ast_arena_expr_set(arena, eq_ref, eqe);

  let block_ref: i32 = ast_arena_block_alloc(arena);
  if (block_ref == 0) {
    return fail;
  }
  let b: Block = ast_arena_block_get(arena, block_ref);
  b.num_consts = 0;
  b.num_lets = 0;
  b.num_early_lets = 0;
  b.num_loops = 0;
  b.num_for_loops = 0;
  b.num_if_stmts = 0;
  b.num_defers = 0;
  b.num_labeled_stmts = 1;
  b.labeled_stmts[0].label_len = 0;
  b.labeled_stmts[0].is_goto = 0;
  b.labeled_stmts[0].goto_target_len = 0;
  b.labeled_stmts[0].return_expr_ref = eq_ref;
  b.num_expr_stmts = 0;
  b.final_expr_ref = 0;
  b.num_stmt_order = 0;
  ast_arena_block_set(arena, block_ref, b);

  /** 仅当有真实字段名且尚未有该类型名 layout 时注册，避免占住名字后真正的 struct 声明被 dup 跳过或遮挡后续槽位。 */
  if (scan.field_len > 0 && !struct_layout_name_exists_arr(module, scan.param_type_name, scan.param_type_len) && module.num_struct_layouts < 32) {
    let idx: i32 = module.num_struct_layouts;
    module.struct_layouts[idx].name_len = scan.param_type_len;
    let si: i32 = 0;
    while (si < 64) {
      if (si < scan.param_type_len) {
        module.struct_layouts[idx].name[si] = scan.param_type_name[si];
      } else {
        module.struct_layouts[idx].name[si] = 0;
      }
      si = si + 1;
    }
    module.struct_layouts[idx].num_fields = 1;
    module.struct_layouts[idx].field_lens[0] = scan.field_len;
    let fj: i32 = 0;
    while (fj < 64) {
      if (fj < scan.field_len) {
        module.struct_layouts[idx].field_names[0][fj] = scan.field_name[fj];
      } else {
        module.struct_layouts[idx].field_names[0][fj] = 0;
      }
      fj = fj + 1;
    }
    module.struct_layouts[idx].field_offsets[0] = 0;
    module.struct_layouts[idx].field_type_refs[0] = 0;
    module.num_struct_layouts = module.num_struct_layouts + 1;
  }

  if (module.num_funcs >= 256) {
    return fail;
  }
  let f: Func = module.funcs[module.num_funcs];
  let ki: i32 = 0;
  while (ki < 64) {
    if (ki < scan.name_len) {
      f.name[ki] = scan.name[ki];
    } else {
      f.name[ki] = 0;
    }
    ki = ki + 1;
  }
  f.name_len = scan.name_len;
  f.num_params = 1;
  let p: Param = f.params[0];
  let pk: i32 = 0;
  while (pk < 32) {
    p.name[pk] = scan.param_name[pk];
    pk = pk + 1;
  }
  p.name_len = scan.param_name_len;
  p.type_ref = token_type_ref;
  f.params[0] = p;
  f.return_type_ref = bool_type_ref;
  f.body_ref = block_ref;
  f.body_expr_ref = 0;
  f.is_extern = 0;
  module.funcs[module.num_funcs] = f;
  module.num_funcs = module.num_funcs + 1;

  /* 直接返回结构体字面量，name 用 scan.name（codegen 会生成 memcpy），避免「return res」时 codegen 漏生成 res 声明。 */
  return LibraryParseResult { ok: true, _pad: [], next_lex: scan.next_lex, name: scan.name, name_len: scan.name_len, _pad_tail: [] };
}

/**
 * 与 parse_one_function_library 等价，接受 (data: *u8, len) 供 parse_into_buf 使用。
 * 委托 slice 路径（parser_slice_from_buf），与 parse_into 行为一致，避免存根导致库形态回退失败、num_funcs 残缺。
 */
function parse_one_function_library_buf(arena: *ASTArena, module: *Module, lex: Lexer, data: *u8, len: i32): LibraryParseResult {
  let slice: []u8 = parser_slice_from_buf(data, len);
  return parse_one_function_library(arena, module, lex, slice);
}

/** 仅当 r 为 TOKEN_IDENT 且 ident_len==5 时调用 try_skip_allow_padding_struct，否则返回 (lex, 0)。主循环统一调用此包装避免复杂条件。 */
function parse_into_try_skip_allow(lex: Lexer, r: LexerResult, source: []u8): TrySkipAllowResult {
  if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len != 5) {
    return TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
  }
  return try_skip_allow_padding_struct(r.next_lex, source);
}

function parse_into_try_skip_allow_buf(lex: Lexer, r: LexerResult, data: *u8, len: i32): TrySkipAllowResult {
  if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len != 5) {
    return TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
  }
  return try_skip_allow_padding_struct_buf(r.next_lex, data, len);
}

function try_skip_allow_padding_struct(lex: Lexer, source: []u8): TrySkipAllowResult {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
  }
  lex = skip_balanced_parens(r.next_lex, source);
  /** 勿 skip_one_struct：须把 lex 留在随后的 struct 关键字，让主循环走 parse_struct_record_layout_into；否则 allow(padding) 前缀会把整块 struct 吞掉且无 layout（FIELD_ACCESS 左侧为 ?）。 */
  return TrySkipAllowResult { lex: lex, skipped: 1, _pad: [] };
}

function try_skip_allow_padding_struct_buf(lex: Lexer, data: *u8, len: i32): TrySkipAllowResult {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    return TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
  }
  lex = skip_balanced_parens_buf(r.next_lex, data, len);
  /** 与 try_skip_allow_padding_struct 一致：保留 struct 给 parse_struct_record_layout_into。 */
  return TrySkipAllowResult { lex: lex, skipped: 1, _pad: [] };
}

/** 与 skip_one_struct 等价，接受 (data: *u8, len) 供 buf 路径使用。 */
/** skip_one_struct_buf 的 _into_buf 变体。 */
function skip_one_struct_into_buf(out: *Lexer, lex: Lexer, data: *u8, len: i32): void {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  lex_from_next_into(&lex, r); r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) { out.pos = lex.pos; out.line = lex.line; out.col = lex.col; return; }
  skip_balanced_braces_into_buf(out, r.next_lex, data, len);
}
function skip_one_struct_buf(lex: Lexer, data: *u8, len: i32): Lexer {
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_STRUCT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    return lex;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return lex;
  }
  lex = skip_balanced_braces_buf(r.next_lex, data, len);
  return lex;
}

/**
 * 判断 token 是否可作为「*」后的指向目标（命名类型或内建标量关键字，含 u8/i32 等）。
 */
function is_pointee_type_token(kind: TokenKind): bool {
  if (kind == TokenKind.TOKEN_IDENT) {
    return true;
  }
  if (kind == TokenKind.TOKEN_I32 || kind == TokenKind.TOKEN_I64 || kind == TokenKind.TOKEN_BOOL) {
    return true;
  }
  if (kind == TokenKind.TOKEN_U8 || kind == TokenKind.TOKEN_U32 || kind == TokenKind.TOKEN_U64) {
    return true;
  }
  if (kind == TokenKind.TOKEN_USIZE || kind == TokenKind.TOKEN_ISIZE || kind == TokenKind.TOKEN_VOID) {
    return true;
  }
  return false;
}

/**
 * 在 r 指向「*」后首 token 时，将指向目标类型写入 arena 类型池并返回其 ref；失败返回 0（不前进 lex）。
 * 须传 *LexerResult：LexerResult 按值传给子函数时主机 ABI（如 AArch64）会撕裂 tok/token_start，导致 *T 的元素名错乱与 struct 布局不匹配。
 */
function alloc_pointee_type_ref_from_tok(arena: *ASTArena, source: []u8, r: *LexerResult): i32 {
  if (!is_pointee_type_token(r.tok.kind)) {
    return 0;
  }
  let elem_ref: i32 = ast_arena_type_alloc(arena);
  if (elem_ref == 0) {
    return 0;
  }
  let te: Type = ast_arena_type_get(arena, elem_ref);
  te.elem_type_ref = 0;
  te.array_size = 0;
  te.name_len = 0;
  if (r.tok.kind == TokenKind.TOKEN_IDENT) {
    te.kind = TypeKind.TYPE_NAMED;
    te.name_len = r.tok.ident_len;
    if (te.name_len > 63) {
      te.name_len = 63;
    }
    /**
     * 与 parse_struct_record_layout_into / parse_one_function_impl 一致：next_lex.pos 反推字面量，
     * 勿用 token_start（部分宿主上不可靠），否则 TYPE_NAMED 名全 0、*T 与 struct_layouts 配不上。
     */
    copy_slice_to_name64_at_end(source, r.next_lex.pos, te.name_len, te.name);
  } else if (r.tok.kind == TokenKind.TOKEN_I32) {
    te.kind = TypeKind.TYPE_I32;
  } else if (r.tok.kind == TokenKind.TOKEN_I64) {
    te.kind = TypeKind.TYPE_I64;
  } else if (r.tok.kind == TokenKind.TOKEN_BOOL) {
    te.kind = TypeKind.TYPE_BOOL;
  } else if (r.tok.kind == TokenKind.TOKEN_U8) {
    te.kind = TypeKind.TYPE_U8;
  } else if (r.tok.kind == TokenKind.TOKEN_U32) {
    te.kind = TypeKind.TYPE_U32;
  } else if (r.tok.kind == TokenKind.TOKEN_U64) {
    te.kind = TypeKind.TYPE_U64;
  } else if (r.tok.kind == TokenKind.TOKEN_USIZE) {
    te.kind = TypeKind.TYPE_USIZE;
  } else if (r.tok.kind == TokenKind.TOKEN_ISIZE) {
    te.kind = TypeKind.TYPE_ISIZE;
  } else {
    te.kind = TypeKind.TYPE_VOID;
  }
  ast_arena_type_set(arena, elem_ref, te);
  return elem_ref;
}

/**
 * 从 lex 起解析一个类型写入 arena（*T、[N]Elem、标量、命名类型），返回 types 池下标，失败返回 0。
 * 成功时写入 *out_lex 为类型最后一个 token 之后的位置，供形参/struct 字段等继续读 , 或 ;。
 */
function parse_type_ref_for_arena_into(arena: *ASTArena, lex: Lexer, source: []u8, out_lex: *Lexer): i32 {
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind == TokenKind.TOKEN_STAR) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    let elem_ref: i32 = alloc_pointee_type_ref_from_tok(arena, source, &r);
    if (elem_ref == 0) {
      out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col; return 0;
    }
    let type_ref_param: i32 = ast_arena_type_alloc(arena);
    if (type_ref_param != 0) {
      let t: Type = ast_arena_type_get(arena, type_ref_param);
      t.kind = TypeKind.TYPE_PTR;
      t.elem_type_ref = elem_ref;
      t.name_len = 0;
      t.array_size = 0;
      ast_arena_type_set(arena, type_ref_param, t);
    }
    lex_from_next_into(&lex, r);
    out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
    return type_ref_param;
  }
  if (r.tok.kind == TokenKind.TOKEN_LBRACKET) {
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_INT) {
      out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col; return 0;
    }
    let asz: i32 = r.tok.int_val;
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_RBRACKET) {
      out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col; return 0;
    }
    lex_from_next_into(&lex, r);
    let elem_tr: i32 = parse_type_ref_for_arena_into(arena, lex, source, &lex);
    if (elem_tr == 0) {
      out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col; return 0;
    }
    let arr_ref: i32 = ast_arena_type_alloc(arena);
    if (arr_ref != 0) {
      let ta: Type = ast_arena_type_get(arena, arr_ref);
      ta.kind = TypeKind.TYPE_ARRAY;
      ta.elem_type_ref = elem_tr;
      ta.array_size = asz;
      ta.name_len = 0;
      ast_arena_type_set(arena, arr_ref, ta);
    }
    out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
    return arr_ref;
  }
  if (r.tok.kind == TokenKind.TOKEN_I32 || r.tok.kind == TokenKind.TOKEN_BOOL || r.tok.kind == TokenKind.TOKEN_I64 || r.tok.kind == TokenKind.TOKEN_U8 || r.tok.kind == TokenKind.TOKEN_U32 || r.tok.kind == TokenKind.TOKEN_U64 || r.tok.kind == TokenKind.TOKEN_USIZE || r.tok.kind == TokenKind.TOKEN_ISIZE || r.tok.kind == TokenKind.TOKEN_VOID) {
    let type_ref_param: i32 = 0;
    if (r.tok.kind == TokenKind.TOKEN_I32) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_I32;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_I64) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_I64;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_BOOL) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_BOOL;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_U8) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_U8;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_U32) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_U32;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_U64) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_U64;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_USIZE) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_USIZE;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_ISIZE) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_ISIZE;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    } else if (r.tok.kind == TokenKind.TOKEN_VOID) {
      type_ref_param = ast_arena_type_alloc(arena);
      if (type_ref_param != 0) {
        let t: Type = ast_arena_type_get(arena, type_ref_param);
        t.kind = TypeKind.TYPE_VOID;
        t.name_len = 0;
        t.elem_type_ref = 0;
        t.array_size = 0;
        ast_arena_type_set(arena, type_ref_param, t);
      }
    }
    lex_from_next_into(&lex, r);
    out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
    return type_ref_param;
  }
  if (r.tok.kind == TokenKind.TOKEN_IDENT) {
    let type_ref_param: i32 = ast_arena_type_alloc(arena);
    if (type_ref_param != 0) {
      let t: Type = ast_arena_type_get(arena, type_ref_param);
      t.kind = TypeKind.TYPE_NAMED;
      t.name_len = r.tok.ident_len;
      if (t.name_len > 63) { t.name_len = 63; }
      /** 与 alloc_pointee_type_ref_from_tok 一致：具名 IDENT 用文字用 next_lex.pos 推导。 */
      copy_slice_to_name64_at_end(source, r.next_lex.pos, t.name_len, t.name);
      t.elem_type_ref = 0;
      t.array_size = 0;
      ast_arena_type_set(arena, type_ref_param, t);
    }
    lex_from_next_into(&lex, r);
    out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
    return type_ref_param;
  }
  out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
  return 0;
}

/**
 * 解析顶层 struct Name { field: T; ... }：写入 module.struct_layouts（偏移 8 字节步进 + field_type_refs）。
 * lex 指向类型名第一个字节（已跳过 struct 关键字）。成功返回 0 且 *out_lex 在闭合 } 之后；失败返回 -1。
 */
function parse_struct_record_layout_into(arena: *ASTArena, module: *Module, lex: Lexer, source: []u8, out_lex: *Lexer): i32 {
  /**
   * IDENT 文本与 parse_one_function_impl 一致：用 next_lex.pos - ident_len 反推起点 + copy_slice_to_name64_at_end。
   * token_start / lex.pos 在本函数部分 codegen 路径不可靠，会导致布局名、字段名缓冲全 0 → typeck *T 字段成 ?。
   */
  let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
    return -1;
  }
  let sname_len: i32 = r.tok.ident_len;
  let sname_buf: [64]u8 = [];
  copy_slice_to_name64_at_end(source, r.next_lex.pos, sname_len, sname_buf);
  lex_from_next_into(&lex, r);
  lexer_next_into(&r, lex, source);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    return -1;
  }
  lex = r.next_lex;
  let dup: bool = struct_layout_name_exists_arr(module, sname_buf, sname_len);
  let weak_idx: i32 = struct_layout_placeholder_idx(module, sname_buf, sname_len);
  /** 重名且非占位：跳过整个 struct 体；重名且为 library 占位槽：解析并覆盖 weak_idx。
   * onefunc_result_layout_prime 预注册的「多字段」布局 dup 为真但 weak_idx<0；须按同名槽覆盖，否则源码 struct 被跳过、FIELD_ACCESS 左侧类型永远 ?。 */
  let replace_idx: i32 = -1;
  if (dup) {
    if (weak_idx < 0) {
      let dup_idx: i32 = struct_layout_first_name_match_idx(module, sname_buf, sname_len);
      if (dup_idx >= 0) {
        replace_idx = dup_idx;
      } else {
        lex = skip_balanced_braces(lex, source);
        out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
        return 0;
      }
    } else {
      replace_idx = weak_idx;
    }
  } else {
    replace_idx = -1;
  }
  if (replace_idx < 0 && module.num_struct_layouts >= 32) {
    return -1;
  }
  /** 单 struct 记录布局上限，须与 ast.StructLayout 中 field_* 数组长度一致（OneFuncResult 五十余字段）。 */
  let fnames: [64][64]u8 = [];
  let flens: [64]i32 = [];
  let ftys: [64]i32 = [];
  let zi: i32 = 0;
  while (zi < 64) {
    flens[zi] = 0;
    ftys[zi] = 0;
    zi = zi + 1;
  }
  let nf: i32 = 0;
  while (true) {
    lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      lex_from_next_into(&lex, r);
      break;
    }
    if (nf >= 64) {
      return -1;
    }
    if (r.tok.kind != TokenKind.TOKEN_IDENT || r.tok.ident_len <= 0 || r.tok.ident_len > 63) {
      return -1;
    }
    let fn_len: i32 = r.tok.ident_len;
    flens[nf] = fn_len;
    copy_slice_to_name64_at_end(source, r.next_lex.pos, fn_len, fnames[nf]);
    lex_from_next_into(&lex, r);
    lexer_next_into(&r, lex, source);
    if (r.tok.kind != TokenKind.TOKEN_COLON) {
      return -1;
    }
    lex_from_next_into(&lex, r);
    let tr: i32 = parse_type_ref_for_arena_into(arena, lex, source, &lex);
    if (tr == 0) {
      return -1;
    }
    ftys[nf] = tr;
    lexer_next_into(&r, lex, source);
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, r);
    } else if (r.tok.kind == TokenKind.TOKEN_RBRACE) {
      /* 末字段后可省略 ;，与单行 struct Tiny { a: i32 } / 前置 *T field 占位等场景对齐。*/
      lex_from_next_into(&lex, r);
      nf = nf + 1;
      break;
    } else {
      return -1;
    }
    nf = nf + 1;
  }
  let idx: i32 = 0;
  if (replace_idx >= 0) {
    idx = replace_idx;
  } else {
    idx = module.num_struct_layouts;
    module.num_struct_layouts = module.num_struct_layouts + 1;
  }
  /* 整块 memcpy 写入 layout：SU 对大嵌套 struct_layout 逐元素赋值在 AArch64 glue 后端可能不写回内存，导致 FIELD_ACCESS 布局名/字段为零。 */
  pipeline_module_struct_layout_reset_slot(module, idx);
  pipeline_module_struct_layout_set_name(module, idx, &sname_buf[0], sname_len);
  module.struct_layouts[idx].num_fields = nf;
  let off: i32 = 0;
  let j: i32 = 0;
  while (j < nf && j < 64) {
    pipeline_module_struct_layout_set_field(module, idx, j, &fnames[j][0], flens[j], ftys[j], off);
    off = off + 8;
    j = j + 1;
  }
  out_lex.pos = lex.pos; out_lex.line = lex.line; out_lex.col = lex.col;
  return 0;
}

/**
 * 与 parse_one_function 等价，接受 (data: *u8, len) 供 buf 路径使用；精简实现：
 * function <ident>(): <标量或 void?> { … }，体须显式 `return <int>;`（分号可省仅当其后直接为 `}` 时与主解析一致），
 * 不支持块末裸字面量当返回值。
 */
/** parse_one_function_buf 的 _into 变体：避免 ARM64 下 OneFuncResult 按值返回导致 ABI 错误。 */
function parse_one_function_buf_into(out: *OneFuncResult, lex: Lexer, data: *u8, len: i32): void {
  let empty32: [32]u8 = [];
  let dummy_pnames: [16][32]u8 = [empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32];
  let dummy_plens: [16]i32 = [];
  let dummy_ptrefs: [16]i32 = [];
  let empty64: [64]u8 = [];
  let dummy_name: [64]u8 = [];
  let dummy_const_names: [256][64]u8 = [];
  let dummy_const_lens: [256]i32 = [];
  let dummy_const_vals: [256]i32 = [];
  let dummy_let_names: [256][64]u8 = [];
  let dummy_let_lens: [256]i32 = [];
  let dummy_let_vals: [256]i32 = [];
  let dummy_let_refs: [256]i32 = [];
  let dummy_loop_refs: [8]i32 = [];
  let dummy_for_refs: [8]i32 = [];
  let dummy_call_arg_vals: [16]i32 = [];
  let r: LexerResult = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_IDENT) {
    set_onefunc_fail(out, lex); return;
  }
  let name_len: i32 = r.tok.ident_len;
  if (name_len <= 0 || name_len > 63) {
    set_onefunc_fail(out, lex); return;
  }
  let name_start: usize = r.next_lex.pos - name_len;
  let name: [64]u8 = dummy_name;
  copy_slice_to_name64_buf(data, len, name_start, name_len, name);
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LPAREN) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_RPAREN) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_COLON) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_I32 && r.tok.kind != TokenKind.TOKEN_I64 && r.tok.kind != TokenKind.TOKEN_BOOL && r.tok.kind != TokenKind.TOKEN_VOID && r.tok.kind != TokenKind.TOKEN_U8 && r.tok.kind != TokenKind.TOKEN_U32 && r.tok.kind != TokenKind.TOKEN_U64 && r.tok.kind != TokenKind.TOKEN_USIZE && r.tok.kind != TokenKind.TOKEN_IDENT) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = lexer_next_buf(lex, data, len);
  if (r.tok.kind != TokenKind.TOKEN_LBRACE) {
    set_onefunc_fail(out, lex); return;
  }
  lex_from_next_into(&lex, r);
  r = body_skip_let_const_then_if_buf(lex, data, len);
  /* 非 void 返回值须 `return` 语句，不得 `{ 42 }` 块末隐式返回（与 parse_one_function_impl 一致）。 */
  if (r.tok.kind == TokenKind.TOKEN_RETURN) {
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_INT) {
      set_onefunc_fail(out, lex); return;
    }
    let ret_val: i32 = r.tok.int_val;
    lex_from_next_into(&lex, r);
    r = lexer_next_buf(lex, data, len);
    if (r.tok.kind != TokenKind.TOKEN_SEMICOLON && r.tok.kind != TokenKind.TOKEN_RBRACE) {
      set_onefunc_fail(out, lex); return;
    }
    if (r.tok.kind == TokenKind.TOKEN_SEMICOLON) {
      lex_from_next_into(&lex, r);
      r = lexer_next_buf(lex, data, len);
      if (r.tok.kind != TokenKind.TOKEN_RBRACE) {
        set_onefunc_fail(out, lex); return;
      }
    }
    lex_from_next_into(&lex, r);
    out.ok = true; out.next_lex = lex; out.name_len = name_len;
    let ni: i32 = 0; while (ni < 64) { if (ni < name_len) { out.name[ni] = name[ni]; } ni = ni + 1; }
    out.return_val = ret_val;
    return;
  }
  set_onefunc_fail(out, lex);
}

/** parse_one_function_library 的 _into 变体：避免 ARM64 下 LibraryParseResult 按值返回 ABI 错误。将结果写入 out 指针。 */
function parse_one_function_library_into(out: *LibraryParseResult, arena: *ASTArena, module: *Module, lex: Lexer, source: []u8): void {
  let res: LibraryParseResult = parse_one_function_library(arena, module, lex, source);
  out.ok = res.ok;
  out._pad[0] = res._pad[0];
  out._pad[1] = res._pad[1];
  out._pad[2] = res._pad[2];
  out._pad[3] = res._pad[3];
  out.next_lex.pos = res.next_lex.pos;
  out.next_lex.line = res.next_lex.line;
  out.next_lex.col = res.next_lex.col;
  let nli: i32 = 0;
  while (nli < 64) { out.name[nli] = res.name[nli]; nli = nli + 1; }
  out.name_len = res.name_len;
  out._pad_tail[0] = res._pad_tail[0];
  out._pad_tail[1] = res._pad_tail[1];
  out._pad_tail[2] = res._pad_tail[2];
  out._pad_tail[3] = res._pad_tail[3];
}

/** parse_into_try_skip_allow 的 _into 变体。将结果写到 out 指针。 */
function parse_into_try_skip_allow_into(out: *TrySkipAllowResult, lex: Lexer, r: LexerResult, source: []u8): void {
  let res: TrySkipAllowResult = parse_into_try_skip_allow(lex, r, source);
  out.lex.pos = res.lex.pos;
  out.lex.line = res.lex.line;
  out.lex.col = res.lex.col;
  out.skipped = res.skipped;
  out._pad[0] = res._pad[0];
  out._pad[1] = res._pad[1];
  out._pad[2] = res._pad[2];
  out._pad[3] = res._pad[3];
}

/** parse_into_try_skip_allow_buf 的 _into 变体。将结果写到 out 指针。 */
function parse_into_try_skip_allow_into_buf(out: *TrySkipAllowResult, lex: Lexer, r: LexerResult, data: *u8, len: i32): void {
  let res: TrySkipAllowResult = parse_into_try_skip_allow_buf(lex, r, data, len);
  out.lex.pos = res.lex.pos;
  out.lex.line = res.lex.line;
  out.lex.col = res.lex.col;
  out.skipped = res.skipped;
  out._pad[0] = res._pad[0];
  out._pad[1] = res._pad[1];
  out._pad[2] = res._pad[2];
  out._pad[3] = res._pad[3];
}

/** 兼容包装：保留旧按值返回签名，供未迁移调用方使用。 */
function parse_one_function_buf(lex: Lexer, data: *u8, len: i32): OneFuncResult {
  let res: OneFuncResult = OneFuncResult { ok: false, next_lex: lex, name: [], name_len: 0, num_params: 0, param_names: [], param_name_lens: [], param_type_refs: [], num_consts: 0, const_names: [], const_name_lens: [], const_init_vals: [], num_lets: 0, let_names: [], let_name_lens: [], let_init_vals: [], let_init_refs: [], let_type_refs: [], has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, if_cond_expr_ref: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, binop_left_param_idx: -1, binop_right_param_idx: -1, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: [], call_callee_len: 0, return_var_name: [], return_var_name_len: 0, return_expr_ref: 0, call_num_args: 0, call_arg_vals: [], num_loops: 0, loop_cond_refs: [], loop_body_refs: [], num_for_loops: 0, for_init_refs: [], for_cond_refs: [], for_step_refs: [], for_body_refs: [], num_if_stmts: 0, if_cond_refs: [], if_then_body_refs: [], num_src_stmt_order: 0, src_stmt_kind: [], src_stmt_idx: [], num_src_body_expr_stmts: 0, src_body_expr_stmt_refs: [], func_return_type_ref: 0 };
  parse_one_function_buf_into(&res, lex, data, len);
  return res;
}

/**
 * 解析若干最小函数并填入 .su AST：每项为 function <ident>(): i32 { return <int>; }，遇非 function 或 EOF 停止。
 * 成功时填充 arena 与 module（funcs[0..num_funcs-1]）；main_idx 由调用方写回 module.main_func_index。
 * 返回 ParseIntoResult：ok 0 成功 -1 失败，main_idx 为 main 下标（无则 -1）。
 */
function parse_into(arena: *ASTArena, module: *Module, source: []u8): ParseIntoResult {
  /* 由调用方在调用 parse_into 前先调用 parse_into_init，避免 codegen 将 init 移到循环后 */
  let lex: Lexer = lexer_init();
  let main_idx: i32 = -1;
  /* 循环前一次性跳过顶层 import，通过 out 参数取 lex 避免按值返回 Lexer（ABI 导致有 import 时错误） */
  let import_res: CollectImportsResult = CollectImportsResult { lex: lex };
  collect_imports(lex, source, module, &import_res);
  copy_lex_from_import_into(&lex, &import_res);
  let loop_count: i32 = 0;
  while (true) {
    /* 防护：避免 ABI/LexerResult 导致 lex 未更新而死循环；大文件（如 parser.su 五千行）需更多迭代，上限 128K 项 */
    if (loop_count >= 131072) {
      return ParseIntoResult { ok: -1, main_idx: -1003 }
    }
    loop_count = loop_count + 1;
    let iter_start: Lexer = lex;
    /* 首 token 必须用 lexer_next_into 写 r，否则结构体返回 ABI 导致 r/next_lex 错，传入 parse_one_function 的 lex 错、自举失败 */
    let r: LexerResult = LexerResult { next_lex: lex, tok: Token { kind: TokenKind.TOKEN_EOF, line: 0, col: 0, int_val: 0, float_val: 0.0, ident: 0, ident_len: 0 }, token_start: 0 };
    lexer_next_into(&r, lex, source);
    lex_from_next_into(&lex, r);
    if (r.tok.kind == TokenKind.TOKEN_STRUCT) {
      if (parse_struct_record_layout_into(arena, module, lex, source, &lex) != 0) {
        skip_one_struct_into(&lex, iter_start, source);
      }
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_ENUM) {
      skip_one_enum_into(&lex, iter_start, source);
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_EXTERN) {
      parse_one_extern_and_add_into(arena, module, lex, source, &lex);
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        skip_one_extern_into(&lex, lex, source);
      }
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_TRAIT) {
      skip_one_trait_into(&lex, iter_start, source);
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind == TokenKind.TOKEN_IMPL) {
      skip_one_impl_into(&lex, iter_start, source);
      if (lex.pos == iter_start.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    if (r.tok.kind != TokenKind.TOKEN_FUNCTION) {
      let try_res: TrySkipAllowResult = TrySkipAllowResult { lex: lex, skipped: 0, _pad: [] };
      parse_into_try_skip_allow_into(&try_res, lex, r, source);
      if (try_res.skipped != 0) {
        lex_from_try_skip_into(&lex, try_res);
        if (lex.pos == iter_start.pos && lex.pos < source.length) {
          lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
        }
        continue;
      }
      /* 非 function 且未 skip：可能是注释等，前进一个 token 再试，避免注释导致只解析前若干函数（与 parse_into_buf 一致） */
      if (r.tok.kind == TokenKind.TOKEN_EOF) {
        break;
      }
      lex_from_next_into(&lex, r);
      continue;
    }
    /* 库模块或正常结束：break 后若为 EOF 则直接返回成功，避免在 EOF 处当作 function 解析导致死循环（-backend asm 编 token.su 等仅 enum 的模块依赖此路径）。 */
    if (r.tok.kind == TokenKind.TOKEN_EOF) {
      if (module.num_funcs == 0) {
        return ParseIntoResult { ok: 0, main_idx: -1 }
      }
      let out_idx_storage: [1]i32 = [];
      out_idx_storage[0] = main_idx;
      return ParseIntoResult { ok: 0, main_idx: out_idx_storage[0] }
    }
    /* 保存「function」前的 lex，library 扫描必须从 function 开始；先消费 "function" 再解析（否则 next_lex 未写回时重复读同一 token）。用 _into 避免 ABI 下 OneFuncResult 按值返回错误。 */
    let lex_at_function: Lexer = lex;
    lex_from_next_into(&lex, r);
    let parse_into_empty64: [64]u8 = [];
    let parse_into_empty32: [32]u8 = [];
    let parse_into_dummy_p: [16][32]u8 = [parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32, parse_into_empty32];
    let parse_into_dummy_plens: [16]i32 = [];
    let parse_into_dummy_ptrefs: [16]i32 = [];
    let parse_into_dummy_c: [256][64]u8 = [];
    let parse_into_dummy_clens: [256]i32 = [];
    let parse_into_dummy_cvals: [256]i32 = [];
    let parse_into_dummy_ln: [256][64]u8 = [];
    let parse_into_dummy_llens: [256]i32 = [];
    let parse_into_dummy_lvals: [256]i32 = [];
    let parse_into_dummy_let_refs: [256]i32 = [];
    let parse_into_dummy_let_trefs: [256]i32 = [];
    let parse_into_dummy_loop_refs: [8]i32 = [];
    let parse_into_dummy_for_refs: [8]i32 = [];
    let parse_into_dummy_if_refs: [16]i32 = [];
    let parse_into_dummy_call_arg_vals: [16]i32 = [];
    let res: OneFuncResult = OneFuncResult { ok: false, next_lex: lex, name: parse_into_empty64, name_len: 0, num_params: 0, param_names: parse_into_dummy_p, param_name_lens: parse_into_dummy_plens, param_type_refs: parse_into_dummy_ptrefs, num_consts: 0, const_names: parse_into_dummy_c, const_name_lens: parse_into_dummy_clens, const_init_vals: parse_into_dummy_cvals, num_lets: 0, let_names: parse_into_dummy_ln, let_name_lens: parse_into_dummy_llens, let_init_vals: parse_into_dummy_lvals, let_init_refs: parse_into_dummy_let_refs, let_type_refs: parse_into_dummy_let_trefs, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, if_cond_expr_ref: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, binop_left_param_idx: -1, binop_right_param_idx: -1, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: parse_into_empty64, call_callee_len: 0, return_var_name: [], return_var_name_len: 0, return_expr_ref: 0, call_num_args: 0, call_arg_vals: parse_into_dummy_call_arg_vals, num_loops: 0, loop_cond_refs: parse_into_dummy_loop_refs, loop_body_refs: parse_into_dummy_loop_refs, num_for_loops: 0, for_init_refs: parse_into_dummy_for_refs, for_cond_refs: parse_into_dummy_for_refs, for_step_refs: parse_into_dummy_for_refs, for_body_refs: parse_into_dummy_for_refs, num_if_stmts: 0, if_cond_refs: parse_into_dummy_if_refs, if_then_body_refs: parse_into_dummy_if_refs, num_src_stmt_order: 0, src_stmt_kind: [], src_stmt_idx: [], num_src_body_expr_stmts: 0, src_body_expr_stmt_refs: [], func_return_type_ref: 0 };
    /* 优先 library：形态「单参 bool return x.y == Enum.V」须走专用 AST（EXPR_ENUM_VARIANT）；若先跑 impl 则会 parse_expr_into 成功却得不到 SU typeck/asm 路径期望的节点 */
    let empty64_lib_first: [64]u8 = [];
    let lib_first: LibraryParseResult = LibraryParseResult { ok: false, _pad: [], next_lex: lex_at_function, name: empty64_lib_first, name_len: 0, _pad_tail: [] };
    parse_one_function_library_into(&lib_first, arena, module, lex_at_function, source);
    if (lib_first.ok) {
      lex_from_library_into(&lex, lib_first);
      if (lex.pos == lex_at_function.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    parse_one_function_impl(&res, arena, lex, source);
    if (!res.ok) {
      skip_one_function_full_into(&lex, lex_at_function, source);
      if (lex.pos == lex_at_function.pos && lex.pos < source.length) {
        lex = Lexer { pos: lex.pos + 1, line: lex.line, col: lex.col + 1 };
      }
      continue;
    }
    /* 立即根据 res 判断是否 main 并存入数组，避免栈上变量被后续代码覆盖 */
    let is_main_storage: [1]i32 = [];
    if (res.name_len == 4 && res.name[0] == 109 && res.name[1] == 97 && res.name[2] == 105 && res.name[3] == 110) {
      is_main_storage[0] = 1;
    }
    if (module.num_funcs >= 256) {
      return ParseIntoResult { ok: -1, main_idx: -1000 }
    }
    /* 使用签名中的返回类型 Ty；若为 0（异常回退），与历史上行为一致再造 TYPE_I32。 */
    let type_ref: i32 = res.func_return_type_ref;
    if (type_ref == 0) {
      type_ref = ast_arena_type_alloc(arena);
      if (type_ref == 0 && module.num_funcs == 0) {
        ast_arena_init(arena);
        type_ref = ast_arena_type_alloc(arena);
      }
      if (type_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1001 }
      }
      let t_fb: Type = ast_arena_type_get(arena, type_ref);
      t_fb.kind = TypeKind.TYPE_I32;
      t_fb.name_len = 0;
      t_fb.elem_type_ref = 0;
      t_fb.array_size = 0;
      ast_arena_type_set(arena, type_ref, t_fb);
    }

    let expr_ref: i32 = ast_arena_expr_alloc(arena);
    if (expr_ref == 0) {
      return ParseIntoResult { ok: -1, main_idx: -1002 }
    }
    let e: Expr = ast_arena_expr_get(arena, expr_ref);
    e.kind = ExprKind.EXPR_LIT;
    e.resolved_type_ref = type_ref;
    e.line = 0;
    e.col = 0;
    e.int_val = res.return_val;
    e.binop_left_ref = 0;
    e.binop_right_ref = 0;
    e.unary_operand_ref = 0;
    e.if_cond_ref = 0;
    e.if_then_ref = 0;
    e.if_else_ref = 0;
    e.block_ref = 0;
    e.match_matched_ref = 0;
    e.match_num_arms = 0;
    ast.expr_init_match_enum(&e);
    e.field_access_base_ref = 0;
    e.field_access_field_len = 0;
    e.field_access_is_enum_variant = 0;
    e.field_access_offset = 0;
    e.index_base_ref = 0;
    e.index_index_ref = 0;
    e.index_base_is_slice = 0;
    e.call_callee_ref = 0;
    e.call_num_args = 0;
    e.method_call_base_ref = 0;
    e.method_call_name_len = 0;
    e.method_call_num_args = 0;
    e.const_folded_val = 0;
    e.const_folded_valid = 0;
    e.index_proven_in_bounds = 0;
    ast_arena_expr_set(arena, expr_ref, e);

    let final_expr_ref: i32 = expr_ref;
    if (res.return_expr_ref != 0) {
      final_expr_ref = res.return_expr_ref;
    }
    if (res.has_mul && !res.has_binop) {
      let mul_right_ref: i32 = ast_arena_expr_alloc(arena);
      if (mul_right_ref == 0) {
        return ParseIntoResult { ok: -1, main_idx: -1 }
      }
      let mre: Expr = ast_arena_expr_get(arena, mul_right_ref);
      mre.kind = ExprKind.EXPR_LIT;
      mre.resolved_type_ref = type_ref;
      mre.line = 0;
      mre.col = 0;
      mre.int_val = res.mul_right_val;
      mre.binop_left_ref = 0;
      mre.binop_right_ref = 0;
      mre.unary_operand_ref = 0;
      mre.if_cond_ref = 0;
      mre.if_then_ref = 0;
      mre.if_else_ref = 0;
      mre.block_ref = 0;
      mre.match_matched_ref = 0;
      mre.match_num_arms = 0;
      ast.expr_init_match_enum(&mre);
      mre.field_access_base_ref = 0;
      mre.field_access_field_len = 0;
      mre.field_access_is_enum_variant = 0;
      mre.field_access_offset = 0;
      mre.index_base_ref = 0;
