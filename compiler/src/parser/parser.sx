/** 判断是否为复合赋值 token（+= … >>=）；10 路 if 链（勿 || 长链，EMIT_HEAVY 曾 elf_ec=-1）。 */
function is_compound_assign_token(kind: TokenKind): bool {
  if (kind == TokenKind.TOKEN_PLUS_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_MINUS_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_STAR_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_SLASH_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_PERCENT_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_AMP_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_PIPE_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_CARET_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_LSHIFT_EQ) {
    return true;
  }
  if (kind == TokenKind.TOKEN_RSHIFT_EQ) {
    return true;
  }
  return false;
}

/** 映射实现见 pipeline_glue.c（C 内比对 TokenKind），避免 .sx typeck 对 `return ExprKind.*` 失败。 */
extern function compound_assign_token_to_expr_kind_from_glue(kind: TokenKind): ExprKind;

/** 复合赋值 token 映射到 ExprKind；EMIT_HEAVY 仍走 C glue（SU return ExprKind.* 曾 elf_ec=-1）。 */
function compound_assign_token_to_expr_kind(kind: TokenKind): ExprKind {
  return compound_assign_token_to_expr_kind_from_glue(kind);
}



