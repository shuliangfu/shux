// pipeline.su — 自举 9.1/9.2/5.3：纯 .su 编译流水线入口
//
// 职责：串联 解析 →（可选）按 import 加载 deps → 类型检查 → 代码生成；5.3 在 .su 内解析 import、按需加载并 parse_into。
// 依赖：ast、parser（parse_into、get_module_num_imports、get_module_import_path）、typeck、codegen、std.fs。
// 与 C 关系：6.1 resolve/read/preprocess 全在 .su（std.fs + preprocess_su_buf）；仅 parse 需从 buf+len 组 slice，保留 1 个 C 桥接。

import ast;
import lexer;
import parser;
import typeck;
import codegen;
import std.fs;
import preprocess;
import asm;

/** C 按需提供第 i 个依赖的 arena/module 缓冲（0≤i<32），pipeline 在解析 import 前取回并写入 ctx，避免 ctx.dep_arenas[i] 为空导致 ast_arena_init 写空指针。 */
extern function driver_dep_arena_buf(i: i32): *u8;
extern function driver_dep_module_buf(i: i32): *u8;
/** 非 0 表示 dep i 已由 C 侧预填，跳过 read/parse 直接使用 driver 槽位。 */
extern function driver_dep_seeded_get(i: i32): i32;
/** 当前 dep 个数（与 ctx.ndep 同步，由 C 在 codegen 前设置）；循环中用 get_ndep() 从源头避免 build 对 while (j < ndep) 的补丁。 */
extern function get_ndep(): i32;

/* codegen.su 的 -E-extern 生成 C 时不自动扫描间接调用，以下显式声明 pipeline 内调用的外部函数。 */
extern function parser_parse_one_function_impl(out: *OneFuncResult, arena: *ASTArena, lex: Lexer, source: []u8): void;
extern function ast_ast_arena_init(arena: *ASTArena): void;
extern function asm_asm_codegen_ast(module: *Module, arena: *ASTArena, out_buf: *CodegenOutBuf, ctx: *PipelineDepCtx): i32;

/** 阶段 6.1 完全自举：resolve、read、preprocess、parse 全在 .su；pipeline_parse_into_buf 调 parser.parse_into_buf，不再依赖 C。 */

/** 将 (buf, buf_len) 传入 parser.parse_into_buf，返回 0 成功 -1 失败。调用前由 C 或调用方保证 arena/module 可用；此处先 parse_into_init 再解析。 */
function pipeline_parse_into_buf(arena: *ASTArena, module: *Module, buf: [262144]u8, buf_len: i32): i32 {
  parser.parse_into_init(module, arena);
  let res: ParseIntoResult = parser.parse_into_buf(arena, module, &buf[0], buf_len);
  if (res.ok != 0) {
    return -1;
  }
  return 0;
}

/** 6.1：将 buf[0..len-1] 复制到 ctx.path_buf[off..]，返回 off+len；不越界检查由调用方保证。 */
function path_append_from_buf_256(ctx: *PipelineDepCtx, off: i32, buf: [256]u8, len: i32): i32 {
  let k: i32 = 0;
  while (k < len && off < 508) {
    ctx.path_buf[off] = buf[k];
    off = off + 1;
    k = k + 1;
  }
  return off;
}
/** 6.1：同 path_append_from_buf_256，用于 entry_dir [512]u8。 */
function path_append_from_buf_512(ctx: *PipelineDepCtx, off: i32, buf: [512]u8, len: i32): i32 {
  let k: i32 = 0;
  while (k < len && off < 508) {
    ctx.path_buf[off] = buf[k];
    off = off + 1;
    k = k + 1;
  }
  return off;
}

/** 6.1：将 import_path[0..path_len-1] 中 '.' 换为 '/' 追加到 ctx.path_buf[off..]，返回新 off。 */
function path_append_import_path(ctx: *PipelineDepCtx, off: i32, import_path: [64]u8, path_len: i32): i32 {
  let k: i32 = 0;
  while (k < path_len && off < 508) {
    if (import_path[k] == 46) {
      ctx.path_buf[off] = 47;
    } else {
      ctx.path_buf[off] = import_path[k];
    }
    off = off + 1;
    k = k + 1;
  }
  return off;
}

/** 6.1：按 lib_roots 与 entry_dir 解析 import 路径，将结果写入 ctx.path_buf（含结尾 0），返回 0 成功 -1 失败。使用 std.fs open 探测存在。 */
function resolve_path_su(ctx: *PipelineDepCtx, import_path: [64]u8, path_len: i32): i32 {
  let r: i32 = 0;
  while (r < ctx.num_lib_roots && r < 8) {
    let off: i32 = 0;
    if (ctx.lib_root_lens[r] > 0) {
      off = path_append_from_buf_256(ctx, 0, ctx.lib_root_bufs[r], ctx.lib_root_lens[r]);
    }
    if (off < 509) {
      ctx.path_buf[off] = 47;
      off = off + 1;
    }
    off = path_append_import_path(ctx, off, import_path, path_len);
    if (off + 4 <= 512) {
      ctx.path_buf[off] = 46;
      ctx.path_buf[off + 1] = 115;
      ctx.path_buf[off + 2] = 117;
      ctx.path_buf[off + 3] = 0;
      let fd: i32 = fs_open_read(ctx.path_buf);
      if (fd >= 0) {
        fs_close(fd);
        return 0;
      }
      /* import std.fs 等约定为目录下 mod.su（如 std/fs/mod.su），.su 不存在时尝试 path/mod.su */
      if (off + 8 <= 512) {
        ctx.path_buf[off] = 47;
        ctx.path_buf[off + 1] = 109;
        ctx.path_buf[off + 2] = 111;
        ctx.path_buf[off + 3] = 100;
        ctx.path_buf[off + 4] = 46;
        ctx.path_buf[off + 5] = 115;
        ctx.path_buf[off + 6] = 117;
        ctx.path_buf[off + 7] = 0;
        let fd_mod: i32 = fs_open_read(ctx.path_buf);
        if (fd_mod >= 0) {
          fs_close(fd_mod);
          return 0;
        }
      }
      /* 单段 import（如 preprocess）：尝试 lib_root/import/import.su（如 src/preprocess/preprocess.su 当 lib_root=src） */
      if (path_len > 0 && path_len < 64) {
        let has_dot: i32 = 0;
        let k: i32 = 0;
        while (k < path_len) { if (import_path[k] == 46) { has_dot = 1; } k = k + 1; }
        if (has_dot == 0) {
          let off_base: i32 = 0;
          if (ctx.lib_root_lens[r] > 0) {
            off_base = path_append_from_buf_256(ctx, 0, ctx.lib_root_bufs[r], ctx.lib_root_lens[r]);
          }
          if (off_base < 509) {
            ctx.path_buf[off_base] = 47;
            off_base = off_base + 1;
          }
          off_base = path_append_import_path(ctx, off_base, import_path, path_len);
          if (off_base < 509) {
            ctx.path_buf[off_base] = 47;
            off_base = off_base + 1;
          }
          off_base = path_append_import_path(ctx, off_base, import_path, path_len);
          if (off_base + 4 <= 512) {
            ctx.path_buf[off_base] = 46;
            ctx.path_buf[off_base + 1] = 115;
            ctx.path_buf[off_base + 2] = 117;
            ctx.path_buf[off_base + 3] = 0;
            let fd_dir: i32 = fs_open_read(ctx.path_buf);
            if (fd_dir >= 0) {
              fs_close(fd_dir);
              return 0;
            }
          }
        }
      }
    }
    r = r + 1;
  }
  if (ctx.entry_dir_len > 0) {
    let has_dot: i32 = 0;
    let k: i32 = 0;
    while (k < path_len && k < 64) {
      if (import_path[k] == 46) {
        has_dot = 1;
      }
      k = k + 1;
    }
    if (has_dot == 0) {
      let off: i32 = path_append_from_buf_512(ctx, 0, ctx.entry_dir_buf, ctx.entry_dir_len);
      if (off < 509) {
        ctx.path_buf[off] = 47;
        off = off + 1;
      }
      off = path_append_import_path(ctx, off, import_path, path_len);
      if (off + 4 <= 512) {
        ctx.path_buf[off] = 46;
        ctx.path_buf[off + 1] = 115;
        ctx.path_buf[off + 2] = 117;
        ctx.path_buf[off + 3] = 0;
        let fd: i32 = fs_open_read(ctx.path_buf);
        if (fd >= 0) {
          fs_close(fd);
          return 0;
        }
        /* import std.fs 等约定为目录下 mod.su，.su 不存在时尝试 path/mod.su */
        if (off + 8 <= 512) {
          ctx.path_buf[off] = 47;
          ctx.path_buf[off + 1] = 109;
          ctx.path_buf[off + 2] = 111;
          ctx.path_buf[off + 3] = 100;
          ctx.path_buf[off + 4] = 46;
          ctx.path_buf[off + 5] = 115;
          ctx.path_buf[off + 6] = 117;
          ctx.path_buf[off + 7] = 0;
          let fd_mod: i32 = fs_open_read(ctx.path_buf);
          if (fd_mod >= 0) {
            fs_close(fd_mod);
            return 0;
          }
        }
      }
    }
  }
  return -1;
}

/** 6.1：将 ctx.path_buf 指向的文件读入 ctx.loaded_buf，设置 ctx.loaded_len（isize），返回 0 成功 -1 失败。纯 .su + std.fs。 */
function read_file_su(ctx: *PipelineDepCtx): i32 {
  let fd: i32 = fs_open_read(ctx.path_buf);
  if (fd < 0) {
    return -1;
  }
  let cap: usize = 262144;
  let n: isize = fs_read(fd, ctx.loaded_buf, cap);
  fs_close(fd);
  if (n < 0) {
    return -1;
  }
  ctx.loaded_len = n;
  return 0;
}

/**
 * 诊断用：仅调用 parse_one_function_impl(lexer_init(), source)，返回 res.ok 的整型（1 成功，0 失败）。
 * arena 用于解析 let 时构建 init 表达式；调用方（如 C 诊断路径）传入临时 arena 即可。
 */
function parse_one_function_ok(source: []u8, arena: *ASTArena): i32 {
  let lex: Lexer = lexer_init();
  let empty64: [64]u8 = [];
  let empty32: [32]u8 = [];
  let dummy_let_refs: [24]i32 = [];
  let dummy_loop_refs: [8]i32 = [];
  let dummy_for_refs: [8]i32 = [];
  let dummy_call_arg_vals: [16]i32 = [];
  let dummy_pnames: [16][32]u8 = [empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32, empty32];
  let dummy_plens: [16]i32 = [];
  let dummy_ptrefs: [16]i32 = [];
  let dummy_const_names: [24][64]u8 = [empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64];
  let dummy_const_lens: [24]i32 = [];
  let dummy_const_vals: [24]i32 = [];
  let dummy_let_names: [24][64]u8 = [empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64, empty64];
  let dummy_let_lens: [24]i32 = [];
  let dummy_let_vals: [24]i32 = [];
  let res: OneFuncResult = OneFuncResult { ok: false, next_lex: lex, name: empty64, name_len: 0, num_params: 0, param_names: dummy_pnames, param_name_lens: dummy_plens, param_type_refs: dummy_ptrefs, num_consts: 0, const_names: dummy_const_names, const_name_lens: dummy_const_lens, const_init_vals: dummy_const_vals, num_lets: 0, let_names: dummy_let_names, let_name_lens: dummy_let_lens, let_init_vals: dummy_let_vals, let_init_refs: dummy_let_refs, has_if_expr: false, if_cond_true: false, if_then_val: 0, if_else_val: 0, has_mul: false, mul_right_val: 0, has_binop: false, binop_right_val: 0, binop_left_param_idx: -1, binop_right_param_idx: -1, has_unary_neg: false, return_val: 0, has_call_expr: false, call_callee_name: empty64, call_callee_len: 0, call_num_args: 0, call_arg_vals: dummy_call_arg_vals, num_loops: 0, loop_cond_refs: dummy_loop_refs, loop_body_refs: dummy_loop_refs, num_for_loops: 0, for_init_refs: dummy_for_refs, for_cond_refs: dummy_for_refs, for_step_refs: dummy_for_refs, for_body_refs: dummy_for_refs };
  parser.parse_one_function_impl(&res, arena, lex, source);
  if (res.ok) {
    return 1;
  }
  return 0;
}

/**
 * 先 init 再 parse_into，返回结果。arena 显式在此处初始化，避免 codegen 将 run_su_pipeline_impl 中的 init 移到 parse 之后导致 type_alloc 读到未清零的 num_types。
 */
function parse_into_with_init(arena: *ASTArena, module: *Module, source: []u8): ParseIntoResult {
  ast.ast_arena_init(arena);
  parse_into_init(module, arena);
  return parse_into(arena, module, source);
}

/** 以 (data, len) 解析入口，避免 C 传 slice 与 .su []u8 布局不一致；供 run_su_pipeline_impl 在 C 传 (data, len) 时使用。 */
function parse_into_with_init_buf(arena: *ASTArena, module: *Module, data: *u8, len: i32): ParseIntoResult {
  ast.ast_arena_init(arena);
  parse_into_init(module, arena);
  return parser.parse_into_buf(arena, module, data, len);
}

/**
 * 诊断用：parse_into_with_init + set_main_index 后跑 typeck；库模块（无 main）走 typeck_su_ast_library，否则 typeck_su_ast。与 run_su_pipeline_impl 一致，-backend asm -o xxx.o 编库模块依赖此路径。
 */
function typeck_after_parse_ok(arena: *ASTArena, module: *Module, source: []u8, ctx: *PipelineDepCtx): i32 {
  let r: ParseIntoResult = parse_into_with_init(arena, module, source);
  if (r.ok != 0) {
    return r.main_idx;
  }
  parse_into_set_main_index(module, r.main_idx);
  if (module.main_func_index < 0) {
    return typeck_su_ast_library(module, arena, ctx);
  }
  return typeck_su_ast(module, arena, ctx);
}

/** C 诊断：parse 失败时打印 main_idx、num_funcs、arena_num_types（-1001 时便于确认 arena 是否已满）。由 runtime.c 实现。 */
extern function driver_diagnostic_parse_fail(main_idx: i32, num_funcs: i32, arena_num_types: i32): void;
/** C 诊断：codegen 前打印 module.num_funcs、out_buf.len，便于排查 -su -E 多文件 dep 产出为空。由 runtime.c 实现。 */
extern function driver_diagnostic_before_codegen(num_funcs: i32, out_len: i32): void;
/** C 诊断：每个 dep codegen 后打印 j 与 out_buf.len，确认是否递增。由 runtime.c 实现。 */
extern function driver_diagnostic_after_dep_codegen(j: i32, out_len: i32): void;
extern function driver_diagnostic_codegen_fail(dep_index: i32, is_dep: i32): void;
/** 非 0 时跳过 dep 0 的 codegen（-o 时 C 设，driver 由 io.o 提供）；用 extern 避免与 ctx 布局耦合。 */
extern function driver_skip_codegen_dep_0_get(): i32;
/** 诊断：pipeline 入口打印 ctx.entry_already_parsed（非 0 则跳过解析）。由 runtime.c 实现。 */
extern function driver_diagnostic_entry_already(v: i32): void;
/** 诊断：解析前打印 source_len（0 表示无源码）。由 runtime.c 实现。 */
extern function driver_diagnostic_source_len(len: i32): void;
/** 诊断：entry 解析后打印 module.num_funcs（0 表示未解析）。由 runtime.c 实现。 */
extern function driver_diagnostic_after_entry_parse(num_funcs: i32): void;
/** 诊断：解析 entry 后打印 module 的 main body_ref，便于排查 main 空体。由 pipeline_glue.c 实现。 */
extern function driver_diagnostic_entry_module(module: *Module, arena: *ASTArena): void;
/** 设置当前 codegen 的 dep 路径，供 codegen 生成 C 符号前缀（如 std_io_driver_）；传 0 表示清除。由 runtime.c 实现。 */
extern function driver_set_current_dep_path_for_codegen(path: *u8): void;

/**
 * 从源码到 C 的完整 .su 流水线；5.3/6.1 编排逻辑全在此处，dep 通过 ctx 传入，C 只提供 resolve/read/parse_into 原语。
 * 形参顺序 (module, arena) 与 driver 调用 (module_buf, arena_buf) 一致；source 以 (data, len) 传入并用 parse_into_with_init_buf 解析，避免 C 与 .su 的 []u8 布局不一致导致 entry 解析得 num_funcs=0。
 * 函数名 run_su_pipeline_impl 与 main.su extern 一致，避免 Makefile 对 -E 产出做重命名补丁。
 */
function run_su_pipeline_impl(module: *Module, arena: *ASTArena, source_data: *u8, source_len: usize, out_buf: *CodegenOutBuf, ctx: *PipelineDepCtx): i32 {
  driver_diagnostic_entry_already(ctx.entry_already_parsed);
  if (ctx.entry_already_parsed == 0) {
    let len_i32: i32 = (source_len) as i32;
    driver_diagnostic_source_len(len_i32);
    let r: ParseIntoResult = parse_into_with_init_buf(arena, module, source_data, len_i32);
    if (r.ok != 0) {
      driver_diagnostic_parse_fail(r.main_idx, module.num_funcs, arena.num_types);
      return -2;
    }
    parse_into_set_main_index(module, r.main_idx);
  }
  driver_diagnostic_after_entry_parse(module.num_funcs);
  driver_diagnostic_entry_module(module, arena);
  let n_imports: i32 = get_module_num_imports(module);
  /* C 已填 ctx.ndep（如 driver_run_compiler_full 的 pctx.ndep）时不再用 n_imports 覆盖，保证 codegen 阶段遍历全部传递依赖。 */
  if (ctx.ndep == 0) {
    ctx.ndep = 0;
  if (n_imports > 0) {
    let i: i32 = 0;
    while (i < n_imports) {
      if (i >= 32) {
        return -1;
      }
      if (driver_dep_seeded_get(i) != 0) {
        /* C 侧已预填 dep i，直接使用 driver 槽位，不 resolve/read/parse。 */
        ctx.dep_arenas[i] = (driver_dep_arena_buf(i)) as *ASTArena;
        ctx.dep_modules[i] = (driver_dep_module_buf(i)) as *Module;
      } else {
        let path_buf: [64]u8 = [];
        get_module_import_path(module, i, path_buf);
        let path_len: i32 = 0;
        while (path_len < 64 && path_buf[path_len] != 0) {
          path_len = path_len + 1;
        }
        if (resolve_path_su(ctx, path_buf, path_len) != 0) {
          return -7;
        }
        if (read_file_su(ctx) != 0) {
          return -8;
        }
        let out_len: i32 = preprocess_su_buf(ctx.loaded_buf, ctx.loaded_len, ctx.preprocess_buf, 262144);
        if (out_len < 0) {
          return -9;
        }
        ctx.preprocess_len = out_len;
        ctx.dep_arenas[i] = (driver_dep_arena_buf(i)) as *ASTArena;
        ctx.dep_modules[i] = (driver_dep_module_buf(i)) as *Module;
        let dep_arena: *ASTArena = ctx.dep_arenas[i];
        let dep_module: *Module = ctx.dep_modules[i];
        if (pipeline_parse_into_buf(dep_arena, dep_module, ctx.preprocess_buf, ctx.preprocess_len) != 0) {
          return -10;
        }
      }
      i = i + 1;
    }
    ctx.ndep = n_imports;
  }
  }
  /* 失败时传播具体码：-5 库 typeck，-6 代码生成，便于诊断。 */
  if (module.main_func_index < 0) {
    let tc: i32 = typeck_su_ast_library(module, arena, ctx);
    if (tc != 0) {
      return tc;
    }
  } else {
    if (typeck_su_ast(module, arena, ctx) != 0) {
      return -1;
    }
  }
  out_buf.len = 0;
  driver_diagnostic_before_codegen(module.num_funcs, out_buf.len);
  let j: i32 = 0;
  while (j < ctx.ndep) {
    if (j >= 32) {
      break;
    }
    if (j == 0 && driver_skip_codegen_dep_0_get() != 0) {
      j = j + 1;
      continue;
    }
    /* .su 驱动路径下自行加载 deps 时未填 ctx.dep_paths，此处用 entry 的 j 号 import 路径补全，供 codegen 生成正确 C 前缀（如 std_io_）。 */
    if (ctx.dep_paths[j] == 0 as *u8) {
      let path_buf: [64]u8 = [];
      get_module_import_path(module, j, path_buf);
      let k: i32 = 0;
      while (k < 64) {
        ctx.path_buf[k] = path_buf[k];
        k = k + 1;
      }
      ctx.dep_paths[j] = &ctx.path_buf[0];
    }
    /* 仅对含函数的 dep 做代码生成，num_funcs==0 的库模块（如仅 extern/struct 的 std.io.core）跳过避免 codegen 返回 -1；设置当前 dep 路径供 codegen 加 C 符号前缀。 */
    let dep_mod: *Module = ctx.dep_modules[j];
    driver_set_current_dep_path_for_codegen(ctx.dep_paths[j]);
    if (dep_mod.num_funcs > 0) {
      if (ctx.use_asm_backend != 0) {
        if (asm.asm_codegen_ast(dep_mod, ctx.dep_arenas[j], out_buf, ctx) != 0) {
          driver_diagnostic_codegen_fail(j, 1);
          return -6;
        }
      } else {
        if (codegen_su_ast(dep_mod, ctx.dep_arenas[j], out_buf, ctx, j) != 0) {
          driver_diagnostic_codegen_fail(j, 1);
          return -6;
        }
      }
    }
    driver_diagnostic_after_dep_codegen(j, out_buf.len);
    driver_set_current_dep_path_for_codegen(0 as *u8);
    j = j + 1;
  }
  driver_diagnostic_entry_module(module, arena);
  if (ctx.use_asm_backend != 0) {
    if (asm.asm_codegen_ast(module, arena, out_buf, ctx) != 0) {
      driver_diagnostic_codegen_fail(0, 0);
      return -6;
    }
  } else {
    let main_dep_index: i32 = -1;
    if (codegen_su_ast(module, arena, out_buf, ctx, main_dep_index) != 0) {
      driver_diagnostic_codegen_fail(0, 0);
      return -6;
    }
  }
  return 0;
}
