function pipeline_typeck_parsed_module(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx, fail_mapped: i32): i32 {
  if (module == 0 as *Module || arena == 0 as *ASTArena || ctx == 0 as *PipelineDepCtx) {
    return pipeline_typeck_null_fail_return_c(fail_mapped);
  }
  if (pipeline_module_main_func_index(module) < 0) {
    if (typeck_typeck_sx_ast_library(module, arena, ctx) != 0) {
      return pipeline_typeck_fail_return_c(fail_mapped);
    }
    if (pipeline_typeck_scan_module_struct_stack_escape_c(module, arena, ctx) != 0) {
      return pipeline_typeck_fail_return_c(fail_mapped);
    }
    return 0;
  }
  if (typeck_typeck_sx_ast(module, arena, ctx) != 0) {
    return pipeline_typeck_fail_return_c(fail_mapped);
  }
  if (pipeline_typeck_scan_module_struct_stack_escape_c(module, arena, ctx) != 0) {
    return pipeline_typeck_fail_return_c(fail_mapped);
  }
  return 0;
}

