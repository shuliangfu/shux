  driver_diagnostic_source_len(source_len as i32);
  if (pipeline_parse_set_main_from_buf(module, arena, source_data, source_len as i32) != 0) {
    return -2;
  }
  driver_diagnostic_after_entry_parse(pipeline_module_num_funcs(module));
  driver_diagnostic_entry_module(module, arena);
  return 0;
