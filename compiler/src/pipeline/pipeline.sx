 */
function pipeline_load_import_from_disk(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx, import_idx: i32): i32 {
  if (module == 0 as *Module || arena == 0 as *ASTArena || ctx == 0 as *PipelineDepCtx || import_idx < 0) {
    return -1;
  }
  let path_buf: u8[64] = [0];
  parser_copy_module_import_path64(module, import_idx, &path_buf[0]);
  if (pipeline_resolve_path_sx_from_buf64_c(ctx, &path_buf[0]) != 0) {
    return -7;
  }
  if (read_file_sx(ctx) != 0) {
    return -8;
  }
  if (pipeline_preprocess_loaded_into_ctx(ctx) != 0) {
    return -9;
  }
  pipeline_bind_import_dep_buffers(ctx, import_idx);
  /** EMIT_HEAVY：parse 实参内联 arena_at/module_at/preprocess ptr+len；勿 let dep_mod。 */
  if (pipeline_parse_into_buf(pipeline_dep_ctx_arena_at(ctx, import_idx), pipeline_dep_ctx_module_at(ctx, import_idx), pipeline_dep_ctx_preprocess_buf_ptr(ctx), pipeline_dep_ctx_preprocess_len_get(ctx)) != 0) {
    return -10;
  }
  return 0;
}

/**
 * 装载单个 import 槽：已 seed 则 bind，否则 load_import_from_disk；EMIT_HEAVY SX 真 emit。
 */
function pipeline_load_one_import_slot(module: *Module, arena: *ASTArena, ctx: *PipelineDepCtx, import_idx: i32): i32 {
  if (module == 0 as *Module || arena == 0 as *ASTArena || ctx == 0 as *PipelineDepCtx || import_idx < 0) {
