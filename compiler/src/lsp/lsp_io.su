// lsp_io.su — LSP 用 std.io / std.heap 实现的读写、读消息、文档缓冲与 JSON
// 响应构建（替代 lsp_io.c 中对应逻辑）
//
// 职责：从 stdin 读 LSP 消息（Content-Length + body）、向 stdout
// 写；维护当前文档缓冲；从 JSON 提取 text、
// 构建 InitializeResult 与 JSON-RPC 响应外壳；alloc/free 使用
// std.heap。诊断/definition/references/hover 仍由 lsp_diag.c 提供。
// 全部用 .su 实现，仅用数组下标与变量索引，不依赖任何 C 辅助函数。

import std.io;
import std.heap;

/** 文档变更时使诊断缓存失效；由 lsp_diag.c 提供。 */
extern function lsp_diag_invalidate_cache(): void;

/** 单条消息 body 安全上限（64MB），与 lsp.su 中 LSP_BODY_CAP 一致。 */
let LSP_BODY_SAFETY_CAP: i32 = 67108864;

/** leftover 从 state_buf 起始存放；长度放在 buffer 末尾，避免与可能相邻的
* out_buf 等重叠被零写。 */
let LSP_STATE_LEFTOVER_OFF: i32 = 0;
let LSP_STATE_LEFTOVER_MAX: i32 = 8192 * 2;
let LSP_STATE_LEN_OFF: i32 = 8192 * 2;

/** 调试：LSP_READ_DEBUG 时打 leftover 长度（仅 n>0），由 lsp_diag 提供。 */
extern function lsp_debug_u32(n: u32): void;
/** 调试：打 state 指针。 */
extern function lsp_debug_ptr(p: *u8): void;

/** 从 fd（0=stdin）读取一条 LSP 消息到 body_out，返回 body 长度；失败/EOF 返回
* -1。state_buf 布局：state_buf[0..LSP_STATE_LEFTOVER_MAX-1] 为 leftover
* 内容，state_buf[LSP_STATE_LEN_OFF..LSP_STATE_LEN_OFF+3] 为 leftover 长度（小端）；仅用
* state_buf[i] 与 &state_buf[expr]，无指针运算。 */
function read_message(fd: i32, body_out: *u8, body_cap: i32, state_buf: *u8): isize {
  let h: usize = 0 as usize;
  if (fd != 0) { return -1; }
  let b0: u8 = state_buf[LSP_STATE_LEN_OFF];
  let b1: u8 = state_buf[LSP_STATE_LEN_OFF + 1];
  let b2: u8 = state_buf[LSP_STATE_LEN_OFF + 2];
  let b3: u8 = state_buf[LSP_STATE_LEN_OFF + 3];
  /* 小端 4 字节合成 i32；用中间变量避免 codegen 生成 C 时丢掉括号导致 <<
  与 + 优先级错误 */
  let n0: i32 = b0 as i32;
  let n1: i32 = (b1 as i32) << 8;
  let n2: i32 = (b2 as i32) << 16;
  let n3: i32 = (b3 as i32) << 24;
  let n: i32 = n0 + n1 + n2 + n3;
  if (n < 0 || n > LSP_STATE_LEFTOVER_MAX) {
    n = 0;
  }
  lsp_debug_ptr(state_buf);
  if (n > 0) {
    lsp_debug_u32(n as u32);
  }
  /* 循环读直到缓冲区满或 EOF/错误，避免部分环境一次 read
  只返回首条消息长度导致后续 n=0 即退出 */
  if (n < LSP_STATE_LEFTOVER_MAX) {
    while (n < LSP_STATE_LEFTOVER_MAX) {
      let got: i32 = std.io.read(h, &state_buf[n], (LSP_STATE_LEFTOVER_MAX - n) as usize, 0 as u32);
      if (got > 0) {
        n = n + got;
      } else {
        break;
      }
    }
  }
  if (n <= 0) {
    return -1;
  }
  let i: i32 = 0;
  while (i + 4 <= n) {
    if (state_buf[i] == 13 && state_buf[i + 1] == 10 && state_buf[i + 2] == 13 && state_buf[i + 3]
    == 10) {
      break;
    }
    i = i + 1;
  }
  if (i + 4 > n) {
    return -1;
  }
  let header_end: i32 = i + 4;
  let content_len: i32 = parse_content_length_in_buf(state_buf, 0, header_end);
  if (content_len <= 0 || content_len > body_cap || content_len > LSP_BODY_SAFETY_CAP) {
    return -1;
  }
  let body_in_buf: i32 = n - header_end;
  let to_copy: i32 = if (body_in_buf > content_len) { content_len } else { body_in_buf };
  let j: i32 = 0;
  while (j < to_copy) {
    body_out[j] = state_buf[header_end + j];
    j = j + 1;
  }
  if (content_len > to_copy) {
    let remain: i32 = content_len - to_copy;
    let r: i32 = std.io.read(h, &state_buf[0], remain as usize, 0 as u32);
    if (r != remain) {
      return -1;
    }
    let j2: i32 = 0;
    while (j2 < remain) {
      body_out[to_copy + j2] = state_buf[j2];
      j2 = j2 + 1;
    }
  }
  let consumed: i32 = header_end + content_len;
  let new_n: i32 = n - consumed;
  if (new_n > 0) {
    let k: i32 = 0;
    while (k < new_n) {
      state_buf[k] = state_buf[consumed + k];
      k = k + 1;
    }
    state_buf[LSP_STATE_LEN_OFF] = (new_n & 255) as u8;
    state_buf[LSP_STATE_LEN_OFF + 1] = ((new_n >> 8) & 255) as u8;
    state_buf[LSP_STATE_LEN_OFF + 2] = ((new_n >> 16) & 255) as u8;
    state_buf[LSP_STATE_LEN_OFF + 3] = ((new_n >> 24) & 255) as u8;
    lsp_debug_u32((new_n as u32)); /* 调试：写入的 leftover 长度，LSP_READ_DEBUG 时打
    "leftover n=821" */
  } else {
    state_buf[LSP_STATE_LEN_OFF] = 0;
    state_buf[LSP_STATE_LEN_OFF + 1] = 0;
    state_buf[LSP_STATE_LEN_OFF + 2] = 0;
    state_buf[LSP_STATE_LEN_OFF + 3] = 0;
  }
  return content_len as isize;
}

/** 在 state_buf[off..off+header_end) 中解析 "Content-Length: "
* 后的数字；允许冒号后有多余空白（如 BSD wc -c 产生的前导空格）。 */
function parse_content_length_in_buf(state_buf: *u8, off: i32, header_end: i32): i32 {
  if (header_end < 16) { return -1; }
  let key: [16]u8 = [67, 111, 110, 116, 101, 110, 116, 45, 76, 101, 110, 103, 116, 104, 58, 32];
  let ki: i32 = 0;
  while (ki < 16) {
    if (state_buf[off + ki] != key[ki]) { return -1; }
    ki = ki + 1;
  }
  let val: i32 = 0;
  let i: i32 = 16;
  /* 跳过冒号后的可选空白（空格 \t 等），兼容 "Content-Length:
  107"；括号保证先判 i < header_end 再读字节，避免 codegen 后 C 的 &&/||
  优先级导致越界 */
  while (i < header_end) {
    let c0: u8 = state_buf[off + i];
    if (c0 != 32 && c0 != 9) { break; }
    i = i + 1;
  }
  while (i < header_end) {
    let c: u8 = state_buf[off + i];
    if (c >= 48 && c <= 57) {
      val = val * 10 + (c as i32) - 48;
      i = i + 1;
    } else {
      break;
    }
  }
  return val;
}

/** 向 fd（1=stdout）写 ptr[0..count-1]；返回写入字节数，-1 错误。 */
function write_fd(fd: i32, ptr: *u8, count: usize): isize {
  let h: usize = 1 as usize;
  if (fd != 1) { return (-1) as isize; }
  let r: i32 = std.io.write(h, ptr, count, 0 as u32);
  if (r < 0) { return (-1) as isize; }
  return r as isize;
}

/** 从 body 中找 "text":" 并取其后 JSON 字符串到 out_buf（做 \", \\, \n, \r, \t
* 反义）；返回长度，失败 -1。全部用 body[i]、out_buf[i] 下标。 */
function extract_document_text(body: *u8, body_len: i32, out_buf: *u8, out_cap: i32): i32 {
  let key_len: i32 = 8;
  let key: [8]u8 = [34, 116, 101, 120, 116, 34, 58, 34];
  let i: i32 = 0;
  while (i + key_len <= body_len) {
    let is_match: i32 = 1;
    let k: i32 = 0;
    while (k < key_len) {
      if (body[i + k] != key[k]) { is_match = 0; break; }
      k = k + 1;
    }
    if (is_match != 0) {
      let start: i32 = i + key_len;
      let out_len: i32 = 0;
      while (start < body_len && out_len < out_cap - 1) {
        let c: u8 = body[start];
        if (c == 34) {
          break;
        }
        if (c == 92 && start + 1 < body_len) {
          start = start + 1;
          let next: u8 = body[start];
          if (next == 110) { out_buf[out_len] = 10; out_len = out_len + 1; start = start + 1;
            continue; }
          if (next == 114) { out_buf[out_len] = 13; out_len = out_len + 1; start = start + 1;
            continue; }
          if (next == 116) { out_buf[out_len] = 9; out_len = out_len + 1; start = start + 1;
            continue; }
          if (next == 34 || next == 92) { out_buf[out_len] = next; out_len = out_len + 1; start =
            start + 1; continue; }
          out_buf[out_len] = next;
          out_len = out_len + 1;
          start = start + 1;
          continue;
        }
        out_buf[out_len] = c;
        out_len = out_len + 1;
        start = start + 1;
      }
      out_buf[out_len] = 0;
      return out_len;
    }
    i = i + 1;
  }
  return -1;
}

/** build_response_with_result 仍由 lsp_io.c 提供，供 C 内 build_definition 等与 lsp.su
* 共用。 */

/** 分配 size 字节；失败返回 0。 */
function lsp_alloc(size: usize): *u8 {
  if (size == 0 || size > (LSP_BODY_SAFETY_CAP as usize)) { return 0 as *u8; }
  return std.heap.alloc(size);
}

/** 释放由 lsp_alloc 得到的指针。 */
function lsp_free(ptr: *u8): void {
  std.heap.free(ptr);
}

/** 判断指针是否为空（1=空，0=非空）。 */
function lsp_is_null(ptr: *u8): i32 {
  if (ptr == 0 as *u8) { return 1; }
  return 0;
}
