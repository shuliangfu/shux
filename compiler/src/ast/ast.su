  let blk: Block = ast_arena_block_get(a, br);
  if (wi >= blk.num_loops) {
    return 0;
  }
  return blk.loops[wi].cond_ref;
}

function ast_block_while_body_ref(a: *ASTArena, br: i32, wi: i32): i32 {
