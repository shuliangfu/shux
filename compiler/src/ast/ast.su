function ast_block_if_cond_ref(a: *ASTArena, br: i32, ii: i32): i32 {
  if (br <= 0 || br > a.num_blocks || ii < 0 || ii >= 16) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (ii >= blk.num_if_stmts) {
    return 0;
  }
  return blk.if_stmts[ii].cond_ref;
}

function ast_block_if_then_body_ref(a: *ASTArena, br: i32, ii: i32): i32 {
  if (br <= 0 || br > a.num_blocks || ii < 0 || ii >= 16) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (ii >= blk.num_if_stmts) {
    return 0;
  }
  return blk.if_stmts[ii].then_body_ref;
}

/**
 * 在块内按 const/let 顺序解析局部名到类型池 ref；供 import ast 的模块避免 materialize Block 再取字段（无 StructLayout）。
 */
function ast_block_resolve_var_to_type_ref(a: *ASTArena, block_ref: i32, vname: *u8, vlen: i32): i32 {
  if (block_ref <= 0 || block_ref > a.num_blocks) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, block_ref);
  let i: i32 = 0;
  while (i < blk.num_consts && i < 256) {
    let cd: ConstDecl = blk.const_decls[i];
    if (!ref_is_null(cd.type_ref) && ast_name_bytes_equal(&cd.name[0], cd.name_len, vname, vlen)) {
      return cd.type_ref;
    }
    i = i + 1;
  }
  i = 0;
  while (i < blk.num_lets && i < 256) {
    let ld: LetDecl = blk.let_decls[i];
    if (!ref_is_null(ld.type_ref) && ast_name_bytes_equal(&ld.name[0], ld.name_len, vname, vlen)) {
      return ld.type_ref;
    }
    i = i + 1;
  }
  return 0;
}

/** 将 Block 节点写回池中 ref 槽位；ref 须为 1..num_blocks。用于 parser 构建 AST。 */
function ast_arena_block_set(arena: *ASTArena, ref: i32, b: Block): void {
  let idx: i32 = ref - 1;
  arena.blocks[idx] = b;
}

/** 在 Func 池中分配一个槽位，返回 1-based ref；已满（256）时返回 0。供 parse_into_buf 使用。 */
function ast_arena_func_alloc(arena: *ASTArena): i32 {
  if (arena.num_funcs >= 256) {
    return 0;
  }
  arena.num_funcs = arena.num_funcs + 1;
  return arena.num_funcs;
}

/** 按 ref 取 Func 池中节点（副本）；ref 须为 1..num_funcs。 */
function ast_arena_func_get(arena: *ASTArena, ref: i32): Func {
  let idx: i32 = ref - 1;
  return arena.funcs[idx];
}

/** 将 Func 节点写回池中 ref 槽位；ref 须为 1..num_funcs。用于 parser 构建 AST。 */
function ast_arena_func_set(arena: *ASTArena, ref: i32, f: Func): void {
  let idx: i32 = ref - 1;
  arena.funcs[idx] = f;
}
