  return blk.let_decls[li].type_ref;
}

function ast_block_expr_stmt_ref(a: *ASTArena, br: i32, ei: i32): i32 {
  if (br <= 0 || br > a.num_blocks || ei < 0 || ei >= 32) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (ei >= blk.num_expr_stmts) {
    return 0;
