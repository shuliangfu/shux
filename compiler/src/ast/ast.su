// ast.su — 纯 .su 抽象语法树（完全自举：不依赖 C 的 ast.h）
//
// 职责：定义编译器前端/中端/后端共用的 AST 节点类型，全部用 .su 的 struct/enum 表示。
// 与 C 的关系：无。不引用任何 C 头文件或 extern；parser/typeck/codegen 均基于本模块。
// 约定：.su 无 union，变体数据用独立字段；子节点用“池下标”表示，0 表示空（无子节点）。

/** 类型节点种类：与 C 的 ASTTypeKind 一一对应，供 typeck/codegen 使用 */
enum TypeKind {
  TYPE_I32,
  TYPE_BOOL,
  TYPE_U8,
  TYPE_U32,
  TYPE_U64,
  TYPE_I64,
  TYPE_USIZE,
  TYPE_ISIZE,
  TYPE_NAMED,
  TYPE_PTR,
  TYPE_ARRAY,
  TYPE_SLICE,
  TYPE_VECTOR,
  TYPE_F32,
  TYPE_F64,
  TYPE_VOID
}

/** 表达式节点种类：与 C 的 ASTExprKind 一一对应（须在 struct 前，因解析顺序为 enum* 再 struct*） */
enum ExprKind {
  EXPR_LIT,
  EXPR_FLOAT_LIT,
  EXPR_BOOL_LIT,
  EXPR_VAR,
  EXPR_ADD,
  EXPR_SUB,
  EXPR_MUL,
  EXPR_DIV,
  EXPR_MOD,
  EXPR_SHL,
  EXPR_SHR,
  EXPR_BITAND,
  EXPR_BITOR,
  EXPR_BITXOR,
  EXPR_EQ,
  EXPR_NE,
  EXPR_LT,
  EXPR_LE,
  EXPR_GT,
  EXPR_GE,
  EXPR_LOGAND,
  EXPR_LOGOR,
  EXPR_NEG,
  EXPR_BITNOT,
  EXPR_LOGNOT,
  EXPR_IF,
  EXPR_BLOCK,
  EXPR_TERNARY,
  EXPR_ASSIGN,
  /** 复合赋值：左值 op= 右值（+=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=）；复用 binop_left_ref/binop_right_ref */
  EXPR_ADD_ASSIGN,
  EXPR_SUB_ASSIGN,
  EXPR_MUL_ASSIGN,
  EXPR_DIV_ASSIGN,
  EXPR_MOD_ASSIGN,
  EXPR_BITAND_ASSIGN,
  EXPR_BITOR_ASSIGN,
  EXPR_BITXOR_ASSIGN,
  EXPR_SHL_ASSIGN,
  EXPR_SHR_ASSIGN,
  EXPR_BREAK,
  EXPR_CONTINUE,
  EXPR_RETURN,
  EXPR_PANIC,
  EXPR_MATCH,
  EXPR_FIELD_ACCESS,
  EXPR_STRUCT_LIT,
  EXPR_ARRAY_LIT,
  EXPR_INDEX,
  EXPR_CALL,
  EXPR_METHOD_CALL,
  EXPR_ENUM_VARIANT,
  /** 通用二元运算占位（parser 在 parse_into_buf 中先用 BINOP 再细分；与 EXPR_ADD/EXPR_MUL 等并存） */
  EXPR_BINOP,
  /** 类型转换 expr as type（operand + 目标类型在类型池） */
  EXPR_AS
}

/** 类型节点：kind + 具名类型名（NAMED 时）+ 元素类型下标（PTR/ARRAY/SLICE/VECTOR 时）+ 数组长度（ARRAY/VECTOR 时） */
struct Type {
  kind: TypeKind;
  name: [64]u8;
  name_len: i32;
  elem_type_ref: i32;
  array_size: i32;
}

/** 表达式节点（最小集）：.su 无 union，变体用独立字段；ref 为池下标，0 表示空。allow(padding) 满足 f64 对齐。 */
allow(padding) struct Expr {
  kind: ExprKind;
  resolved_type_ref: i32;
  line: i32;
  col: i32;
  int_val: i32;
  float_val: f64;
  var_name: [64]u8;
  var_name_len: i32;
  binop_left_ref: i32;
  binop_right_ref: i32;
  unary_operand_ref: i32;
  if_cond_ref: i32;
  if_then_ref: i32;
  if_else_ref: i32;
  block_ref: i32;
  match_matched_ref: i32;
  match_arm_result_refs: [16]i32;
  match_num_arms: i32;
  /** 每臂模式：is_wildcard=1 表示 _；否则用 lit_val 或（is_enum_variant=1 时）variant_index 比较。由 parser/typeck 填写。 */
  match_arm_is_wildcard: [16]i32;
  match_arm_lit_val: [16]i32;
  match_arm_is_enum_variant: [16]i32;
  match_arm_variant_index: [16]i32;
  field_access_base_ref: i32;
  field_access_field_name: [64]u8;
  field_access_field_len: i32;
  field_access_is_enum_variant: i32;
  /** 字段偏移（字节），由 typeck 从结构体布局填写；未设时为 0。 */
  field_access_offset: i32;
  index_base_ref: i32;
  index_index_ref: i32;
  index_base_is_slice: i32;
  call_callee_ref: i32;
  call_arg_refs: [16]i32;
  call_num_args: i32;
  method_call_base_ref: i32;
  method_call_name: [64]u8;
  method_call_name_len: i32;
  method_call_arg_refs: [16]i32;
  method_call_num_args: i32;
  const_folded_val: i32;
  const_folded_valid: i32;
  index_proven_in_bounds: i32;
  /** STRUCT_LIT：结构体类型名 + 字段（名 + 初值表达式 ref）；最多 8 个字段。 */
  struct_lit_struct_name: [64]u8;
  struct_lit_struct_name_len: i32;
  struct_lit_num_fields: i32;
  struct_lit_field_names: [8][64]u8;
  struct_lit_field_lens: [8]i32;
  struct_lit_init_refs: [8]i32;
  /** ARRAY_LIT：元素个数 + 各元素表达式 ref；最多 16 个元素。 */
  array_lit_num_elems: i32;
  array_lit_elem_refs: [16]i32;
  /** EXPR_FLOAT_LIT：double 的 64 位位模式，由 typeck/parser 填写（低 32 位、高 32 位），asm 用于 movq 立即数。 */
  float_bits_lo: i32;
  float_bits_hi: i32;
  /** EXPR_ENUM_VARIANT：变体 tag（0-based 序号），由 typeck 填写，asm 用于 ret 或比较。 */
  enum_variant_tag: i32;
  /** EXPR_AS：被转换表达式池下标 + 目标类型池下标。 */
  as_operand_ref: i32;
  as_target_type_ref: i32;
}

/** 常量声明：名称 + 类型池下标 + 初值表达式池下标 */
struct ConstDecl {
  name: [64]u8;
  name_len: i32;
  type_ref: i32;
  init_ref: i32;
}

/** 变量声明：名称 + 类型池下标 + 初值表达式池下标 */
struct LetDecl {
  name: [64]u8;
  name_len: i32;
  type_ref: i32;
  init_ref: i32;
}

/** 单条 while 循环：条件表达式池下标 + 体块池下标 */
struct WhileLoop {
  cond_ref: i32;
  body_ref: i32;
}

/** 单条 for 循环：init/cond/step 表达式池下标 + 体块池下标 */
struct ForLoop {
  init_ref: i32;
  cond_ref: i32;
  step_ref: i32;
  body_ref: i32;
}

/** 单条 if 语句：条件表达式池下标 + then 分支块池下标（须为 `{ ... }` 块，无 else 子句）。 */
struct IfStmt {
  cond_ref: i32;
  then_body_ref: i32;
}

/** 块内语句顺序项：kind 0=const, 1=let, 2=expr_stmt, 3=loop, 4=for, 5=if；idx 为对应数组下标 */
allow(padding) struct StmtOrderItem {
  kind: u8;
  idx: i32;
}

/** 带标签的语句：goto 或 return；标签名与目标/返回值由后续字段表示 */
struct LabeledStmt {
  label: [32]u8;
  label_len: i32;
  is_goto: i32;
  goto_target: [32]u8;
  goto_target_len: i32;
  return_expr_ref: i32;
}

/** 块：const/let 声明 + while/for/if + defer 块 + 标签语句 + 表达式语句 + 最终表达式 + stmt_order；
 * const/let 槽容量与 parser.c 中 MAX_CONST_DECLS / MAX_LET_DECLS（均为 256）对齐。 */
struct Block {
  const_decls: [256]ConstDecl;
  num_consts: i32;
  let_decls: [256]LetDecl;
  num_lets: i32;
  num_early_lets: i32;
  loops: [8]WhileLoop;
  num_loops: i32;
  for_loops: [8]ForLoop;
  num_for_loops: i32;
  /** 块内链式 if(cond){ block }（最多 16 条），与 stmt_order kind=5 对应 */
  if_stmts: [16]IfStmt;
  num_if_stmts: i32;
  defer_block_refs: [8]i32;
  num_defers: i32;
  labeled_stmts: [8]LabeledStmt;
  num_labeled_stmts: i32;
  expr_stmt_refs: [32]i32;
  num_expr_stmts: i32;
  final_expr_ref: i32;
  stmt_order: [96]StmtOrderItem;
  num_stmt_order: i32;
}

/** 函数形参：名称 + 类型池下标 */
struct Param {
  name: [32]u8;
  name_len: i32;
  type_ref: i32;
}

/** 函数：名称 + 形参 + 返回类型池下标 + 体块/体表达式池下标 + 是否 extern。body_ref 为块池 ref，body_expr_ref 为表达式池 ref（parse_into_buf 用）。 */
struct Func {
  name: [64]u8;
  name_len: i32;
  params: [16]Param;
  num_params: i32;
  return_type_ref: i32;
  body_ref: i32;
  /** 体为单表达式时用表达式池 ref（与 body_ref 二选一，0 表示未用） */
  body_expr_ref: i32;
  is_extern: i32;
}

/** 结构体布局（用于 typeck 填 field_access_offset / 字段类型）：名称 + 最多 24 个字段名与偏移；偏移按 8 字节步进（与解析器占位一致）；field_type_refs 为 arena 中 Type 池下标。 */
struct StructLayout {
  name: [64]u8;
  name_len: i32;
  num_fields: i32;
  /** OneFuncResult 等大块结果体：须 ≥ parser OneFuncResult 字段数；与 parse_struct_record_layout_into、pipeline_glue 上界一致 */
  field_names: [64][64]u8;
  field_lens: [64]i32;
  field_offsets: [64]i32;
  field_type_refs: [64]i32;
}

/** import 种类：与 C 的 AST_IMPORT_KIND_* 一致，供 parser/codegen 使用 */
enum ImportKind { IMPORT_WHOLE, IMPORT_BINDING, IMPORT_SELECT }

/** 模块：顶层函数列表（或 arena func 池的 ref 表）+ main 函数下标 + import 路径与种类 + 顶层 let/const + 结构体布局（与 C 的 ASTModule 同步，供自举） */
struct Module {
  funcs: [256]Func;
  /** parse_into_buf 路径：顶层函数在 arena 的 func 池中的 1-based ref，与 num_funcs 同长 */
  func_refs: [256]i32;
  num_funcs: i32;
  main_func_index: i32;
  /** import 路径扁平存储：路径 i 在 data[i*64..(i+1)*64-1]，len 为 import_path_lens[i] */
  import_path_data: [2048]u8;
  import_path_lens: [32]i32;
  num_imports: i32;
  /** 与 num_imports 对应：0=整模块 import path;，1=const x = import path;，2=const { a,b } = import path; */
  import_kinds: [32]i32;
  /** import_kinds[i]==IMPORT_BINDING 时的绑定名（如 "process"） */
  import_binding_name: [32][64]u8;
  import_binding_name_len: [32]i32;
  /** import_kinds[i]==IMPORT_SELECT 时的选取名个数（最多 8 个） */
  import_select_count: [32]i32;
  import_select_names: [32][8][64]u8;
  import_select_name_lens: [32][8]i32;
  /** 顶层 let/const：与 C 的 top_level_lets 同步，最多 32 条；name 在 type 在 arena.types，init 在 arena.exprs */
  num_top_level_lets: i32;
  top_level_let_names: [32][64]u8;
  top_level_let_name_lens: [32]i32;
  top_level_let_type_refs: [32]i32;
  top_level_let_init_refs: [32]i32;
  top_level_let_is_const: [32]i32;
  /** 结构体布局：由 typeck 从 STRUCT_LIT 推导，供 EXPR_FIELD_ACCESS 填 field_access_offset */
  struct_layouts: [32]StructLayout;
  num_struct_layouts: i32;
}

/** 统一 AST 分配器（池化）：Type/Expr/Block/Func 固定数组 + 计数，1-based ref，0 表示空；不依赖 C 的 malloc。 */
allow(padding) struct ASTArena {
  types: [512]Type;
  num_types: i32;
  /** 大块单模块（backend.su/parser.su）易超旧 4096；与 ast_arena_expr_alloc 上限须一致 */
  exprs: [8192]Expr;
  num_exprs: i32;
  blocks: [512]Block;
  num_blocks: i32;
  funcs: [256]Func;
  num_funcs: i32;
}

/** 阶段 6.1：pipeline/typeck 共用的 dep 上下文，由调用方分配并传入。
 *  路径与缓冲：entry_dir/lib_roots 供 .su 内 resolve；path_buf 写解析后路径；loaded/preprocess 缓冲由 C 提供指针与容量。 */
allow(padding) struct PipelineDepCtx {
  dep_modules: [32]*Module;
  dep_arenas: [32]*ASTArena;
  ndep: i32;
  /** 6.1 路径解析：入口目录与库根（固定数组避免 .su 中指针下标），供 .su resolve_path_su 使用 */
  entry_dir_buf: [512]u8;
  entry_dir_len: i32;
  num_lib_roots: i32;
  /** -L 库根上限：build_shu_asm 的 LIBROOT 常含 10+ 条，旧 8 槽会截断 src/asm 等导致 arch.* import 无法 resolve（rc=-7）。 */
  lib_root_bufs: [16][256]u8;
  lib_root_lens: [16]i32;
  /** 解析出的文件路径（含结尾 0，供 open 使用） */
  path_buf: [512]u8;
  /** 6.1 完全自举：读入与预处理用固定数组，全部在 .su 内完成，不依赖 C 缓冲指针 */
  loaded_buf: [524288]u8;
  loaded_len: isize;
  preprocess_buf: [524288]u8;
  preprocess_len: i32;
  /** 非 0 时 pipeline 使用 asm 后端（出汇编）而非 codegen（出 C）；由 driver 解析 -backend asm 设置。 */
  use_asm_backend: i32;
  /** 目标架构：0=x86_64，1=arm64（aarch64），2=riscv64；由 driver 按 -target 设置，asm 后端据此分派。 */
  target_arch: i32;
  /** 非 0 时出 .o 走 Mach-O 而非 ELF（macOS 宿主机由 C driver 设置）。 */
  use_macho_o: i32;
  /** 非 0 时出 .o 走 COFF/PE .obj（Windows 目标由 C driver 设置）。 */
  use_coff_o: i32;
  /** typeck 用：当前检查的块 ref，供 EXPR_VAR 查 const/let 填 resolved_type_ref。0 表示未在块内。 */
  current_block_ref: i32;
  /** typeck 用：当前检查的函数在 module.funcs 中的下标，供 EXPR_VAR 查形参填 resolved_type_ref。-1 表示未在函数内。 */
  current_func_index: i32;
  /** 每个 dep 的逻辑 import 路径副本（ASCII+NUL）；dep_paths[j] 须指向本行首字节，禁止与 path_buf 共用（codegen 环内 path_buf 会被反复覆盖）。 */
  dep_logical_path_mirror: [32][64]u8;
  /** 每个 dep 的 import 路径（如 "std.io.driver"），供 codegen/asm 生成 C ABI 前缀，与 dep_modules 一一对应。 */
  dep_paths: [32]*u8;
  /** 非 0 时跳过 dep 0 的 codegen（-o 时设，driver 由 io.o 提供，避免重复符号） */
  skip_codegen_dep_0: i32;
  /** 非 0 时 entry 已由 C 侧 parser_parse_into 解析，pipeline 跳过 parse 直接 typeck+codegen，避免二次解析导致 main body_ref 丢失。 */
  entry_already_parsed: i32;
  /** codegen 用：当前函数中唯一无名/空格名形参的下标（0..num_params-1），供 EXPR_VAR 无名时输出 _pN；若无或不止一个则为 -1。 */
  current_func_single_empty_param_index: i32;
  /** codegen 用：当前函数无名形参个数（≥2 时与下一字段配合）；无名引用按出现顺序用对应 param 下标输出 _pN。 */
  current_func_empty_param_count: i32;
  /** codegen 用：当前函数无名形参的 param 下标（如 [1,2] 表示第 1、2 个形参无名），与声明 _p1,_p2 一致。 */
  current_func_empty_param_indices: [16]i32;
  /** codegen 用：下一个待发射的无名 EXPR_VAR 使用的下标（0..current_func_empty_param_count-1），每发射一次自增。 */
  current_emit_empty_var_next_index: i32;
  /** codegen 用：非 0 表示当前在发射 EXPR_CALL 的 callee，无名 EXPR_VAR 不占 _pN 而输出 _0。 */
  emit_expr_as_callee: i32;
  /** codegen 用：当前正在生成 C 的模块/arena，供 CALL 未在 dep 中解析时判断是否为本模块函数并加前缀。 */
  current_codegen_module: *Module;
  current_codegen_arena: *ASTArena;
}

/** 池下标空值：所有 ref 字段用 0 表示“无” */
function ref_is_null(ref: i32): bool {
  return ref == 0;
}

/** 占位：表示本 AST 模块可被 parser/typeck/codegen 引用；后续接池分配与 parser 构建。 */
function ast_placeholder(): i32 {
  return 0;
}

/** 将 Arena 内所有计数清零，用于复用或初始化。 */
function ast_arena_init(arena: *ASTArena): void {
  arena.num_types = 0;
  arena.num_exprs = 0;
  arena.num_blocks = 0;
  arena.num_funcs = 0;
}

/** 在 Type 池中分配一个槽位，返回 1-based ref；已满（512）时返回 0。 */
function ast_arena_type_alloc(arena: *ASTArena): i32 {
  if (arena.num_types >= 512) {
    return 0;
  }
  arena.num_types = arena.num_types + 1;
  return arena.num_types;
}

/** 在 Expr 池中分配一个槽位，返回 1-based ref；已满（8192）时返回 0。须与 ASTArena.exprs 长度一致。 */
function ast_arena_expr_alloc(arena: *ASTArena): i32 {
  if (arena.num_exprs >= 8192) {
    return 0;
  }
  arena.num_exprs = arena.num_exprs + 1;
  return arena.num_exprs;
}

/** 在 Block 池中分配一个槽位，返回 1-based ref；已满（512）时返回 0。 */
function ast_arena_block_alloc(arena: *ASTArena): i32 {
  if (arena.num_blocks >= 512) {
    return 0;
  }
  arena.num_blocks = arena.num_blocks + 1;
  return arena.num_blocks;
}

/** 按 ref 取 Type 池中节点（副本）；ref 须为 1..num_types。ref<=0 时返回默认 TYPE_I32，避免 C 生成码中 ref-1 越界触发 panic。 */
function ast_arena_type_get(arena: *ASTArena, ref: i32): Type {
  if (ref <= 0) {
    let empty_name: [64]u8 = [];
    /* TYPE_I32 为 TypeKind 首项判别式 0；.su pipeline 不解析 Enum.VARIANT 限定名（见 token.su token_is_eof 注释）。 */
    return Type { kind: (0 as TypeKind), name: empty_name, name_len: 0, elem_type_ref: 0, array_size: 0 };
  }
  let idx: i32 = ref - 1;
  return arena.types[idx];
}

/** 将 Type 节点写回池中 ref 槽位；ref 须为 1..num_types。用于 parser 构建 AST。 */
function ast_arena_type_set(arena: *ASTArena, ref: i32, t: Type): void {
  let idx: i32 = ref - 1;
  arena.types[idx] = t;
}

/** 将 Expr 的 match 每臂数组与 enum_variant_tag 置 0，供 parser 在构建任意 Expr 时调用，避免未初始化。 */
function expr_init_match_enum(e: *Expr): void {
  let i: i32 = 0;
  while (i < 16) {
    e.match_arm_is_wildcard[i] = 0;
    e.match_arm_lit_val[i] = 0;
    e.match_arm_is_enum_variant[i] = 0;
    e.match_arm_variant_index[i] = 0;
    i = i + 1;
  }
  e.enum_variant_tag = 0;
}

/** 按 ref 取 Expr 池中节点（副本）；ref 须为 1..num_exprs。 */
function ast_arena_expr_get(arena: *ASTArena, ref: i32): Expr {
  /* 须先令 idx = ref - 1 再下标：写成 arena.exprs[ref - 1] 时，解析器会在 ] 之后把「- 1」收成二元减法（等价 arena.exprs[ref] - 1），导致 typeck/codegen 错误。 */
  let idx: i32 = ref - 1;
  return arena.exprs[idx];
}

/** 将 Expr 节点写回池中 ref 槽位；ref 须为 1..num_exprs。用于 parser 构建 AST。 */
function ast_arena_expr_set(arena: *ASTArena, ref: i32, e: Expr): void {
  let idx: i32 = ref - 1;
  arena.exprs[idx] = e;
}

/** 按 ref 取 Block 池中节点（副本）；ref 须为 1..num_blocks。 */
function ast_arena_block_get(arena: *ASTArena, ref: i32): Block {
  let idx: i32 = ref - 1;
  return arena.blocks[idx];
}

/** 两段字节名字是否相等；供 ast 模块内解析块绑定，不复用 typeck 的 name_equal。 */
function ast_name_bytes_equal(a_nm: *u8, a_len: i32, b_nm: *u8, b_len: i32): bool {
  if (a_len != b_len || a_len <= 0) {
    return false;
  }
  let j: i32 = 0;
  while (j < a_len) {
    if (a_nm[j] != b_nm[j]) {
      return false;
    }
    j = j + 1;
  }
  return true;
}

/** 取块池中某块的 final_expr_ref（无尾表达式时为 0）；封装在 ast 内避免 import 模块对 Block 做字段访问（其 struct_layout 常未含 Block）。 */
function ast_block_final_expr_ref(a: *ASTArena, body_ref: i32): i32 {
  if (body_ref <= 0 || body_ref > a.num_blocks) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, body_ref);
  return blk.final_expr_ref;
}

/**
 * SU 无法用局部 Expr 安全读取 expr.kind；由 pipeline_glue.c 实现该裸 C 符号（无前缀，
 * preamble 与原样 extern 对齐，避免 import 前缀叠层）。
 */
extern function implicit_tail_expr_disallowed_by_glue(a: *ASTArena, expr_ref: i32): bool;

/** 末表达式若为 RETURN/PANIC/BREAK/CONTINUE，则不允许隐式尾返回；委托 glue。 */
function ast_expr_disallows_implicit_tail(a: *ASTArena, expr_ref: i32): bool {
  return implicit_tail_expr_disallowed_by_glue(a, expr_ref);
}

function ast_block_num_consts(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  /** shu-c 不能在 return 上对函数返回值再做 .field，须先绑到局部 Block。 */
  let blk_nc: Block = ast_arena_block_get(a, br);
  return blk_nc.num_consts;
}

function ast_block_num_lets(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nl: Block = ast_arena_block_get(a, br);
  return blk_nl.num_lets;
}

function ast_block_num_loops(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nlp: Block = ast_arena_block_get(a, br);
  return blk_nlp.num_loops;
}

function ast_block_num_for_loops(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nfp: Block = ast_arena_block_get(a, br);
  return blk_nfp.num_for_loops;
}

function ast_block_num_if_stmts(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nif: Block = ast_arena_block_get(a, br);
  return blk_nif.num_if_stmts;
}

function ast_block_num_expr_stmts(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nes: Block = ast_arena_block_get(a, br);
  return blk_nes.num_expr_stmts;
}

function ast_block_num_stmt_order(a: *ASTArena, br: i32): i32 {
  if (br <= 0 || br > a.num_blocks) {
    return 0;
  }
  let blk_nso: Block = ast_arena_block_get(a, br);
  return blk_nso.num_stmt_order;
}

function ast_block_stmt_order_kind(a: *ASTArena, br: i32, si: i32): u8 {
  if (br <= 0 || br > a.num_blocks || si < 0) {
    return 0 as u8;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (si >= blk.num_stmt_order || si >= 96) {
    return 0 as u8;
  }
  return blk.stmt_order[si].kind;
}

function ast_block_stmt_order_idx(a: *ASTArena, br: i32, si: i32): i32 {
  if (br <= 0 || br > a.num_blocks || si < 0) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (si >= blk.num_stmt_order || si >= 96) {
    return 0;
  }
  return blk.stmt_order[si].idx;
}

function ast_block_const_init_ref(a: *ASTArena, br: i32, ci: i32): i32 {
  if (br <= 0 || br > a.num_blocks || ci < 0 || ci >= 256) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (ci >= blk.num_consts) {
    return 0;
  }
  return blk.const_decls[ci].init_ref;
}

function ast_block_const_type_ref(a: *ASTArena, br: i32, ci: i32): i32 {
  if (br <= 0 || br > a.num_blocks || ci < 0 || ci >= 256) {
    return 0;
  }
  let blk: Block = ast_arena_block_get(a, br);
  if (ci >= blk.num_consts) {
    return 0;
  }
  return blk.const_decls[ci].type_ref;
}

function ast_block_let_init_ref(a: *ASTArena, br: i32, li: i32): i32 {
