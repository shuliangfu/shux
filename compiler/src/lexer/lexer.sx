    return t;
  }
  if (len == 5 && match_keyword(data, start, 5, [99, 111, 110, 115, 116])) {
    let t: Token = Token {
      kind: TokenKind.TOKEN_CONST,
      line: line0,
      col: col0,
      int_val: 0,
      float_val: 0.0,
      ident: 0,
      ident_len: 0
