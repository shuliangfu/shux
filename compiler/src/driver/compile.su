// compile.su — 完整编译入口 argv 解析与后端分派（从 runtime.c
// driver_run_compiler_full 迁入）
//
// C 侧保留 read_file、invoke_cc、driver_run_asm_backend 等原语；本模块负责
// -o/-L/-backend/-target/-O 解析。

import ast;

/** 与 main.su DriverSuEmitState 字段布局兼容的编译参数块（sidecar 键为
&state）。 */
struct DriverCompileState {
  path_buf: [512]u8;
  path_len: i32;
  out_path_buf: [512]u8;
  out_path_len: i32;
  use_asm_backend: i32;
  target_arch: i32;
  /** `-target` 原始字符串（供 asm/ld 使用）。 */
  target_buf: [512]u8;
  target_len: i32;
  opt_level_buf: [8]u8;
  opt_level_len: i32;
  use_lto: i32;
}

extern function driver_get_argv_i(argc: i32, argv: *u8, i: i32, buf: *u8, max: i32): i32;
extern function driver_emit_lib_root_reset(key: *u8): void;
extern function driver_emit_append_lib_root(key: *u8, path: *u8, len: i32): i32;
extern function driver_emit_lib_root_count(key: *u8): i32;
extern function driver_resolve_target_arch(parsed: i32, saw_target: i32): i32;
extern function driver_source_has_generic_syntax(path: *u8, path_len: i32): i32;
/** C：源码含 += 等复合赋值时返回 1（.su parse 未覆盖，须走 C 后端）。 */
extern function driver_source_has_compound_assign_syntax(path: *u8, path_len: i32): i32;
/** C：源码含顶层 import 时返回 1（seed asm 入口 parse 易 0 func，须走 C
* 后端）。 */
extern function driver_source_has_top_level_import_path(path: *u8, path_len: i32): i32;
extern function driver_asm_output_want_exe(out_path: *u8): i32;
extern function driver_check_only_get(): i32;
extern function driver_bump_stack_limit(): void;
/** C：build_shu_asm 设 SHU_ASM_ENTRY_MODULE_ONLY=1 时非 0；单模块 -o 仍走 asm 后端。 */
extern function driver_asm_entry_module_only_from_env(): i32;

/** C：asm 后端（读文件、dep、pipeline、.o/ld）。 */
extern function driver_run_asm_backend_c(
input_path: *u8,
out_path: *u8,
lib_key: *u8,
target: *u8,
argc: i32,
argv: *u8,
): i32;

/** C：C 后端（预处理、pipeline 出 C、cc 链接）。 */
extern function driver_run_emit_c_path_c(
input_path: *u8,
out_path: *u8,
lib_key: *u8,
target: *u8,
opt_level: *u8,
use_lto: i32,
argc: i32,
argv: *u8,
): i32;

/** sidecar 键：state 指针。 */
function driver_compile_state_key(state: *DriverCompileState): *u8 {
  return state as *u8;
}

/** 无 -L 时默认库根 "."（与 runtime driver_run_compiler_full 一致）。 */
function driver_compile_ensure_default_lib(key: *u8): void {
  if (driver_emit_lib_root_count(key) == 0) {
    let dot: [1]u8 = [46];
    driver_emit_append_lib_root(key, &dot[0], 1);
  }
}

function eq_minus_o(buf: *u8, len: i32): i32 {
  if (len == 2 && buf[0] == 45 && buf[1] == 111) {
    return 1;
  }
  return 0;
}

function eq_minus_L(buf: *u8, len: i32): i32 {
  if (len == 2 && buf[0] == 45 && buf[1] == 76) {
    return 1;
  }
  return 0;
}

/** 比较 buf 与 "-backend"（8 字节）；须 len==8，勿写成 9（与 main.su 一致）。 */
function eq_minus_backend(buf: *u8, len: i32): i32 {
  if (len == 8 && buf[0] == 45 && buf[1] == 98 && buf[2] == 97 && buf[3] == 99 && buf[4] == 107 &&
  buf[5] == 101 && buf[6] == 110 && buf[7] == 100) {
    return 1;
  }
  return 0;
}

function eq_minus_target(buf: *u8, len: i32): i32 {
  if (len < 7) {
    return 0;
  }
  if (buf[0] == 45 && buf[1] == 116 && buf[2] == 97 && buf[3] == 114 && buf[4] == 103 && buf[5] ==
  101 && buf[6] == 116) {
    return 1;
  }
  return 0;
}

function eq_minus_O(buf: *u8, len: i32): i32 {
  if (len == 2 && buf[0] == 45 && buf[1] == 79) {
    return 1;
  }
  return 0;
}

function eq_flto(buf: *u8, len: i32): i32 {
  if (len == 5 && buf[0] == 45 && buf[1] == 102 && buf[2] == 108 && buf[3] == 116 && buf[4] == 111)
  {
    return 1;
  }
  return 0;
}

function eq_asm_word(buf: *u8, len: i32): i32 {
  if (len == 3 && buf[0] == 97 && buf[1] == 115 && buf[2] == 109) {
    return 1;
  }
  return 0;
}

function eq_c_word(buf: *u8, len: i32): i32 {
  if (len == 1 && buf[0] == 99) {
    return 1;
  }
  return 0;
}

function path_ends_su(buf: *u8, len: i32): i32 {
  if (len >= 3 && buf[len - 3] == 46 && buf[len - 2] == 115 && buf[len - 1] == 117) {
    return 1;
  }
  return 0;
}

function target_has_arm(buf: *u8, len: i32): i32 {
  let start: i32 = 0;
  while (start + 5 <= len) {
    if (buf[start] == 97 && buf[start + 1] == 114 && buf[start + 2] == 109 && buf[start + 3] == 54
    &&
    buf[start + 4] == 52) {
      return 1;
    }
    start = start + 1;
  }
  return 0;
}

/**
* 解析完整编译 argv；返回 0 成功，1 无输入 .su。
*/
function driver_compile_parse_argv(argc: i32, argv: *u8, state: *DriverCompileState): i32 {
  state.path_len = 0;
  state.out_path_len = 0;
  /** 默认 asm，与 main.su / 旧 driver_run_compiler_full 一致；仅 `-backend c` 显式置
  0。 */
  state.use_asm_backend = 1;
  state.target_arch = 0;
  state.target_len = 0;
  state.opt_level_len = 1;
  state.opt_level_buf[0] = 50;
  state.use_lto = 0;
  driver_emit_lib_root_reset(driver_compile_state_key(state));
  if (argc < 2) {
    return 1;
  }
  let arg_buf: [512]u8 = [];
  let lib_tmp: [512]u8 = [];
  let saw_target: i32 = 0;
  let i: i32 = 1;
  while (i < argc) {
    let len: i32 = driver_get_argv_i(argc, argv, i, arg_buf, 512);
    if (len < 0) {
      i = i + 1;
      continue;
    }
    if (eq_minus_o(arg_buf, len) != 0 && i + 1 < argc) {
      let olen: i32 = driver_get_argv_i(argc, argv, i + 1, state.out_path_buf, 512);
      if (olen >= 0) {
        state.out_path_len = olen;
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_L(arg_buf, len) != 0 && i + 1 < argc) {
      let llen: i32 = driver_get_argv_i(argc, argv, i + 1, lib_tmp, 512);
      if (llen >= 0) {
        driver_emit_append_lib_root(driver_compile_state_key(state), &lib_tmp[0], llen);
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_O(arg_buf, len) != 0 && i + 1 < argc) {
      let olen: i32 = driver_get_argv_i(argc, argv, i + 1, state.opt_level_buf, 8);
      if (olen >= 0) {
        state.opt_level_len = olen;
      }
      i = i + 2;
      continue;
    }
    if (eq_flto(arg_buf, len) != 0) {
      state.use_lto = 1;
      i = i + 1;
      continue;
    }
    if (eq_minus_backend(arg_buf, len) != 0 && i + 1 < argc) {
      let vlen: i32 = driver_get_argv_i(argc, argv, i + 1, arg_buf, 512);
      if (vlen >= 0 && eq_asm_word(arg_buf, vlen) != 0) {
        state.use_asm_backend = 1;
      }
      if (vlen >= 0 && eq_c_word(arg_buf, vlen) != 0) {
        state.use_asm_backend = 0;
      }
      i = i + 2;
      continue;
    }
    if (eq_minus_target(arg_buf, len) != 0 && i + 1 < argc) {
      saw_target = 1;
      let tlen: i32 = driver_get_argv_i(argc, argv, i + 1, state.target_buf, 512);
      if (tlen >= 0) {
        state.target_len = tlen;
        if (target_has_arm(&state.target_buf[0], tlen) != 0) {
          state.target_arch = 1;
        }
      }
      i = i + 2;
      continue;
    }
    if (arg_buf[0] != 45 && path_ends_su(arg_buf, len) != 0) {
      let plen: i32 = len;
      if (plen > 511) {
        plen = 511;
      }
      let k: i32 = 0;
      while (k < plen) {
        state.path_buf[k] = arg_buf[k];
        k = k + 1;
      }
      state.path_len = plen;
      i = i + 1;
      continue;
    }
    i = i + 1;
  }
  if (state.path_len <= 0) {
    return 1;
  }
  state.target_arch = driver_resolve_target_arch(state.target_arch, saw_target);
  driver_compile_ensure_default_lib(driver_compile_state_key(state));
  return 0;
}

/**
* 完整编译入口（.su）：解析 argv 后分派 asm 或 C 后端。
* runtime.c 的 driver_run_compiler_full 转调本函数（链接符号
* driver_run_compiler_full_su）。
*/
function run_compiler_full_su(argc: i32, argv: *u8): i32 {
  let state: DriverCompileState = DriverCompileState {
    path_len: 0,
    out_path_len: 0,
    use_asm_backend: 1,
    target_arch: 0,
    opt_level_len: 0,
    use_lto: 0,
  };
  state.opt_level_buf[0] = 50;
  state.opt_level_len = 1;
  driver_bump_stack_limit();
  if (driver_compile_parse_argv(argc, argv, &state) != 0) {
    return 1;
  }
  if (driver_check_only_get() != 0) {
    state.use_asm_backend = 0;
  }
  let want_generic_check: i32 = 0;
  if (state.out_path_len == 0) {
    want_generic_check = 1;
  } else if (driver_asm_output_want_exe(&state.out_path_buf[0]) != 0) {
    want_generic_check = 1;
  }
  if (state.use_asm_backend != 0 && want_generic_check != 0) {
    if (driver_source_has_generic_syntax(&state.path_buf[0], state.path_len) != 0) {
      state.use_asm_backend = 0;
    }
    if (driver_source_has_compound_assign_syntax(&state.path_buf[0], state.path_len) != 0) {
      state.use_asm_backend = 0;
    }
  }
  /** 链可执行文件（-o 无 .o/.s 后缀）且含复合赋值：须 C codegen+cc，asm
  * 单文件 parse 会 num_funcs=0。 */
  if (state.use_asm_backend != 0 && state.out_path_len > 0 &&
  driver_asm_output_want_exe(&state.out_path_buf[0]) != 0) {
    if (driver_source_has_compound_assign_syntax(&state.path_buf[0], state.path_len) != 0) {
      state.use_asm_backend = 0;
    }
  }
  let out_ptr: *u8 = 0 as *u8;
  if (state.out_path_len > 0) {
    out_ptr = &state.out_path_buf[0];
  }
  let target_ptr: *u8 = 0 as *u8;
  if (state.target_len > 0) {
    target_ptr = &state.target_buf[0];
  }
  /* 含 import 的用户可执行走 C codegen+cc；单模块 build_asm -o 时 import 由并列 .o 满足，仍走 asm。 */
  if (state.use_asm_backend != 0 &&
      driver_asm_entry_module_only_from_env() == 0 &&
      driver_source_has_top_level_import_path(&state.path_buf[0], state.path_len) != 0) {
    state.use_asm_backend = 0;
  }
  if (state.use_asm_backend != 0) {
    return driver_run_asm_backend_c(
    &state.path_buf[0],
    out_ptr,
    driver_compile_state_key(&state),
    target_ptr,
    argc,
    argv
    );
  }
  return driver_run_emit_c_path_c(
  &state.path_buf[0],
  out_ptr,
  driver_compile_state_key(&state),
  target_ptr,
  &state.opt_level_buf[0],
  state.use_lto,
  argc,
  argv
  );
}
