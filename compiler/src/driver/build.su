// build.su — shu build 子命令
// 行为：
//   - 有参数（如 shu build x.su -o exe）：编译指定 .su（run_compiler_su_path_impl）。
//   - 无参数（仅 shu build）：由 C 侧在当前目录查找 build.su，编译并运行默认产物 ./a.out（driver_build_build_su）。
// 用法：shu build [x.su] [-o exe] [-E] [-backend c] [-L path]

import ast;

/** 在 entry() 里声明，run_compiler_su_path_impl 实现于 main.su。 */
extern function run_compiler_su_path_impl(argc: i32, argv: *u8): i32;

/** C 侧 runtime.c：当前目录 build.su → driver_run_compiler_full，成功后 exec ./a.out。 */
extern function driver_build_build_su(): i32;

/**
 * shu build 入口：子命令已从 argv 剥离后，argc==1 表示除程序名外无额外参数。
 */
function cmd_build(argc: i32, argv: *u8): i32 {
  if (argc < 2) {
    return driver_build_build_su();
  }
  return run_compiler_su_path_impl(argc, argv);
}
