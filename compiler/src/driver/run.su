// run.su — shu run 子命令
// 行为：编译 .su → a.out → 运行
// 用法：shu run x.su [-o exe]
// 注：cmd_run 内用 `if (rc == 0)` 再执行 exec；`if (rc != 0) return` 与 import ast 同编时 typeck 会误报 check_block（compiler 限制）。

import ast;
/** 由 C 侧 runtime.c 提供：fork+exec 运行编译产物。符号名为 driver_exec_compiled；源码标识符用 exec_compiled，与同模块 C 前缀 driver_ 拼接后一致。 */
extern function exec_compiled(argc: i32, argv: *u8): i32;
/** main.su 提供的编译入口 */
extern function run_compiler_su_path_impl(argc: i32, argv: *u8): i32;

/** 比较 buf[0..len-1] 与 word_ptr[0..word_len-1]（当前未使用，保留供将来子命令解析复用）。 */
function run_eq_word(buf: *u8, len: i32, word_ptr: *u8, word_len: i32): i32 {
  if (len != word_len) {
    return 0;
  }
  let i: i32 = 0;
  while (i < len) {
    if (buf[i] != word_ptr[i]) {
      return 0;
    }
    i = i + 1;
  }
  return 1;
}

function cmd_run(argc: i32, argv: *u8): i32 {
  if (argc < 2) {
    return 1;
  }
  let rc: i32 = run_compiler_su_path_impl(argc, argv);
  if (rc == 0) {
    return exec_compiled(argc, argv);
  }
  return rc;
}
