// check.su — shu check 子命令：parse + typeck（含 import deps），不 codegen、不链接。
// 符号名 driver_cmd_check：源码标识符 cmd_check + 模块前缀 driver_

import ast;

/** C 侧 runtime.c：置 check_only 标志后走 driver_run_compiler_full 的 SU pipeline，typeck 通过后早退。 */
extern function driver_run_compiler_check(argc: i32, argv: *u8): i32;

/**
 * shu check [flags] file.su
 * 用法与 shu build/run 类似（支持 -L 等）；成功返回 0，失败返回 1。
 */
function cmd_check(argc: i32, argv: *u8): i32 {
  if (argc < 2) {
    return 1;
  }
  return driver_run_compiler_check(argc, argv);
}
