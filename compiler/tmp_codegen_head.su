// codegen.su — 代码生成（纯 .su，完全自举）
//
// 职责：将 .su AST（Module + Arena）生成 C 源码，全部逻辑在 .su，不依赖任何 C 业务接口。
// 输出：写入内存缓冲区 CodegenOutBuf，由 C 在调用 pipeline 后将 data[0..len-1] 写到 FILE*。
// 依赖：import ast。

import ast;

/** C 侧：base 为指针或 slice 时返回 1（仅 pointer-based AST 时有效）；ref-based 路径用 field_access_base_is_pointer_ref 从 arena 取类型。 */
extern function codegen_su_field_access_base_is_pointer(expr: *u8): i32;

/** C 侧：将当前 dep 路径转为 C 前缀写入 buf（如 "std.io.driver" -> "std_io_driver_"），供库模块函数名加前缀避免与 C 关键字冲突。 */
extern function driver_get_current_dep_prefix_for_codegen(buf: *u8, len: i32): void;
/** 当前 dep 路径是否为 std.io.core（与 ctx.dep_paths 互补，确保 core 不加前缀）。 */
extern function driver_current_dep_path_is_std_io_core(): i32;
/** 仅按名跳过：submit_read_batch_buf/submit_write_batch_buf 任何 dep 都跳过，由 preamble 提供 extern。 */
extern function driver_should_skip_emit_func_by_name(name: *u8, name_len: i32): i32;
/** 调用处补第 4 参：若为 submit_*_batch_buf 且 3 参调用，需补 ", 0" 作为 timeout_ms。 */
extern function driver_is_submit_batch_buf_call(name: *u8, name_len: i32): i32;
/** 生成函数定义时：若首参为 size_t（submit_*_batch_buf 的 handle），返回 1。 */
extern function driver_force_param_size_t(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, param_index: i32): i32;
/** 生成函数定义时：若 prefix 为 std_io_driver_ 且 preamble 将该参数声明为 ptrdiff_t（首参 register/submit_read/submit_write），返回 1。 */
extern function driver_force_param_ptrdiff_t(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, param_index: i32): i32;
/** 生成函数定义时：若 prefix 为 std_io_driver_ 且 preamble 将该参数声明为 uint32_t（timeout_ms/nr），返回 1。 */
extern function driver_force_param_uint32_t(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, param_index: i32): i32;
/** 生成函数定义时：若 prefix 为 std_io_driver_ 且 preamble 将该参数声明为 int32_t，返回 1，本模块对该参数输出 int32_t。 */
extern function driver_force_param_i32(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, param_index: i32): i32;
/** 当前为 std.io.driver 且函数名为 driver_read_ptr_len/driver_read_ptr 时返回 1，pipeline 跳过生成此二函数避免与 core 的 shu_io_* 重定义。 */
extern function driver_should_skip_emit_func(name: *u8, name_len: i32): i32;
/** 同上，显式传 dep 路径，供 dep_index>=0 时用 ctx.dep_paths[dep_index] 调用。 */
extern function driver_should_skip_emit_func_for_dep_path(path: *u8, name: *u8, name_len: i32): i32;
/** 按已算出的 C 前缀判断跳过（prefix 为 std_io_driver_ 且名为 driver_read_ptr_len/driver_read_ptr），不依赖 path。 */
extern function driver_should_skip_emit_func_for_prefix(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32): i32;
/** std.io.core 的 shu_io_read_ptr_len/shu_io_read_ptr 由 io.o 提供，跳过生成。 */
extern function driver_should_skip_emit_func_core_read_ptr(name: *u8, name_len: i32): i32;
/** std.io 的 read_fixed_fd/write_fixed_fd 定义须生成为 std_io_*_impl，返回 1 时 emit_func 在 name 后追加 "_impl"。 */
extern function driver_std_io_fixed_fd_emit_impl(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32): i32;

/** 对已知 0 参函数强制只发射 0 个实参，避免 (0, 0)。返回应发射的实参个数。 */
extern function driver_call_num_args_override(prefix: *u8, prefix_len: i32, name: *u8, name_len: i32, num_args: i32): i32;
/** 是否对此次 core 调用使用 _buf 包装名（1 参 register / 2 参 submit_read|submit_write）。 */
extern function codegen_su_use_buf_wrapper(name: *u8, name_len: i32, num_args: i32): i32;
/** C 侧：将任意 import 路径转为 C 前缀写入 buf，供生成跨 dep 调用时加前缀。 */
extern function codegen_su_import_path_to_c_prefix(path: *u8, buf: *u8, len: i32): void;
/** C 侧：path 为 "std.io.core" 时返回 1，此时不为其函数加前缀，生成 shu_io_register 等以匹配 #define std_io_core_*。 */
extern function codegen_su_path_is_std_io_core(path: *u8): i32;

/** 从 arena 判断 base 表达式（base_ref）类型是否为指针或 slice，用于字段访问输出 ->（ref-based AST 时 resolved_type_ref 有效，source/out_buf 等形参由 typeck 已填）。 */
function field_access_base_is_pointer_ref(arena: *ASTArena, base_ref: i32): i32 {
  if (ref_is_null(base_ref) || base_ref <= 0 || base_ref > arena.num_exprs) {
    return 0;
  }
  let base: Expr = ast_arena_expr_get(arena, base_ref);
  if (ref_is_null(base.resolved_type_ref) || base.resolved_type_ref <= 0 || base.resolved_type_ref > arena.num_types) {
    return 0;
