enum K { A }

allow(padding) struct Type {
    kind: K;
    name: [64]u8;
    name_len: i32;
    elem_type_ref: i32;
    array_size: i32;
}

struct Arena {
    types: [4]Type;
}

function getter(a: *Arena, ref: i32): Type {
    if (ref <= 0) {
        let empty_name: [64]u8 = [];
        return Type {
            kind: (0 as K),
            name: empty_name,
            name_len: 0,
            elem_type_ref: 0,
            array_size: 0,
        };
    }
    { (*a).types[(ref - 1) as isize] }
}
