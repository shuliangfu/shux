struct Buffer {
  ptr: *u8;
  len: usize;
  handle: usize;
}

extern function io_read_batch_buf(fd: i32, bufs: *Buffer, n: i32, timeout_ms: u32): isize;

function g(handle: usize, bufs: *Buffer, n: i32, timeout_ms: u32): i32 {
  let r: isize = io_read_batch_buf(handle as i32, bufs, n, timeout_ms);
  if (r < 0) { return -1; }
  return (r as i32);
}

function main(): i32 {
  return 0;
}
