// 最小 repro：逐步逼近 ast_arena_type_alloc 的 if+return；仅调试用。
import ast;

/** 仅用参数比较，去掉字段访问干扰。若仍失败则说明 if/then body 通路问题。 */
function repro_simple(arena: *ASTArena, n: i32): i32 {
  if (n >= 4096) {
    return 0;
  }
  return n + 1;
}

function repro_field(arena: *ASTArena): i32 {
  if (arena.num_types >= 4096) {
    return 0;
  }
  arena.num_types = arena.num_types + 1;
  return arena.num_types;
}

function main(): i32 {
  return 0;
}
