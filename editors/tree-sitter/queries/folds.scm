; Tree-sitter folding queries for Shux
; 与 editors/vscode/language-configuration.json folding.markers 对齐

[
  (block)
  (struct_body)
  (struct_declaration)
  (enum_declaration)
  (trait_declaration)
  (impl_declaration)
  (function_declaration)
  (match_statement)
  (if_expression)
  (while_statement)
  (for_statement)
  (loop_statement)
  (unsafe_block)
  (region_block)
  (with_arena_block)
  (block_comment)
] @fold
