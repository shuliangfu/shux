{
  "function": {
    "prefix": "func",
    "body": [
      "function ${1:name}(${2:params}): ${3:i32} {",
      "\t$0",
      "}"
    ],
    "description": "函数定义"
  },
  "function_extern": {
    "prefix": "extern",
    "body": [
      "extern function ${1:name}(${2:params}): ${3:i32};"
    ],
    "description": "外部函数声明（默认 X ABI）"
  },
  "function_extern_c": {
    "prefix": "externc",
    "body": [
      "extern \"C\" function ${1:name}(${2:params}): ${3:i32};"
    ],
    "description": "C ABI 外部函数声明"
  },
  "function_export": {
    "prefix": "export",
    "body": [
      "export function ${1:name}(${2:params}): ${3:i32} {",
      "\t$0",
      "}"
    ],
    "description": "导出函数定义"
  },
  "function_export_c": {
    "prefix": "exportc",
    "body": [
      "export extern \"C\" function ${1:name}(${2:params}): ${3:i32};"
    ],
    "description": "导出 C ABI 函数声明"
  },
  "function_main": {
    "prefix": "main",
    "body": [
      "function main(): i32 {",
      "\t$0",
      "\treturn 0;",
      "}"
    ],
    "description": "main 函数"
  },
  "struct": {
    "prefix": "struct",
    "body": [
      "struct ${1:Name} {",
      "\t${2:field}: ${3:i32},$0",
      "}"
    ],
    "description": "结构体定义（字段用逗号分隔）"
  },
  "struct_packed": {
    "prefix": "packed",
    "body": [
      "packed struct ${1:Name} {",
      "\t${2:field}: ${3:i32},$0",
      "}"
    ],
    "description": "紧凑结构体（无 padding）"
  },
  "struct_allow_padding": {
    "prefix": "structp",
    "body": [
      "allow(padding) struct ${1:Name} {",
      "\t${2:field}: ${3:i32},$0",
      "}"
    ],
    "description": "带 padding 的结构体"
  },
  "struct_soa": {
    "prefix": "soa",
    "body": [
      "soa struct ${1:Name} {",
      "\t${2:field}: ${3:i32},$0",
      "}"
    ],
    "description": "SOA 结构体（结构数组布局）"
  },
  "type_alias": {
    "prefix": "type",
    "body": [
      "type ${1:Name} = ${2:i32};"
    ],
    "description": "类型别名"
  },
  "enum": {
    "prefix": "enum",
    "body": [
      "enum ${1:Name} {",
      "\t${2:VARIANT},$0",
      "}"
    ],
    "description": "枚举定义"
  },
  "trait": {
    "prefix": "trait",
    "body": [
      "trait ${1:Name} {",
      "\t$0",
      "}"
    ],
    "description": "trait 定义"
  },
  "impl": {
    "prefix": "impl",
    "body": [
      "impl ${1:Trait} for ${2:Type} {",
      "\t$0",
      "}"
    ],
    "description": "trait 实现"
  },
  "import_module": {
    "prefix": "import",
    "body": [
      "const ${1:mod} = import(\"${2:std.xxx}\");"
    ],
    "description": "绑定 import（const mod = import(\"path\")）"
  },
  "let_decl": {
    "prefix": "let",
    "body": [
      "let ${1:name}: ${2:i32} = ${3:0};"
    ],
    "description": "变量声明"
  },
  "const_decl": {
    "prefix": "const",
    "body": [
      "const ${1:NAME}: ${2:i32} = ${3:0};"
    ],
    "description": "常量声明"
  },
  "if_block": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "if 语句"
  },
  "if_else": {
    "prefix": "ife",
    "body": [
      "if (${1:condition}) {",
      "\t${2:// then}",
      "} else {",
      "\t$0",
      "}"
    ],
    "description": "if / else 语句"
  },
  "while_loop": {
    "prefix": "while",
    "body": [
      "while (${1:condition}) {",
      "\t$0",
      "}"
    ],
    "description": "while 循环"
  },
  "for_loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:i}: i32 = ${2:0}; ${1:i} < ${3:n}; ${1:i} = ${1:i} + 1) {",
      "\t$0",
      "}"
    ],
    "description": "for 循环"
  },
  "loop_infinite": {
    "prefix": "loop",
    "body": [
      "loop {",
      "\t$0",
      "}"
    ],
    "description": "无限循环"
  },
  "match": {
    "prefix": "match",
    "body": [
      "match (${1:expr}) {",
      "\t${2:Variant} => ${3:result},",
      "\t_ => ${4:default},",
      "}"
    ],
    "description": "match 表达式"
  },
  "defer": {
    "prefix": "defer",
    "body": [
      "defer {",
      "\t$0",
      "}"
    ],
    "description": "defer 块"
  },
  "unsafe_block": {
    "prefix": "unsafe",
    "body": [
      "unsafe {",
      "\t$0",
      "}"
    ],
    "description": "unsafe 块（C ABI 调用等）"
  },
  "region_block": {
    "prefix": "region",
    "body": [
      "region ${1:ra} {",
      "\t$0",
      "}"
    ],
    "description": "region 借用域块"
  },
  "with_arena_block": {
    "prefix": "with_arena",
    "body": [
      "with_arena(${1:4096}) {",
      "\t$0",
      "}"
    ],
    "description": "arena 分配域块"
  },
  "return_result": {
    "prefix": "return",
    "body": [
      "return ${1:expr};"
    ],
    "description": "return 语句"
  },
  "break_stmt": {
    "prefix": "break",
    "body": [
      "break;"
    ],
    "description": "break 语句"
  },
  "continue_stmt": {
    "prefix": "continue",
    "body": [
      "continue;"
    ],
    "description": "continue 语句"
  },
  "goto_stmt": {
    "prefix": "goto",
    "body": [
      "goto ${1:label};"
    ],
    "description": "goto 语句"
  },
  "panic_stmt": {
    "prefix": "panic",
    "body": [
      "panic;"
    ],
    "description": "panic 语句"
  },
  "as_cast": {
    "prefix": "as",
    "body": [
      "${1:expr} as ${2:Type}"
    ],
    "description": "类型转换"
  },
  "attribute_no_mangle": {
    "prefix": "nomangle",
    "body": [
      "#[no_mangle]"
    ],
    "description": "#[no_mangle] 属性（导出符号不修饰）"
  },
  "attribute_cfg": {
    "prefix": "cfg",
    "body": [
      "#[cfg(target_os = \"${1:linux}\")]"
    ],
    "description": "#[cfg(...)] 条件编译属性"
  },
  "comment_doc": {
    "prefix": "/**",
    "body": [
      "/**",
      " * ${1:description}",
      " */"
    ],
    "description": "文档注释"
  }
}
