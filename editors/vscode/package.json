{
  "name": "vscode-shux",
  "displayName": "Shux Language",
  "description": "Shux (.x) 完整开发体验：语法高亮、LSP、智能补全、参数提示、悬停、大纲、折叠、片段、任务、错误跳转、实时缩进、选区扩展与状态栏",
  "version": "0.2.0",
  "license": "MIT",
  "publisher": "shux",
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "shux",
    "sx",
    "compiler",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shuxliangfu/shux"
  },
  "contributes": {
    "languages": [
      {
        "id": "sx",
        "extensions": [
          ".x"
        ],
        "aliases": [
          "Shux",
          "sx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/sx.png",
          "dark": "./icons/sx.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "sx",
        "scopeName": "source.x",
        "path": "./grammars/sx.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Shux",
      "properties": {
        "shux.serverPath": {
          "type": "string",
          "default": "compiler/shux",
          "markdownDescription": "Shux 编译器（`shux`）可执行文件路径，用于 LSP（诊断、跳转定义、查找引用、格式化）。可填 `shux`（PATH 查找；若工作区存在 `compiler/shux` 会自动使用）、相对工作区路径（如 `compiler/shux`）或绝对路径。",
          "scope": "machine-overridable"
        },
        "shux.server.trace": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "enumDescriptions": [
            "不记录 LSP 通信日志",
            "记录请求/响应消息摘要",
            "记录完整 JSON 通信内容"
          ],
          "markdownDescription": "LSP 客户端与服务端之间的通信日志级别。调试语言服务问题时设为 `verbose` 可查看完整 JSON 交互。日志输出到 VS Code 的 **Shux** 输出通道。",
          "scope": "window"
        },
        "shux.server.restartOnCrash": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "语言服务进程崩溃时是否自动重启。关闭后需要手动 **Shux: 重启语言服务** 命令来恢复。",
          "scope": "window"
        },
        "shux.format.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用 Shux 代码格式化。关闭后 `.x` 文件的 **格式化文档** 命令不生效，同时禁用编辑器格式化快捷键。",
          "scope": "resource"
        },
        "shux.format.tabSize": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 16,
          "markdownDescription": "每级缩进空格数。仅当 `shux.format.insertSpaces` 为 `true` 时生效。",
          "scope": "resource"
        },
        "shux.format.insertSpaces": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "使用空格缩进。设为 `false` 时使用 Tab（制表符）缩进。",
          "scope": "resource"
        },
        "shux.format.maxLineLength": {
          "type": "integer",
          "default": 100,
          "minimum": 20,
          "maximum": 512,
          "markdownDescription": "每行最大字符数。超出时格式化器会在合适位置折行。",
          "scope": "resource"
        },
        "shux.format.insertFinalNewline": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "文件末尾插入一个换行符。启用后保存时保证文件末尾恰好有一个换行。",
          "scope": "resource"
        },
        "shux.format.trimTrailingWhitespace": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "去除行尾多余空格和制表符。保存时自动清理。",
          "scope": "resource"
        },
        "shux.format.trimFinalNewlines": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "压缩文件末尾多余空行。启用后末尾只保留至多一个换行符。",
          "scope": "resource"
        },
        "shux.features.symbols": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用大纲视图与面包屑导航（DocumentSymbolProvider）。",
          "scope": "resource"
        },
        "shux.features.folding": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用语义代码折叠（FoldingRangeProvider）。",
          "scope": "resource"
        },
        "shux.features.hover": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用悬停提示（HoverProvider，LSP 不可用时的本地回退）。",
          "scope": "resource"
        },
        "shux.features.codeLens": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用行内 CodeLens（▶ Run、struct/enum 字段数等）。",
          "scope": "resource"
        },
        "shux.features.codeLensFunctionLabels": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "在 `function` / `extern function` 定义行上方显示 `fn` / `extern fn` 标签。默认关闭；不影响 ▶ Run 与 struct/enum 提示。",
          "scope": "resource"
        },
        "shux.features.signatureHelp": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用函数参数签名提示（SignatureHelpProvider）。",
          "scope": "resource"
        },
        "shux.features.completion": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用智能补全（CompletionItemProvider）。",
          "scope": "resource"
        },
        "shux.features.formatOnType": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用输入时实时缩进（OnTypeFormattingProvider）。",
          "scope": "resource"
        },
        "shux.features.documentLinks": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用 import 路径可点击跳转（DocumentLinkProvider）。",
          "scope": "resource"
        },
        "shux.features.statusBar": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用右下角符号统计状态栏。",
          "scope": "resource"
        },
        "shux.features.selectionRange": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "启用 Ctrl+Shift+→ 智能选区扩展（SelectionRangeProvider）。",
          "scope": "resource"
        },
        "shux.features.formatOnBlur": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "`.x` 编辑器失去焦点（切换标签页或文件）时自动格式化上一个文档。",
          "scope": "resource"
        },
        "shux.compiler.diagnosticLevel": {
          "type": "string",
          "default": "warning",
          "enum": [
            "off",
            "error",
            "warning",
            "info"
          ],
          "enumDescriptions": [
            "关闭所有编译器诊断",
            "仅显示错误",
            "显示警告和错误（默认）",
            "显示信息、警告和错误"
          ],
          "markdownDescription": "编译器诊断报告的最低级别。影响问题面板中 `.x` 文件的诊断标记。",
          "scope": "resource"
        },
        "shux.compiler.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "传递给 `shux --lsp` 的额外命令行参数，如 `[\"--verbose\"]`。",
          "scope": "resource"
        },
        "shux.compiler.targetDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "编译器输出目录（如 `build/`）。相对路径基于工作区根目录。留空使用编译器默认输出位置。",
          "scope": "resource"
        },
        "shux.compiler.libRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [".", "compiler/src", "core", "std"],
          "markdownDescription": "import 路径解析库根目录列表，与 shux -L 布局一致。用于 import 跳转与跨模块符号索引。",
          "scope": "resource"
        },
        "shux.compiler.envJson": {
          "type": "object",
          "default": {},
          "markdownDescription": "传递给 `shux` 进程的环境变量，例如 `{ \"SHUX_PATH\": \"/opt/shux\" }`。",
          "scope": "resource"
        }
      }
    },
    "configurationDefaults": {
      "[sx]": {
        "editor.defaultFormatter": "shux.vscode-shux",
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.codeLens": true
      }
    },
    "commands": [
      {
        "command": "shux.restartServer",
        "title": "重启语言服务",
        "category": "Shux"
      },
      {
        "command": "shux.showServerOutput",
        "title": "显示语言服务输出",
        "category": "Shux"
      },
      {
        "command": "shux.openSettings",
        "title": "打开设置（工作区 settings.json）",
        "category": "Shux"
      },
      {
        "command": "shux.runFile",
        "title": "运行当前 .x 文件",
        "category": "Shux"
      },
      {
        "command": "shux.refreshCodeLens",
        "title": "刷新 CodeLens",
        "category": "Shux"
      }
    ],
    "snippets": [
      {
        "language": "sx",
        "path": "./snippets/sx.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "shux-parse",
        "label": "Shux: parse error",
        "owner": "sx",
        "source": "shux",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^parse error at (\\d+):(\\d+):\\s*(.+)$",
          "line": 1,
          "column": 2,
          "message": 3
        }
      },
      {
        "name": "shux-typeck",
        "label": "Shux: typeck error",
        "owner": "sx",
        "source": "shux",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^typeck error:\\s*(.+?)\\s+at\\s+(\\d+):(\\d+)\\s*$",
          "message": 1,
          "line": 2,
          "column": 3
        }
      },
      {
        "name": "shux-generic",
        "label": "Shux: generic error",
        "owner": "sx",
        "source": "shux",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.*?)(?:\\s+at\\s+|\\s+in\\s+)(\\S+):(\\d+):(\\d+)",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "shux",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "Shux 任务类型: build / build-file / run / check",
            "enum": [
              "build",
              "build-file",
              "run",
              "check"
            ]
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
