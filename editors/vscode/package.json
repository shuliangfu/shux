{
  "name": "vscode-xlang",
  "displayName": "Xlang Language",
  "description": "Xlang (.x) 完整开发体验：语法高亮、LSP、智能补全、参数提示、悬停、大纲、折叠、片段、任务、错误跳转、实时缩进、选区扩展、状态栏、语义高亮、CodeAction、DocumentHighlight、多语言",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "publisher": "xlang",
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "xlang",
    "x",
    "compiler",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/shuliangfu/x-lang"
  },
  "contributes": {
    "languages": [
      {
        "id": "x",
        "extensions": [
          ".x"
        ],
        "aliases": [
          "Xlang",
          "x"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/x-128.png",
          "dark": "./icons/x-128.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "x",
        "scopeName": "source.x",
        "path": "./grammars/x.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Xlang",
      "properties": {
        "xlang.locale": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "en",
            "zh-cn",
            "zh-tw",
            "ja",
            "ko",
            "de",
            "fr",
            "es",
            "ru",
            "pt-br",
            "it",
            "tr",
            "pl"
          ],
          "enumDescriptions": [
            "%xlang.config.locale.auto%",
            "%xlang.config.locale.en%",
            "%xlang.config.locale.zh-cn%",
            "%xlang.config.locale.zh-tw%",
            "%xlang.config.locale.ja%",
            "%xlang.config.locale.ko%",
            "%xlang.config.locale.de%",
            "%xlang.config.locale.fr%",
            "%xlang.config.locale.es%",
            "%xlang.config.locale.ru%",
            "%xlang.config.locale.pt-br%",
            "%xlang.config.locale.it%",
            "%xlang.config.locale.tr%",
            "%xlang.config.locale.pl%"
          ],
          "markdownDescription": "%xlang.config.locale%",
          "scope": "window"
        },
        "xlang.serverPath": {
          "type": "string",
          "default": "compiler/xlang",
          "markdownDescription": "%xlang.config.serverPath%",
          "scope": "machine-overridable"
        },
        "xlang.server.trace": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "enumDescriptions": [
            "%xlang.config.server.trace.off%",
            "%xlang.config.server.trace.messages%",
            "%xlang.config.server.trace.verbose%"
          ],
          "markdownDescription": "%xlang.config.server.trace%",
          "scope": "window"
        },
        "xlang.server.restartOnCrash": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.server.restartOnCrash%",
          "scope": "window"
        },
        "xlang.format.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.format.enabled%",
          "scope": "resource"
        },
        "xlang.format.tabSize": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 16,
          "markdownDescription": "%xlang.config.format.tabSize%",
          "scope": "resource"
        },
        "xlang.format.insertSpaces": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.format.insertSpaces%",
          "scope": "resource"
        },
        "xlang.format.maxLineLength": {
          "type": "integer",
          "default": 100,
          "minimum": 20,
          "maximum": 512,
          "markdownDescription": "%xlang.config.format.maxLineLength%",
          "scope": "resource"
        },
        "xlang.features.folding": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.folding%",
          "scope": "resource"
        },
        "xlang.features.codeLens": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.codeLens%",
          "scope": "resource"
        },
        "xlang.features.codeLensFunctionLabels": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%xlang.config.features.codeLensFunctionLabels%",
          "scope": "resource"
        },
        "xlang.features.formatOnType": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.formatOnType%",
          "scope": "resource"
        },
        "xlang.features.documentLinks": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.documentLinks%",
          "scope": "resource"
        },
        "xlang.features.statusBar": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.statusBar%",
          "scope": "resource"
        },
        "xlang.features.selectionRange": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.selectionRange%",
          "scope": "resource"
        },
        "xlang.features.documentHighlight": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.documentHighlight%",
          "scope": "resource"
        },
        "xlang.features.codeAction": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.codeAction%",
          "scope": "resource"
        },
        "xlang.features.workspaceSymbol": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.workspaceSymbol%",
          "scope": "resource"
        },
        "xlang.features.statusBarDiagnostics": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.statusBarDiagnostics%",
          "scope": "resource"
        },
        "xlang.features.statusBarLspStatus": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.statusBarLspStatus%",
          "scope": "resource"
        },
        "xlang.features.codeLensRunButton": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.codeLensRunButton%",
          "scope": "resource"
        },
        "xlang.features.codeLensStructInfo": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%xlang.config.features.codeLensStructInfo%",
          "scope": "resource"
        },
        "xlang.compiler.diagnosticLevel": {
          "type": "string",
          "default": "warning",
          "enum": [
            "off",
            "error",
            "warning",
            "info"
          ],
          "enumDescriptions": [
            "%xlang.config.compiler.diagnosticLevel.off%",
            "%xlang.config.compiler.diagnosticLevel.error%",
            "%xlang.config.compiler.diagnosticLevel.warning%",
            "%xlang.config.compiler.diagnosticLevel.info%"
          ],
          "markdownDescription": "%xlang.config.compiler.diagnosticLevel%",
          "scope": "resource"
        },
        "xlang.compiler.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "%xlang.config.compiler.extraArgs%",
          "scope": "resource"
        },
        "xlang.compiler.targetDir": {
          "type": "string",
          "default": "",
          "markdownDescription": "%xlang.config.compiler.targetDir%",
          "scope": "resource"
        },
        "xlang.compiler.libRoots": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [".", "compiler/src", "core", "std"],
          "markdownDescription": "%xlang.config.compiler.libRoots%",
          "scope": "resource"
        },
        "xlang.compiler.envJson": {
          "type": "object",
          "default": {},
          "markdownDescription": "%xlang.config.compiler.envJson%",
          "scope": "resource"
        },
        "xlang.build.optimizationLevel": {
          "type": "string",
          "default": "0",
          "enum": ["0", "1", "2", "3"],
          "enumDescriptions": [
            "%xlang.config.build.optimizationLevel.0%",
            "%xlang.config.build.optimizationLevel.1%",
            "%xlang.config.build.optimizationLevel.2%",
            "%xlang.config.build.optimizationLevel.3%"
          ],
          "markdownDescription": "%xlang.config.build.optimizationLevel%",
          "scope": "resource"
        },
        "xlang.build.debugInfo": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%xlang.config.build.debugInfo%",
          "scope": "resource"
        },
        "xlang.build.outputName": {
          "type": "string",
          "default": "",
          "markdownDescription": "%xlang.config.build.outputName%",
          "scope": "resource"
        },
        "xlang.workspaceSymbol.maxFiles": {
          "type": "integer",
          "default": 2000,
          "minimum": 100,
          "maximum": 50000,
          "markdownDescription": "%xlang.config.workspaceSymbol.maxFiles%",
          "scope": "resource"
        },
        "xlang.workspaceSymbol.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.git/**",
            "**/out/**",
            "**/dist/**",
            "**/target/**",
            "**/build/**"
          ],
          "markdownDescription": "%xlang.config.workspaceSymbol.excludePatterns%",
          "scope": "resource"
        }
      }
    },
    "configurationDefaults": {
      "[x]": {
        "editor.defaultFormatter": "xlang.vscode-xlang",
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.codeLens": true,
        "editor.semanticHighlighting.enabled": true
      }
    },
    "commands": [
      {
        "command": "xlang.restartServer",
        "title": "%xlang.command.restartServer%",
        "category": "Xlang"
      },
      {
        "command": "xlang.showServerOutput",
        "title": "%xlang.command.showServerOutput%",
        "category": "Xlang"
      },
      {
        "command": "xlang.openSettings",
        "title": "%xlang.command.openSettings%",
        "category": "Xlang"
      },
      {
        "command": "xlang.runFile",
        "title": "%xlang.command.runFile%",
        "category": "Xlang"
      },
      {
        "command": "xlang.buildFile",
        "title": "%xlang.command.buildFile%",
        "category": "Xlang"
      },
      {
        "command": "xlang.checkFile",
        "title": "%xlang.command.checkFile%",
        "category": "Xlang"
      },
      {
        "command": "xlang.buildProject",
        "title": "%xlang.command.buildProject%",
        "category": "Xlang"
      },
      {
        "command": "xlang.formatDocument",
        "title": "%xlang.command.formatDocument%",
        "category": "Xlang"
      },
      {
        "command": "xlang.refreshCodeLens",
        "title": "%xlang.command.refreshCodeLens%",
        "category": "Xlang"
      }
    ],
    "snippets": [
      {
        "language": "x",
        "path": "./snippets/x.json"
      }
    ],
    "iconThemes": [
      {
        "id": "xlang-icons",
        "label": "Xlang Icons",
        "path": "./icons/xlang-icon-theme.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "xlang-parse",
        "label": "%xlang.problemMatcher.parse%",
        "owner": "x",
        "source": "xlang",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^parse error at (\\d+):(\\d+):\\s*(.+)$",
          "line": 1,
          "column": 2,
          "message": 3
        }
      },
      {
        "name": "xlang-typeck",
        "label": "%xlang.problemMatcher.typeck%",
        "owner": "x",
        "source": "xlang",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^typeck error:\\s*(.+?)\\s+at\\s+(\\d+):(\\d+)\\s*$",
          "message": 1,
          "line": 2,
          "column": 3
        }
      },
      {
        "name": "xlang-generic",
        "label": "%xlang.problemMatcher.generic%",
        "owner": "x",
        "source": "xlang",
        "fileLocation": "relative",
        "pattern": {
          "regexp": "^(.*?)(?:\\s+at\\s+|\\s+in\\s+)(\\S+):(\\d+):(\\d+)",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "xlang",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "%xlang.taskDefinition.task.description%",
            "enum": [
              "build",
              "build-file",
              "run",
              "check"
            ]
          }
        }
      }
    ],
    "walkthroughs": [
      {
        "id": "xlang.welcome",
        "title": "%xlang.walkthrough.welcome.title%",
        "description": "%xlang.walkthrough.welcome.description%",
        "steps": [
          {
            "id": "open.project",
            "title": "%xlang.walkthrough.openProject.title%",
            "description": "%xlang.walkthrough.openProject.description%",
            "media": {
              "markdown": "%xlang.walkthrough.openProject.media%"
            }
          },
          {
            "id": "build.compiler",
            "title": "%xlang.walkthrough.buildCompiler.title%",
            "description": "%xlang.walkthrough.buildCompiler.description%",
            "media": {
              "markdown": "%xlang.walkthrough.buildCompiler.media%"
            }
          },
          {
            "id": "open.x.file",
            "title": "%xlang.walkthrough.openXFile.title%",
            "description": "%xlang.walkthrough.openXFile.description%",
            "media": {
              "markdown": "%xlang.walkthrough.openXFile.media%"
            }
          },
          {
            "id": "run.file",
            "title": "%xlang.walkthrough.runFile.title%",
            "description": "%xlang.walkthrough.runFile.description%",
            "media": {
              "markdown": "%xlang.walkthrough.runFile.media%"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
