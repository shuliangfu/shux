{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Shux",
  "scopeName": "source.x",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#imports" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#literals" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash", "match": "//.*$" },
        { "name": "comment.line.number-sign", "match": "#.*$" },
        { "begin": "/\\*", "end": "\\*/", "name": "comment.block" }
      ]
    },

    "strings": {
      "patterns": [
        {
          "begin": "\"", "end": "\"", "name": "string.quoted.double",
          "patterns": [
            { "name": "constant.character.escape", "match": "\\\\." }
          ]
        }
      ]
    },

    "imports": {
      "patterns": [
        {
          "comment": "绑定 import：const mod = import(\"path\")",
          "match": "\\b(const)\\s+(\\w+)\\s*=\\s*(import)\\s*\\(\\s*(\"[^\"]*\")\\s*\\)",
          "captures": {
            "1": { "name": "storage.type" },
            "2": { "name": "variable.other.constant" },
            "3": { "name": "keyword.control.import" },
            "4": { "name": "string.quoted.double" }
          }
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "comment": "结构体属性 allow(padding)",
          "match": "\\ballow\\((padding)\\)",
          "captures": {
            "0": { "name": "meta.attribute.shux" },
            "1": { "name": "constant.other.attribute" }
          }
        }
      ]
    },

    "struct-body": {
      "patterns": [
        {
          "comment": "结构体定义体：字段名与类型分色",
          "begin": "(\\b(?:allow\\(padding\\)\\s+)?)(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\{",
          "beginCaptures": {
            "1": { "name": "meta.attribute.shux" },
            "2": { "name": "storage.type" },
            "3": { "name": "entity.name.type" }
          },
          "end": "\\}",
          "name": "meta.block.struct",
          "patterns": [
            { "include": "#comments" },
            {
              "comment": "结构体字段名（variable.other.readwrite 在主流主题中有独立颜色）",
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*:",
              "captures": {
                "1": { "name": "variable.other.readwrite" }
              }
            },
            { "include": "#types" },
            { "include": "#literals" },
            { "include": "#operators" }
          ]
        }
      ]
    },

    "enum-body": {
      "patterns": [
        {
          "comment": "枚举定义体：变体名高亮",
          "begin": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*\\{",
          "beginCaptures": {
            "1": { "name": "storage.type" },
            "2": { "name": "entity.name.type" }
          },
          "end": "\\}",
          "name": "meta.block.enum",
          "patterns": [
            { "include": "#comments" },
            {
              "match": "\\b([A-Z][A-Z0-9_]{1,})\\b",
              "name": "constant.other.enum"
            },
            { "include": "#operators" }
          ]
        }
      ]
    },

    "declarations": {
      "patterns": [
        { "include": "#attributes" },
        { "include": "#struct-body" },
        { "include": "#enum-body" },
        {
          "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function" },
            "2": { "name": "entity.name.function" }
          }
        },
        {
          "match": "\\b(extern)\\s+(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.modifier" },
            "2": { "name": "storage.type.function" },
            "3": { "name": "entity.name.function" }
          }
        },
        {
          "comment": "无花括号的 struct/enum/trait 声明（如前向声明）",
          "match": "\\b(struct|enum|trait)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type" },
            "2": { "name": "entity.name.type" }
          }
        },
        {
          "match": "\\b(let)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type" },
            "2": { "name": "variable.other.readwrite" }
          }
        },
        {
          "match": "\\b(const)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type" },
            "2": { "name": "variable.other.constant" }
          }
        },
        {
          "comment": "函数调用；排除 allow(padding) 属性",
          "match": "\\b(?!allow\\b)([A-Za-z_][A-Za-z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function" }
          }
        },
        {
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function" }
          }
        },
        {
          "match": "\\.([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.member" }
          }
        },
        {
          "comment": "match 臂 / goto 标签",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*:",
          "captures": {
            "1": { "name": "entity.name.label" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        { "name": "storage.type", "match": "\\bstruct\\b" },
        { "name": "storage.type", "match": "\\benum\\b" },
        { "name": "storage.type", "match": "\\btrait\\b" },
        { "name": "storage.type", "match": "\\bimpl\\b" },
        { "name": "storage.type.function", "match": "\\bfunction\\b" },
        { "name": "storage.type", "match": "\\blet\\b" },
        { "name": "storage.type", "match": "\\bconst\\b" },
        { "name": "storage.modifier", "match": "\\bextern\\b" },
        { "name": "keyword.control", "match": "\\b(async|await)\\b" },
        { "name": "keyword.control", "match": "\\b(unsafe)\\b" },
        { "name": "keyword.control", "match": "\\b(if|else|match)\\b" },
        { "name": "keyword.control", "match": "\\b(while|for|loop)\\b" },
        { "name": "keyword.control", "match": "\\b(break|continue)\\b" },
        { "name": "keyword.control", "match": "\\breturn\\b" },
        { "name": "keyword.control", "match": "\\b(defer|goto|panic)\\b" },
        { "name": "keyword.control", "match": "\\bimport\\b" },
        { "name": "keyword.other", "match": "\\b(self|as)\\b" },
        { "name": "keyword.other", "match": "\\ballow\\b" },
        { "name": "keyword.control", "match": "\\b_\\b" }
      ]
    },

    "types": {
      "patterns": [
        {
          "match": "\\b(i32|i64|u8|u32|u64|usize|isize)\\b",
          "name": "support.type.primitive"
        },
        {
          "match": "\\b(f32|f64)\\b",
          "name": "support.type.primitive"
        },
        {
          "match": "\\b(bool|void)\\b",
          "name": "support.type.primitive"
        },
        {
          "match": "\\b(i32x4|i32x8|i32x16|u32x4|u32x8|u32x16)\\b",
          "name": "support.type.primitive"
        },
        {
          "comment": "泛型类型参数 Option<T> / Result<T,E>",
          "begin": "\\b([A-Z][A-Za-z0-9_]*)<",
          "beginCaptures": {
            "1": { "name": "support.type" }
          },
          "end": ">",
          "name": "meta.type.generic",
          "patterns": [
            { "include": "#types" },
            { "include": "#literals" },
            { "name": "punctuation.separator", "match": "," }
          ]
        },
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
          "name": "support.type"
        },
        {
          "comment": "Enum variants: UPPER_CASE outside enum bodies",
          "match": "\\b[A-Z][A-Z0-9_]{1,}\\b",
          "name": "constant.other.enum"
        }
      ]
    },

    "literals": {
      "patterns": [
        { "name": "constant.language", "match": "\\b(true|false)\\b" },
        {
          "name": "constant.numeric",
          "match": "\\b(0[xX][0-9a-fA-F]+|0[oO][0-7]+|0[bB][01]+|[0-9]+)([uU]?[iI]?(8|16|32|64|size))?\\b"
        },
        {
          "name": "constant.numeric.float",
          "match": "\\b[0-9]*\\.[0-9]+([eE][+-]?[0-9]+)?[fF]?\\b"
        }
      ]
    },

    "operators": {
      "patterns": [
        { "name": "keyword.operator", "match": "=>|->" },
        { "name": "keyword.operator", "match": "==|!=|<=|>=|<<|>>|&&|\\|\\||[+\\-*/%&|^!~=?<>]" },
        { "name": "punctuation.section.braces", "match": "[\\{\\}]" },
        { "name": "punctuation.section.brackets", "match": "[\\[\\]]" },
        { "name": "punctuation.section.parens", "match": "[\\(\\)]" },
        { "name": "punctuation.separator", "match": "[,;:]" },
        { "name": "punctuation.separator", "match": "\\." }
      ]
    }
  }
}
