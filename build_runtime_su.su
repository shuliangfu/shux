// build_runtime_su.su — build_tool 完全无 C：run_step 与 patch 的 .su 实现
//
// 与 build_runner.su 配合：本文件提供 build_run_step(step_id, shu_path)，由
// build_runner.su 的 entry 调用。
// 链接时仅需 crt0 + build_runner.o + build_tool.o + build_runtime_su.o + -lc，不再链接
// build_runtime.c。
// 字面量与 build_runtime.c 的 run_step 一致；patch 使用 libc 的
// fopen/fread/fwrite/strstr/memmove。

/** libc：执行命令行。 */
extern function system(cmd: *u8): i32;
/** libc：文件与内存，供 patch 使用。 */
extern function fopen(path: *u8, mode: *u8): *u8;
extern function fclose(f: *u8): i32;
extern function fseek(f: *u8, off: i64, whence: i32): i32;
extern function ftell(f: *u8): i64;
extern function fread(ptr: *u8, sz: i64, n: i64, f: *u8): i64;
extern function fwrite(ptr: *u8, sz: i64, n: i64, f: *u8): i64;
extern function strstr(hay: *u8, needle: *u8): *u8;
extern function strlen(s: *u8): i32;
extern function memmove(dest: *u8, src: *u8, n: i64): *u8;
extern function memcpy(dest: *u8, src: *u8, n: i64): *u8;
extern function malloc(n: i64): *u8;
extern function free(p: *u8): void;

/** 将 path（NUL 结尾）复制到 buf[off]，返回 off+len 或 -1 若溢出。 */
function copy_path(buf: *u8, size: i32, off: i32, path: *u8): i32 {
  let i: i32 = 0;
  while (path[i] != 0 && off + i < size - 1) {
    buf[off + i] = path[i];
    i = i + 1;
  }
  if (off + i >= size) { return -1; }
  return off + i;
}

/** 将 lit[0..len) 复制到 buf[off]，返回 off+len 或 -1 若溢出。 */
function append_lit(buf: *u8, size: i32, off: i32, lit: *u8, len: i32): i32 {
  if (off + len >= size) { return -1; }
  let i: i32 = 0;
  while (i < len) {
    buf[off + i] = lit[i];
    i = i + 1;
  }
  return off + len;
}

/** 执行 step_id 对应的 patch（1 pipeline_gen.c，3 driver_gen.c）。step 6
* 不再补丁，codegen 已对 source/out_buf 生成 ->。返回 0 成功，-1 失败。 */
function build_patch_after_step(step_id: i32): i32 {
  if (step_id == 1) { return build_patch_pipeline_gen_c(); }
  if (step_id == 3) { return build_patch_driver_gen_c(); }
  return 0;
}

/** 从 buf 起逐字节扫描，找到与 p 相同的地址的偏移（即 p 在 buf
* 中的下标）。若未找到返回 -1。 */
function buf_offset(buf: *u8, p: *u8): i32 {
  let i: i32 = 0;
  while (i < 524288) {
    if (buf + i == p) { return i; }
    i = i + 1;
  }
  return -1;
}

/** 对 buf 做一次 from→to 替换（从第一次出现处）；cur_len
* 为当前逻辑长度（含 NUL）。返回新长度或 -1。用下标复制避免指针+整型。
*/
function replace_one(buf: *u8, cur_len: i32, from: *u8, from_len: i32, to: *u8, to_len: i32): i32 {
  let p: *u8 = strstr(buf, from);
  if (p == 0) { return cur_len; }
  let pos: i32 = buf_offset(buf, p);
  if (pos < 0) { return -1; }
  let tail_len: i32 = cur_len - pos - from_len;
  if (tail_len < 0) { return -1; }
  if (to_len > from_len) {
    let i: i32 = tail_len - 1;
    while (i >= 0) {
      buf[pos + to_len + i] = buf[pos + from_len + i];
      i = i - 1;
    }
  }
  let j: i32 = 0;
  while (j < to_len) {
    buf[pos + j] = to[j];
    j = j + 1;
  }
  if (to_len < from_len) {
    let i: i32 = 0;
    while (i < tail_len) {
      buf[pos + to_len + i] = buf[pos + from_len + i];
      i = i + 1;
    }
  }
  return cur_len - from_len + to_len;
}

/** 在 buf 中反复替换 from→to 直到无匹配。len 为 strlen(buf)（不含
* NUL）。返回 0 成功。 */
function replace_all(buf: *u8, len: i32, from: *u8, from_len: i32, to: *u8, to_len: i32): i32 {
  let n: i32 = len + 1;
  let next: i32 = replace_one(buf, n, from, from_len, to, to_len);
  while (next != n && next >= 0) {
    n = next;
    next = replace_one(buf, n, from, from_len, to, to_len);
  }
  return 0;
}

