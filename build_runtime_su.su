/** driver_gen.c：slice . -> -> 与 preprocess_su_buf 签名、run_compiler_c 包装。 */
function build_patch_driver_gen_c(): i32 {
  let path: [16]u8 = [100,114,105,118,101,114,95,103,101,110,46,99,0,0,0,0];
  let mode_r: [3]u8 = [114,98,0];
  let mode_w: [3]u8 = [119,98,0];
  let f: *u8 = fopen(path, mode_r);
  if (f == 0) { return -1; }
  if (fseek(f, 0, 2) != 0) { fclose(f); return -1; }
  let sz: i64 = ftell(f);
  if (sz <= 0 || sz >= 524288) { fclose(f); return -1; }
  fseek(f, 0, 0);
  let buf: *u8 = malloc(sz + 256);
  if (buf == 0) { fclose(f); return -1; }
  if (fread(buf, 1, sz, f) != sz) { free(buf); fclose(f); return -1; }
  buf[sz] = 0;
  fclose(f);
  /* slice . -> ->、preprocess_su_buf 签名、run_compiler_c 均已从源头产出，不再补丁
  */
  f = fopen(path, mode_w);
  if (f == 0) { free(buf); return -1; }
  let len: i32 = strlen(buf);
  let len64: i64 = len;
  if (fwrite(buf, 1, len64, f) != len64) { fclose(f); free(buf); return -1; }
  fclose(f);
  free(buf);
  return 0;
}

/** pipeline_gen.c：从源头去补丁。仅必要时插入 parser_parse_into extern，并追加
#include "pipeline_glue.c"（与 build_runtime.c 一致，由 cc 编译时包含）。 */
function build_patch_pipeline_gen_c(): i32 {
  let path: [20]u8 = [112,105,112,101,108,105,110,101,95,103,101,110,46,99,0,0,0,0,0,0];
  let mode_r: [3]u8 = [114,98,0];
  let mode_w: [3]u8 = [119,98,0];
  let f: *u8 = fopen(path, mode_r);
  if (f == 0) { return -1; }
  if (fseek(f, 0, 2) != 0) { fclose(f); return -1; }
  let sz: i64 = ftell(f);
  if (sz <= 0 || sz >= 524288) { fclose(f); return -1; }
  fseek(f, 0, 0);
  let buf: *u8 = malloc(sz + 4096);
  if (buf == 0) { fclose(f); return -1; }
  if (fread(buf, 1, sz, f) != sz) { free(buf); fclose(f); return -1; }
  buf[sz] = 0;
  fclose(f);
  let cur_sz: i64 = sz;
  /* 若调用了 parser_parse_into 但缺少其 extern，则插入（与 build_runtime.c 2a
  一致） */
  let need1: [24]u8 =
  [112,97,114,115,101,114,95,112,97,114,115,101,95,105,110,116,111,40,97,114,101,110,97,0];
  let need2: [39]u8 =
  [112,97,114,115,101,114,95,112,97,114,115,101,95,105,110,116,111,40,115,116,114,117,99,116,32,97,1
  15,116,95,65,83,84,65,114,101,110,97,0];
  let anchor: [35]u8 =
  [101,120,116,101,114,110,32,118,111,105,100,32,112,97,114,115,101,114,95,112,97,114,115,101,95,105
  ,110,116,111,95,105,110,105,116,40,0];
  let ins: [132]u8 =
  [101,120,116,101,114,110,32,115,116,114,117,99,116,32,112,97,114,115,101,114,95,80,97,114,115,101,
  73,110,116,111,82,101,115,117,108,116,32,112,97,114,115,101,114,95,112,97,114,115,101,95,105,110,1
  16,111,40,115,116,114,117,99,116,32,97,115,116,95,65,83,84,65,114,101,110,97,32,42,44,32,115,116,1
  14,117,99,116,32,97,115,116,95,77,111,100,117,108,101,32,42,44,32,115,116,114,117,99,116,32,115,10
  4,117,108,97,110,103,95,115,108,105,99,101,95,117,105,110,116,56,95,116,32,42,41,59,10];
  if (strstr(buf, need1) != 0 && strstr(buf, need2) == 0) {
    let pos: *u8 = strstr(buf, anchor);
    if (pos != 0) {
      let pos_i: i32 = buf_offset(buf, pos);
      if (pos_i >= 0) {
        let tail: i64 = cur_sz - pos_i;
        if (tail > 0 && cur_sz + 132 <= 524288) {
          memmove(buf + pos_i + 132, buf + pos_i, tail);
          memcpy(buf + pos_i, ins, 132);
          cur_sz = cur_sz + 132;
        }
      }
    }
  }
  /* 追加 #include "pipeline_glue.c"，由 cc 编译时包含，不再读入整份文件 */
  let inc: [28]u8 =
  [10,35,105,110,99,108,117,100,101,32,34,112,105,112,101,108,105,110,101,95,103,108,117,101,46,99,3
  4,10];
  memcpy(buf + cur_sz, inc, 28);
  cur_sz = cur_sz + 28;
  f = fopen(path, mode_w);
  if (f == 0) { free(buf); return -1; }
  if (fwrite(buf, 1, cur_sz, f) != cur_sz) { fclose(f); free(buf); return -1; }
  fclose(f);
  free(buf);
  return 0;
}
