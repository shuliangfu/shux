*.o.fast
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# 链接与中间文件
*.ll
*.bc
*.asm
# 编译器输出的 .s（保留 compiler/src/asm/ 手写启动/运行时汇编）
*.s
!compiler/src/asm/*.s
# 内核测试需要的手写 .s 汇编文件
!tests/kernel/*.s
# G-03：Linux x86_64 typeck 双精度位取（Makefile 链入，非编译器临时 .s）
!compiler/src/typeck/typeck_f64_bits_x86_64.s
!compiler/src/typeck/typeck_f64_bits_arm64.s
!compiler/src/typeck/typeck_f64_bits_aarch64_elf.s
!compiler/src/typeck/typeck_f64_bits_x86_64_mingw.s


