!.vscode/extensions.json
.cursor/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# Hermes / 相关工具链本地缓存目录（不提交）
.hermes/

# OS
.DS_Store
Thumbs.db
*.log

# --- compiler 目录：构建产物与生成文件（不提交） ---
# 可执行文件（根已有 shu/shu-c，此处补 compiler 下特有）
compiler/shu_driver
compiler/build_tool
# 构建目录（含历史手工 build_v* / build_final 等）
compiler/build_asm/
compiler/build/
compiler/build_*/
compiler/su/
# 本地调试 scratch（保留已提交的 _stubs.c / _su_stubs*.c）
compiler/_*
!compiler/_stubs.c
!compiler/_su_stubs.c
!compiler/_su_stubs2.c
!compiler/_stubs_driver.c
compiler/0
compiler/bootstrap_shu
compiler/shu_stage1
compiler/shu_stage2
compiler/shu_su_dbg
compiler/shu_asm2
compiler/shu-su
compiler/shu-su2
compiler/shu_asm
compiler/asm_min
compiler/asm_v2
compiler/shu_stage1_test
# 由 -E 或脚本生成的 C 源文件（parser_gen.c, driver_gen.c, pipeline_gen.c, typeck_gen.c, codegen_gen.c 等）
compiler/*_gen.c
compiler/**/*_gen.c
# Stage2 验证脚本产出的第二代生成 C（token_gen2.c 等）
compiler/*_gen2.c
compiler/**/*_gen2.c
compiler/std_fs_gen.c
# 生成 C 的快照/副本（与 *_gen.c 等价，构建时产出，不提交）
compiler/*_gen_new.c
# .su 自举时生成的中间 C（typeck_su_su.c, codegen_su_su.c）
compiler/*_su_su.c
# 备份与临时（含 .bak2, .bak3 等）
compiler/*.new
compiler/*.bak
compiler/*.bak*
compiler/**/*.bak*
compiler/*.append
# 调试与临时（perl/汇编烟测、链接器 .o.tmp、编辑器缓冲）
compiler/scripts/lldb_crash_bt.txt
compiler/test_perl.txt
compiler/test_pre_out.s
*.o.tmp
/rvwbuf.tmp
**/*.su.bak
# LLDB：本地导出的会话/断点命令脚本（非仓库约定资产）
compiler/.lldb_*
# 本地 scratch：tmp_* 调试草稿（compiler/ 与仓库根目录）
compiler/tmp_*
compiler/tmp_bisect/
/tmp_*.su
/tmp_*.c

