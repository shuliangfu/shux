/**
 * Cookbook ERR-01：错误码→模块 base 与 sidecar 种类（STD-020）。
 */
const { error_base_io, error_code_to_module_base, error_mod_tag_from_base, error_mod_tag_fs, error_mod_tag_io, error_module_sidecar_kind, error_sidecar_errno_i32, io_err_timeout } = import("std.error");

function main(): i32 {
  let base_io: i32 = error_code_to_module_base(io_err_timeout());
  if (base_io != error_base_io()) { return 1; }
  if (error_mod_tag_from_base(base_io) != error_mod_tag_io()) { return 2; }
  if (error_module_sidecar_kind(error_mod_tag_fs()) != error_sidecar_errno_i32()) { return 3; }
  return 0;
}
