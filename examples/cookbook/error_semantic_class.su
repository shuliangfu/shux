/**
 * Cookbook ERR-02：跨模块错误语义类（STD-158）。
 */
const { error_is_cancelled, error_is_timeout, error_recommend_retry, error_sem_cancelled, error_sem_timeout, error_semantic_class, io_err_timeout, net_err_cancelled } = import("std.error");

function main(): i32 {
  let io_to: i32 = io_err_timeout();
  if (error_semantic_class(io_to) != error_sem_timeout()) { return 1; }
  if (error_is_timeout(io_to) != 1) { return 2; }
  if (error_recommend_retry(io_to) != 1) { return 3; }
  let net_cn: i32 = net_err_cancelled();
  if (error_semantic_class(net_cn) != error_sem_cancelled()) { return 4; }
  if (error_is_cancelled(net_cn) != 1) { return 5; }
  return 0;
}
