/**
 * Cookbook PATH-02：path_clean 连续斜杠折叠（STD-140）。
 */
const path = import("std.path");

function main(): i32 {
  let inp: [7]u8 = [47, 47, 97, 47, 47, 47, 98];
  let out: [16]u8 = [];
  let n: i32 = path.path_clean(&inp[0], 7, &out[0], 16);
  if (n != 4) { return 1; }
  if (out[0] != 47 || out[1] != 97 || out[2] != 47 || out[3] != 98) { return 2; }
  return 0;
}
