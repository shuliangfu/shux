/**
 * Cookbook DYN-01：dynlib open/sym/close 跨平台烟测（STD-027）。
 */
const dynlib = import("std.dynlib");

/** 尝试打开 path；成功返回句柄，否则 0。 */
function try_open(path: *u8): *u8 {
  return dynlib.open(path);
}

function main(): i32 {
  /** "/usr/lib/libSystem.B.dylib" */
  let path_mac: [27]u8 = [
    47, 117, 115, 114, 47, 108, 105, 98, 47, 108, 105, 98, 83, 121, 115, 116, 101, 109, 46, 66, 46, 100, 121, 108, 105, 98, 0
  ];
  /** "libc.so.6" */
  let path_lin: [10]u8 = [108, 105, 98, 99, 46, 115, 111, 46, 54, 0];
  /** "kernel32.dll" */
  let path_win: [13]u8 = [107, 101, 114, 110, 101, 108, 51, 50, 46, 100, 108, 108, 0];
  let lib: *u8 = try_open(&path_mac[0]);
  if (lib == 0) { lib = try_open(&path_lin[0]); }
  if (lib == 0) { lib = try_open(&path_win[0]); }
  if (lib == 0) { return 1; }
  dynlib.close(lib);
  return 0;
}
