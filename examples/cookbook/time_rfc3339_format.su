/**
 * Cookbook TIME-03：format_wall_rfc3339 / wall_local_offset_min（STD-137）。
 */
const time = import("std.time");

function main(): i32 {
  let buf: [32]u8 = [];
  let n: i32 = time.format_wall_rfc3339(&buf[0], 32);
  if (n < 20) { return 1; }
  let off: i32 = time.wall_local_offset_min();
  if (off < -840 || off > 840) { return 2; }
  return 0;
}
