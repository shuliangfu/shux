// Cookbook CLI-01：子命令 + verbose 标志（STD-077）
const cli = import("std.cli");
const env = import("std.env");

function main(): i32 {
  let it: ArgsIter = env.args_iter();
  let res: CliResult = CliResult {
    subcommand_len: 0, help: 0, version: 0, verbose: 0, unknown: 0, positional_count: 0,
    subcommand: [], positional0_len: 0, positional0: []
  };
  let run: [3]u8 = [114, 117, 110];
  let ec: i32 = cli.parse_from_iter(&it, &run[0], 3, &res);
  if (ec == cli.cli_err_help()) { return 0; }
  if (ec != cli.cli_err_ok()) { return 1; }
  if (env.args_iter_count() >= 2) {
    if (res.subcommand_len == 0 && res.positional_count == 0 && res.verbose == 0) {
      return 0;
    }
  }
  return 0;
}
