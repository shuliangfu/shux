// SAFE-004 C4：cstring_new 复制 len 字节并 NUL 结尾；cstr_len 校验。
const ffi = import("std.ffi");

function main(): i32 {
  let src: [4]u8 = [120, 121, 122, 0];
  let p: *u8 = ffi.cstring_new(&src[0], 3);
  if (p == 0 as *u8) {
    return 1;
  }
  if (p[0] != 120 || p[1] != 121 || p[2] != 122 || p[3] != 0) {
    ffi.cstring_free(p);
    return 2;
  }
  let n: i32 = ffi.cstr_len(p);
  if (n != 3) {
    ffi.cstring_free(p);
    return 3;
  }
  ffi.cstring_free(p);
  return 0;
}
