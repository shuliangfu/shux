// STD-092：std.net connect_ctx/accept_ctx/stream_*_ctx + Context 烟测
const net = import("std.net");
const context = import("std.context");
const err = import("std.error");

function main(): i32 {
  let bg: Context = context.background();
  let loopback: Ipv4Addr = Ipv4Addr { a: 127, b: 0, c: 0, d: 1 };
  let buf: u8[1] = [0];
  let p: *u8 = &buf[0];
  let fake: TcpStream = TcpStream { fd: 1 };

  let cancelled: Context = context.with_cancel(bg);
  context.cancel(cancelled);
  if (net.connect_ctx_fd(loopback, 9, cancelled) != net_err_cancelled()) {
    return 1;
  }
  if (net.connect_ipv6_ctx_fd(net.ipv6_loopback(), 9, cancelled) != net_err_cancelled()) {
    return 2;
  }

  let expired: Context = context.with_deadline(bg, 1);
  if (net.connect_ctx_fd(loopback, 9, expired) != net_err_timeout()) {
    return 3;
  }
  if (net.stream_read_ctx(fake, p, 0, expired) != net_err_timeout()) {
    return 4;
  }
  if (net.stream_write_ctx(fake, p, 0, expired) != net_err_timeout()) {
    return 5;
  }

  let listener: TcpListener = net.listen(loopback, 0);
  if (listener.fd < 0) {
    return 6;
  }
  if (net.accept_ctx_fd(listener, cancelled) != net_err_cancelled()) {
    net.close_listener(listener);
    return 7;
  }
  if (net.accept_ctx_fd(listener, expired) != net_err_timeout()) {
    net.close_listener(listener);
    return 8;
  }

  context.free(cancelled);
  context.free(expired);
  net.close_listener(listener);
  return 0;
}
