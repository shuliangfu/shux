// 测试 std.net 切片化 UDP API：udp_recv_many_buf、udp_send_many_buf（指针+段数）
// 覆盖 net_udp_recv_many_buf_c/net_udp_send_many_buf_c 的编译与链接；bind 后 recv
// 无数据、send 一发。
const net = import("std.net");
const driver = import("std.io.driver");

function main(): i32 {
  let addr: Ipv4Addr = Ipv4Addr { a: 127, b: 0, c: 0, d: 1 };
  let sock: UdpSocket = net.udp_bind(addr, 0);
  if (sock.fd < 0) { return 1; }
  let recv_buf: u8[64] = 0;
  let bufs: Buffer[1] = [ Buffer { ptr: &recv_buf[0], len: 64, handle: 0 } ];
  let out_sizes: i32[1] = [0];
  let out_addrs: u32[1] = [0];
  let out_ports: u32[1] = [0];
  let n_recv: i32 = net.udp_recv_many_buf(sock, &bufs[0], 1, 1, &out_sizes[0], &out_addrs[0],
  &out_ports[0]);
  let dst_addr: u32 = net.addr_to_u32(addr);
  let dst_port: u32 = 9;
  let addrs: u32[1] = [dst_addr];
  let ports: u32[1] = [dst_port];
  let payload: u8[4] = [1, 2, 3, 4];
  let send_bufs: Buffer[1] = [ Buffer { ptr: &payload[0], len: 4, handle: 0 } ];
  let n_send: i32 = net.udp_send_many_buf(sock, &addrs[0], &ports[0], &send_bufs[0], 1);
  let c: i32 = net.close_udp(sock);
  if (c != 0) { return 2; }
  if (n_send != 1) { return 3; }
  return 0;
}
