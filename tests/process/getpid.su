// 测试 std.process：getpid()
//
// 【文件职责】本文件为 std.process 当前进程 ID 查询的回归测试。
// 【测试目的】确认 getpid() 返回正整数（当前进程 ID），与 Rust
// std::process::id()、Go os.Getpid 语义一致。
// 【覆盖 API】getpid(): i32。
// 【预期结果】退出码 0 表示 getpid()>0；退出码 1 表示返回值≤0（异常）。
// 【运行方式】./tests/run-process.sh
import std.process;

function main(): i32 {
  let pid: i32 = getpid();
  if (pid <= 0) {
    return 1;
  }
  return 0;
}
