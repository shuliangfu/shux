// STD-077：std.cli 选项/usage 烟测
const cli = import("std.cli");

function main(): i32 {
  let help: u8[6] = [45, 45, 104, 101, 108, 112];
  let hshort: u8[2] = [45, 104];
  let verbose: u8[9] = [45, 45, 118, 101, 114, 98, 111, 115, 101];
  let vname: u8[7] = [118, 101, 114, 98, 111, 115, 101];
  let prog: u8[4] = [116, 111, 111, 108];
  let desc: u8[4] = [100, 101, 109, 111];
  let out: u8[128] = [];
  let n: i32 = 0;

  if (cli.is_help(&help[0], 6) == 0) { return 1; }
  if (cli.match_long(&verbose[0], 9, &vname[0], 7) == 0) { return 2; }
  if (cli.match_short(&hshort[0], 2, 104) == 0) { return 3; }
  n = cli.write_usage(&prog[0], 4, &desc[0], 4, &out[0], 128);
  if (n <= 0) { return 4; }
  if (cli.cli_err_help() != 1) { return 5; }
  return 0;
}
