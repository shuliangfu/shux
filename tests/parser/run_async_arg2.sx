// run_async_arg2.sx — A4/run v2：`run async_fn(i32, i32)` 经 seed 队列传参
/** 双 i32 形参 + await；run 时按序 seed 注入 a、b。 */
async function add_two(a: i32, b: i32): i32 {
  let x: i32 = await a;
  let y: i32 = await b;
  return x + y;
}

function main(): i32 {
  let r: i32 = run add_two(41, 1);
  if (r != 42) {
    return 11;
  }
  let r2: i32 = run add_two(10, 32);
  if (r2 != 42) {
    return 12;
  }
  return 0;
}
