// async_await_io.su — IO-A5 v1：`await read(...)` → submit_read_async + suspend_io + complete
extern function read(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32;

/** await IO 后返回读入字节数。 */
async function io_read_demo(): i32 {
  let buf: [8]u8 = [];
  let n: i32 = await read(0, buf as *u8, 8, 0);
  return n;
}

function main(): i32 {
  return io_read_demo();
}
