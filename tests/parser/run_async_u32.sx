// run_async_u32.sx — run v3：u32 形参 seed 传参
/** u32 形参 + await；run 时 push_u32 / take_u32。 */
async function id_u32(x: u32): i32 {
  let v: u32 = await x;
  return v as i32;
}

function main(): i32 {
  let seed: u32 = 42;
  let r: i32 = run id_u32(seed);
  if (r != 42) {
    return 11;
  }
  return 0;
}
