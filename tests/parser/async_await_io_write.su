// async_await_io_write.su — IO-A5 v1：`await write(...)` → submit_write_async + suspend_io + complete
extern function write(handle: usize, ptr: *u8, len: usize, timeout_ms: u32): i32;

/** await IO 写 pipe/stdout 后返回写入字节数。 */
async function io_write_demo(): i32 {
  let msg: [4]u8 = [104, 105, 10, 0];
  let n: i32 = await write(1, msg as *u8, 3, 0);
  return n;
}

function main(): i32 {
  return io_write_demo();
}
