// 最小复现：arm64_enc 第二函数 enc_prologue 体含 ctx.field 赋值与 if 内无 let 重赋值
import platform.elf;

function enc_u32_le(ctx: *platform.elf.ElfCodegenCtx, val: i32): i32 {
  let buf: [4]u8 = [];
  return platform.elf.append_elf_bytes(ctx, buf, 4);
}

function enc_prologue(ctx: *platform.elf.ElfCodegenCtx, frame_size: i32): i32 {
  ctx.current_frame_size = frame_size;
  if (enc_u32_le(ctx, 1) != 0) { return -1; }
  let imm12: i32 = frame_size;
  if (imm12 > 4095) { imm12 = 4095; }
  return enc_u32_le(ctx, 0);
}
