// run_async_i64.sx — run v3：i64 形参 seed 传参
/** i64 形参 + await；run 时 push_i64 / take_i64。 */
async function id_i64(x: i64): i64 {
  let v: i64 = await x;
  return v;
}

function main(): i32 {
  let seed: i64 = 10000000000;
  let r: i64 = run id_i64(seed);
  if (r != 10000000000) {
    return 11;
  }
  return 0;
}
