// TST-002：std.vec 边界烟测（Vec_i32 push/pop/clear/reserve）
//
// 【文件职责】≥8 边界 case；动态数组基本路径。
// 【运行方式】tests/run-tst-002-boundary-gate.sh
const vec = import("std.vec");

function main(): i32 {
  let v: Vec_i32 = vec.vec_i32_new();
  // case 1：新建为空
  if (vec.vec_i32_is_empty(v) != 1) { return 1; }
  // case 2：新建 cap 为 0（首次 push 懒分配）
  if (vec.vec_i32_capacity(v) != 0) { return 2; }
  // case 3：push 三个元素
  if (vec.vec_i32_push(&v, 10) != 0) { return 3; }
  if (vec.vec_i32_push(&v, 20) != 0) { return 4; }
  if (vec.vec_i32_push(&v, 30) != 0) { return 5; }
  // case 4：长度
  if (vec.vec_i32_len(v) != 3) { return 6; }
  // case 5：get/set
  if (vec.vec_i32_get(v, 1) != 20) { return 7; }
  vec.vec_i32_set(&v, 1, 21);
  if (vec.vec_i32_get(v, 1) != 21) { return 8; }
  // case 6：pop
  let popped: i32 = vec.vec_i32_pop(&v);
  if (popped != 30) { return 9; }
  if (vec.vec_i32_len(v) != 2) { return 10; }
  // case 7：append_slice
  let tail: i32[2] = [40, 50];
  if (vec.vec_i32_append_slice(&v, &tail[0], 2) != 0) { return 11; }
  if (vec.vec_i32_len(v) != 4) { return 12; }
  // case 8：clear 后为空
  vec.vec_i32_clear(&v);
  if (vec.vec_i32_is_empty(v) != 1) { return 13; }
  // case 9：truncate + deinit
  if (vec.vec_i32_push(&v, 1) != 0) { return 14; }
  vec.vec_i32_truncate(&v, 0);
  if (vec.vec_i32_len(v) != 0) { return 15; }
  vec.vec_i32_deinit(&v);
  return 0;
}
