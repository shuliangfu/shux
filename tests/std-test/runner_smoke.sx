// STD-145：std.test 统一 runner 烟测（pass + skip + summary）
const test = import("std.test");

/** 简单断言用例：1+1==2。 */
function case_add(): i32 {
  if (test.expect_eq_i32(1 + 1, 2) != 0) { return 1; }
  return 0;
}

function main(): i32 {
  test.runner_reset();
  let n_ok: [7]u8 = [99, 97, 115, 101, 95, 111, 107];
  test.runner_case(&n_ok[0], 7, case_add());
  let n_skip: [9]u8 = [99, 97, 115, 101, 95, 115, 107, 105, 112];
  test.runner_skip(&n_skip[0], 9);
  return test.runner_finish();
}
