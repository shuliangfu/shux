// Minimal repro: let [64]u8 = [], &buf[0], recursive call
const ast = import("ast");

extern function pipeline_type_named_name_into(arena: *ASTArena, type_ref: i32, out: *u8): i32;
extern function pipeline_type_kind_ord_at(arena: *ASTArena, type_ref: i32): i32;
extern function pipeline_type_elem_ref_at(arena: *ASTArena, type_ref: i32): i32;
extern function pipeline_type_array_size_at(arena: *ASTArena, type_ref: i32): i32;

function helper_size(module: *Module, arena: *ASTArena, ty_ref: i32, depth: i32): i32 {
  if (ty_ref <= 0 || depth > 64) {
    return 0;
  }
  let kind_ord: i32 = pipeline_type_kind_ord_at(arena, ty_ref);
  if (kind_ord == 10) {
    let elem_ref: i32 = pipeline_type_elem_ref_at(arena, ty_ref);
    let asz: i32 = pipeline_type_array_size_at(arena, ty_ref);
    if (elem_ref <= 0 || asz <= 0) {
      return 0;
    }
    let es: i32 = helper_size(module, arena, elem_ref, depth + 1);
    if (es <= 0) {
      return 0;
    }
    return asz * es;
  }
  if (kind_ord == 8) {
    let nm_buf: [64]u8 = [];
    let nlen: i32 = pipeline_type_named_name_into(arena, ty_ref, &nm_buf[0]);
    return nlen;
  }
  return 4;
}

function main(): i32 {
  return 0;
}
