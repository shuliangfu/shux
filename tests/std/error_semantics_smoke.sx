// tests/std/error_semantics_smoke.sx — STD-158：跨模块错误语义类烟测
const err = import("std.error");

function main(): i32 {
  if (error_semantic_class(io_err_timeout()) != error_sem_timeout()) { return 1; }
  if (error_semantic_class(net_err_cancelled()) != error_sem_cancelled()) { return 2; }
  if (error_semantic_class(http_err_timeout()) != error_sem_timeout()) { return 3; }
  if (error_semantic_class(fs_err_not_found()) != error_sem_not_found()) { return 4; }
  if (error_is_timeout(io_err_timeout()) != 1) { return 5; }
  if (error_is_cancelled(net_err_cancelled()) != 1) { return 6; }
  if (error_is_not_found(error_code_not_found()) != 1) { return 7; }
  if (error_recommend_retry(io_err_timeout()) != 1) { return 8; }
  if (error_recommend_retry(fs_err_not_found()) != 0) { return 9; }
  if (error_code_to_module_base(io_err_timeout()) != error_base_io()) { return 10; }
  if (error_code_to_module_base(http_err_cancelled()) != error_base_net()) { return 11; }
  return 0;
}
