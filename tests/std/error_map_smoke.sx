// tests/std/error_map_smoke.sx вЂ” STD-020пјљй”™иЇЇз Ѓв†’жЁЎеќ— base дёЋ last_error дѕ§иЅ¦з§Ќз±»зѓџжµ‹
const err = import("std.error");

function main(): i32 {
  let base_io: i32 = code_to_module_base(io_err_timeout());
  if (base_io != base_io()) { return 1; }
  if (mod_tag_from_base(base_io) != mod_tag_io()) { return 2; }
  if (mod_base_from_tag(mod_tag_io()) != base_io()) { return 3; }
  let base_fs: i32 = code_to_module_base(fs_err_not_found());
  if (base_fs != base_fs()) { return 4; }
  if (module_sidecar_kind(mod_tag_fs()) != sidecar_errno()) { return 5; }
  if (module_sidecar_kind(mod_tag_db()) != sidecar_db_struct()) { return 6; }
  if (module_sidecar_kind(mod_tag_io()) != sidecar_none()) { return 7; }
  if (code_to_module_base(code_invalid()) != 0) { return 8; }
  if (mod_base_from_tag(mod_tag_db()) != 0) { return 9; }
  return 0;
}
