// STD-128：流式 CSV reader/writer 往返烟测
const csv = import("std.csv");

function main(): i32 {
  let blob: [16]u8 = [97, 108, 105, 99, 101, 98, 111, 98, 49, 50, 51, 0, 0, 0, 0, 0];
  let starts: [3]i32 = [0, 5, 8];
  let lens: [3]i32 = [5, 3, 3];
  let out: [128]u8 = [];
  let w: StreamCsvWriter = StreamCsvWriter { out: 0, out_cap: 0, out_len: 0 };
  stream_writer_init(&w, &out[0], 128);
  if (stream_writer_append_row(&w, &blob[0], &starts[0], &lens[0], 3) != 0) { return 1; }
  let starts2: [3]i32 = [10, 11, 12];
  let lens2: [3]i32 = [1, 0, 1];
  if (stream_writer_append_row(&w, &blob[0], &starts2[0], &lens2[0], 3) != 0) { return 2; }
  let total: i32 = stream_writer_len(w);
  if (total <= 0) { return 3; }
  let r: StreamCsvReader = StreamCsvReader { ptr: 0, len: 0, offset: 0 };
  stream_reader_init(&r, &out[0], total);
  let pstarts: [4]i32 = [0, 0, 0, 0];
  let plens: [4]i32 = [0, 0, 0, 0];
  let cnt: i32 = 0;
  if (stream_reader_next_row(&r, &pstarts[0], &plens[0], 4, &cnt) != 0) { return 4; }
  if (cnt != 3 || plens[0] != 5 || plens[1] != 3 || plens[2] != 3) { return 5; }
  cnt = 0;
  if (stream_reader_next_row(&r, &pstarts[0], &plens[0], 4, &cnt) != 0) { return 6; }
  if (cnt != 3 || plens[1] != 0) { return 7; }
  if (stream_reader_next_row(&r, &pstarts[0], &plens[0], 4, &cnt) != 1) { return 8; }
  if (stream_reader_eof(r) != 1) { return 9; }
  if (csv_stream_smoke() != 0) { return 10; }
  return 0;
}
