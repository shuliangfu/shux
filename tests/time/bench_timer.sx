// STD-133：std.time benchmark 计时器烟测
//
// 校验 elapsed / lap / reset 与 sleep 下限（宽松，兼容调度抖动）。
const time = import("std.time");

function main(): i32 {
  let t: time.Timer = time.timer_start();
  // CI 调度抖动大：sleep 100ms，阈值放宽到 5ms（仍验证单调递增）
  time.sleep_ms(100);
  let ns: i64 = time.timer_elapsed_ns(t);
  if (ns < 5000000) { return 1; }
  let ms: i64 = time.timer_elapsed_ms(t);
  if (ms < 5) { return 2; }
  let us: i64 = time.timer_elapsed_us(t);
  if (us < 5000) { return 3; }
  let sec: i64 = time.timer_elapsed_sec(t);
  if (sec < 0) { return 4; }

  time.timer_reset(&t);
  time.sleep_ms(60);
  let after_reset: i64 = time.timer_elapsed_ns(t);
  if (after_reset < 3000000) { return 5; }
  /* macOS 单调时钟 reset 后基准可能仍接近全局起点，勿与 reset 前 ns 比较。 */

  time.timer_reset(&t);
  time.sleep_ms(40);
  let lap1: i64 = time.timer_lap_ns(&t);
  if (lap1 < 3000000) { return 7; }
  time.sleep_ms(40);
  let lap2: i64 = time.timer_lap_ns(&t);
  if (lap2 < 3000000) { return 8; }
  let tail: i64 = time.timer_elapsed_ns(t);
  if (tail < 0) { return 9; }
  return 0;
}
