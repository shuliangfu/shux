// STD-137：std.time 墙钟 RFC3339 格式化与时区偏移烟测
const time = import("std.time");

function main(): i32 {
  let buf: u8[32] = [];
  let n: i32 = time.format_wall_rfc3339(&buf[0], 32);
  if (n < 20) { return 1; }
  if (buf[n - 1] != 90) { return 2; }
  let off: i32 = time.wall_local_offset_min();
  if (off < -840 || off > 840) { return 3; }
  if (time.format_timezone_smoke() != 0) { return 4; }
  return 0;
}
