// STD-006：mem_eq 常量时间比较边界
const crypto = import("std.crypto");

function main(): i32 {
  let a: [5]u8 = [10, 20, 30, 40, 50];
  let b: [5]u8 = [10, 20, 30, 40, 50];
  if (crypto.mem_eq(&a[0], &b[0], 5) != 1) { return 1; }
  b[4] = 51;
  if (crypto.mem_eq(&a[0], &b[0], 5) != 0) { return 2; }
  if (crypto.mem_eq(&a[0], &b[0], 0) != 1) { return 3; }
  return 0;
}
