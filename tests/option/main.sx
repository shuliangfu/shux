// CORE-002：Option 类型族 + map/and_then + 泛型 unwrap_or 烟测
const option = import("core.option");

function main(): i32 {
  let none_opt: Option_i32 = option.none_i32();
  let some_opt: Option_i32 = option.some_i32(42);
  let a: i32 = option.unwrap_or_i32(none_opt, 10);
  let b: i32 = option.unwrap_or_i32(some_opt, 10);
  let c: i32 = option.expect_i32(option.some_i32(7));
  let u1: u8 = option.unwrap_or_u8(option.some_u8(3), 0);
  let u2: u8 = option.unwrap_or_u8(option.none_u8(), 5);
  if (!option.is_some_i32(some_opt) || option.is_none_i32(some_opt)) { return -1; }
  if (option.is_some_i32(none_opt) || !option.is_none_i32(none_opt)) { return -2; }
  let o1: Option_i32 = option.or_i32(none_opt, option.some_i32(99));
  let o2: Option_i32 = option.or_i32(some_opt, option.some_i32(99));
  if (!option.is_some_i32(o1) || option.expect_i32(o1) != 99) { return -3; }
  if (option.expect_i32(o2) != 42) { return -4; }
  let a1: Option_i32 = option.and_i32(option.some_i32(1), option.some_i32(2));
  let a2: Option_i32 = option.and_i32(option.none_i32(), option.some_i32(2));
  if (option.expect_i32(a1) != 2) { return -5; }
  if (option.is_some_i32(a2)) { return -6; }
  let uo: Option_u8 = option.or_u8(option.none_u8(), option.some_u8(10));
  if (option.unwrap_or_u8(uo, 0) != 10) { return -7; }
  let eu: u8 = option.expect_u8(option.some_u8(6));
  if (eu != 6) { return -8; }
  if (!option.is_some_u8(option.some_u8(1)) || option.is_none_u8(option.some_u8(1))) { return -9; }
  if (option.is_some_u8(option.none_u8()) || !option.is_none_u8(option.none_u8())) { return -10; }
  let au1: Option_u8 = option.and_u8(option.some_u8(1), option.some_u8(2));
  let au2: Option_u8 = option.and_u8(option.none_u8(), option.some_u8(2));
  if (!option.is_some_u8(au1) || option.expect_u8(au1) != 2) { return -11; }
  if (option.is_some_u8(au2)) { return -12; }
  // map / and_then（eager）
  let m1: i32 = option.expect_i32(map_i32(option.some_i32(3), 6));
  let m2: u8 = option.expect_u8(map_u8(option.some_u8(4), 8));
  let at: i32 = option.expect_i32(and_then_i32(option.some_i32(1), option.some_i32(9)));
  if (m1 != 6 || m2 != 8 || at != 9) { return -13; }
  // 泛型 unwrap_or<i32>
  let g: i32 = unwrap_or<i32>(none_opt.is_some, none_opt.value, 11);
  if (g != 11) { return -14; }
  // Option_ptr_u8
  let buf: [4]u8 = [1, 2, 3, 4];
  let sp: Option_ptr_u8 = some_ptr_u8(buf);
  let mp: Option_ptr_u8 = map_ptr_u8(sp, buf);
  if (!is_some_ptr_u8(mp)) { return -15; }
  let bp: *u8 = expect_ptr_u8(mp);
  if (bp[0] != 1) { return -16; }
  let extra: i32 = m1 + (m2 as i32) + at + g + (bp[0] as i32);
  return a + b + c + u1 + u2 + extra;
}
