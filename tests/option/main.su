// 测试 core.option：Option_i32 / Option_u8 全
// API（none/some/unwrap_or/expect/is_some/is_none、or/and）
import core.option;

function main(): i32 {
  let none_opt: Option_i32 = none_i32();
  let some_opt: Option_i32 = some_i32(42);
  let a: i32 = unwrap_or_i32(none_opt, 10);
  let b: i32 = unwrap_or_i32(some_opt, 10);
  let c: i32 = expect_i32(some_i32(7));
  let u1: u8 = unwrap_or_u8(some_u8(3), 0);
  let u2: u8 = unwrap_or_u8(none_u8(), 5);
  if (!is_some_i32(some_opt) || is_none_i32(some_opt)) { return -1; }
  if (is_some_i32(none_opt) || !is_none_i32(none_opt)) { return -2; }
  let o1: Option_i32 = or_i32(none_opt, some_i32(99));
  let o2: Option_i32 = or_i32(some_opt, some_i32(99));
  if (!is_some_i32(o1) || expect_i32(o1) != 99) { return -3; }
  if (expect_i32(o2) != 42) { return -4; }
  let a1: Option_i32 = and_i32(some_i32(1), some_i32(2));
  let a2: Option_i32 = and_i32(none_i32(), some_i32(2));
  if (expect_i32(a1) != 2) { return -5; }
  if (is_some_i32(a2)) { return -6; }
  let uo: Option_u8 = or_u8(none_u8(), some_u8(10));
  if (unwrap_or_u8(uo, 0) != 10) { return -7; }
  let eu: u8 = expect_u8(some_u8(6));
  if (eu != 6) { return -8; }
  if (!is_some_u8(some_u8(1)) || is_none_u8(some_u8(1))) { return -9; }
  if (is_some_u8(none_u8()) || !is_none_u8(none_u8())) { return -10; }
  let au1: Option_u8 = and_u8(some_u8(1), some_u8(2));
  let au2: Option_u8 = and_u8(none_u8(), some_u8(2));
  if (!is_some_u8(au1) || expect_u8(au1) != 2) { return -11; }
  if (is_some_u8(au2)) { return -12; }
  return a + b + c + u1 + u2;
}
