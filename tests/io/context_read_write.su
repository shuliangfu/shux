// STD-091：std.io read_ctx/write_ctx + Context 取消与 deadline 烟测
const io = import("std.io");
const context = import("std.context");
const err = import("std.error");

function main(): i32 {
  let bg: Context = context.background();
  let buf: [1]u8 = [0];
  let p: *u8 = &buf[0];

  let cancelled: Context = context.with_cancel(bg);
  context.cancel(cancelled);
  if (io.read_ctx(io.handle_stdout(), p, 0, cancelled) != io_err_cancelled()) {
    return 1;
  }
  if (io.write_ctx(io.handle_stdout(), p, 0, cancelled) != io_err_cancelled()) {
    return 2;
  }

  let expired: Context = context.with_deadline(bg, 1);
  if (io.read_ctx(io.handle_stdout(), p, 0, expired) != io_err_timeout()) {
    return 3;
  }
  if (io.write_ctx(io.handle_stdout(), p, 0, expired) != io_err_timeout()) {
    return 4;
  }

  if (io.timeout_ms_for_context(bg) != 0) {
    return 5;
  }

  let live: Context = context.with_timeout(bg, 1000000000);
  let tm: i32 = io.timeout_ms_for_context(live);
  if (tm <= 0) {
    return 6;
  }

  context.free(cancelled);
  context.free(expired);
  context.free(live);
  return 0;
}
