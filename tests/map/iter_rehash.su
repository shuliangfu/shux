// STD-162：Map 迭代与负载因子烟测
const map = import("std.map");

function main(): i32 {
  let m: Map_i32_i32 = map.map_i32_i32_new();
  if (map.map_i32_i32_with_capacity(&m, 8) != 0) { return 1; }
  let i: i32 = 0;
  while (i < 6) {
    if (map.map_i32_i32_insert(&m, i, i * 10) != 0) { return 2; }
    i = i + 1;
  }
  if (map.map_i32_i32_load_factor_pct(m) <= 0) { return 3; }
  let it: MapIter_i32_i32 = map.map_i32_i32_iter_init(m);
  let n: i32 = 0;
  let done: i32 = 0;
  while (done == 0) {
    let item: MapIterItem_i32 = map.map_i32_i32_iter_next(&it);
    if (item.ok == 0) {
      done = 1;
    } else {
      n = n + 1;
    }
  }
  if (n != 6) { return 4; }
  map.map_i32_i32_deinit(&m);
  return 0;
}
