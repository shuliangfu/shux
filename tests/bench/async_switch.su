// async_switch.su — B-ASYNC：1M 双任务 ping-pong（A1 手工状态机，预 async fn 语法）
// 两帧 phase 0↔1 交替；与 std/async/scheduler.c 语义一致，测 Shu 纯 codegen 切换开销。
allow(padding)
struct CoopFrame {
  phase: i32
  ops: i64
}

/** 单帧一步：phase 翻转并 ops++；返回 0。 */
function coop_frame_step(f: *CoopFrame): i32 {
  if (f.phase == 0) {
    f.ops = f.ops + 1;
    f.phase = 1;
    return 0;
  }
  f.ops = f.ops + 1;
  f.phase = 0;
  return 0;
}

function main(): i32 {
  let rounds: i64 = 1000000;
  let ping: CoopFrame = CoopFrame { phase: 0, ops: 0 };
  let pong: CoopFrame = CoopFrame { phase: 0, ops: 0 };
  let i: i64 = 0;
  while (i < rounds) {
    let _p: i32 = coop_frame_step(&ping);
    let _q: i32 = coop_frame_step(&pong);
    i = i + 1;
  }
  let total: i64 = ping.ops + pong.ops;
  if (total != 2000000) { return 5; }
  return 0;
}
