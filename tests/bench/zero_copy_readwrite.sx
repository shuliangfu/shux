/**
 * zero_copy_readwrite.sx — PERF-008 对照：64KiB read+write 循环推文件到 socket（非 splice/sendfile）
 * 与 zero_copy_splice.sx 同 16MiB 吞吐；strace 上 read/write 次数应显著高于 splice 路径。
 */
const fs = import("std.fs");
const net = import("std.net");
const process = import("std.process");

/** 解析十进制 u32 端口（NUL 结尾 ASCII）；非法字符返回 default_port。 */
function bench_parse_port(s: *u8, default_port: u32): u32 {
  if (s == 0 as *u8) { return default_port; }
  let n: u32 = 0 as u32;
  let i: i32 = 0;
  while (true) {
    let c: u8 = s[i];
    if (c == 0) { break; }
    if (c < 48 || c > 57) { return default_port; }
    n = n * 10 + ((c - 48) as u32);
    i = i + 1;
  }
  if (i <= 0) { return default_port; }
  return n;
}

function main(): i32 {
  /** "tests/bench/.io_mmap_bench_tmp\0" */
  let path: u8[31] =
  [116, 101, 115, 116, 115, 47, 98, 101, 110, 99, 104, 47, 46, 105, 111, 95, 109, 109, 97, 112, 95,
  98, 101, 110, 99, 104, 95,
  116, 109, 112, 0];
  let sink_port: u32 = 38461 as u32;
  if (process.args_count() >= 2) {
    sink_port = bench_parse_port(process.arg(1), sink_port);
  }
  let bench_bytes: usize = 16777216 as usize;
  let chunk: usize = 65536 as usize;
  let addr: Ipv4Addr = Ipv4Addr { a: 127, b: 0, c: 0, d: 1 };
  let file_fd: i32 = fs.fs_open_read(&path[0]);
  if (file_fd < 0) { return 1; }
  let stream: TcpStream = net.connect_blocking(addr, sink_port, 0);
  if (stream.fd < 0) {
    fs.fs_close(file_fd);
    return 2;
  }
  let buf: u8[65536] = [];
  let sent: usize = 0 as usize;
  while (sent < bench_bytes) {
    let left: usize = bench_bytes - sent;
    let ask: usize = chunk;
    if (left < ask) { ask = left; }
    let nr: isize = fs.fs_read(file_fd, &buf[0], ask);
    if (nr <= 0) {
      net.close_stream(stream);
      fs.fs_close(file_fd);
      return 3;
    }
    let nw: i32 = net.stream_write_batch(stream, &buf[0], nr as usize, 0 as *u8, 0, 0 as *u8, 0, 0 as *u8, 0, 1, 0);
    if (nw != (nr as i32)) {
      net.close_stream(stream);
      fs.fs_close(file_fd);
      return 4;
    }
    sent = sent + (nr as usize);
  }
  if (net.close_stream(stream) != 0) {
    fs.fs_close(file_fd);
    return 5;
  }
  if (fs.fs_close(file_fd) != 0) { return 6; }
  return (sent as i32) & 255;
}
