// struct_param.sx — 性能基线：循环内按值传递小 struct（Pair 两个 i32）
struct Pair {
  a: i32
  b: i32
}

/** 按值累加 struct 字段，测传参/拷贝与字段访问代码质量。 */
function add_pair(p: Pair): i32 {
  return p.a + p.b;
}

function main(): i32 {
  let n: i32 = 100000000;
  let s: i32 = 0;
  let i: i32 = 0;
  let p: Pair = Pair { a: 0, b: 0 };
  while (i < n) {
    p.a = i;
    p.b = i + 1;
    s = s + add_pair(p);
    i = i + 1;
  }
  return s;
}
