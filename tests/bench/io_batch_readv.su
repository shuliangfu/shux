// io_batch_readv.su — I/O 基线：4 段 read_batch_fd 顺序读满 16MiB（与 run-perf-io.sh 配套）
// 输入：tests/bench/.io_mmap_bench_tmp（脚本预生成，默认 16MiB）
import std.fs;

function main(): i32 {
  // 路径 "tests/bench/.io_mmap_bench_tmp"
  let path: [31]u8 =
  [116, 101, 115, 116, 115, 47, 98, 101, 110, 99, 104, 47, 46, 105, 111, 95, 109, 109, 97, 112, 95,
  98, 101, 110, 99, 104, 95, 116, 109, 112, 0];
  let fd: i32 = fs_open_read(&path[0]);
  if (fd < 0) { return 1; }
  let b0: [4096]u8 = [];
  let b1: [4096]u8 = [];
  let b2: [4096]u8 = [];
  let b3: [4096]u8 = [];
  let sum: i32 = 0;
  let rounds: i32 = 0;
  /** 每轮 4×4KiB=16KiB；1024 轮 = 16MiB。 */
  while (rounds < 1024) {
    let nr: i32 = read_batch_fd(fd, &b0[0], 4096, &b1[0], 4096, &b2[0], 4096, &b3[0], 4096, 4);
    if (nr != 16384) {
      fs_close(fd);
      return 2;
    }
    let si: i32 = 0;
    while (si < 4096) {
      sum = sum + (b0[si] as i32);
      sum = sum + (b1[si] as i32);
      sum = sum + (b2[si] as i32);
      sum = sum + (b3[si] as i32);
      si = si + 1;
    }
    rounds = rounds + 1;
  }
  if (fs_close(fd) != 0) { return 3; }
  return sum & 255;
}
