// io_random_pread.su — I/O 基线：随机 offset pread（PERF-002 随机读路径）
// 输入：tests/bench/.io_mmap_bench_tmp（脚本预生成，默认 16MiB）
// 1024 次 4KiB 随机 pread（LCG 伪随机页号，与 .c/.zig 一致）
const fs = import("std.fs");

function main(): i32 {
  /** 路径 "tests/bench/.io_mmap_bench_tmp"（NUL 结尾）。 */
  let path: [31]u8 =
  [116, 101, 115, 116, 115, 47, 98, 101, 110, 99, 104, 47, 46, 105, 111, 95, 109, 109, 97, 112, 95,
  98, 101, 110, 99, 104, 95, 116, 109, 112, 0];
  let fd: i32 = fs.fs_open_read(&path[0]);
  if (fd < 0) { return 1; }
  let buf: [4096]u8 = [];
  let sum: i32 = 0;
  let seed: u32 = 12345;
  let rounds: i32 = 0;
  /** 16MiB / 4KiB = 4096 页。 */
  while (rounds < 1024) {
    seed = (seed * 1103515245 + 12345) as u32;
    let page: u32 = seed % 4096;
    let off: i64 = (page as i64) * 4096;
    let nr: isize = fs.fs_pread(fd, &buf[0], 4096, off);
    if (nr != 4096) {
      fs.fs_close(fd);
      return 2;
    }
    let bi: i32 = 0;
    while (bi < 4096) {
      sum = sum + (buf[bi] as i32);
      bi = bi + 1;
    }
    rounds = rounds + 1;
  }
  if (fs.fs_close(fd) != 0) { return 3; }
  return sum & 255;
}
