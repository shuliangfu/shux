/**
 * DOD f32 AoS L1 bench 对照：4096 粒子交错布局 arr[i].x 累加（addss）。
 * 每 x=1.0 → sum=4096.0；main 返回 (s as i32)/256（=16）。
 */
struct Particle {
  x: f32
  y: f32
  z: f32
}

function main(): i32 {
  let n: i32 = 4096;
  let arr: [4096]Particle = [];
  let i: i32 = 0;
  while (i < n) {
    arr[i].x = 1.0;
    arr[i].y = 2.0;
    arr[i].z = 3.0;
    i = i + 1;
  }
  let s: f32 = 0.0;
  i = 0;
  while (i < n) {
    s = s + arr[i].x;
    i = i + 1;
  }
  return (s as i32) / 256;
}
