/*
* SX 流水线 typeck：`struct.field == Enum.VAR`，与 codegen.sx/typeck.sx 中 `ty.kind ==
* * * * * TypeKind.TYPE_*` 同形态。
* * * * * * 无 import ast，仅用本地 enum/struct（run-sx-pipeline 风格 -sx -E）。
*/
enum ShapeKind {
  SK_I32,
  SK_PTR,
  SK_SLICE
}

struct Shape {
  kind: ShapeKind;
  tag: i32;
}

/** 指针形态：kind 为 SK_PTR */
function shape_is_ptr(s: Shape): bool {
  return s.kind == ShapeKind.SK_PTR;
}

function main(): i32 {
  return 0;
}
