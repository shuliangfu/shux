// tests/fs/crossplatform_core.su — STD-003：std.fs 三平台对齐烟测（同一套 .su）
// 覆盖：open/read/write/pread/pwrite/mmap/readv/io_fd/append/create/last_error/path_readable
const fs = import("std.fs");

/** 写入 tests/fs/.crossplatform_tmp 固定 payload；成功返回 0。 */
function cp_write_base(path: *u8, payload: *u8, len: usize): i32 {
  let fd: i32 = fs.fs_open_write(path);
  if (fd < 0) { return 1; }
  let nw: isize = fs.fs_write(fd, payload, len);
  if (fs.fs_sync(fd) != 0) {
    fs.fs_close(fd);
    return 2;
  }
  if (fs.fs_close(fd) != 0) { return 3; }
  if (nw != (len as isize)) { return 4; }
  return 0;
}

function main(): i32 {
  /** "tests/fs/.crossplatform_tmp\0" */
  let path: [28]u8 =
  [116, 101, 115, 116, 115, 47, 102, 115, 47, 46, 99, 114, 111, 115, 115, 112, 108, 97, 116, 102, 111, 114, 109, 95, 116, 109, 112, 0];
  let payload: [32]u8 =
  [83, 84, 68, 45, 48, 48, 51, 32, 102, 115, 32, 99, 114, 111, 115, 115, 112, 108, 97, 116, 102, 111, 114, 109, 10, 0, 0, 0, 0, 0, 0, 0];
  let pay_len: usize = 25 as usize;
  let buf: [64]u8 = 0;
  let fd: i32 = 0;
  let nr: isize = 0;
  let sum: i32 = 0;
  let i: i32 = 0;

  if (cp_write_base(&path[0], &payload[0], pay_len) != 0) { return 10; }
  if (fs.fs_path_readable(&path[0]) != 1) { return 11; }

  fd = fs.fs_open_read(&path[0]);
  if (fd < 0) { return 12; }
  nr = fs.fs_read(fd, &buf[0], pay_len);
  if (fs.fs_close(fd) != 0) { return 13; }
  if (nr != (pay_len as isize)) { return 14; }

  fd = fs.fs_open_read(&path[0]);
  if (fd < 0) { return 15; }
  nr = fs.fs_pread(fd, &buf[0], 8 as usize, 4 as i64);
  if (fs.fs_close(fd) != 0) { return 16; }
  if (nr != 8) { return 17; }

  fd = fs.fs_open_write(&path[0]);
  if (fd < 0) { return 18; }
  if (fs.fs_pwrite(fd, &payload[0], 4 as usize, 0 as i64) != 4) {
    fs.fs_close(fd);
    return 19;
  }
  if (fs.fs_sync(fd) != 0) {
    fs.fs_close(fd);
    return 20;
  }
  if (fs.fs_close(fd) != 0) { return 21; }

  {
    let fd_a: i32 = fs.fs_open_append(&path[0]);
    if (fd_a < 0) { return 22; }
    if (fs.fs_write(fd_a, &payload[0], 1 as usize) != 1) {
      fs.fs_close(fd_a);
      return 23;
    }
    fs.fs_close(fd_a);
  }
  {
    let fd_c: i32 = fs.fs_open_create(&path[0]);
    if (fd_c < 0) { return 24; }
    if (fs.fs_write(fd_c, &payload[0], pay_len) != (pay_len as isize)) {
      fs.fs_close(fd_c);
      return 25;
    }
    fs.fs_sync(fd_c);
    fs.fs_close(fd_c);
  }

  {
    let sz: usize = 0;
    let mp: *u8 = fs.fs_mmap_ro(&path[0], &sz);
    if (mp == 0 as *u8) { return 26; }
    if (sz < pay_len) {
      fs.fs_munmap(mp, sz);
      return 27;
    }
    if (mp[0] != payload[0]) {
      fs.fs_munmap(mp, sz);
      return 28;
    }
    if (fs.fs_munmap(mp, sz) != 0) { return 29; }
  }

  fd = fs.fs_open_read(&path[0]);
  if (fd < 0) { return 30; }
  {
    let b0: [8]u8 = 0;
    let b1: [8]u8 = 0;
    let rv: i64 = fs.fs_readv2(fd, &b0[0], 4 as usize, &b1[0], 4 as usize);
    if (rv < 0) {
      fs.fs_close(fd);
      return 31;
    }
  }
  if (fs.fs_close(fd) != 0) { return 32; }

  fd = fs.fs_open_write(&path[0]);
  if (fd < 0) { return 33; }
  {
    let w0: [4]u8 = [65, 66, 67, 68];
    let w1: [4]u8 = [69, 70, 71, 72];
    let wv: i64 = fs.fs_writev2(fd, &w0[0], 4 as usize, &w1[0], 4 as usize);
    if (wv != 8) {
      fs.fs_close(fd);
      return 34;
    }
  }
  fs.fs_sync(fd);
  fs.fs_close(fd);

  fd = fs.fs_open_read(&path[0]);
  if (fd < 0) { return 35; }
  {
    let n: i32 = read_fd(fd, &buf[0], 16 as usize);
    if (n <= 0) {
      fs.fs_close(fd);
      return 36;
    }
    sum = sum + n;
  }
  fs.fs_close(fd);

  fd = fs.fs_open_write(&path[0]);
  if (fd < 0) { return 37; }
  {
    let n2: i32 = write_fd(fd, &payload[0], 4 as usize);
    if (n2 != 4) {
      fs.fs_close(fd);
      return 38;
    }
  }
  fs.fs_sync(fd);
  fs.fs_close(fd);

  fd = fs.fs_open_read(&bad_path_placeholder());
  if (fd >= 0) {
    fs.fs_close(fd);
    return 39;
  }
  if (fs.fs_last_error() == 0) { return 40; }

  i = 0;
  while (i < 25) {
    sum = sum + (payload[i] as i32);
    i = i + 1;
  }
  return sum & 255;
}

/** 故意不存在的路径（NUL 结尾）。 */
function bad_path_placeholder(): *u8 {
  let p: [32]u8 =
  [116, 101, 115, 116, 115, 47, 102, 115, 47, 46, 110, 111, 95, 115, 117, 99, 104, 95, 102, 105, 108, 101, 95, 120, 120, 120, 0, 0, 0, 0, 0, 0];
  return &p[0];
}
