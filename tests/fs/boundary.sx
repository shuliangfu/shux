// TST-001：std.fs 边界烟测（invalid handle / 读写 / pread / 路径）
//
// 【文件职责】≥8 边界 case；使用 /tmp/shux_fs_boundary 临时文件。
// 【运行方式】tests/run-tst-001-boundary-gate.sh
const fs = import("std.fs");

function main(): i32 {
  // case 1：无效 handle 哨兵
  if (fs.fs_invalid_handle() != -1) { return 1; }
  // case 2：读块大小常量
  if (fs.fs_read_chunk() < 4096) { return 2; }
  // case 3：不存在路径打开失败
  let bad: u8[20] = [47, 116, 109, 112, 47, 110, 111, 95, 115, 117, 99, 104, 95, 102, 105, 108, 101, 0, 0, 0];
  if (fs.fs_open_read(&bad[0]) >= 0) { return 3; }
  // case 4：写读往返 — 打开写
  let path: u8[22] = [47, 116, 109, 112, 47, 115, 104, 117, 95, 102, 115, 95, 98, 111, 117, 110, 100, 97, 114, 121, 0, 0];
  let fd_w: i32 = fs.fs_open_write(&path[0]);
  if (fd_w < 0) { return 4; }
  // case 5：写入 4 字节
  let payload: u8[4] = [1, 2, 3, 4];
  if (fs.fs_write(fd_w, &payload[0], 4) != 4) { return 5; }
  fs.fs_close(fd_w);
  // case 6：重新打开读
  let fd_r: i32 = fs.fs_open_read(&path[0]);
  if (fd_r < 0) { return 6; }
  // case 7：fs_read 全量
  let buf: u8[4] = [0, 0, 0, 0];
  if (fs.fs_read(fd_r, &buf[0], 4) != 4) { return 7; }
  // case 8：内容校验
  if (buf[0] != 1 || buf[3] != 4) { return 8; }
  // case 9：pread 偏移读
  let buf2: u8[2] = [0, 0];
  if (fs.fs_pread(fd_r, &buf2[0], 2, 1) != 2) { return 9; }
  if (buf2[0] != 2 || buf2[1] != 3) { return 10; }
  fs.fs_close(fd_r);
  // case 10：路径可读探测
  if (fs.fs_path_readable(&path[0]) != 1) { return 11; }
  return 0;
}
