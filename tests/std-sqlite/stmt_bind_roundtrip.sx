// STD-070：内存库 stmt bind + 缓存烟测（须 sqlite-o + -lsqlite3 链接）
const sqlite = import("std.db.sqlite");

/** 比较 buf 前 n 字节与 expect（最多 5 字节）。 */
function text_eq5(buf: *u8, n: i32, b0: u8, b1: u8, b2: u8, b3: u8, b4: u8, expect_len: i32): i32 {
  if (n != expect_len) { return 0; }
  if (expect_len > 0 && buf[0] != b0) { return 0; }
  if (expect_len > 1 && buf[1] != b1) { return 0; }
  if (expect_len > 2 && buf[2] != b2) { return 0; }
  if (expect_len > 3 && buf[3] != b3) { return 0; }
  if (expect_len > 4 && buf[4] != b4) { return 0; }
  return 1;
}

function main(): i32 {
  let mem: u8[9] = [58, 109, 101, 109, 111, 114, 121, 58, 0];
  let sql_create: u8[38] = [
    67, 82, 69, 65, 84, 69, 32, 84, 65, 66, 76, 69, 32, 116, 40, 107,
    32, 73, 78, 84, 69, 71, 69, 82, 44, 32, 110, 97, 109, 101, 32, 84,
    69, 88, 84, 41, 59, 0
  ];
  let sql_ins: u8[37] = [
    73, 78, 83, 69, 82, 84, 32, 73, 78, 84, 79, 32, 116, 40, 107, 44,
    110, 97, 109, 101, 41, 32, 86, 65, 76, 85, 69, 83, 40, 63, 44, 63,
    41, 59, 0
  ];
  let sql_sel: u8[32] = [
    83, 69, 76, 69, 67, 84, 32, 110, 97, 109, 101, 32, 70, 82, 79, 77,
    32, 116, 32, 87, 72, 69, 82, 69, 32, 107, 61, 63, 59, 0
  ];
  let alice: u8[6] = [97, 108, 105, 99, 101, 0];
  let bob: u8[4] = [98, 111, 98, 0];
  let out: u8[16] = [];
  let c: DbConn = sqlite.open(&mem[0]);
  let ins: DbStmt = DbStmt { handle: 0 };
  let sel: DbStmt = DbStmt { handle: 0 };
  let sel2: DbStmt = DbStmt { handle: 0 };
  let st: i32 = 0;
  let n: i32 = 0;

  if (c.handle == 0) { return 1; }
  if (sqlite.exec(c, &sql_create[0]) != 0) {
    sqlite.close(c);
    return 2;
  }
  ins = sqlite.prepare(c, &sql_ins[0]);
  if (ins.handle == 0) {
    sqlite.close(c);
    return 3;
  }
  if (sqlite.stmt_bind_i32(ins, 1, 10) != 0 || sqlite.stmt_bind_text(ins, 2, &alice[0]) != 0) {
    sqlite.stmt_finalize(ins);
    sqlite.close(c);
    return 4;
  }
  if (sqlite.stmt_step(ins) != 0) {
    sqlite.stmt_finalize(ins);
    sqlite.close(c);
    return 5;
  }
  if (sqlite.stmt_reset(ins) != 0) {
    sqlite.stmt_finalize(ins);
    sqlite.close(c);
    return 6;
  }
  if (sqlite.stmt_bind_i32(ins, 1, 20) != 0 || sqlite.stmt_bind_text(ins, 2, &bob[0]) != 0) {
    sqlite.stmt_finalize(ins);
    sqlite.close(c);
    return 7;
  }
  if (sqlite.stmt_step(ins) != 0) {
    sqlite.stmt_finalize(ins);
    sqlite.close(c);
    return 8;
  }
  if (sqlite.stmt_finalize(ins) != 0) {
    sqlite.close(c);
    return 9;
  }
  sel = sqlite.prepare_cached(c, &sql_sel[0]);
  sel2 = sqlite.prepare_cached(c, &sql_sel[0]);
  if (sel.handle == 0 || sel2.handle != sel.handle) {
    sqlite.close(c);
    return 10;
  }
  if (sqlite.stmt_bind_i32(sel, 1, 10) != 0) {
    sqlite.close(c);
    return 11;
  }
  st = sqlite.stmt_step(sel);
  if (st != 1) {
    sqlite.close(c);
    return 12;
  }
  n = sqlite.stmt_col_text(sel, 0, &out[0], 16);
  if (text_eq5(&out[0], n, 97, 108, 105, 99, 101, 5) == 0) {
    sqlite.close(c);
    return 13;
  }
  if (sqlite.stmt_reset(sel) != 0 || sqlite.stmt_bind_i32(sel, 1, 20) != 0) {
    sqlite.close(c);
    return 14;
  }
  st = sqlite.stmt_step(sel);
  if (st != 1) {
    sqlite.close(c);
    return 15;
  }
  n = sqlite.stmt_col_text(sel, 0, &out[0], 16);
  if (text_eq5(&out[0], n, 98, 111, 98, 0, 0, 3) == 0) {
    sqlite.close(c);
    return 16;
  }
  if (sqlite.stmt_cache_clear(c) != 0) {
    sqlite.close(c);
    return 17;
  }
  if (sqlite.close(c) != 0) {
    return 18;
  }
  return 0;
}
