// STD-137：大 BLOB 分块读烟测（须 sqlite-o + -lsqlite3；stub 时 open 失败 exit 1）
const sqlite = import("std.db.sqlite");

/** 比较 buf 前 n 字节是否等于 0..n-1。 */
function bytes_seq(buf: *u8, n: i32): i32 {
  let i: i32 = 0;
  while (i < n) {
    if (buf[i] != i as u8) {
      return 0;
    }
    i = i + 1;
  }
  return 1;
}

function main(): i32 {
  let mem: u8[9] = [58, 109, 101, 109, 111, 114, 121, 58, 0];
  /* INSERT 96 字节 0x00..0x5f 的 hex SQL（预构建） */
  let sql_ins: u8[226] = [
    73, 78, 83, 69, 82, 84, 32, 73, 78, 84, 79, 32, 116, 40, 100, 97,
    116, 97, 41, 32, 86, 65, 76, 85, 69, 83, 32, 40, 120, 39, 48, 48,
    48, 49, 48, 50, 48, 51, 48, 52, 48, 53, 48, 54, 48, 55, 48, 56,
    48, 57, 48, 97, 48, 98, 48, 99, 48, 100, 48, 101, 48, 102, 49, 48,
    49, 49, 49, 50, 49, 51, 49, 52, 49, 53, 49, 54, 49, 55, 49, 56,
    49, 57, 49, 97, 49, 98, 49, 99, 49, 100, 49, 101, 49, 102, 50, 48,
    50, 49, 50, 50, 50, 51, 50, 52, 50, 53, 50, 54, 50, 55, 50, 56,
    50, 57, 50, 97, 50, 98, 50, 99, 50, 100, 50, 101, 50, 102, 51, 48,
    51, 49, 51, 50, 51, 51, 51, 52, 51, 53, 51, 54, 51, 55, 51, 56,
    51, 57, 51, 97, 51, 98, 51, 99, 51, 100, 51, 101, 51, 102, 52, 48,
    52, 49, 52, 50, 52, 51, 52, 52, 52, 53, 52, 54, 52, 55, 52, 56,
    52, 57, 52, 97, 52, 98, 52, 99, 52, 100, 52, 101, 52, 102, 53, 48,
    53, 49, 53, 50, 53, 51, 53, 52, 53, 53, 53, 54, 53, 55, 53, 56,
    53, 57, 53, 97, 53, 98, 53, 99, 53, 100, 53, 101, 53, 102, 39, 41,
    59, 0,
  ];
  let sql_create: u8[28] = [
    67, 82, 69, 65, 84, 69, 32, 84, 65, 66, 76, 69, 32, 116, 40, 100,
    97, 116, 97, 32, 66, 76, 79, 66, 41, 59, 0
  ];
  let sql_sel: u8[22] = [
    83, 69, 76, 69, 67, 84, 32, 100, 97, 116, 97, 32, 70, 82, 79, 77,
    32, 116, 59, 0
  ];
  let chunk: u8[32] = [];
  let acc: u8[96] = [];
  let c: DbConn = sqlite.open(&mem[0]);
  let cur: DbRowCursor = DbRowCursor { cursor: 0 };
  let total: i32 = 0;
  let off: i32 = 0;
  let got: i32 = 0;
  let acc_len: i32 = 0;
  if (c.handle == 0) {
    return 1;
  }
  if (sqlite.exec(c, &sql_create[0]) != 0) {
    sqlite.close(c);
    return 2;
  }
  if (sqlite.exec(c, &sql_ins[0]) != 0) {
    sqlite.close(c);
    return 3;
  }
  cur = sqlite.query_begin(c, &sql_sel[0]);
  if (cur.cursor == 0) {
    sqlite.close(c);
    return 4;
  }
  if (sqlite.next_row(cur) != sqlite.DB_ROW_OK) {
    sqlite.query_end(cur);
    sqlite.close(c);
    return 5;
  }
  total = sqlite.row_col_blob_len(cur, 0);
  if (total != 96) {
    sqlite.query_end(cur);
    sqlite.close(c);
    return 6;
  }
  while (off < total) {
    got = sqlite.row_col_blob_read(cur, 0, off, &chunk[0], 32);
    if (got <= 0) {
      sqlite.query_end(cur);
      sqlite.close(c);
      return 7;
    }
    let i: i32 = 0;
    while (i < got) {
      acc[acc_len] = chunk[i];
      acc_len = acc_len + 1;
      i = i + 1;
    }
    off = off + got;
  }
  if (acc_len != 96 || bytes_seq(&acc[0], 96) == 0) {
    sqlite.query_end(cur);
    sqlite.close(c);
    return 8;
  }
  if (sqlite.query_end(cur) != 0) {
    sqlite.close(c);
    return 9;
  }
  if (sqlite.close(c) != 0) {
    return 10;
  }
  return 0;
}
