// STD-057：std.db.sqlite import 烟测（默认 SQLite3 后端 + -lsqlite3 链接）
const sqlite = import("std.db.sqlite");

function main(): i32 {
  let mem: [9]u8 = [58, 109, 101, 109, 111, 114, 121, 58, 0];
  let sql_create: [27]u8 = [
    67, 82, 69, 65, 84, 69, 32, 84, 65, 66, 76, 69, 32, 116, 40, 107,
    32, 73, 78, 84, 69, 71, 69, 82, 41, 59, 0
  ];
  let sql_insert: [30]u8 = [
    73, 78, 83, 69, 82, 84, 32, 73, 78, 84, 79, 32, 116, 40, 107, 41,
    32, 86, 65, 76, 85, 69, 83, 32, 40, 55, 41, 59, 0
  ];
  let c: DbConn = sqlite.open(&mem[0]);
  if (c.handle == 0) {
    return 1;
  }
  if (sqlite.exec(c, &sql_create[0]) != 0) {
    sqlite.close(c);
    return 2;
  }
  if (sqlite.exec(c, &sql_insert[0]) != 0) {
    sqlite.close(c);
    return 3;
  }
  if (sqlite.changes(c) != 1) {
    sqlite.close(c);
    return 4;
  }
  if (sqlite.close(c) != 0) {
    return 5;
  }
  return 0;
}
