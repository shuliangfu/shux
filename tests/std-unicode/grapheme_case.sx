// STD-114：std.unicode grapheme / case fold 烟测
const unicode = import("std.unicode");

function main(): i32 {
  let decomposed: [3]u8 = [101, 0xCC, 0x81];
  let hello: [5]u8 = [72, 101, 108, 108, 111];
  let fold: [8]u8 = [];
  let g: i32 = 0;
  let n: i32 = 0;
  g = grapheme_next(&decomposed[0], 3, 0);
  if (g != 3) {
    return 1;
  }
  g = grapheme_next(&hello[0], 5, 0);
  if (g != 1) {
    return 2;
  }
  n = case_fold_buf(&hello[0], 5, &fold[0], 8);
  if (n != 5 || fold[0] != 104) {
    return 3;
  }
  if (grapheme_case_smoke() != 0) {
    return 4;
  }
  return 0;
}
