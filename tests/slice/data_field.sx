// 测试 []u8 的 .data（*u8）与 .length（usize）字段（typeck + codegen）
function take_slice(buf: []u8): i32 {
  let p: *u8 = buf.data;
  let n: usize = buf.length;
  if (n == 0) { return 0; }
  return (p != 0) ? 1 : -1;
}

function main(): i32 {
  let arr: [4]u8 = [1, 2, 3, 4];
  let s: []u8 = arr;
  let r: i32 = take_slice(s);
  if (r != 1) { return 1; }
  if (s.length != 4) { return 2; }
  return 0;
}
