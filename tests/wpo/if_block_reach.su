// WPO 烟测：if 分支 block 内 return call 须计入 call graph（get_i32→some_i32/none_i32）。
import core.slice;
import core.option;

function main(): i32 {
  let a: [2]i32 = [10, 20];
  let s: []i32 = a;
  let o: Option_i32 = get_i32(s, 0);
  if (!o.is_some) {
    return 1;
  }
  if (o.value != 10) {
    return 2;
  }
  return 0;
}
