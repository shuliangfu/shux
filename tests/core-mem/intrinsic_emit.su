// CORE-008：跨模块 import("core.mem") 后四条热路径应 -E 为 __builtin_* 调用。
const mem = import("core.mem");

function main(): i32 {
  let a: [8]u8 = [1, 2, 3, 4, 5, 6, 7, 8];
  let b: [8]u8 = [0, 0, 0, 0, 0, 0, 0, 0];
  let c: [8]u8 = [1, 2, 3, 4, 9, 9, 9, 9];
  mem.mem_copy(b, a, 8);
  mem.mem_set(b, 0, 4);
  mem.mem_move(b, a, 4);
  let cmp: i32 = mem.mem_compare(a, c, 8);
  if (cmp >= 0) {
    return 1;
  }
  return 0;
}
