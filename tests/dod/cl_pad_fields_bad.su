/**
 * DOD-CL -pad-fields 负例：相邻 u32 字段同 cache line，无 align(64)。
 * SHU_PAD_FIELDS=1 check 时应打印 warning（不 error）。
 */
struct BadShare {
  head: u32
  data: u32
}

function main(): i32 {
  let s: BadShare = BadShare { head: 0, data: 0 };
  s.head = 1 as u32;
  s.data = 2 as u32;
  return s.head + s.data;
}
