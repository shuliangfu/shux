// STD-121：std.elf 写入 + 只读解析 round-trip 烟测
const elf = import("std.elf");
function main(): i32 {
  let text: u8[4] = [144, 144, 144, 144];
  let out: u8[512] = [];
  let out_len: i32 = 0;
  let hdr: Elf64Hdr = Elf64Hdr {
    e_type: 0,
    machine: 0,
    entry: 0,
    phoff: 0,
    phnum: 0,
    shnum: 0,
    shoff: 0,
    shstrndx: 0,
  };
  let sec: Elf64Sec = Elf64Sec {
    name_off: 0,
    sh_type: 0,
    addr: 0,
    offset: 0,
    size: 0,
  };
  let idx: i32 = 0;
  let byte: u8 = 0;
  let sz: i32 = 0;
  let name_text: u8[6] = [46, 116, 101, 120, 116, 0];

  sz = elf.write_min_reloc_size(4);
  if (sz != 267) {
    return 1;
  }
  if (elf.write_min_reloc(&out[0], 512, &text[0], 4, &out_len) != elf.elf_write_err_ok()) {
    return 2;
  }
  if (out_len != 267) {
    return 3;
  }
  if (elf.parse_hdr(&out[0], out_len, &hdr) != 0) {
    return 4;
  }
  if (hdr.e_type != 1 || hdr.machine != 62) {
    return 5;
  }
  if (elf.find_section_idx(&out[0], out_len, &hdr, &name_text[0], &idx) != 0) {
    return 6;
  }
  if (idx != 1) {
    return 7;
  }
  if (elf.read_section(&out[0], out_len, &hdr, idx, &sec) != 0) {
    return 8;
  }
  if (elf.read_sec_byte(&out[0], out_len, &sec, 0 as u64, &byte) != 0) {
    return 9;
  }
  if (byte != 144) {
    return 10;
  }
  if (elf.write_smoke() != 0) {
    return 11;
  }
  return 0;
}
