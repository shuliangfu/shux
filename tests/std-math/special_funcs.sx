// STD-115：std.math erf/log1p/expm1 特殊函数烟测
const math = import("std.math");

/** 近似相等；1 是，0 否。 */
function near(a: f64, b: f64, eps: f64): i32 {
  let d: f64 = a - b;
  if (d < 0.0) {
    d = 0.0 - d;
  }
  if (d <= eps) {
    return 1;
  }
  return 0;
}

function main(): i32 {
  if (near(expm1(0.0), 0.0, 1e-12) == 0) {
    return 1;
  }
  if (near(log1p(0.0), 0.0, 1e-12) == 0) {
    return 2;
  }
  if (near(erf(0.0), 0.0, 1e-12) == 0) {
    return 3;
  }
  if (near(erf(1.0), 0.8427007929497149, 1e-6) == 0) {
    return 4;
  }
  if (near(erfc(0.0), 1.0, 1e-12) == 0) {
    return 5;
  }
  if (special_smoke() != 0) {
    return 6;
  }
  return 0;
}
