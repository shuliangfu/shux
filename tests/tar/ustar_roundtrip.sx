// tests/tar/ustar_roundtrip.sx — STD-038 内存归档 round-trip：目录遍历 + 文件提取
//
// 【文件职责】append_entry 构建 UStar 归档，next_entry 遍历，read_entry_data 提取。
const tar = import("std.tar");

/** 比较 name_out 与期望字节序列（len 字节）。 */
function name_eq(name_out: *u8, expect: *u8, len: i32): bool {
  let i: i32 = 0;
  while (i < len) {
    if (name_out[i] != expect[i]) {
      return false;
    }
    i = i + 1;
  }
  if (name_out[len] != 0) {
    return false;
  }
  return true;
}

function main(): i32 {
  let arc: u8[3072] = [];
  let off: i32 = 0;

  let n1: u8[5] = [97, 46, 116, 120, 116];
  let d1: u8[3] = [102, 111, 111];
  if (tar.append_entry(&arc[0], 3072, &off, &n1[0], 5, &d1[0], 3, 0) != 0) {
    return 1;
  }

  let nd: u8[4] = [115, 117, 98, 47];
  if (tar.append_entry(&arc[0], 3072, &off, &nd[0], 4, 0 as *u8, 0, 1) != 0) {
    return 2;
  }

  let n2: u8[5] = [98, 46, 116, 120, 116];
  let d2: u8[3] = [98, 97, 114];
  if (tar.append_entry(&arc[0], 3072, &off, &n2[0], 5, &d2[0], 3, 0) != 0) {
    return 3;
  }

  let z: i32 = 0;
  while (z < 512 && off < 3072) {
    arc[off] = 0;
    off = off + 1;
    z = z + 1;
  }
  let arc_len: i32 = off;

  let pos: i32 = 0;
  let name_out: u8[128] = [];
  let sz: i32 = 0;
  let typ: i32 = 0;
  let file_n: i32 = 0;
  let dir_n: i32 = 0;
  let a_off: i32 = 0;
  let b_off: i32 = 0;

  while (pos < arc_len) {
    let entry_off: i32 = pos;
    let nr: i32 = tar.next_entry(&arc[0], arc_len, &pos, &name_out[0], 128, &sz, &typ);
    if (nr == 1) {
      break;
    }
    if (nr != 0) {
      return 4;
    }
    if (typ == 53) {
      dir_n = dir_n + 1;
      if (!name_eq(&name_out[0], &nd[0], 4)) {
        return 5;
      }
    } else if (typ == 48) {
      file_n = file_n + 1;
      if (name_eq(&name_out[0], &n1[0], 5)) {
        a_off = entry_off;
      } else if (name_eq(&name_out[0], &n2[0], 5)) {
        b_off = entry_off;
      } else {
        return 6;
      }
    } else {
      return 7;
    }
  }

  if (file_n != 2 || dir_n != 1) {
    return 8;
  }

  let out: u8[8] = [];
  let n: i32 = tar.read_entry_data(&arc[0], arc_len, a_off, &out[0], 8);
  if (n != 3 || out[0] != 102 || out[1] != 111 || out[2] != 111) {
    return 9;
  }
  n = tar.read_entry_data(&arc[0], arc_len, b_off, &out[0], 8);
  if (n != 3 || out[0] != 98 || out[1] != 97 || out[2] != 114) {
    return 10;
  }
  return 0;
}
