// 7.3：assign (i-j+k)*lit 后 read (i-j)*lit 复用 minus_pair 前缀栈（run-asm-assign-index-block.sh）。
function main(): i32 {
  let arr: [8]i32 = [10, 20, 30, 40, 50, 60, 70, 80];
  let i: i32 = 2;
  let j: i32 = 1;
  let k: i32 = 0;
  arr[(i - j + k) * 2] = 11;
  let t: i32 = arr[(i - j) * 2];
  return t + arr[2];
}
