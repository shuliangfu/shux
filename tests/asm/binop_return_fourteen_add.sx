// 7.3：十四 VAR 左结合加链；|live|max≥9 时第六 spill 用 x15（1+…+14=105）。
function main(): i32 {
  let a: i32 = 1;
  let b: i32 = 2;
  let c: i32 = 3;
  let d: i32 = 4;
  let e: i32 = 5;
  let f: i32 = 6;
  let g: i32 = 7;
  let h: i32 = 8;
  let i: i32 = 9;
  let j: i32 = 10;
  let k: i32 = 11;
  let l: i32 = 12;
  let m: i32 = 13;
  let n: i32 = 14;
  return a + b + c + d + e + f + g + h + i + j + k + l + m + n;
}
