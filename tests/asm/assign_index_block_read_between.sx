// 7.3：let INDEX 读介于两次相同 INDEX assign 之间须失效址缓存（run-asm-assign-index-block.sh）。
function main(): i32 {
  let arr: [4]i32 = [10, 20, 30, 40];
  let i: i32 = 1;
  let j: i32 = 0;
  let k: i32 = 0;
  arr[(i - j + k) * 2] = 11;
  let t: i32 = arr[(i - j + k) * 2];
  arr[(i - j + k) * 2] = 22;
  return t + arr[2];
}
