// STD-HTTP-H2-v18：h2 over TLS server push 响应烟测（fork + ALPN h2）
const http = import("std.http");

function main(): i32 {
  if (http.http2_server_push_tls_smoke() != 0) { return 1; }
  if (http.http2_server_push_is_available() == false) { return 2; }
  if (http.http2_err_server_push() != -1242) { return 3; }
  return 0;
}
