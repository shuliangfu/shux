/**
 * STD-033 烟测：chunked 解码 + keep-alive 检测 + GET keep-alive 请求构建。
 */
const http = import("std.http");

function main(): i32 {
  // 合成 HTTP/1.1 chunked + keep-alive 响应
  let resp: [86]u8 = [
    72, 84, 84, 80, 47, 49, 46, 49, 32, 50, 48, 48, 32, 79, 75, 13, 10,
    84, 114, 97, 110, 115, 102, 101, 114, 45, 69, 110, 99, 111, 100, 105, 110, 103, 58, 32, 99, 104, 117, 110, 107, 101, 100, 13, 10,
    67, 111, 110, 110, 101, 99, 116, 105, 111, 110, 58, 32, 107, 101, 101, 112, 45, 97, 108, 105, 118, 101, 13, 10,
    13, 10,
    53, 13, 10, 104, 101, 108, 108, 111, 13, 10, 48, 13, 10, 13, 10
  ];
  let resp_len: i32 = 86;

  if (!http.has_chunked_encoding(&resp[0], resp_len)) { return 1; }
  if (!http.has_keep_alive(&resp[0], resp_len)) { return 2; }

  let hdr_end: i32 = 0;
  if (http.headers_body_offset(&resp[0], resp_len, &hdr_end) != 0) { return 3; }
  if (hdr_end != 71) { return 4; }

  let body: [16]u8 = [];
  let body_len: i32 = http.decode_chunked_body(&resp[0], resp_len, hdr_end, &body[0], 16);
  if (body_len != 5) { return 5; }
  if (body[0] != 104 || body[4] != 111) { return 6; }

  let host: [10]u8 = [108, 111, 99, 97, 108, 104, 111, 115, 116, 0];
  let path: [5]u8 = [47, 97, 112, 105, 0];
  let req: [128]u8 = [];
  let req_len: i32 = build_get_keep_alive(&host[0], &path[0], &req[0], 128);
  if (req_len < 40) { return 7; }
  if (req[0] != 71) { return 8; }

  return 0;
}
