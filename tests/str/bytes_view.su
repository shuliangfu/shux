// CORE-007 烟测：BytesView 构造 / subview 钳制 / eq / from_slice
const str = import("core.str");

function main(): i32 {
  let buf: [7]u8 = [72, 101, 108, 108, 111, 33, 0];
  let full: BytesView = str.bytes_view(&buf[0], 6);
  if (str.bytes_view_is_empty(full) != 0) { return 1; }
  if (str.bytes_view_len(full) != 6) { return 2; }

  if (str.bytes_view_is_empty(str.bytes_view(&buf[0], 0)) != 1) { return 3; }

  let mid: BytesView = str.bytes_view_subview(full, 2, 3);
  if (str.bytes_view_len(mid) != 3) { return 4; }
  if (str.bytes_view_get(mid, 0) != 108) { return 5; }

  let empty: BytesView = str.bytes_view_subview(full, 99, 1);
  if (str.bytes_view_is_empty(empty) != 1) { return 6; }

  let tail: BytesView = str.bytes_view_subview(full, 4, 99);
  if (str.bytes_view_len(tail) != 2) { return 7; }

  let v1: BytesView = str.bytes_view(&buf[0], 2);
  let ab: [2]u8 = [72, 101];
  if (str.bytes_view_eq(v1, str.bytes_view(&ab[0], 2)) != 1) { return 8; }
  if (str.bytes_view_eq_bytes(v1, &ab[0], 2) != 1) { return 9; }

  let s: []u8 = buf;
  let from_sl: BytesView = str.bytes_view_from_slice(s);
  if (str.bytes_view_len(from_sl) != 7) { return 10; }
  if (str.bytes_view_get(from_sl, 0) != 72) { return 11; }

  return 0;
}
