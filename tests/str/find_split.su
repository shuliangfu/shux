// STD-131：BytesView 查找 / 分割烟测（index + subview 模式）
// 分割与 starts_with 分函数，避免同帧多 BytesView + 多数组触发的栈布局问题。
const str = import("core.str");

/** 校验 starts_with 正/反例。 */
function test_starts_with(v: BytesView): i32 {
  let hi: [2]u8 = [104, 101];
  if (str.bytes_view_starts_with(v, &hi[0], 2) != 1) { return 8; }
  if (str.bytes_view_starts_with(v, &hi[0], 3) != 0) { return 9; }
  return 0;
}

/** 按 idx 分割并校验左右子视图。 */
function test_split(v: BytesView, idx: i32): i32 {
  let left: BytesView = str.bytes_view_subview(v, 0, idx);
  let right: BytesView = str.bytes_view_subview(v, idx + 1, v.len - idx - 1);
  if (str.bytes_view_len(left) != 5) { return 4; }
  if (str.bytes_view_len(right) != 5) { return 5; }
  if (str.bytes_view_get(left, 0) != 104) { return 6; }
  if (str.bytes_view_get(right, 0) != 119) { return 7; }
  return 0;
}

function main(): i32 {
  let buf: [11]u8 = [104, 101, 108, 108, 111, 44, 119, 111, 114, 108, 100];
  let v: BytesView = str.bytes_view(&buf[0], 11);
  let idx: i32 = str.bytes_view_index_of_byte(v, 44);
  if (idx != 5) { return 1; }
  let needle: [5]u8 = [119, 111, 114, 108, 100];
  if (str.bytes_view_index_of(v, &needle[0], 5) != 6) { return 2; }
  if (str.bytes_view_contains_byte(v, 44) != 1) { return 3; }
  let r: i32 = test_split(v, idx);
  if (r != 0) { return r; }
  r = test_starts_with(v);
  if (r != 0) { return r; }
  let no_sep: BytesView = str.bytes_view(&buf[0], 5);
  if (str.bytes_view_contains_byte(no_sep, 44) != 0) { return 10; }
  if (str.bytes_view_index_of_byte(no_sep, 44) != -1) { return 11; }
  return 0;
}
