// tests/std-simd/autovec_strategy.sx — STD-153 hw_available / recommend_simd_path 烟测
//
// 【文件职责】验证 auto 策略在已知 SIMD 宿主上推荐 HW 路径。
const simd = import("std.simd");

function main(): i32 {
  let hw: i32 = simd.hw_available();
  let path: i32 = simd.recommend_path();
  if (hw != 0 && path != 1) {
    return 1;
  }
  if (hw == 0 && path != 0) {
    return 2;
  }
  if (path != 0 && path != 1) {
    return 3;
  }
  return 0;
}
