// STD-129：Set_i32 union / intersect / difference 烟测
const set = import("std.set");

/** 检查 dst 是否恰好包含 expect 中的 n 个元素（顺序无关）。 */
function set_has_keys(dst: Set_i32, expect: *i32, n: i32): i32 {
  if (set.set_i32_len(dst) != n) { return 0; }
  let i: i32 = 0;
  while (i < n) {
    if (set.set_i32_contains(dst, expect[i]) == 0) { return 0; }
    i = i + 1;
  }
  return 1;
}

function main(): i32 {
  let a: Set_i32 = set.set_i32_new();
  let b: Set_i32 = set.set_i32_new();
  let dst: Set_i32 = set.set_i32_new();
  if (set.set_i32_with_capacity(&a, 8) != 0) { return 1; }
  if (set.set_i32_with_capacity(&b, 8) != 0) { return 2; }
  if (set.set_i32_with_capacity(&dst, 16) != 0) { return 3; }
  if (set.set_i32_insert(&a, 1) != 0) { return 4; }
  if (set.set_i32_insert(&a, 2) != 0) { return 5; }
  if (set.set_i32_insert(&a, 3) != 0) { return 6; }
  if (set.set_i32_insert(&b, 2) != 0) { return 7; }
  if (set.set_i32_insert(&b, 3) != 0) { return 8; }
  if (set.set_i32_insert(&b, 4) != 0) { return 9; }
  if (set_i32_union_into(&dst, a, b) != 0) { return 10; }
  let u: [4]i32 = [1, 2, 3, 4];
  if (set_has_keys(dst, &u[0], 4) == 0) { return 11; }
  if (set_i32_intersect_into(&dst, a, b) != 0) { return 12; }
  let ic: [2]i32 = [2, 3];
  if (set_has_keys(dst, &ic[0], 2) == 0) { return 13; }
  if (set_i32_difference_into(&dst, a, b) != 0) { return 14; }
  let d: [1]i32 = [1];
  if (set_has_keys(dst, &d[0], 1) == 0) { return 15; }
  if (set_i32_difference_into(&dst, b, a) != 0) { return 16; }
  let d2: [1]i32 = [4];
  if (set_has_keys(dst, &d2[0], 1) == 0) { return 17; }
  set.set_i32_deinit(&a);
  set.set_i32_deinit(&b);
  set.set_i32_deinit(&dst);
  return 0;
}
