// freestanding/hello — S4：syscall write 输出 "Hello Shu!\n"，不链 std/io
/** Linux write(2) 包装；由 freestanding_io_x86_64.s 提供。 */
extern function shulang_sys_write(fd: i32, buf: *u8, len: i32): i32;

function main(): i32 {
  let msg: [12]u8 = [72, 101, 108, 108, 111, 32, 83, 104, 117, 33, 10, 0];
  let n: i32 = shulang_sys_write(1, &msg[0], 11);
  if (n != 11) {
    return 1;
  }
  return 0;
}
