// STD-144：std.mem 有界 copy/set/compare 与 buffer_from 烟测
const mem = import("std.mem");

function main(): i32 {
  let src: [4]u8 = [1, 2, 3, 4];
  let dst: [4]u8 = [0, 0, 0, 0];

  // copy_bounded：正常与 cap 溢出
  if (copy_bounded(&dst[0], 4, &src[0], 4) != 4) { return 1; }
  if (dst[3] != 4) { return 2; }
  if (copy_bounded(&dst[0], 4, &src[0], 5) != -1) { return 3; }
  if (copy_bounded(&dst[0], 4, &src[0], 0) != 0) { return 4; }

  // set_bounded
  if (set_bounded(&dst[0], 4, 9, 2) != 2) { return 5; }
  if (dst[0] != 9 || dst[1] != 9) { return 6; }
  if (set_bounded(&dst[0], 4, 9, 8) != -1) { return 7; }

  // compare_bounded：前缀相等 + 长度决胜
  let a: [3]u8 = [1, 2, 3];
  let b: [4]u8 = [1, 2, 3, 4];
  if (compare_bounded(&a[0], 3, &b[0], 4) >= 0) { return 8; }
  if (compare_bounded(&b[0], 4, &a[0], 3) <= 0) { return 9; }
  if (compare_bounded(&a[0], 3, &a[0], 3) != 0) { return 10; }

  // buffer_from
  let buf: Buffer = buffer_from(&src[0], 4);
  if ((buf.len as i32) != 4) { return 11; }
  if (buf.ptr[0] != 1) { return 12; }
  let empty: Buffer = buffer_from(&src[0], 0);
  if ((empty.len as i32) != 0) { return 13; }

  return 0;
}
