// tests/atomic/main.sx — std.atomic
// 回归：load/store、compare_exchange、fetch_add/sub（i32/u32/i64）。
// 成功退出码 0。
// 注：shux_asm pass-0 CALL hoist 未 relink 前，勿将 fetch_* 返回值绑到 let（见 pipeline_glue pass-0/1）。

const atomic = import("std.atomic");

function main(): i32 {
  // i32
  let x: i32 = 0;
  if (atomic.load_i32(&x) != 0) { return 1; }
  atomic.store_i32(&x, 10);
  if (atomic.load_i32(&x) != 10) { return 2; }
  atomic.fetch_add_i32(&x, 5);
  if (atomic.load_i32(&x) != 15) { return 3; }
  atomic.fetch_sub_i32(&x, 3);
  if (atomic.load_i32(&x) != 12) { return 4; }
  let exp: i32 = 12;
  atomic.compare_exchange_i32(&x, &exp, 100);
  if (atomic.load_i32(&x) != 100) { return 5; }
  let exp2: i32 = 99;
  atomic.compare_exchange_i32(&x, &exp2, 0);
  if (atomic.load_i32(&x) != 100) { return 6; }
  if (exp2 != 100) { return 7; }

  // u32
  let u: u32 = 0;
  atomic.store_u32(&u, 42);
  if (atomic.load_u32(&u) != 42) { return 8; }
  atomic.fetch_add_u32(&u, 8);
  if (atomic.load_u32(&u) != 50) { return 9; }

  // i64
  let y: i64 = 0;
  atomic.store_i64(&y, 1000);
  if (atomic.load_i64(&y) != 1000) { return 10; }
  atomic.fetch_add_i64(&y, 500);
  if (atomic.load_i64(&y) != 1500) { return 11; }

  return 0;
}
