// SIMD-S4 烟测：@shuffle / @select 语法糖 → simd_shuffle/simd_select 内联。
import std.simd;

function main(): i32 {
  let v: Vec8i = [0, 1, 2, 3, 4, 5, 6, 7];
  let r: Vec8i = @shuffle(v, [3, 2, 1, 0, 7, 6, 5, 4]);
  let mask: Vec8i = [1, 0, 1, 0, 0, 1, 0, 1];
  let a: Vec8i = [10, 10, 10, 10, 10, 10, 10, 10];
  let b: Vec8i = [1, 1, 1, 1, 1, 1, 1, 1];
  let s: Vec8i = @select(mask, a, b);
  let _unused: Vec8i = r + s - r - s;
  return 0;
}
