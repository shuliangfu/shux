// SIMD-S3 烟测：while i<N { dst[i]=a[i]-b[i]; i+=1 } 应剥离为 vpsubd/psubd。
function main(): i32 {
  let a: [8]i32 = [10, 10, 10, 10, 10, 10, 10, 10];
  let b: [8]i32 = [1, 2, 3, 4, 5, 6, 7, 8];
  let dst: [8]i32 = [0, 0, 0, 0, 0, 0, 0, 0];
  let i: i32 = 0;
  while (i < 8) {
    dst[i] = a[i] - b[i];
    i += 1;
  }
  return dst[0] + dst[7];
}
