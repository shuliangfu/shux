// tests/unicode/main.su — std.unicode category、to_lower/to_upper
const unicode = import("std.unicode");

function main(): i32 {
  if (unicode.category(65) != 1) { return 1; }
  if (unicode.category(48) != 2) { return 2; }
  if (unicode.to_lower(65) != 97) { return 3; }
  if (unicode.to_upper(97) != 65) { return 4; }
  return 0;
}
