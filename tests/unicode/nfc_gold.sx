// tests/unicode/nfc_gold.sx — STD-037 NFC 金样与非 BMP 烟测
//
// 金样：e+◌́ → é；非 BMP U+1F600 直通。
const unicode = import("std.unicode");

/** 比较 buf 前 n 字节与 expect。 */
function bytes_eq(buf: *u8, n: i32, e0: u8, e1: u8, e2: u8, e3: u8, expect_len: i32): bool {
  if (n != expect_len) {
    return false;
  }
  if (expect_len > 0 && buf[0] != e0) {
    return false;
  }
  if (expect_len > 1 && buf[1] != e1) {
    return false;
  }
  if (expect_len > 2 && buf[2] != e2) {
    return false;
  }
  if (expect_len > 3 && buf[3] != e3) {
    return false;
  }
  return true;
}

function main(): i32 {
  // U+1F600 为非 BMP
  if (unicode.is_supplementary(128512 as u32) != 1) {
    return 1;
  }
  if (unicode.is_supplementary(0xFFFF as u32) != 0) {
    return 2;
  }
  if (unicode.rune_utf8_len(128512 as u32) != 4) {
    return 3;
  }
  if (unicode.rune_utf8_len(233 as u32) != 2) {
    return 4;
  }

  // "e" + U+0301 → NFC "é" (C3 A9)
  let decomposed: u8[3] = [101, 204, 129];
  let out: u8[8] = [];
  let n: i32 = nfc_buf(&decomposed[0], 3, &out[0], 8);
  if (!bytes_eq(&out[0], n, 195, 169, 0, 0, 2)) {
    return 5;
  }

  // 已预组合 é 保持不变
  let composed: u8[2] = [195, 169];
  let out2: u8[8] = [];
  let n2: i32 = nfc_buf(&composed[0], 2, &out2[0], 8);
  if (!bytes_eq(&out2[0], n2, 195, 169, 0, 0, 2)) {
    return 6;
  }

  // 非 BMP emoji U+1F600 UTF-8 直通
  let emoji: u8[4] = [240, 159, 152, 128];
  let out3: u8[8] = [];
  let n3: i32 = nfc_buf(&emoji[0], 4, &out3[0], 8);
  if (!bytes_eq(&out3[0], n3, 240, 159, 152, 128, 4)) {
    return 7;
  }

  // ASCII 直通
  let ascii: u8[3] = [97, 98, 99];
  let out4: u8[8] = [];
  let n4: i32 = nfc_buf(&ascii[0], 3, &out4[0], 8);
  if (!bytes_eq(&out4[0], n4, 97, 98, 99, 0, 3)) {
    return 8;
  }
  return 0;
}
