// tests/string/main.su — std.string 全面 + 边界测试
//
// 覆盖：empty/capacity/new/from_char/from_slice/len/is_empty/eq/clear/append/find/starts/ends_with/
// view/copy_to；边界：空串、单字节、缓冲不足。

import std.string;

function main(): i32 {
  if (string_empty() != 0) { return 1; }
  if (string_capacity() != 256) { return 2; }
  
  let s: String = string_new();
  if (string_len(s) != 0) { return 3; }
  if (string_is_empty(s) != 1) { return 4; }
  
  let one_byte: [1]u8 = [97];
  let s1: String = string_from_slice(&one_byte[0], 1);
  if (string_len(s1) != 1) { return 5; }
  if (string_get(s1, 0) != 97) { return 6; }
  
  let slice_empty: [1]u8 = [0];
  let s2: String = string_from_slice(&slice_empty[0], 0);
  if (string_len(s2) != 0) { return 7; }
  
  let slice_ab: [3]u8 = [97, 98, 0];
  let s3: String = string_from_slice(&slice_ab[0], 2);
  if (string_len(s3) != 2) { return 8; }
  if (string_get(s3, 0) != 97 || string_get(s3, 1) != 98) { return 9; }
  
  let s4: String = string_from_slice(&slice_ab[0], 2);
  if (string_eq(s3, s4) != 1) { return 10; }
  let one_c: [1]u8 = [99];
  let s5: String = string_from_slice(&one_c[0], 1);
  if (string_eq(s3, s5) != 0) { return 11; }
  
  let hay: [6]u8 = [97, 98, 99, 100, 101, 0];
  let h: String = string_from_slice(&hay[0], 5);
  if (string_find_char(h, 99) != 2) { return 12; }
  if (string_find_char(h, 122) != (0 - 1)) { return 13; }
  let pref: [2]u8 = [97, 98];
  if (string_starts_with(h, &pref[0], 2) != 1) { return 14; }
  let bad_pref: [2]u8 = [98, 97];
  if (string_starts_with(h, &bad_pref[0], 2) != 0) { return 15; }
  let suf: [2]u8 = [100, 101];
  if (string_ends_with(h, &suf[0], 2) != 1) { return 16; }
  if (string_ends_with(h, &bad_pref[0], 2) != 0) { return 17; }
  
  let sub: [2]u8 = [98, 99];
  if (string_find_slice(h, &sub[0], 2) != 1) { return 18; }
  if (string_contains(h, &sub[0], 2) != 1) { return 19; }
  let no: [2]u8 = [122, 122];
  if (string_contains(h, &no[0], 2) != 0) { return 20; }
  
  let v: StrView = string_view(&hay[0], 5);
  if (string_view_len(v) != 5) { return 21; }
  if (string_view_is_empty(v) != 0) { return 22; }
  let v0: StrView = string_view(&hay[0], 0);
  if (string_view_is_empty(v0) != 1) { return 23; }
  if (string_view_get(v, 2) != 99) { return 24; }
  let v2: StrView = string_view(&hay[0], 5);
  if (string_view_eq(v, v2) != 1) { return 25; }
  let v3: StrView = string_view(&hay[0], 4);
  if (string_view_eq(v, v3) != 0) { return 26; }
  
  let out_full: [8]u8 = [0, 0, 0, 0, 0, 0, 0, 0];
  let copied: i32 = string_copy_to(h, &out_full[0], 8);
  if (copied != 5) { return 27; }
  if (out_full[0] != 97 || out_full[1] != 98 || out_full[2] != 99) { return 28; }
  let out_small: [2]u8 = [0, 0];
  let copy_fail: i32 = string_copy_to(h, &out_small[0], 2);
  if (copy_fail != (0 - 1)) { return 29; }
  let out_zero: [1]u8 = [0];
  let c0: i32 = string_copy_to(s2, &out_zero[0], 1);
  if (c0 != 0) { return 30; }
  
  return 0;
}
