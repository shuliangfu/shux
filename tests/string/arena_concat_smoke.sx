/**
 * ZC-4 smoke：string_view_concat_arena 仅 Arena64 bump，无 heap_alloc。
 * 两段栈缓冲拼接 → eq 期望串；多轮 concat 仍走同一 arena → exit 0。
 */
const string = import("std.string");
const heap = import("std.heap");

function main(): i32 {
  let arena: Arena64 = heap.arena64_empty();
  if (heap.arena64_init(&arena, 4096) != 0) {
    return 1;
  }
  let a_buf: u8[3] = [97, 98, 99];
  let b_buf: u8[3] = [100, 101, 102];
  let va: StrView = string.string_view(&a_buf[0], 3);
  let vb: StrView = string.string_view(&b_buf[0], 3);
  let ab: StrView = string.string_view_concat_arena(&arena, va, vb);
  if (string.string_view_len(ab) != 6) {
    heap.arena64_deinit(&arena);
    return 2;
  }
  let expect: u8[6] = [97, 98, 99, 100, 101, 102];
  let exp_v: StrView = string.string_view(&expect[0], 6);
  if (string.string_view_eq(ab, exp_v) != 1) {
    heap.arena64_deinit(&arena);
    return 3;
  }
  let c_buf: u8[2] = [103, 104];
  let vc: StrView = string.string_view(&c_buf[0], 2);
  let abc: StrView = string.string_view_concat_arena(&arena, ab, vc);
  if (string.string_view_len(abc) != 8) {
    heap.arena64_deinit(&arena);
    return 4;
  }
  if (string.string_view_get(abc, 7) != 104) {
    heap.arena64_deinit(&arena);
    return 5;
  }
  let sub: StrView = string.string_view_subview(abc, 3, 3);
  let mid_exp: u8[3] = [100, 101, 102];
  let mid_v: StrView = string.string_view(&mid_exp[0], 3);
  if (string.string_view_eq(sub, mid_v) != 1) {
    heap.arena64_deinit(&arena);
    return 6;
  }
  heap.arena64_deinit(&arena);
  return 0;
}
