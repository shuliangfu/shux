// vec_div4_call_inline.sx — let c = vec_div4(a,b) 应逐 lane 内联，_main 无 bl
/** 两形参向量除法，供 CALL 内联 fold（return a / b）。 */
function vec_div4(a: i32x4, b: i32x4): i32x4 {
  return a / b;
}

function main(): i32 {
  let a: i32x4 = [8, 12, 20, 4];
  let b: i32x4 = [2, 3, 4, 2];
  let c: i32x4 = vec_div4(a, b);
  let expect: i32x4 = [4, 4, 5, 2];
  let d: i32x4 = c - expect;
  let z: i32x4 = d - d;
  return 0;
}
