// struct_mk_let_inline.sx — let p = mk(...) 独立 CALL 内联：struct 按值返回直写 let 栈槽
struct Pair {
  a: i32
  b: i32
}

/** 由形参构造小 struct 按值返回。 */
function mk(a: i32, b: i32): Pair {
  return Pair { a: a, b: b };
}

function main(): i32 {
  let a: Pair = mk(1, 2);
  let b: Pair = mk(3, 4);
  return a.a + a.b + b.a + b.b;
}
