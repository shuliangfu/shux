// struct_get_field_inline.su — get_a(p.a) 运行时内联：p.a 可变，不可循环折叠
struct Pair {
  a: i32
  b: i32
}

/** 按值读取 struct 单 i32 字段。 */
function get_a(p: Pair): i32 {
  return p.a;
}

function main(): i32 {
  let n: i32 = 5;
  let s: i32 = 0;
  let i: i32 = 0;
  let p: Pair = Pair { a: 0, b: 2 };
  while (i < n) {
    p.a = i;
    s = s + get_a(p);
    i = i + 1;
  }
  return s;
}
