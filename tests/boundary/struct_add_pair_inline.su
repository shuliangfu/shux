// struct_add_pair_inline.su — add_pair(p.a+p.b) 运行时内联：p 字段可变，不可循环折叠
struct Pair {
  a: i32
  b: i32
}

/** 按值累加 struct 两 i32 字段。 */
function add_pair(p: Pair): i32 {
  return p.a + p.b;
}

function main(): i32 {
  let n: i32 = 5;
  let s: i32 = 0;
  let i: i32 = 0;
  let p: Pair = Pair { a: 0, b: 2 };
  while (i < n) {
    p.a = i & 1;
    s = s + add_pair(p);
    i = i + 1;
  }
  return s;
}
