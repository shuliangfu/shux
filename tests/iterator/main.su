// CORE-006 烟测：next_i32 / next_u8 + iter_remaining + 空切片
const iterator = import("core.iterator");
const option = import("core.option");

function main(): i32 {
  let a: [3]i32 = [10, 20, 30];
  let s: []i32 = a;
  let it: SliceIter_i32 = iterator.iter_i32(s);
  if (iterator.iter_remaining_i32(&it) != 3 as usize) { return 1; }

  let o1: Option_i32 = iterator.next_i32(&it);
  let o2: Option_i32 = iterator.next_i32(&it);
  let o3: Option_i32 = iterator.next_i32(&it);
  let o4: Option_i32 = iterator.next_i32(&it);
  if (!option.is_some_i32(o1) || option.unwrap_or_i32(o1, 0) != 10) { return 2; }
  if (!option.is_some_i32(o2) || option.unwrap_or_i32(o2, 0) != 20) { return 3; }
  if (!option.is_some_i32(o3) || option.unwrap_or_i32(o3, 0) != 30) { return 4; }
  if (!option.is_none_i32(o4)) { return 5; }
  if (iterator.iter_remaining_i32(&it) != 0 as usize) { return 6; }

  let empty: [1]i32 = [0];
  let es: []i32 = empty;
  es.length = 0 as usize;
  let eit: SliceIter_i32 = iterator.iter_i32(es);
  if (!option.is_none_i32(iterator.next_i32(&eit))) { return 7; }

  let b: [2]u8 = [5, 15];
  let su: []u8 = b;
  let uit: SliceIter_u8 = iterator.iter_u8(su);
  let ou1: Option_u8 = iterator.next_u8(&uit);
  let ou2: Option_u8 = iterator.next_u8(&uit);
  let ou3: Option_u8 = iterator.next_u8(&uit);
  if (!option.is_some_u8(ou1) || option.unwrap_or_u8(ou1, 0) != 5) { return 8; }
  if (!option.is_some_u8(ou2) || option.unwrap_or_u8(ou2, 0) != 15) { return 9; }
  if (!option.is_none_u8(ou3)) { return 10; }

  return 0;
}
