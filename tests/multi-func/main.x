/** Internal function `add`.
 * Implements `add`.
 * @param a i32
 * @param b i32
 * @return i32
 */
function add(a: i32, b: i32): i32 { return a + b; }
/** Internal function `main`.
 * Program/test entry point.
 * @param ) i32 { return add(1
 * @param 2
 * @return void
 */
function main(): i32 { return add(1, 2); }
