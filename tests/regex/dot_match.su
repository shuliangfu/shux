// STD-051：`.` 任意单字节
const regex = import("std.regex");

function main(): i32 {
  let pat: [3]u8 = [104, 46, 108];
  let re: *u8 = regex.compile(&pat[0], 3);
  if (re == 0) { return 1; }
  let hay: [4]u8 = [104, 105, 108, 111];
  if (regex.regex_match(re, &hay[0], 4) != 0) { regex.free(re); return 2; }
  regex.free(re);
  return 0;
}
