// STD-051：字符类 [0-9]
const regex = import("std.regex");

function main(): i32 {
  let pat: [5]u8 = [91, 48, 45, 57, 93];
  let re: *u8 = regex.compile(&pat[0], 5);
  if (re == 0) { return 1; }
  let hay: [3]u8 = [120, 53, 121];
  if (regex.regex_match(re, &hay[0], 3) != 0) { regex.free(re); return 2; }
  regex.free(re);
  return 0;
}
