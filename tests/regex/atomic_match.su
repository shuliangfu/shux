// STD-124：原子分组 `(?>...)` 烟测 — (a+)a 匹配 aaa，(?>(a+))a 不回溯故失败
const regex = import("std.regex");

function main(): i32 {
  let pat_norm: [5]u8 = [40, 97, 43, 41, 97];
  let pat_atom: [9]u8 = [40, 63, 62, 40, 97, 43, 41, 41, 97];
  let hay: [3]u8 = [97, 97, 97];
  let re_n: *u8 = regex.compile(&pat_norm[0], 5);
  let re_a: *u8 = regex.compile(&pat_atom[0], 9);
  if (re_n == 0 || re_a == 0) {
    return 1;
  }
  if (regex.regex_match(re_n, &hay[0], 3) != 0) {
    regex.free(re_n);
    regex.free(re_a);
    return 2;
  }
  if (regex.regex_match(re_a, &hay[0], 3) == 0) {
    regex.free(re_n);
    regex.free(re_a);
    return 3;
  }
  if (group_count(re_a) != 2) {
    regex.free(re_n);
    regex.free(re_a);
    return 4;
  }
  regex.free(re_n);
  regex.free(re_a);
  return 0;
}
