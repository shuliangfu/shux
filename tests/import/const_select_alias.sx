// 测试绑定 import + 跨模块类型：driver.Buffer
const io = import("std.io");
const driver = import("std.io.driver");

function main(): i32 {
  let msg: [12]u8 = [72, 101, 108, 108, 111, 32, 87, 111, 114, 108, 100, 10];
  let n: i32 = io.print_str(msg, 12);
  let buf: Buffer = Buffer { ptr: 0, len: 0, handle: 0 };
  return if (n >= 0 && buf.len == 0) { 0 } else { 1 };
}
