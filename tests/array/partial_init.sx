/** 部分初始化：let x: [N]T = [e1,e2,...]，不足 N 的部分按 0 填充 */
function main(): i32 {
  let a: [5]i32 = [1, 2, 3];
  if (a[0] != 1 || a[1] != 2 || a[2] != 3) { return 1; }
  if (a[3] != 0 || a[4] != 0) { return 2; }
  
  let b: [3]u8 = [];
  if (b[0] != 0 || b[1] != 0 || b[2] != 0) { return 3; }
  
  return 0;
}
