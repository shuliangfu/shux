// STD-040：hex/Base64 与 std.string 互操作金样
const encoding = import("std.encoding");
const string = import("std.string");

/** 比较 String 与期望 ASCII 字节序列（len 字节）。 */
function str_bytes_eq(s: *String, expect: *u8, len: i32): bool {
  if (string.string_len_ptr(s) != len) { return false; }
  let p: *u8 = string.string_data_ptr(s);
  let i: i32 = 0;
  while (i < len) {
    if (p[i] != expect[i]) { return false; }
    i = i + 1;
  }
  return true;
}

function main(): i32 {
  let raw: [4]u8 = [222, 173, 190, 239];
  let hex_expect: [8]u8 = [100, 101, 97, 100, 98, 101, 101, 102];
  let hex_out: String = string.string_new();
  if (encode_hex_string(&raw[0], 4, &hex_out) != 0) { return 1; }
  if (!str_bytes_eq(&hex_out, &hex_expect[0], 8)) { return 2; }
  let dec_buf: [8]u8 = [];
  let hv: StrView = string_view_from_string(&hex_out);
  let dn: i32 = decode_hex_string(hv, &dec_buf[0], 8);
  if (dn != 4) { return 3; }
  let j: i32 = 0;
  while (j < 4) {
    if (dec_buf[j] != raw[j]) { return 4; }
    j = j + 1;
  }
  let foo: [3]u8 = [102, 111, 111];
  let b64_expect: [4]u8 = [90, 109, 57, 118];
  let b64_out: String = string.string_new();
  if (encode_base64_string(&foo[0], 3, &b64_out) != 0) { return 5; }
  if (!str_bytes_eq(&b64_out, &b64_expect[0], 4)) { return 6; }
  let b64_dec: [8]u8 = [];
  let bv: StrView = string_view_from_string(&b64_out);
  let bn: i32 = decode_base64_string(bv, &b64_dec[0], 8);
  if (bn != 3) { return 7; }
  let k: i32 = 0;
  while (k < 3) {
    if (b64_dec[k] != foo[k]) { return 8; }
    k = k + 1;
  }
  return 0;
}
