// vec_add_verify.sx — memcmp 校验向量逐 lane 加法结果（依赖 &vector + as *u8）
extern function shux_string_memcmp_c(a: *u8, b: *u8, n: i32): i32;

function main(): i32 {
  let a: i32x4 = [1, 2, 3, 4];
  let b: i32x4 = [10, 20, 30, 40];
  let c: i32x4 = a + b;
  let expect: i32x4 = [11, 22, 33, 44];
  let pc: *u8 = &c as *u8;
  let pe: *u8 = &expect as *u8;
  if (shux_string_memcmp_c(pc, pe, 16) != 0) {
    return 1;
  }
  return 0;
}
