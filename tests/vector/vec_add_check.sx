// vec_add_check.sx — VAR+VAR 向量加法 + 减法链（asm 逐 lane emit 冒烟）
function main(): i32 {
  let a: i32x4 = [1, 2, 3, 4];
  let b: i32x4 = [10, 20, 30, 40];
  let c: i32x4 = a + b;
  let expect: i32x4 = [11, 22, 33, 44];
  let d: i32x4 = c - expect;
  let z: i32x4 = d - d;
  let w: i32x4 = z + z;
  let v: i32x4 = w - w;
  return 0;
}
