// STD-125：Brotli 压缩→解压往返（未链 Brotli 时 n_br<=0 仍通过）
const compress = import("std.compress");

function main(): i32 {
  let raw: [13]u8 = [72, 101, 108, 108, 111, 44, 32, 98, 114, 33, 33, 33, 0];
  let out_buf: [256]u8 = [];
  let dec_buf: [256]u8 = [];
  if (brotli_available() == 0) {
    return 0;
  }
  let n_br: i32 = compress.brotli_compress(&raw[0], 12, &out_buf[0], 256);
  if (n_br <= 0) {
    return 0;
  }
  let m_br: i32 = compress.brotli_decompress(&out_buf[0], n_br, &dec_buf[0], 256);
  if (m_br != 12) {
    return 1;
  }
  let i: i32 = 0;
  while (i < 12) {
    if (dec_buf[i] != raw[i]) {
      return 2;
    }
    i = i + 1;
  }
  if (brotli_smoke() != 0) {
    return 3;
  }
  return 0;
}
