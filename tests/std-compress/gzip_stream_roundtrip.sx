// STD-039：gzip 分块压缩→分块解压往返（未链 zlib 时 init 失败仍 exit 0）
const compress = import("std.compress");

function main(): i32 {
  let raw: [13]u8 = [72, 101, 108, 108, 111, 44, 32, 103, 122, 33, 33, 33, 0];
  let raw_len: i32 = 12;
  let sb: i32 = gzip_stream_state_bytes();
  if (sb <= 0 || sb > 256) { return 99; }
  let st_c: [256]u8 = [];
  let st_d: [256]u8 = [];
  if (gzip_stream_init_compress(&st_c[0], sb) != 0) { return 0; }
  let comp: [512]u8 = [];
  let comp_len: i32 = 0;
  let scratch: [128]u8 = [];
  let off: i32 = 0;
  let chunk: i32 = 4;
  while (off < raw_len) {
    let take: i32 = chunk;
    if (off + take > raw_len) { take = raw_len - off; }
    let is_last: i32 = 0;
    if (off + take >= raw_len) { is_last = 1; }
    let pending: i32 = take;
    let pin: i32 = off;
    while (pending > 0) {
      let consumed: i32 = 0;
      let n: i32 = gzip_stream_compress(&st_c[0], sb, &raw[pin], pending, &scratch[0], 128, 0, &consumed);
      if (n < 0) { gzip_stream_end(&st_c[0], sb); return 1; }
      let j: i32 = 0;
      while (j < n) {
        if (comp_len >= 512) { gzip_stream_end(&st_c[0], sb); return 2; }
        comp[comp_len] = scratch[j];
        comp_len = comp_len + 1;
        j = j + 1;
      }
      if (consumed <= 0) { break; }
      pin = pin + consumed;
      pending = pending - consumed;
    }
    if (is_last != 0) {
      let drain: i32 = 1;
      while (drain != 0) {
        let consumed2: i32 = 0;
        let n2: i32 = gzip_stream_compress(&st_c[0], sb, &raw[0], 0, &scratch[0], 128, 1, &consumed2);
        if (n2 < 0) { drain = 0; break; }
        let k: i32 = 0;
        while (k < n2) {
          if (comp_len >= 512) { gzip_stream_end(&st_c[0], sb); return 3; }
          comp[comp_len] = scratch[k];
          comp_len = comp_len + 1;
          k = k + 1;
        }
        if (n2 == 0 && consumed2 == 0) { drain = 0; }
      }
    }
    off = off + take;
  }
  gzip_stream_end(&st_c[0], sb);
  if (comp_len <= 0) { return 4; }
  if (gzip_stream_init_decompress(&st_d[0], sb) != 0) { return 5; }
  let dec: [256]u8 = [];
  let dec_len: i32 = 0;
  let cin: i32 = 0;
  let dchunk: i32 = 5;
  while (cin < comp_len) {
    let dtake: i32 = dchunk;
    if (cin + dtake > comp_len) { dtake = comp_len - cin; }
    let dconsumed: i32 = 0;
    let dn: i32 = gzip_stream_decompress(&st_d[0], sb, &comp[cin], dtake, &scratch[0], 128, &dconsumed);
    if (dn < 0) { gzip_stream_end(&st_d[0], sb); return 6; }
    let m: i32 = 0;
    while (m < dn) {
      if (dec_len >= 256) { gzip_stream_end(&st_d[0], sb); return 7; }
      dec[dec_len] = scratch[m];
      dec_len = dec_len + 1;
      m = m + 1;
    }
    if (dconsumed <= 0) { break; }
    cin = cin + dconsumed;
  }
  gzip_stream_end(&st_d[0], sb);
  if (dec_len != raw_len) { return 8; }
  let i: i32 = 0;
  while (i < raw_len) {
    if (dec[i] != raw[i]) { return 9; }
    i = i + 1;
  }
  return 0;
}
