// STD-087：std.cache LRU 淘汰 + 对象池烟测
const cache = import("std.cache");

function main(): i32 {
  let zero: i64 = 0;
  let lru: LruCache = cache.lru_new(2);
  let pool: ObjPool = cache.pool_new(2);
  let v: i64 = 0;
  let r: i64 = 0;
  let st: CacheStats = CacheStats { hits: 0, misses: 0, evictions: 0, size: 0 };
  let ps: PoolStats = PoolStats { idle: 0, in_use: 0, unhealthy: 0, acquires: 0 };

  if (lru.handle == zero || pool.handle == zero) {
    return 1;
  }
  if (cache.lru_put(&lru, 1, 100, zero) != cache.cache_err_ok()) { return 2; }
  if (cache.lru_put(&lru, 2, 200, zero) != cache.cache_err_ok()) { return 3; }
  if (cache.lru_put(&lru, 3, 300, zero) != cache.cache_err_ok()) { return 4; }
  if (cache.lru_get(&lru, 1, &v) != cache.cache_err_not_found()) { return 5; }
  if (cache.lru_get(&lru, 2, &v) != cache.cache_err_ok() || v != 200) { return 6; }
  cache.lru_stats(&lru, &st);
  if (st.hits < 1 || st.misses < 1) { return 7; }
  if (cache.pool_add(&pool, 1001) != cache.cache_err_ok()) { return 8; }
  if (cache.pool_add(&pool, 1002) != cache.cache_err_ok()) { return 9; }
  if (cache.pool_acquire(&pool, &r) != cache.cache_err_ok() || r == zero) { return 10; }
  if (cache.pool_release(&pool, r) != cache.cache_err_ok()) { return 11; }
  if (cache.pool_acquire(&pool, &r) != cache.cache_err_ok()) { return 12; }
  if (cache.pool_mark_unhealthy(&pool, r) != cache.cache_err_ok()) { return 13; }
  if (cache.pool_release(&pool, r) != cache.cache_err_ok()) { return 14; }
  cache.pool_stats(&pool, &ps);
  if (cache.pool_idle(&pool) != 1) { return 15; }
  cache.lru_free(&lru);
  cache.pool_free(&pool);
  return 0;
}
