// STD-096：std.dynlib last_error 烟测
const dynlib = import("std.dynlib");

function main(): i32 {
  // "/nonexistent/shux_dynlib_missing.so"
  let bad: [35]u8 = [47, 110, 111, 110, 101, 120, 105, 115, 116, 101, 110, 116, 47, 115, 104, 117,
    95, 100, 121, 110, 108, 105, 98, 95, 109, 105, 115, 115, 105, 110, 103, 46, 115, 111, 0];
  let buf: [128]u8 = [];
  let lib: *u8 = dynlib.open(&bad[0]);
  if (lib != 0) {
    dynlib.close(lib);
    return 1;
  }
  if (dynlib.last_error(&buf[0], 128) <= 0) {
    return 2;
  }
  return 0;
}
