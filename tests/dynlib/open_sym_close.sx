// tests/dynlib/open_sym_close.sx — STD-027：open/sym/close 烟测（POSIX + Windows 路径）
//
// 【文件职责】按序尝试平台已知系统库路径，校验 sym 非空后 close。
// 【平台】macOS libSystem / Linux libc.so.6 / Windows kernel32.dll
const dynlib = import("std.dynlib");

/** 尝试打开 path；成功返回句柄，否则 0。 */
function try_open(path: *u8): *u8 {
  return dynlib.open(path);
}

/** 尝试 sym；lib 为 0 时返回 0。 */
function try_sym(lib: *u8, name: *u8): *u8 {
  if (lib == 0) { return 0; }
  return dynlib.sym(lib, name);
}

function main(): i32 {
  // "/usr/lib/libSystem.B.dylib"
  let path_mac: u8[27] = [
    47, 117, 115, 114, 47, 108, 105, 98, 47, 108, 105, 98, 83, 121, 115, 116, 101, 109, 46, 66, 46, 100, 121, 108, 105, 98, 0
  ];
  // "libc.so.6"
  let path_lin: u8[10] = [108, 105, 98, 99, 46, 115, 111, 46, 54, 0];
  // "kernel32.dll"
  let path_win: u8[13] = [107, 101, 114, 110, 101, 108, 51, 50, 46, 100, 108, 108, 0];
  let lib: *u8 = try_open(&path_mac[0]);
  if (lib == 0) { lib = try_open(&path_lin[0]); }
  if (lib == 0) { lib = try_open(&path_win[0]); }
  if (lib == 0) { return 1; }
  // "malloc"
  let sym_malloc: u8[7] = [109, 97, 108, 108, 111, 99, 0];
  // "GetTickCount"
  let sym_tick: u8[13] = [71, 101, 116, 84, 105, 99, 107, 67, 111, 117, 110, 116, 0];
  let fn: *u8 = try_sym(lib, &sym_malloc[0]);
  if (fn == 0) { fn = try_sym(lib, &sym_tick[0]); }
  if (fn == 0) {
    dynlib.close(lib);
    return 2;
  }
  dynlib.close(lib);
  return 0;
}
