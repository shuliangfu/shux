/**
 * CORE-012 烟测：core.debug assert_eq/ne 扩展（u64、bool、*u8 指针）。
 */
const debug = import("core.debug");

function main(): i32 {
  // u64：含 U64_MAX
  let max_u: u64 = 18446744073709551615 as u64;
  assert_eq_u64(0 as u64, 0 as u64);
  assert_eq_u64(max_u, max_u);
  assert_ne_u64(1 as u64, 2 as u64);

  // bool：不等断言
  debug.assert_eq_bool(true, true);
  assert_ne_bool(true, false);
  assert_ne_bool(false, true);

  // 指针：同址、null、异址
  let buf: [4]u8 = [1, 2, 3, 4];
  let p: *u8 = &buf[0];
  assert_eq_ptr(p, &buf[0]);
  let null_p: *u8 = 0 as *u8;
  assert_eq_ptr(null_p, 0 as *u8);
  let q: *u8 = &buf[2];
  assert_ne_ptr(p, q);

  return 0;
}
