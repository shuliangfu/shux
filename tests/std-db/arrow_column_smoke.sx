// std.db.arrow v2 烟测：F32 + null bitmap + adopt + SIMD 归约。
const dbarrow = import("std.db.arrow");

function main(): i32 {
  let col_i: ArrowColumn = dbarrow.column_i32_new(64);
  let col_f: ArrowColumn = dbarrow.column_f32_new(64);
  let nic: [4]f32 = [1.0, 2.0, 3.0, 4.0];
  if (col_i.handle == 0 || col_f.handle == 0) {
    return 1;
  }
  if (dbarrow.column_i32_append_nullable(col_i, 100, 1) != 0) {
    return 2;
  }
  if (dbarrow.column_i32_append_nullable(col_i, 0, 0) != 0) {
    return 3;
  }
  if (dbarrow.column_is_valid(col_i, 1) != 0) {
    return 4;
  }
  if (dbarrow.column_f32_append(col_f, 2.718) != 0) {
    return 5;
  }
  let adopted: ArrowColumn = dbarrow.column_adopt_f32(&nic[0], 4, 4);
  let fdata: *f32 = dbarrow.column_f32_data(adopted);
  if (adopted.handle == 0 || dbarrow.column_data_owned(adopted) != 0) {
    return 6;
  }
  if (fdata[2] != 3.0) {
    return 7;
  }
  if (dbarrow.column_i32_sum_valid(col_i, 2) != 100) {
    return 8;
  }
  let batch: ArrowBatch = dbarrow.batch_new(4);
  if (batch.handle == 0) {
    dbarrow.column_destroy(adopted);
    return 9;
  }
  if (dbarrow.batch_add_column(batch, col_i) != 0 || dbarrow.batch_add_column(batch, adopted) != 0) {
    dbarrow.batch_destroy(batch);
    return 10;
  }
  if (dbarrow.batch_len(batch) != 2) {
    dbarrow.batch_destroy(batch);
    return 11;
  }
  dbarrow.batch_destroy(batch);
  dbarrow.column_destroy(col_f);
  return 0;
}
