// STD-102：std.channel N 路 select 烟测（3 路；单线程；Windows stub 时 skip）
const channel = import("std.channel");
const debug = import("core.debug");

function main(): i32 {
  let ch0: *u8 = channel.channel_i32_bounded(2);
  let ch1: *u8 = channel.channel_i32_bounded(2);
  let ch2: *u8 = channel.channel_i32_bounded(2);
  if (ch0 == 0 || ch1 == 0 || ch2 == 0) {
    return 0;
  }
  let slots: i64[4] = [];
  channel_select_chs_set(&slots[0], 0, ch0);
  channel_select_chs_set(&slots[0], 1, ch1);
  channel_select_chs_set(&slots[0], 2, ch2);
  let v: i32 = 0;
  let which: i32 = 0;
  debug.assert_eq_i32(channel_select_try_recv_n(&slots[0], 3, &v, &which), 1);
  debug.assert_eq_i32(channel.channel_i32_send(ch2, 99), 0);
  debug.assert_eq_i32(channel_select_try_recv_n(&slots[0], 3, &v, &which), 0);
  debug.assert_eq_i32(which, 2);
  debug.assert_eq_i32(v, 99);
  debug.assert_eq_i32(channel.channel_i32_send(ch0, 11), 0);
  debug.assert_eq_i32(channel_select_recv_n(&slots[0], 3, &v, &which), 0);
  debug.assert_eq_i32(which, 0);
  debug.assert_eq_i32(v, 11);
  debug.assert_eq_i32(channel.channel_i32_send(ch1, 22), 0);
  debug.assert_eq_i32(channel_select_recv_n(&slots[0], 3, &v, &which), 0);
  debug.assert_eq_i32(which, 1);
  debug.assert_eq_i32(v, 22);
  channel.channel_i32_close(ch0);
  channel.channel_i32_close(ch1);
  channel.channel_i32_close(ch2);
  debug.assert_eq_i32(channel_select_try_recv_n(&slots[0], 3, &v, &which), 0 - 1);
  channel.channel_i32_free(ch0);
  channel.channel_i32_free(ch1);
  channel.channel_i32_free(ch2);
  return 0;
}
