// STD-108：std.channel N 路混合 select 烟测（recv/recv/send；Windows stub 时 skip）
const channel = import("std.channel");
const debug = import("core.debug");

function main(): i32 {
  let ch0: *u8 = channel.channel_i32_bounded(2);
  let ch1: *u8 = channel.channel_i32_bounded(2);
  let ch2: *u8 = channel.channel_i32_bounded(1);
  if (ch0 == 0 || ch1 == 0 || ch2 == 0) {
    return 0;
  }
  let slots: i64[4] = [];
  let dirs: i32[4] = [];
  channel_select_chs_set(&slots[0], 0, ch0);
  channel_select_dirs_set(&dirs[0], 0, 0);
  channel_select_chs_set(&slots[0], 1, ch1);
  channel_select_dirs_set(&dirs[0], 1, 0);
  channel_select_chs_set(&slots[0], 2, ch2);
  channel_select_dirs_set(&dirs[0], 2, 1);
  let v: i32 = 0;
  let which: i32 = 0;
  let is_send: i32 = 0;
  debug.assert_eq_i32(channel.channel_i32_send(ch2, 111), 0);
  debug.assert_eq_i32(channel_select_try_mixed_n(&slots[0], &dirs[0], 3, 99, &v, &which, &is_send), 1);
  debug.assert_eq_i32(channel.channel_i32_send(ch1, 42), 0);
  debug.assert_eq_i32(channel_select_try_mixed_n(&slots[0], &dirs[0], 3, 99, &v, &which, &is_send), 0);
  debug.assert_eq_i32(is_send, 0);
  debug.assert_eq_i32(which, 1);
  debug.assert_eq_i32(v, 42);
  debug.assert_eq_i32(channel.channel_i32_recv(ch2, &v), 0);
  debug.assert_eq_i32(v, 111);
  debug.assert_eq_i32(channel_select_try_mixed_n(&slots[0], &dirs[0], 3, 99, &v, &which, &is_send), 0);
  debug.assert_eq_i32(is_send, 1);
  debug.assert_eq_i32(which, 2);
  debug.assert_eq_i32(channel.channel_i32_recv(ch2, &v), 0);
  debug.assert_eq_i32(v, 99);
  channel.channel_i32_close(ch0);
  channel.channel_i32_close(ch1);
  channel.channel_i32_close(ch2);
  channel.channel_i32_free(ch0);
  channel.channel_i32_free(ch1);
  channel.channel_i32_free(ch2);
  return 0;
}
