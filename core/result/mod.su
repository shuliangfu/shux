// core.result — Result<T,E> 与错误传播（自举前实现）
// Result 寄存器化：双 8 字节槽布局，满足 x86-64 SysV 两寄存器返回（rax/rdx），错误检查零内存访问（见 analysis/Result寄存器化.md）。
// 当前：Result_i32 全系列（ok/err、unwrap_or、is_ok/is_err、expect、expect_i32_or_panic、or/and）；泛型 Result<T,E> 与 map/and_then 待类型实参与函数类型支持后扩展。

// Result_i32：两对 (i32, padding) 共 16 字节，C 侧两寄存器返回；第二槽 err 为 0 表示成功
allow(padding) struct Result_i32 {
  value: i32;
  _pad1: i32;
  err: i32;
  _pad2: i32;
}

// 构造成功值：第一槽为值，第二槽为 0
function ok_i32(x: i32): Result_i32 {
  return Result_i32 { value: x, _pad1: 0, err: 0, _pad2: 0 }
}

// 构造错误值：第二槽为错误码
function err_i32(e: i32): Result_i32 {
  return Result_i32 { value: 0, _pad1: 0, err: e, _pad2: 0 }
}

// 成功则返回值，否则返回默认值（错误检查为 err==0，零内存访问）
function unwrap_or_i32(r: Result_i32, default_val: i32): i32 {
  return r.err == 0 ? r.value : default_val;
}

// 是否为成功
function is_ok_i32(r: Result_i32): bool {
  return r.err == 0;
}

// 是否为错误
function is_err_i32(r: Result_i32): bool {
  return r.err != 0;
}

// 成功则返回值，否则返回默认值（与 unwrap_or_i32 同义，命名供“期望有默认”的调用方使用）
function expect_i32(r: Result_i32, default_val: i32): i32 {
  return r.err == 0 ? r.value : default_val;
}

// 成功则返回值，否则 panic（用于必须成功的场景）
function expect_i32_or_panic(r: Result_i32): i32 {
  if (r.err == 0) {
    return r.value;
  } else {
    return panic();
  }
}

// 成功则返回本结果，否则返回 other（组合两个结果，取第一个 Ok）
function or_i32(r: Result_i32, other: Result_i32): Result_i32 {
  return r.err == 0 ? r : other;
}

// 失败则返回本结果，否则返回 other（串联：当前成功才继续）
function and_i32(r: Result_i32, other: Result_i32): Result_i32 {
  return r.err != 0 ? r : other;
}

// ——— eager 组合子（CORE-003 map/and_then/or_else） ———

/** 成功则 ok(mapped)，否则保持 err。 */
function map_i32(r: Result_i32, mapped: i32): Result_i32 {
  if (is_ok_i32(r)) {
    return ok_i32(mapped);
  }
  return r;
}

/** 成功则返回 next，否则保持 err。 */
function and_then_i32(r: Result_i32, next: Result_i32): Result_i32 {
  if (is_ok_i32(r)) {
    return next;
  }
  return r;
}

/** 失败则返回 other，否则保持 ok。 */
function or_else_i32(r: Result_i32, other: Result_i32): Result_i32 {
  if (is_err_i32(r)) {
    return other;
  }
  return r;
}

// ——— Result_u8 ———
allow(padding) struct Result_u8 {
  value: u8;
  _pad1: u8;
  _pad2: u8;
  _pad3: u8;
  err: i32;
  _pad4: i32;
}

/** 构造成功 Result_u8。 */
function ok_u8(x: u8): Result_u8 {
  return Result_u8 { value: x, _pad1: 0, _pad2: 0, _pad3: 0, err: 0, _pad4: 0 };
}

/** 构造错误 Result_u8。 */
function err_u8(e: i32): Result_u8 {
  return Result_u8 { value: 0, _pad1: 0, _pad2: 0, _pad3: 0, err: e, _pad4: 0 };
}

/** 成功则返回值，否则 default。 */
function unwrap_or_u8(r: Result_u8, default_val: u8): u8 {
  return r.err == 0 ? r.value : default_val;
}

/** 是否为成功。 */
function is_ok_u8(r: Result_u8): bool {
  return r.err == 0;
}

/** 是否为错误。 */
function is_err_u8(r: Result_u8): bool {
  return r.err != 0;
}

/** 成功则返回值，否则 panic。 */
function expect_u8_or_panic(r: Result_u8): u8 {
  if (r.err == 0) {
    return r.value;
  }
  return panic();
}

/** 成功则 ok(mapped)，否则保持 err。 */
function map_u8(r: Result_u8, mapped: u8): Result_u8 {
  if (is_ok_u8(r)) {
    return ok_u8(mapped);
  }
  return r;
}

/** 失败则返回 other，否则保持 ok。 */
function or_else_u8(r: Result_u8, other: Result_u8): Result_u8 {
  if (is_err_u8(r)) {
    return other;
  }
  return r;
}

// 泛型占位，表示本模块可 import；完整 Result<T,E> 待类型实参语法后扩展
function result_placeholder<T>(x: T): T { return x; }
